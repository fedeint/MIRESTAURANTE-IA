<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Competencia - dignita.tech</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-binoculars-fill me-2" style="color:var(--dg-primary);"></i>Competencia</h4>
                <p class="text-muted small mb-0">Monitorea a tus competidores: seguidores, likes, publicaciones e historias</p>
            </div>
            <button class="btn btn-primary" id="btnAgregar"><i class="bi bi-plus-lg me-1"></i>Agregar competidor</button>
        </div>

        <div id="competidoresList"></div>
        <div id="emptyState" class="text-center py-5" style="display:none;">
            <div style="width:70px;height:70px;background:rgba(99,102,241,0.08);border-radius:1rem;display:inline-flex;align-items:center;justify-content:center;font-size:1.8rem;color:#94a3b8;margin-bottom:1rem;"><i class="bi bi-binoculars"></i></div>
            <p class="text-muted">No tienes competidores registrados.<br>Agrega uno para empezar a monitorear.</p>
        </div>
    </div>
    </main>
    <%- include('partials/footer') %>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
    (function(){
        var KEY = 'dg-competidores';
        var data = [];
        try { data = JSON.parse(localStorage.getItem(KEY)) || []; } catch(e){}

        function save(){ localStorage.setItem(KEY, JSON.stringify(data)); }

        function render(){
            var list = document.getElementById('competidoresList');
            var empty = document.getElementById('emptyState');
            list.innerHTML = '';
            empty.style.display = data.length === 0 ? 'block' : 'none';

            data.forEach(function(comp, idx){
                var card = document.createElement('div');
                card.className = 'card mb-3';
                card.innerHTML = `
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div style="width:48px;height:48px;background:linear-gradient(135deg,#f43f5e,#e11d48);border-radius:.875rem;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.2rem;flex-shrink:0;"><i class="bi bi-shop"></i></div>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-0">${comp.nombre||'Competidor '+(idx+1)}</h6>
                                <small class="text-muted">${comp.instagram||'Sin Instagram'}</small>
                            </div>
                            <button class="btn btn-outline-danger btn-sm" data-del="${idx}" title="Eliminar"><i class="bi bi-trash"></i></button>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Nombre del restaurante</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="nombre" value="${comp.nombre||''}" placeholder="Nombre">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold"><i class="bi bi-instagram me-1"></i>Instagram</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="instagram" value="${comp.instagram||''}" placeholder="@competidor">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold"><i class="bi bi-facebook me-1"></i>Facebook</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="facebook" value="${comp.facebook||''}" placeholder="facebook.com/...">
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold"><i class="bi bi-people-fill me-1"></i>Seguidores</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="seguidores" value="${comp.seguidores||''}" placeholder="Ej: 5,200">
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold"><i class="bi bi-heart-fill me-1"></i>Likes promedio</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="likes" value="${comp.likes||''}" placeholder="Ej: 120">
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold"><i class="bi bi-camera-reels me-1"></i>Historias/dia</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="historias" value="${comp.historias||''}" placeholder="Ej: 3">
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold"><i class="bi bi-tiktok me-1"></i>TikTok</label>
                                <input type="text" class="form-control comp-field" data-idx="${idx}" data-key="tiktok" value="${comp.tiktok||''}" placeholder="@tiktok">
                            </div>
                        </div>

                        <div class="row g-2">
                            <div class="col-12">
                                <label class="form-label small fw-bold"><i class="bi bi-clock-history me-1"></i>Ultimas 3 publicaciones</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control form-control-sm comp-field" data-idx="${idx}" data-key="post0" value="${(comp.posts&&comp.posts[0])||''}" placeholder="1ra publicacion">
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control form-control-sm comp-field" data-idx="${idx}" data-key="post1" value="${(comp.posts&&comp.posts[1])||''}" placeholder="2da publicacion">
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control form-control-sm comp-field" data-idx="${idx}" data-key="post2" value="${(comp.posts&&comp.posts[2])||''}" placeholder="3ra publicacion">
                            </div>
                        </div>
                    </div>
                `;
                list.appendChild(card);
            });

            // Auto-save on input change
            document.querySelectorAll('.comp-field').forEach(function(input){
                input.addEventListener('change', function(){
                    var idx = parseInt(this.getAttribute('data-idx'));
                    var key = this.getAttribute('data-key');
                    if (key.startsWith('post')) {
                        var pi = parseInt(key.replace('post',''));
                        if (!data[idx].posts) data[idx].posts = ['','',''];
                        data[idx].posts[pi] = this.value.trim();
                    } else {
                        data[idx][key] = this.value.trim();
                    }
                    save();
                });
            });

            // Delete buttons
            document.querySelectorAll('[data-del]').forEach(function(btn){
                btn.addEventListener('click', function(){
                    var idx = parseInt(this.getAttribute('data-del'));
                    Swal.fire({title:'Eliminar competidor?',text:data[idx].nombre||'Este competidor',icon:'warning',showCancelButton:true,confirmButtonText:'Eliminar',cancelButtonText:'Cancelar'}).then(function(r){
                        if(r.isConfirmed){ data.splice(idx,1); save(); render(); }
                    });
                });
            });
        }

        document.getElementById('btnAgregar').addEventListener('click', function(){
            Swal.fire({title:'Nombre del competidor',input:'text',inputPlaceholder:'Ej: Restaurante La Esquina',showCancelButton:true,confirmButtonText:'Agregar'}).then(function(r){
                if(r.isConfirmed && r.value){
                    data.push({nombre:r.value.trim(),instagram:'',facebook:'',tiktok:'',seguidores:'',likes:'',historias:'',posts:['','','']});
                    save(); render();
                }
            });
        });

        render();
    })();
    </script>
</body>
</html>
