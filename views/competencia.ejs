<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1e1b4b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dignita">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
    <title>Competencia - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-binoculars-fill me-2" style="color:var(--dg-primary);"></i>Competencia</h4>
                <p class="text-muted small mb-0">Monitorea las redes de tu competencia con datos reales via API de Meta, TikTok</p>
            </div>
            <button class="btn btn-primary" id="btnAgregar"><i class="bi bi-plus-lg me-1"></i>Agregar competidor</button>
        </div>

        <div id="compList"></div>

        <div id="emptyState" class="text-center py-5" style="display:none;">
            <div style="width:70px;height:70px;background:rgba(99,102,241,0.08);border-radius:1rem;display:inline-flex;align-items:center;justify-content:center;font-size:1.8rem;color:#94a3b8;margin-bottom:1rem;"><i class="bi bi-binoculars"></i></div>
            <p class="text-muted">No tienes competidores registrados.<br>Agrega uno para monitorear sus redes sociales.</p>
        </div>

        <!-- RANKING COMPARATIVO -->
        <div class="card mt-4" id="rankingCard" style="display:none;">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-trophy-fill" style="color:#f59e0b;font-size:1.2rem;"></i>
                <h6 class="fw-bold mb-0 flex-grow-1">Ranking: Quien tiene mas seguidores?</h6>
                <button class="btn btn-sm btn-primary" id="btnRefreshRanking"><i class="bi bi-arrow-clockwise me-1"></i>Actualizar ranking</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width:8%;">#</th>
                                <th>Cuenta</th>
                                <th class="text-center">Seguidores</th>
                                <th class="text-center">Engagement</th>
                                <th class="text-center">Posts</th>
                            </tr>
                        </thead>
                        <tbody id="rankingBody">
                            <tr><td colspan="5" class="text-center text-muted py-3">Click "Actualizar ranking" para comparar</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    </main>
    <%- include('partials/footer') %>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
    (function(){
        var KEY='dg-competidores-v2';
        var data=[]; try{data=JSON.parse(localStorage.getItem(KEY))||[];}catch(e){}
        function save(){localStorage.setItem(KEY,JSON.stringify(data));}
        function fmt(n){n=Number(n)||0;if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return n.toLocaleString();}

        function render(){
            var list=document.getElementById('compList');
            var empty=document.getElementById('emptyState');
            list.innerHTML='';
            empty.style.display=data.length===0?'block':'none';

            data.forEach(function(comp,idx){
                var card=document.createElement('div');
                card.className='card mb-4';
                card.innerHTML=`
                    <div class="card-header d-flex align-items-center gap-2">
                        <div style="width:36px;height:36px;background:linear-gradient(135deg,#f43f5e,#e11d48);border-radius:.625rem;display:flex;align-items:center;justify-content:center;color:#fff;"><i class="bi bi-shop"></i></div>
                        <h6 class="fw-bold mb-0 flex-grow-1">${comp.nombre||'Competidor '+(idx+1)}</h6>
                        <button class="btn btn-outline-danger btn-sm btn-del" data-idx="${idx}"><i class="bi bi-trash"></i></button>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">Ingresa las paginas/usernames del competidor y haz click en <strong>Consultar</strong> para obtener datos reales.</p>

                        <!-- Facebook -->
                        <div class="row g-2 align-items-end mb-2">
                            <div class="col-auto" style="width:40px;text-align:center;"><i class="bi bi-facebook" style="color:#1877f2;font-size:1.2rem;"></i></div>
                            <div class="col"><input type="text" class="form-control form-control-sm comp-fb" data-idx="${idx}" value="${comp.facebook||''}" placeholder="ID pagina Facebook"></div>
                            <div class="col-auto"><button class="btn btn-sm btn-outline-primary btn-query-fb" data-idx="${idx}"><i class="bi bi-search"></i> Consultar</button></div>
                        </div>
                        <div class="comp-fb-result mb-3" id="comp-fb-${idx}" style="display:none;"></div>

                        <!-- Instagram -->
                        <div class="row g-2 align-items-end mb-2">
                            <div class="col-auto" style="width:40px;text-align:center;"><i class="bi bi-instagram" style="color:#e1306c;font-size:1.2rem;"></i></div>
                            <div class="col"><input type="text" class="form-control form-control-sm comp-ig" data-idx="${idx}" value="${comp.instagram||''}" placeholder="@username Instagram"></div>
                            <div class="col-auto"><button class="btn btn-sm btn-outline-primary btn-query-ig" data-idx="${idx}"><i class="bi bi-search"></i> Consultar</button></div>
                        </div>
                        <div class="comp-ig-result mb-3" id="comp-ig-${idx}" style="display:none;"></div>

                        <!-- TikTok -->
                        <div class="row g-2 align-items-end mb-2">
                            <div class="col-auto" style="width:40px;text-align:center;"><i class="bi bi-tiktok" style="font-size:1.2rem;"></i></div>
                            <div class="col"><input type="text" class="form-control form-control-sm comp-tt" data-idx="${idx}" value="${comp.tiktok||''}" placeholder="@username TikTok"></div>
                            <div class="col-auto"><button class="btn btn-sm btn-outline-primary btn-query-tt" data-idx="${idx}"><i class="bi bi-search"></i> Consultar</button></div>
                        </div>
                        <div class="comp-tt-result mb-3" id="comp-tt-${idx}" style="display:none;"></div>

                        <!-- Anuncios -->
                        <div class="mt-2 pt-2 border-top" style="border-color:rgba(0,0,0,0.04)!important;">
                            <button class="btn btn-sm btn-outline-warning btn-query-ads" data-idx="${idx}"><i class="bi bi-megaphone-fill me-1"></i>Ver anuncios activos (Ad Library)</button>
                            <div class="comp-ads-result mt-2" id="comp-ads-${idx}" style="display:none;"></div>
                        </div>
                    </div>
                `;
                list.appendChild(card);
            });

            // Save inputs on change
            list.querySelectorAll('.comp-fb,.comp-ig,.comp-tt').forEach(function(inp){
                inp.addEventListener('change',function(){
                    var i=parseInt(this.getAttribute('data-idx'));
                    if(this.classList.contains('comp-fb')) data[i].facebook=this.value.trim();
                    if(this.classList.contains('comp-ig')) data[i].instagram=this.value.trim();
                    if(this.classList.contains('comp-tt')) data[i].tiktok=this.value.trim();
                    save();
                });
            });

            // Delete
            list.querySelectorAll('.btn-del').forEach(function(b){
                b.addEventListener('click',function(){
                    var i=parseInt(this.getAttribute('data-idx'));
                    Swal.fire({title:'Eliminar?',text:data[i].nombre,icon:'warning',showCancelButton:true,confirmButtonText:'Si'}).then(function(r){if(r.isConfirmed){data.splice(i,1);save();render();}});
                });
            });

            // Query buttons
            list.querySelectorAll('.btn-query-fb').forEach(function(b){
                b.addEventListener('click',function(){
                    var i=parseInt(this.getAttribute('data-idx'));
                    var v=list.querySelector('.comp-fb[data-idx="'+i+'"]').value.trim();
                    if(v){data[i].facebook=v;save();queryAPI(this,'/api/social/facebook/'+encodeURIComponent(v),'comp-fb-'+i);}
                });
            });
            list.querySelectorAll('.btn-query-ig').forEach(function(b){
                b.addEventListener('click',function(){
                    var i=parseInt(this.getAttribute('data-idx'));
                    var v=list.querySelector('.comp-ig[data-idx="'+i+'"]').value.trim().replace('@','');
                    if(v){data[i].instagram=v;save();queryAPI(this,'/api/social/instagram/'+encodeURIComponent(v),'comp-ig-'+i);}
                });
            });
            list.querySelectorAll('.btn-query-tt').forEach(function(b){
                b.addEventListener('click',function(){
                    var i=parseInt(this.getAttribute('data-idx'));
                    var v=list.querySelector('.comp-tt[data-idx="'+i+'"]').value.trim().replace('@','');
                    if(v){data[i].tiktok=v;save();queryAPI(this,'/api/social/tiktok/'+encodeURIComponent(v),'comp-tt-'+i);}
                });
            });

            // Ads buttons
            list.querySelectorAll('.btn-query-ads').forEach(function(b){
                b.addEventListener('click',function(){
                    var i=parseInt(this.getAttribute('data-idx'));
                    var fbId=data[i].facebook;
                    if(!fbId){Swal.fire({icon:'info',title:'Facebook ID requerido',text:'Primero ingresa el ID de la pagina de Facebook del competidor'});return;}
                    queryAds(this,fbId,'comp-ads-'+i);
                });
            });

            // Show ranking card if there are competitors
            document.getElementById('rankingCard').style.display = data.length > 0 ? 'block' : 'none';
        }

        async function queryAPI(btn,endpoint,resultId){
            var old=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm"></span>';
            var el=document.getElementById(resultId);
            try{
                var r=await fetch(endpoint);var d=await r.json();
                if(!r.ok)throw new Error(d.error||d.help||'Error');
                el.style.display='block';
                var h='<div class="d-flex align-items-center gap-3 p-2 rounded" style="background:rgba(99,102,241,0.04);">';
                if(d.foto) h+='<img src="'+d.foto+'" style="width:40px;height:40px;border-radius:.5rem;object-fit:cover;">';
                h+='<div class="small"><strong>'+(d.nombre||d.username||'')+'</strong></div>';
                h+='<div class="ms-auto d-flex gap-3 text-center small">';
                h+='<div><div style="font-weight:800;color:#6366f1;">'+fmt(d.seguidores)+'</div><div class="text-muted" style="font-size:.7rem;">Seguidores</div></div>';
                if(d.likes!==undefined) h+='<div><div style="font-weight:800;color:#ef4444;">'+fmt(d.likes)+'</div><div class="text-muted" style="font-size:.7rem;">Likes</div></div>';
                if(d.publicaciones!==undefined) h+='<div><div style="font-weight:800;color:#10b981;">'+fmt(d.publicaciones)+'</div><div class="text-muted" style="font-size:.7rem;">Posts</div></div>';
                if(d.videos!==undefined) h+='<div><div style="font-weight:800;color:#10b981;">'+fmt(d.videos)+'</div><div class="text-muted" style="font-size:.7rem;">Videos</div></div>';
                h+='</div></div>';
                if(d.ultimos_posts&&d.ultimos_posts.length){
                    h+='<div class="mt-2 small"><strong>Ultimas publicaciones:</strong>';
                    d.ultimos_posts.forEach(function(p,pi){
                        h+='<div class="d-flex gap-2 py-1 border-bottom" style="border-color:rgba(0,0,0,0.04)!important;">';
                        if(p.imagen) h+='<img src="'+p.imagen+'" style="width:32px;height:32px;border-radius:.375rem;object-fit:cover;">';
                        h+='<span class="flex-grow-1">'+(p.caption||'Post '+(pi+1))+'</span>';
                        h+='<span style="color:#ef4444;"><i class="bi bi-heart-fill"></i> '+fmt(p.likes)+'</span>';
                        h+='</div>';
                    });
                    h+='</div>';
                }
                el.innerHTML=h;
            }catch(e){
                el.style.display='block';
                el.innerHTML='<div class="alert alert-danger small mb-0 py-1"><i class="bi bi-exclamation-triangle me-1"></i>'+e.message+'</div>';
            }
            btn.disabled=false;btn.innerHTML=old;
        }

        // Query Ads
        async function queryAds(btn,fbPageId,resultId){
            var old=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Buscando...';
            var el=document.getElementById(resultId);
            try{
                var r=await fetch('/api/social/ads/'+encodeURIComponent(fbPageId));var d=await r.json();
                if(!r.ok)throw new Error(d.error||'Error');
                el.style.display='block';
                if(!d.anuncios||d.anuncios.length===0){el.innerHTML='<div class="alert alert-info small mb-0 py-1"><i class="bi bi-info-circle me-1"></i>No se encontraron anuncios activos para esta pagina en Peru.</div>';return;}
                var h='<div class="small"><strong><i class="bi bi-megaphone-fill me-1"></i>'+d.total+' anuncios encontrados:</strong></div>';
                d.anuncios.forEach(function(ad){
                    h+='<div class="p-2 my-1 rounded" style="background:rgba(245,158,11,0.04);border:1px solid rgba(245,158,11,0.1);border-radius:.5rem;">';
                    h+='<div class="small fw-bold">'+(ad.titulo||'Sin titulo')+'</div>';
                    h+='<div class="small text-muted">'+(ad.texto||'Sin texto')+'</div>';
                    h+='<div class="small text-muted mt-1"><i class="bi bi-calendar me-1"></i>'+ad.inicio+' → '+(ad.fin||'Activo');
                    if(ad.snapshot_url) h+=' · <a href="'+ad.snapshot_url+'" target="_blank">Ver anuncio</a>';
                    h+='</div></div>';
                });
                el.innerHTML=h;
            }catch(e){el.style.display='block';el.innerHTML='<div class="alert alert-danger small mb-0 py-1">'+e.message+'</div>';}
            btn.disabled=false;btn.innerHTML=old;
        }

        // Ranking comparativo
        document.getElementById('btnRefreshRanking')?.addEventListener('click', async function(){
            var btn=this;var old=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Consultando...';
            // Build accounts list from all competitors' IG usernames
            var accounts=[];
            // Add my own IG if saved
            var myIg=localStorage.getItem('dg-ig-user');
            if(myIg) accounts.push('ig:'+myIg);
            data.forEach(function(c){
                if(c.instagram) accounts.push('ig:'+c.instagram.replace('@',''));
                if(c.facebook) accounts.push('fb:'+c.facebook);
            });
            if(accounts.length===0){btn.disabled=false;btn.innerHTML=old;Swal.fire({icon:'info',text:'Agrega Instagram o Facebook a tus competidores primero'});return;}

            try{
                var r=await fetch('/api/social/ranking?accounts='+encodeURIComponent(accounts.join(',')));
                var d=await r.json();
                if(!r.ok)throw new Error(d.error||'Error');
                var tbody=document.getElementById('rankingBody');
                var medals=['#f59e0b','#9ca3af','#cd7f32'];
                var html='';
                (d.ranking||[]).forEach(function(item){
                    var badge=item.rank<=3?'<span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;background:'+medals[item.rank-1]+';color:#fff;font-weight:bold;font-size:.8rem;">'+item.rank+'</span>':'<span class="badge" style="background:rgba(100,116,139,0.1);color:#64748b;">'+item.rank+'</span>';
                    var isMe=(myIg&&item.id===myIg);
                    html+='<tr'+(isMe?' style="background:rgba(99,102,241,0.06);"':'')+'>';
                    html+='<td>'+badge+'</td>';
                    html+='<td><div class="d-flex align-items-center gap-2">';
                    if(item.foto) html+='<img src="'+item.foto+'" style="width:28px;height:28px;border-radius:.375rem;object-fit:cover;">';
                    html+='<div><strong>'+item.nombre+'</strong>'+(isMe?' <span class="badge" style="background:#6366f1;color:#fff;font-size:.65rem;">TU</span>':'')+'<br><small class="text-muted">'+item.platform+' · @'+item.id+'</small></div>';
                    html+='</div></td>';
                    html+='<td class="text-center"><span style="font-weight:800;color:#6366f1;">'+fmt(item.seguidores)+'</span></td>';
                    html+='<td class="text-center">'+(item.engagement_promedio?'<span style="font-weight:700;color:#10b981;">'+fmt(item.engagement_promedio)+'</span>':'-')+'</td>';
                    html+='<td class="text-center">'+(item.publicaciones?fmt(item.publicaciones):'-')+'</td>';
                    html+='</tr>';
                });
                tbody.innerHTML=html||'<tr><td colspan="5" class="text-center text-muted">Sin resultados</td></tr>';
            }catch(e){document.getElementById('rankingBody').innerHTML='<tr><td colspan="5" class="text-center text-danger">'+e.message+'</td></tr>';}
            btn.disabled=false;btn.innerHTML=old;
        });

        document.getElementById('btnAgregar').addEventListener('click',function(){
            Swal.fire({title:'Nombre del competidor',input:'text',inputPlaceholder:'Ej: Restaurante La Esquina',showCancelButton:true,confirmButtonText:'Agregar'}).then(function(r){
                if(r.isConfirmed&&r.value){data.push({nombre:r.value.trim(),facebook:'',instagram:'',tiktok:''});save();render();}
            });
        });

        render();
    })();
    </script>
</body>
</html>
