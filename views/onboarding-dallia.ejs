<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#10152f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="DallIA">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <title>DallIA — Configura tu restaurante</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* ── Reset ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    html {
      height: 100%;
      height: 100dvh;
    }
    body {
      margin: 0;
      padding: 0;
      font-family: 'DM Sans', system-ui, sans-serif;
      background: #F0F2F8;
      height: 100%;
      height: 100dvh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    /* ── Shell ─────────────────────────────────────────── */
    .chat-shell {
      width: 100%;
      max-width: 480px;
      height: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      background: #F0F2F8;
      position: relative;
      overflow: hidden;
    }

    /* ── Header ─────────────────────────────────────────── */
    .chat-header {
      background: linear-gradient(180deg, #10152f 0%, #0a0f24 60%, #090d1d 100%);
      border-radius: 0 0 20px 20px;
      padding: 16px 20px 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      flex-shrink: 0;
      z-index: 10;
    }
    .chat-header-top {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .dallia-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ef520f 0%, #df2c05 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
      border: 2px solid rgba(255,255,255,0.15);
    }
    .dallia-info {
      flex: 1;
    }
    .dallia-name {
      color: #ffffff;
      font-size: 16px;
      font-weight: 700;
      line-height: 1.2;
      margin: 0;
    }
    .dallia-sub {
      color: #8B8FAD;
      font-size: 12px;
      font-weight: 400;
      margin: 0;
    }

    /* Progress dots */
    .progress-row {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .progress-label {
      color: #8B8FAD;
      font-size: 11px;
      font-weight: 500;
      flex: 1;
    }
    .progress-dots {
      display: flex;
      gap: 6px;
    }
    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(139, 143, 173, 0.35);
      transition: all 0.3s ease;
    }
    .dot.completed {
      background: #ef520f;
      box-shadow: 0 0 6px rgba(239, 82, 15, 0.6);
    }
    .dot.current {
      background: #ef520f;
      width: 20px;
      border-radius: 4px;
      box-shadow: 0 0 8px rgba(239, 82, 15, 0.7);
    }

    /* Block name pill */
    .block-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(239, 82, 15, 0.18);
      border: 1px solid rgba(239, 82, 15, 0.4);
      border-radius: 20px;
      padding: 4px 12px;
      color: #ef7c45;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* ── Chat area ─────────────────────────────────────── */
    .chat-area {
      flex: 1;
      overflow-y: auto;
      padding: 16px 16px 8px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      scroll-behavior: smooth;
    }
    .chat-area::-webkit-scrollbar { width: 0; }

    /* ── Bubbles ────────────────────────────────────────── */
    .bubble-row {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .bubble-row.dallia { align-items: flex-start; }
    .bubble-row.user   { align-items: flex-end; }

    .bubble {
      max-width: 80%;
      padding: 12px 16px;
      border-radius: 16px;
      font-size: 14px;
      line-height: 1.5;
      word-break: break-word;
    }
    .bubble.dallia {
      background: #ffffff;
      color: #0a0f24;
      border-bottom-left-radius: 4px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    }
    .bubble.user {
      background: linear-gradient(135deg, #ef520f 0%, #df2c05 100%);
      color: #ffffff;
      border-bottom-right-radius: 4px;
      box-shadow: 0 2px 8px rgba(239, 82, 15, 0.35);
    }

    /* Typing indicator */
    .typing-bubble {
      background: #ffffff;
      border-radius: 16px;
      border-bottom-left-radius: 4px;
      padding: 12px 16px;
      max-width: 80px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    }
    .typing-dots {
      display: flex;
      gap: 4px;
      align-items: center;
    }
    .typing-dots span {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #8B8FAD;
      animation: bounce 1.2s infinite;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40%           { transform: translateY(-6px); }
    }

    /* ── Quick-reply chips ──────────────────────────────── */
    .chips-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding: 4px 0 6px;
      max-width: 90%;
    }
    .chip {
      background: #ffffff;
      border: 1.5px solid #ef520f;
      color: #ef520f;
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      transition: all 0.18s ease;
      white-space: nowrap;
    }
    .chip:active, .chip:hover {
      background: linear-gradient(135deg, #ef520f 0%, #df2c05 100%);
      color: #ffffff;
      border-color: transparent;
      transform: scale(0.97);
    }
    .chip:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      transform: none;
    }

    /* ── Input bar ──────────────────────────────────────── */
    .input-bar {
      background: #ffffff;
      padding: 12px 16px;
      padding-bottom: max(12px, env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 -2px 16px rgba(0,0,0,0.07);
      flex-shrink: 0;
    }
    .input-bar input {
      flex: 1;
      border: 1.5px solid #e8eaf2;
      border-radius: 24px;
      padding: 10px 18px;
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      outline: none;
      background: #F0F2F8;
      color: #0a0f24;
      transition: border-color 0.2s;
    }
    .input-bar input:focus {
      border-color: #ef520f;
      background: #fff;
    }
    .input-bar input::placeholder { color: #8B8FAD; }
    .send-btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ef520f 0%, #df2c05 100%);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      box-shadow: 0 3px 10px rgba(239, 82, 15, 0.4);
    }
    .send-btn:active { transform: scale(0.92); }
    .send-btn svg {
      width: 20px;
      height: 20px;
      fill: none;
      stroke: #fff;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* ── Completion overlay ─────────────────────────────── */
    .completion-overlay {
      display: none;
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, #10152f 0%, #090d1d 100%);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      z-index: 50;
      text-align: center;
      padding: 32px;
    }
    .completion-overlay.active { display: flex; }
    .completion-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      box-shadow: 0 0 40px rgba(239,82,15,0.5);
      animation: pulse-glow 2s infinite;
    }
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 30px rgba(239,82,15,0.4); }
      50%       { box-shadow: 0 0 60px rgba(239,82,15,0.7); }
    }
    .completion-title {
      color: #ffffff;
      font-size: 22px;
      font-weight: 700;
      margin: 0;
    }
    .completion-sub {
      color: #8B8FAD;
      font-size: 14px;
      font-weight: 400;
      margin: 0;
    }
    .completion-bar {
      width: 100%;
      max-width: 280px;
      height: 4px;
      background: rgba(255,255,255,0.1);
      border-radius: 2px;
      overflow: hidden;
    }
    .completion-progress {
      height: 100%;
      background: linear-gradient(90deg, #ef520f, #df2c05);
      border-radius: 2px;
      width: 0%;
      transition: width 2.5s ease;
    }
  </style>
</head>
<body>
<div class="chat-shell" id="chatShell">

  <!-- ── Header ── -->
  <header class="chat-header">
    <div class="chat-header-top">
      <div class="dallia-avatar">🤖</div>
      <div class="dallia-info">
        <p class="dallia-name">DallIA</p>
        <p class="dallia-sub">Configurando tu restaurante</p>
      </div>
    </div>
    <div class="progress-row">
      <div class="block-badge" id="blockBadge">Tu equipo</div>
      <div class="progress-dots">
        <div class="dot current" id="dot1"></div>
        <div class="dot" id="dot2"></div>
        <div class="dot" id="dot3"></div>
        <div class="dot" id="dot4"></div>
        <div class="dot" id="dot5"></div>
      </div>
    </div>
  </header>

  <!-- ── Chat area ── -->
  <div class="chat-area" id="chatArea"></div>

  <!-- ── Input bar ── -->
  <div class="input-bar">
    <input
      type="text"
      id="textInput"
      placeholder="Escribe tu respuesta..."
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
    >
    <button class="send-btn" id="sendBtn" aria-label="Enviar">
      <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>

  <!-- ── Completion overlay ── -->
  <div class="completion-overlay" id="completionOverlay">
    <div class="completion-icon">🎉</div>
    <p class="completion-title">¡Todo listo!</p>
    <p class="completion-sub">Configuré tu sistema según tu perfil.<br>Preparando tu dashboard...</p>
    <div class="completion-bar">
      <div class="completion-progress" id="completionProgress"></div>
    </div>
  </div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────

const BLOQUES = [
  { nombre: 'Tu equipo',      num: 1 },
  { nombre: 'Tu operación',   num: 2 },
  { nombre: 'Tu dinero',      num: 3 },
  { nombre: 'Tus objetivos',  num: 4 },
  { nombre: 'Tus horarios',   num: 5 }
];

const FLUJO = {
  // Bloque 1 — Tu equipo
  1: [
    {
      id: 'num_personal',
      text: '¡Hola! Soy DallIA 👋 Voy a ayudarte a configurar tu restaurante. ¿Cuántas personas trabajan contigo?',
      chips: [
        { label: 'Solo yo',        value: 'solo_yo' },
        { label: '2-3 personas',   value: '2-3' },
        { label: '4-7 personas',   value: '4-7' },
        { label: '8 o más',        value: '8+' }
      ]
    },
    {
      id: 'dispositivo',
      text: '¿Qué dispositivo usas para tomar pedidos?',
      chips: [
        { label: 'Celular',     value: 'celular' },
        { label: 'Tablet',      value: 'tablet' },
        { label: 'Laptop/PC',   value: 'laptop' },
        { label: 'Todos',       value: 'todos' }
      ]
    },
    {
      id: 'tiene_impresora',
      text: '¿Tienes impresora para tickets?',
      chips: [
        { label: 'Sí, térmica',    value: 'termica' },
        { label: 'Sí, normal',     value: 'normal' },
        { label: 'No por ahora',   value: 'no' }
      ],
      lastInBloque: true
    }
  ],
  // Bloque 2 — Tu operación
  2: [
    {
      id: 'tipo_local',
      text: '¡Perfecto! Ahora cuéntame sobre tu operación. ¿Tienes mesas en tu local?',
      chips: [
        { label: 'Sí, tengo mesas',   value: 'si_mesas' },
        { label: 'No, solo delivery', value: 'solo_delivery' },
        { label: 'Solo para llevar',  value: 'para_llevar' },
        { label: 'Mixto',             value: 'mixto' }
      ]
    },
    {
      id: 'num_mesas',
      text: '¿Cuántas mesas tienes aproximadamente?',
      chips: [
        { label: '1-5 mesas',    value: '1-5' },
        { label: '6-10 mesas',   value: '6-10' },
        { label: '11-20 mesas',  value: '11-20' },
        { label: 'Más de 20',    value: '20+' }
      ],
      conditionalOn: 'tipo_local',
      showIf: ['si_mesas', 'mixto']
    },
    {
      id: 'canales_venta',
      text: '¿Por qué canales recibes pedidos?',
      chips: [
        { label: 'En local',              value: 'local' },
        { label: 'WhatsApp',              value: 'whatsapp' },
        { label: 'PedidosYa / Rappi',     value: 'apps' },
        { label: 'Todos',                 value: 'todos' }
      ],
      lastInBloque: true
    }
  ],
  // Bloque 3 — Tu dinero
  3: [
    {
      id: 'regimen_tributario',
      text: 'Ahora lo importante: el dinero 💰 ¿Cuál es tu situación tributaria?',
      chips: [
        { label: 'Soy informal',          value: 'informal' },
        { label: 'Tengo RUC - NRUS',      value: 'nrus' },
        { label: 'Tengo RUC - RER',       value: 'rer' },
        { label: 'Régimen MYPE/General',  value: 'mype' }
      ]
    },
    {
      id: 'metodos_pago',
      text: '¿Qué métodos de pago aceptas?',
      chips: [
        { label: 'Solo efectivo',          value: 'efectivo' },
        { label: 'Efectivo + Yape/Plin',   value: 'efectivo_yape' },
        { label: 'Tarjeta también',        value: 'tarjeta' },
        { label: 'Todos',                  value: 'todos' }
      ],
      lastInBloque: true
    }
  ],
  // Bloque 4 — Tus objetivos
  4: [
    {
      id: 'principal_problema',
      text: '¡Ya casi terminamos! ¿Qué es lo que más tiempo te quita ahora mismo?',
      chips: [
        { label: 'Tomar pedidos',        value: 'pedidos' },
        { label: 'Controlar caja',       value: 'caja' },
        { label: 'Saber el inventario',  value: 'inventario' },
        { label: 'Todo me quita tiempo', value: 'todo' }
      ]
    },
    {
      id: 'meta_ventas',
      text: '¿Cuál es tu meta de ventas mensual aproximada?',
      chips: [
        { label: 'Menos de S/5,000',      value: 'menos_5k' },
        { label: 'S/5,000 - S/15,000',    value: '5k_15k' },
        { label: 'S/15,000 - S/30,000',   value: '15k_30k' },
        { label: 'Más de S/30,000',        value: 'mas_30k' }
      ],
      lastInBloque: true
    }
  ],
  // Bloque 5 — Horarios
  5: [
    {
      id: 'hora_apertura',
      text: 'Por último, ¿a qué hora abres tu restaurante?',
      chips: [
        { label: '6am',  value: '06:00' },
        { label: '7am',  value: '07:00' },
        { label: '8am',  value: '08:00' },
        { label: '9am',  value: '09:00' },
        { label: '10am', value: '10:00' },
        { label: '11am', value: '11:00' }
      ]
    },
    {
      id: 'hora_cierre',
      text: '¿Y a qué hora cierras?',
      chips: [
        { label: '8pm',        value: '20:00' },
        { label: '9pm',        value: '21:00' },
        { label: '10pm',       value: '22:00' },
        { label: '11pm',       value: '23:00' },
        { label: 'Medianoche', value: '00:00' },
        { label: 'Madrugada',  value: '02:00' }
      ],
      lastInBloque: true,
      lastGlobal: true
    }
  ]
};

// Chat state
const state = {
  bloque: 1,
  preguntaIdx: 0,
  respuestas: {},     // { [bloque]: { field: value, ... } }
  bloqueRespuestas: {},
  chipsDisabled: false
};

// Restore server-side paso if already partially done
const serverPaso = parseInt('<%= onboarding_paso %>', 10) || 0;

// ── DOM refs ───────────────────────────────────────────────────────────────
const chatArea   = document.getElementById('chatArea');
const textInput  = document.getElementById('textInput');
const sendBtn    = document.getElementById('sendBtn');
const blockBadge = document.getElementById('blockBadge');

// ── Utilities ──────────────────────────────────────────────────────────────

function scrollToBottom() {
  chatArea.scrollTo({ top: chatArea.scrollHeight, behavior: 'smooth' });
}

function updateHeader() {
  const bloque = state.bloque;
  const info = BLOQUES[bloque - 1];
  if (info) blockBadge.textContent = info.nombre;

  for (let i = 1; i <= 5; i++) {
    const dot = document.getElementById('dot' + i);
    dot.className = 'dot';
    if (i < bloque)  dot.classList.add('completed');
    if (i === bloque) dot.classList.add('current');
  }
}

function addTypingIndicator() {
  const row = document.createElement('div');
  row.className = 'bubble-row dallia';
  row.id = 'typingIndicator';
  row.innerHTML = `
    <div class="typing-bubble">
      <div class="typing-dots">
        <span></span><span></span><span></span>
      </div>
    </div>`;
  chatArea.appendChild(row);
  scrollToBottom();
  return row;
}

function removeTypingIndicator() {
  const el = document.getElementById('typingIndicator');
  if (el) el.remove();
}

function addDalliaMessage(text, chips, chipsField) {
  const row = document.createElement('div');
  row.className = 'bubble-row dallia';

  const bubble = document.createElement('div');
  bubble.className = 'bubble dallia';
  bubble.textContent = text;
  row.appendChild(bubble);

  if (chips && chips.length > 0) {
    const chipsRow = document.createElement('div');
    chipsRow.className = 'chips-row';
    chips.forEach(chip => {
      const btn = document.createElement('button');
      btn.className = 'chip';
      btn.textContent = chip.label;
      btn.dataset.value = chip.value;
      btn.dataset.field = chipsField || '';
      btn.addEventListener('click', () => handleChipClick(btn, chip.label, chip.value));
      chipsRow.appendChild(btn);
    });
    row.appendChild(chipsRow);
  }

  chatArea.appendChild(row);
  scrollToBottom();
  return row;
}

function addUserMessage(text) {
  const row = document.createElement('div');
  row.className = 'bubble-row user';
  const bubble = document.createElement('div');
  bubble.className = 'bubble user';
  bubble.textContent = text;
  row.appendChild(bubble);
  chatArea.appendChild(row);
  scrollToBottom();
}

function disableAllChips() {
  document.querySelectorAll('.chip').forEach(c => {
    c.disabled = true;
    c.style.pointerEvents = 'none';
  });
}

// ── Core logic ─────────────────────────────────────────────────────────────

function getCurrentPregunta() {
  const preguntas = FLUJO[state.bloque];
  return preguntas ? preguntas[state.preguntaIdx] : null;
}

async function handleChipClick(btn, label, value) {
  if (state.chipsDisabled) return;
  state.chipsDisabled = true;
  disableAllChips();

  addUserMessage(label);

  const pregunta = getCurrentPregunta();
  if (!pregunta) return;

  // Store answer
  if (!state.bloqueRespuestas[state.bloque]) state.bloqueRespuestas[state.bloque] = {};
  state.bloqueRespuestas[state.bloque][pregunta.id] = value;

  // Advance within bloque
  const preguntas = FLUJO[state.bloque];
  let nextIdx = state.preguntaIdx + 1;

  // Skip conditional questions
  while (nextIdx < preguntas.length) {
    const next = preguntas[nextIdx];
    if (next.conditionalOn && next.showIf) {
      const condVal = state.bloqueRespuestas[state.bloque][next.conditionalOn];
      if (!next.showIf.includes(condVal)) {
        nextIdx++;
        continue;
      }
    }
    break;
  }

  if (pregunta.lastInBloque || nextIdx >= preguntas.length) {
    // End of this block — save to server then advance
    await guardarPaso(state.bloque, state.bloqueRespuestas[state.bloque]);

    if (pregunta.lastGlobal) {
      // All done — complete
      await completarOnboarding();
      return;
    }

    // Move to next block
    state.bloque++;
    state.preguntaIdx = 0;
    updateHeader();
    showCurrentPregunta();
  } else {
    state.preguntaIdx = nextIdx;
    showCurrentPregunta();
  }

  state.chipsDisabled = false;
}

function showCurrentPregunta() {
  const pregunta = getCurrentPregunta();
  if (!pregunta) return;

  // Typing indicator delay for UX
  const typing = addTypingIndicator();
  setTimeout(() => {
    removeTypingIndicator();
    addDalliaMessage(pregunta.text, pregunta.chips, pregunta.id);
  }, 700);
}

async function guardarPaso(paso, datos) {
  try {
    const resp = await fetch('/onboarding-dallia/api/guardar-paso', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ paso, datos })
    });
    const json = await resp.json();
    if (!json.ok) console.warn('[onboarding] guardar-paso error:', json.error);
  } catch (err) {
    console.error('[onboarding] guardar-paso fetch error:', err);
  }
}

async function completarOnboarding() {
  // Show final DallIA message
  const typing = addTypingIndicator();
  await delay(1000);
  removeTypingIndicator();
  addDalliaMessage('¡Listo! 🎉 Configuré tu sistema según tu perfil. ¡Comencemos!', null, null);

  await delay(1200);

  try {
    const resp = await fetch('/onboarding-dallia/api/completar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    const json = await resp.json();
    if (json.ok) {
      showCompletionOverlay(json.redirect || '/');
    } else {
      console.error('[onboarding] completar error:', json.error);
      window.location.href = '/';
    }
  } catch (err) {
    console.error('[onboarding] completar fetch error:', err);
    window.location.href = '/';
  }
}

function showCompletionOverlay(redirectUrl) {
  const overlay = document.getElementById('completionOverlay');
  overlay.classList.add('active');

  // Animate progress bar then redirect
  setTimeout(() => {
    const bar = document.getElementById('completionProgress');
    bar.style.width = '100%';
  }, 100);

  setTimeout(() => {
    window.location.href = redirectUrl;
  }, 3000);
}

function delay(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

// Free-text input send
function handleTextSend() {
  const text = textInput.value.trim();
  if (!text) return;
  textInput.value = '';

  const pregunta = getCurrentPregunta();
  if (!pregunta) return;

  if (state.chipsDisabled) return;
  state.chipsDisabled = true;
  disableAllChips();

  addUserMessage(text);

  if (!state.bloqueRespuestas[state.bloque]) state.bloqueRespuestas[state.bloque] = {};
  state.bloqueRespuestas[state.bloque][pregunta.id] = text;

  const preguntas = FLUJO[state.bloque];
  let nextIdx = state.preguntaIdx + 1;

  while (nextIdx < preguntas.length) {
    const next = preguntas[nextIdx];
    if (next.conditionalOn && next.showIf) {
      const condVal = state.bloqueRespuestas[state.bloque][next.conditionalOn];
      if (!next.showIf.includes(condVal)) { nextIdx++; continue; }
    }
    break;
  }

  if (pregunta.lastInBloque || nextIdx >= preguntas.length) {
    guardarPaso(state.bloque, state.bloqueRespuestas[state.bloque]).then(() => {
      if (pregunta.lastGlobal) {
        completarOnboarding();
        return;
      }
      state.bloque++;
      state.preguntaIdx = 0;
      updateHeader();
      showCurrentPregunta();
      state.chipsDisabled = false;
    });
  } else {
    state.preguntaIdx = nextIdx;
    showCurrentPregunta();
    state.chipsDisabled = false;
  }
}

sendBtn.addEventListener('click', handleTextSend);
textInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') handleTextSend();
});

// ── Boot ───────────────────────────────────────────────────────────────────

function boot() {
  // If server says a certain paso was already saved, jump to next block
  if (serverPaso > 0 && serverPaso < 5) {
    state.bloque = serverPaso + 1;
  }
  updateHeader();
  showCurrentPregunta();
}

boot();
</script>
