<%# @variant: pwa %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Caja">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <title>Caja</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #0f172a;
      color: #fff;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
      overscroll-behavior: none;
    }
    .shell {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    }

    /* ─── ABRIR CAJA screen ─── */
    .open-screen {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: calc(100dvh - 80px);
      padding: 32px 24px;
      text-align: center;
    }
    .open-orb {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      background: rgba(239,82,15,0.15);
      border: 1px solid rgba(239,82,15,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
      margin-bottom: 24px;
    }
    .open-title {
      font-size: 24px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 8px;
    }
    .open-sub {
      font-size: 14px;
      color: rgba(255,255,255,0.45);
      margin-bottom: 32px;
      line-height: 1.5;
    }
    .open-form {
      width: 100%;
      max-width: 340px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .form-field label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,0.5);
      margin-bottom: 6px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .form-field .input-wrap {
      display: flex;
      align-items: center;
      background: #1e293b;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px;
      overflow: hidden;
    }
    .form-field .input-prefix {
      padding: 14px 12px 14px 16px;
      font-size: 15px;
      font-weight: 700;
      color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.04);
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .form-field input,
    .form-field select {
      flex: 1;
      background: none;
      border: none;
      outline: none;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      padding: 14px 16px;
    }
    .form-field select option { background: #1e293b; color: #fff; }
    .form-field select { appearance: none; -webkit-appearance: none; }
    .btn-abrir-caja {
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg,#ef520f,#df2c05);
      border: none;
      border-radius: 16px;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 17px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 8px;
      -webkit-tap-highlight-color: transparent;
    }
    .btn-abrir-caja:active { opacity: 0.85; }
    #openMsg { font-size: 13px; color: #ef4444; margin-top: 8px; display: none; }

    /* ─── CAJA ABIERTA screen ─── */
    .caja-section { padding: 16px; }

    /* KPI cards */
    .kpi3-row {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin-bottom: 16px;
    }
    .kpi3 {
      background: #1e293b;
      border-radius: 14px;
      padding: 14px 10px;
      border: 1px solid rgba(255,255,255,0.07);
      text-align: center;
    }
    .kpi3-label { font-size: 10px; color: rgba(255,255,255,0.45); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
    .kpi3-val { font-size: 20px; font-weight: 800; line-height: 1; }
    .kpi3-val.green { color: #22c55e; }
    .kpi3-val.red   { color: #ef4444; }
    .kpi3-val.white { color: #fff; }

    /* Agente Salva card */
    .salva-card {
      background: linear-gradient(135deg,#ef520f,#df2c05);
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 16px;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 14px;
      -webkit-tap-highlight-color: transparent;
    }
    .salva-card:active { opacity: 0.85; }
    .salva-orb {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      flex-shrink: 0;
    }
    .salva-info-title {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
    }
    .salva-info-sub {
      font-size: 12px;
      color: rgba(255,255,255,0.75);
      margin-top: 3px;
      line-height: 1.4;
    }

    /* Section header */
    .sec-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .sec-title {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
    }
    .sec-badge {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
    }

    /* Movimientos list */
    .mov-list { display: flex; flex-direction: column; gap: 8px; }
    .mov-item {
      background: #1e293b;
      border-radius: 12px;
      padding: 12px 14px;
      border: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .mov-dot {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 16px;
    }
    .mov-dot.ing { background: rgba(34,197,94,0.15); }
    .mov-dot.egr { background: rgba(239,68,68,0.15); }
    .mov-info { flex: 1; min-width: 0; }
    .mov-desc { font-size: 13px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mov-time { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }
    .mov-amount { font-size: 15px; font-weight: 700; flex-shrink: 0; }
    .mov-amount.ing { color: #22c55e; }
    .mov-amount.egr { color: #ef4444; }

    /* Empty state */
    .mov-empty {
      text-align: center;
      padding: 28px 16px;
      color: rgba(255,255,255,0.3);
      font-size: 13px;
    }

    /* FABs */
    .caja-fab-row {
      position: fixed;
      bottom: calc(72px + env(safe-area-inset-bottom, 0px));
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      z-index: 200;
    }
    .caja-fab {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(0,0,0,0.3);
      -webkit-tap-highlight-color: transparent;
    }
    .caja-fab:active { transform: scale(0.93); }
    .caja-fab.ing { background: linear-gradient(135deg,#22c55e,#16a34a); color: #fff; }
    .caja-fab.egr { background: linear-gradient(135deg,#ef4444,#dc2626); color: #fff; }

    /* Cerrar caja button */
    .btn-cerrar-caja {
      width: calc(100% - 32px);
      margin: 8px 16px 4px;
      padding: 14px;
      background: rgba(239,68,68,0.12);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 14px;
      color: #ef4444;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .btn-cerrar-caja:active { opacity: 0.7; }

    /* Modal backdrop */
    .mov-modal-bg {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 300;
      align-items: flex-end;
    }
    .mov-modal-bg.open { display: flex; }
    .mov-modal {
      background: #1e293b;
      border-radius: 24px 24px 0 0;
      padding: 24px 20px calc(24px + env(safe-area-inset-bottom, 0px));
      width: 100%;
    }
    .mov-modal-title { font-size: 18px; font-weight: 800; margin-bottom: 20px; }
    .mov-modal-title.ing { color: #22c55e; }
    .mov-modal-title.egr { color: #ef4444; }
    .mov-modal .form-field { margin-bottom: 14px; }
    .mov-modal-btns { display: flex; gap: 10px; margin-top: 20px; }
    .mov-modal-btns button { flex: 1; padding: 14px; border-radius: 14px; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700; border: none; cursor: pointer; }
    .btn-cancel-mov { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }
    .btn-confirm-mov.ing { background: linear-gradient(135deg,#22c55e,#16a34a); color: #fff; }
    .btn-confirm-mov.egr { background: linear-gradient(135deg,#ef4444,#dc2626); color: #fff; }
    #movMsg { font-size: 13px; color: #ef4444; margin-top: 8px; display: none; }
  </style>
</head>
<body>
<% var cajaAbierta = locals.cajaAbierta; var totales = locals.totales || {}; var movimientos = locals.movimientos || []; var turnos = locals.turnos || []; var metodos = locals.metodos || []; %>
<div class="shell">

  <%- include('partials/pwa-header', { title: 'Caja', subtitle: cajaAbierta ? 'Caja abierta' : 'Sin caja abierta' }) %>

  <% if (!cajaAbierta) { %>
  <!-- ===== ABRIR CAJA ===== -->
  <div class="open-screen">
    <div class="open-orb">🏦</div>
    <h2 class="open-title">Abrir Caja</h2>
    <p class="open-sub">No hay caja abierta hoy.<br>Ingresa el fondo inicial para comenzar.</p>

    <form class="open-form" id="formAbrirCaja">
      <div class="form-field">
        <label>Fondo inicial</label>
        <div class="input-wrap">
          <span class="input-prefix">S/</span>
          <input type="number" id="montoApertura" name="monto_apertura" min="0" step="0.01" placeholder="0.00" required>
        </div>
      </div>
      <div class="form-field">
        <label>Turno</label>
        <div class="input-wrap">
          <select id="turnoApertura" name="turno_id" required>
            <option value="" disabled selected>Seleccionar turno</option>
            <% (turnos||[]).forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.nombre %></option>
            <% }); %>
          </select>
        </div>
      </div>
      <button type="submit" class="btn-abrir-caja">Abrir Caja</button>
      <div id="openMsg"></div>
    </form>
  </div>

  <% } else { %>
  <!-- ===== CAJA ABIERTA ===== -->
  <div class="caja-section">

    <!-- KPIs -->
    <div class="kpi3-row">
      <div class="kpi3">
        <div class="kpi3-label">Ingresos</div>
        <div class="kpi3-val green">S/ <%= (totales.ingresos||0).toFixed(0) %></div>
      </div>
      <div class="kpi3">
        <div class="kpi3-label">Egresos</div>
        <div class="kpi3-val red">S/ <%= (totales.egresos||0).toFixed(0) %></div>
      </div>
      <div class="kpi3">
        <div class="kpi3-label">Efectivo</div>
        <div class="kpi3-val white">S/ <%= (totales.efectivo_actual||0).toFixed(0) %></div>
      </div>
    </div>

    <!-- Agente Salva -->
    <a href="/chat?agent=salva&contexto=caja" class="salva-card">
      <div class="salva-orb">🤖</div>
      <div>
        <div class="salva-info-title">Agente Salva</div>
        <div class="salva-info-sub">DalIA cuida tu caja — alertas de meta, stock y diferencias</div>
      </div>
    </a>

    <!-- Movimientos -->
    <div class="sec-header">
      <span class="sec-title">Movimientos de hoy</span>
      <span class="sec-badge"><%= movimientos.length %> movimientos</span>
    </div>

    <div class="mov-list">
      <% if (movimientos.length === 0) { %>
        <div class="mov-empty">Sin movimientos aún</div>
      <% } else { %>
        <% movimientos.forEach(function(mov) {
            var isIng = mov.tipo === 'ingreso';
            var hora = mov.created_at ? new Date(mov.created_at).toLocaleTimeString('es-PE',{hour:'2-digit',minute:'2-digit'}) : '';
        %>
        <div class="mov-item">
          <div class="mov-dot <%= isIng ? 'ing' : 'egr' %>"><%= isIng ? '↑' : '↓' %></div>
          <div class="mov-info">
            <div class="mov-desc"><%= mov.descripcion || (isIng ? 'Ingreso' : 'Egreso') %></div>
            <div class="mov-time"><%= hora %> · <%= mov.metodo_nombre || 'Efectivo' %></div>
          </div>
          <div class="mov-amount <%= isIng ? 'ing' : 'egr' %>"><%= isIng ? '+' : '-' %>S/ <%= Number(mov.monto||0).toFixed(2) %></div>
        </div>
        <% }); %>
      <% } %>
    </div>

  </div>

  <!-- Cerrar caja -->
  <button class="btn-cerrar-caja" id="btnCerrarCaja">Cerrar caja</button>

  <!-- FABs -->
  <div class="caja-fab-row">
    <button class="caja-fab egr" id="fabEgreso" title="Registrar egreso">−</button>
    <button class="caja-fab ing" id="fabIngreso" title="Registrar ingreso">+</button>
  </div>

  <!-- Modal ingreso/egreso -->
  <div class="mov-modal-bg" id="movModalBg">
    <div class="mov-modal">
      <div class="mov-modal-title" id="movModalTitle">Registrar Ingreso</div>
      <div class="form-field">
        <label>Monto</label>
        <div class="input-wrap">
          <span class="input-prefix">S/</span>
          <input type="number" id="movMonto" min="0.01" step="0.01" placeholder="0.00">
        </div>
      </div>
      <div class="form-field">
        <label>Descripción</label>
        <div class="input-wrap">
          <input type="text" id="movDescripcion" placeholder="Ej: Venta efectivo">
        </div>
      </div>
      <div class="form-field">
        <label>Método de pago</label>
        <div class="input-wrap">
          <select id="movMetodo">
            <% (metodos||[]).forEach(function(m) { %>
              <option value="<%= m.id %>"><%= m.nombre %></option>
            <% }); %>
            <option value="">Efectivo</option>
          </select>
        </div>
      </div>
      <div id="movMsg"></div>
      <div class="mov-modal-btns">
        <button class="btn-cancel-mov" id="btnCancelMov">Cancelar</button>
        <button class="btn-confirm-mov ing" id="btnConfirmMov">Guardar</button>
      </div>
    </div>
  </div>

  <% } %>

</div>

<%- include('partials/limelight-nav', { reqPath: '/caja' }) %>

<script src="/js/dallia-fab.js"></script>
<script>
(function() {
  <% if (!cajaAbierta) { %>
  // Abrir caja
  var form = document.getElementById('formAbrirCaja');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var msg = document.getElementById('openMsg');
      msg.style.display = 'none';
      var monto = document.getElementById('montoApertura').value;
      var turno = document.getElementById('turnoApertura').value;
      fetch('/api/caja/abrir', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ monto_apertura: monto, turno_id: turno })
      }).then(function(r){ return r.json(); }).then(function(d) {
        if (d.error) { msg.textContent = d.error; msg.style.display = 'block'; }
        else { location.reload(); }
      }).catch(function(){ msg.textContent = 'Error de conexión'; msg.style.display = 'block'; });
    });
  }
  <% } else { %>
  // Cerrar caja
  var btnCerrar = document.getElementById('btnCerrarCaja');
  if (btnCerrar) {
    btnCerrar.addEventListener('click', function() {
      if (!confirm('¿Cerrar la caja ahora?')) return;
      fetch('/api/caja/cerrar', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' })
        .then(function(r){ return r.json(); }).then(function(d) {
          if (d.error) { alert(d.error); }
          else { location.reload(); }
        });
    });
  }

  // Modal movimientos
  var bg = document.getElementById('movModalBg');
  var movTipo = 'ingreso';
  function openModal(tipo) {
    movTipo = tipo;
    var title = document.getElementById('movModalTitle');
    var btn   = document.getElementById('btnConfirmMov');
    if (tipo === 'ingreso') {
      title.textContent = 'Registrar Ingreso';
      title.className = 'mov-modal-title ing';
      btn.className = 'btn-confirm-mov ing';
    } else {
      title.textContent = 'Registrar Egreso';
      title.className = 'mov-modal-title egr';
      btn.className = 'btn-confirm-mov egr';
    }
    document.getElementById('movMonto').value = '';
    document.getElementById('movDescripcion').value = '';
    document.getElementById('movMsg').style.display = 'none';
    bg.classList.add('open');
  }
  document.getElementById('fabIngreso').addEventListener('click', function() { openModal('ingreso'); });
  document.getElementById('fabEgreso').addEventListener('click', function() { openModal('egreso'); });
  document.getElementById('btnCancelMov').addEventListener('click', function() { bg.classList.remove('open'); });
  bg.addEventListener('click', function(e) { if (e.target === bg) bg.classList.remove('open'); });

  document.getElementById('btnConfirmMov').addEventListener('click', function() {
    var monto = document.getElementById('movMonto').value;
    var desc  = document.getElementById('movDescripcion').value;
    var metodo = document.getElementById('movMetodo').value;
    var msg   = document.getElementById('movMsg');
    if (!monto || Number(monto) <= 0) { msg.textContent = 'Ingresa un monto válido'; msg.style.display = 'block'; return; }
    fetch('/api/caja/movimiento', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tipo: movTipo, monto: monto, descripcion: desc, metodo_pago_id: metodo || null })
    }).then(function(r){ return r.json(); }).then(function(d) {
      if (d.error) { msg.textContent = d.error; msg.style.display = 'block'; }
      else { bg.classList.remove('open'); location.reload(); }
    }).catch(function(){ msg.textContent = 'Error de conexión'; msg.style.display = 'block'; });
  });
  <% } %>
})();
</script>
<script src="/js/salva-alerts.js"></script>
</body>
</html>
