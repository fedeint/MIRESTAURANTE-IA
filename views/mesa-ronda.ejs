<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Ronda <%= ronda_num %> · Mesa <%= mesa.numero %> — MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #F0F2F8;
      height: 100dvh;
      overflow: hidden;
      max-width: 480px;
      margin: 0 auto;
    }
    .app-shell { display: flex; flex-direction: column; height: 100dvh; }

    /* HEADER */
    .app-header {
      background: linear-gradient(180deg, #10152f 0%, #0a0f24 60%, #090d1d 100%);
      border-radius: 0 0 20px 20px;
      padding: 48px 20px 20px;
      color: white; flex-shrink: 0;
    }
    .header-row { display: flex; align-items: center; gap: 10px; }
    .back-btn {
      background: rgba(255,255,255,0.12); border: none; color: white;
      width: 36px; height: 36px; border-radius: 10px;
      cursor: pointer; font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; text-decoration: none;
    }
    .header-title { font-size: 18px; font-weight: 700; flex: 1; }
    .header-cuenta { font-size: 13px; color: rgba(255,255,255,0.5); white-space: nowrap; }

    /* CATEGORY TABS */
    .cats-bar {
      display: flex; gap: 8px; overflow-x: auto;
      padding: 12px 16px 0; scrollbar-width: none; flex-shrink: 0;
    }
    .cats-bar::-webkit-scrollbar { display: none; }
    .cat-btn {
      padding: 7px 16px; border-radius: 20px; border: none;
      background: white; color: #8B8FAD;
      font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600;
      cursor: pointer; white-space: nowrap; flex-shrink: 0;
      transition: background 0.15s, color 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .cat-btn.active { background: #ef520f; color: white; }

    /* CONTENT */
    .content-area {
      flex: 1; overflow-y: auto;
      padding: 12px 16px 160px;
      -webkit-overflow-scrolling: touch;
    }

    /* PRODUCT CARD */
    .product-card {
      background: white; border-radius: 14px; padding: 14px;
      margin-bottom: 10px;
      display: flex; align-items: center; gap: 12px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .product-card.hidden { display: none; }
    .prod-emoji {
      width: 48px; height: 48px;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; flex-shrink: 0;
    }
    .prod-info { flex: 1; min-width: 0; }
    .prod-name { font-size: 14px; font-weight: 700; color: #0a0f24; }
    .prod-price { font-size: 14px; font-weight: 700; color: #ef520f; margin-top: 4px; }
    .qty-ctrl { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .qty-btn {
      width: 30px; height: 30px; border-radius: 50%; border: none;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      color: white; font-size: 18px; font-weight: 700;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      -webkit-tap-highlight-color: transparent;
    }
    .qty-btn.minus { background: #f0f2f8; color: #8B8FAD; }
    .qty-num { font-size: 15px; font-weight: 700; color: #0a0f24; min-width: 20px; text-align: center; }

    /* STICKY CTA */
    .sticky-cta {
      position: fixed; bottom: 64px; left: 50%; transform: translateX(-50%);
      width: calc(100% - 32px); max-width: 448px; z-index: 50;
    }
    .cta-btn {
      width: 100%; padding: 16px 24px;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      color: white; border: none; border-radius: 16px;
      font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      box-shadow: 0 4px 16px rgba(239,82,15,0.4);
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .cta-btn:active { opacity: 0.85; }
    .cta-btn:disabled { opacity: 0.45; cursor: not-allowed; }

    /* BOTTOM NAV */
    .bottom-nav {
      position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 100%; max-width: 480px; background: white;
      display: flex; justify-content: space-around;
      padding: 8px 0; padding-bottom: max(8px, env(safe-area-inset-bottom));
      box-shadow: 0 -2px 16px rgba(0,0,0,0.08); z-index: 100;
    }
    .nav-item {
      display: flex; flex-direction: column; align-items: center; gap: 2px;
      color: #8B8FAD; text-decoration: none; font-size: 10px; font-weight: 500;
    }
    .nav-item.active { color: #ef520f; }
    .nav-icon { font-size: 22px; }

    /* TOAST */
    .toast {
      position: fixed; top: 80px; left: 50%;
      transform: translateX(-50%) translateY(-20px);
      background: #0a0f24; color: white;
      padding: 12px 20px; border-radius: 12px;
      font-size: 14px; font-weight: 500;
      opacity: 0; transition: opacity 0.3s, transform 0.3s;
      z-index: 200; white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.success { background: #16a34a; }
    .toast.error { background: #dc2626; }

    /* LOADING */
    .loading-overlay {
      position: fixed; inset: 0;
      background: rgba(10,15,36,0.7);
      display: flex; align-items: center; justify-content: center;
      z-index: 300;
    }
    .spinner {
      width: 40px; height: 40px;
      border: 3px solid rgba(255,255,255,0.2);
      border-top-color: white; border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none !important; }
  </style>
</head>
<body>
<div class="app-shell">

  <!-- HEADER -->
  <header class="app-header">
    <div class="header-row">
      <a href="/mesa/<%= mesa.id %>" class="back-btn">&#8592;</a>
      <span class="header-title">Mesa <%= mesa.numero %> &middot; Ronda <%= ronda_num %></span>
      <span class="header-cuenta">Cuenta: S/ <%= Number(total_acumulado).toFixed(2) %></span>
    </div>
  </header>

  <!-- CATEGORY TABS -->
  <div class="cats-bar" id="catsBar">
    <button class="cat-btn active" data-cat="todo" onclick="filterCat(this,'todo')">Todo</button>
    <% const cats = [...new Set(productos.map(p => p.categoria).filter(Boolean))]; %>
    <% cats.forEach(function(cat) { %>
      <button class="cat-btn" data-cat="<%= cat %>" onclick="filterCat(this,'<%= cat %>')">
        <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
      </button>
    <% }); %>
  </div>

  <!-- PRODUCT LIST -->
  <div class="content-area" id="productList">
    <% productos.forEach(function(p) { %>
      <div class="product-card"
           data-cat="<%= p.categoria || '' %>"
           data-id="<%= p.id %>"
           data-precio="<%= p.precio %>"
           data-nombre="<%= p.nombre %>">
        <div class="prod-emoji"><%= p.emoji || '🍽️' %></div>
        <div class="prod-info">
          <div class="prod-name"><%= p.nombre %></div>
          <div class="prod-price">S/ <%= Number(p.precio).toFixed(2) %></div>
        </div>
        <div class="qty-ctrl">
          <button class="qty-btn minus" onclick="changeQty(<%= p.id %>, -1)">−</button>
          <span class="qty-num" id="qty-<%= p.id %>">0</span>
          <button class="qty-btn" onclick="changeQty(<%= p.id %>, 1)">+</button>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- STICKY CTA -->
  <div class="sticky-cta">
    <button class="cta-btn" id="ctaBtn" disabled onclick="enviarRonda()">
      &#9992; Enviar ronda <%= ronda_num %> (0) &middot; S/ 0.00
    </button>
  </div>

  <!-- BOTTOM NAV -->
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="nav-icon">🏠</span>INICIO</a>
    <a href="/pedidos" class="nav-item active"><span class="nav-icon">📋</span>PEDIDOS</a>
    <a href="/cocina-display" class="nav-item"><span class="nav-icon">🍳</span>COCINA</a>
    <a href="/caja" class="nav-item"><span class="nav-icon">💰</span>CAJA</a>
    <a href="/configuracion" class="nav-item"><span class="nav-icon">⋯</span>MÁS</a>
  </nav>
</div>

<div class="toast" id="toast"></div>
<div class="loading-overlay hidden" id="loadingOverlay"><div class="spinner"></div></div>

<script>
  const MESA_ID   = <%= mesa.id %>;
  const RONDA_NUM = <%= ronda_num %>;
  const qtys      = {};

  function changeQty(prodId, delta) {
    qtys[prodId] = Math.max(0, (qtys[prodId] || 0) + delta);
    document.getElementById('qty-' + prodId).textContent = qtys[prodId];
    updateCTA();
  }

  function updateCTA() {
    let totalQty = 0, totalMonto = 0;
    document.querySelectorAll('.product-card').forEach(function(card) {
      const id  = Number(card.dataset.id);
      const qty = qtys[id] || 0;
      if (qty > 0) {
        totalQty   += qty;
        totalMonto += qty * Number(card.dataset.precio);
      }
    });
    const btn = document.getElementById('ctaBtn');
    btn.disabled  = totalQty === 0;
    btn.innerHTML = '\u2708 Enviar ronda ' + RONDA_NUM + ' (' + totalQty + ') \u00B7 S/ ' + totalMonto.toFixed(2);
  }

  function filterCat(el, cat) {
    document.querySelectorAll('.cat-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    document.querySelectorAll('.product-card').forEach(function(card) {
      if (cat === 'todo' || card.dataset.cat === cat) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }

  function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = 'toast ' + (type || '');
    t.classList.add('show');
    setTimeout(function() { t.classList.remove('show'); }, 3000);
  }

  async function enviarRonda() {
    const items = [];
    document.querySelectorAll('.product-card').forEach(function(card) {
      const id  = Number(card.dataset.id);
      const qty = qtys[id] || 0;
      if (qty > 0) items.push({ producto_id: id, cantidad: qty });
    });
    if (!items.length) return;

    document.getElementById('loadingOverlay').classList.remove('hidden');
    try {
      const res  = await fetch('/mesa/' + MESA_ID + '/ronda', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ items })
      });
      const data = await res.json();
      if (data.ok) {
        showToast('Ronda ' + RONDA_NUM + ' enviada a cocina', 'success');
        setTimeout(function() { window.location.href = '/mesa/' + MESA_ID; }, 1000);
      } else {
        showToast(data.error || 'Error al enviar ronda', 'error');
      }
    } catch (e) {
      showToast('Error de conexión', 'error');
    } finally {
      document.getElementById('loadingOverlay').classList.add('hidden');
    }
  }
</script>
<script src="/js/dallia-fab.js"></script>
</body>
</html>
