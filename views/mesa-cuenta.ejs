<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Mesa <%= mesa.numero %> — MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #F0F2F8;
      height: 100dvh;
      overflow: hidden;
      max-width: 480px;
      margin: 0 auto;
    }
    .app-shell { display: flex; flex-direction: column; height: 100dvh; }

    /* HEADER */
    .app-header {
      background: linear-gradient(180deg, #10152f 0%, #0a0f24 60%, #090d1d 100%);
      border-radius: 0 0 20px 20px;
      padding: 48px 20px 20px;
      color: white;
      flex-shrink: 0;
    }
    .header-row { display: flex; align-items: center; gap: 10px; }
    .back-btn {
      background: rgba(255,255,255,0.12);
      border: none; color: white;
      width: 36px; height: 36px;
      border-radius: 10px;
      cursor: pointer; font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; text-decoration: none;
    }
    .header-main { flex: 1; display: flex; align-items: center; gap: 10px; }
    .header-title { font-size: 18px; font-weight: 700; }
    .pill-abierta {
      background: rgba(34,197,94,0.2);
      color: #22C55E;
      font-size: 11px; font-weight: 600;
      padding: 3px 10px; border-radius: 20px;
      display: flex; align-items: center; gap: 4px;
      white-space: nowrap;
    }
    .timer {
      margin-left: auto;
      font-size: 13px; font-weight: 700;
      color: #ef520f;
      white-space: nowrap;
    }
    .header-subtitle { font-size: 12px; color: rgba(255,255,255,0.55); margin-top: 6px; }

    /* TOTAL BANNER */
    .total-banner {
      background: white;
      margin: 16px 16px 0;
      border-radius: 16px;
      padding: 14px 16px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      flex-shrink: 0;
    }
    .total-label { font-size: 13px; color: #8B8FAD; font-weight: 500; }
    .total-amount { font-size: 26px; font-weight: 700; color: #ef520f; }

    /* CONTENT */
    .content-area {
      flex: 1; overflow-y: auto;
      padding: 12px 16px 160px;
      -webkit-overflow-scrolling: touch;
    }

    /* RONDA CARD */
    .ronda-card {
      background: white;
      border-radius: 16px;
      padding: 14px 16px;
      margin-bottom: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .ronda-header {
      display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
    }
    .ronda-badge {
      width: 28px; height: 28px;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      border-radius: 8px;
      color: white; font-size: 13px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ronda-title { font-size: 14px; font-weight: 700; color: #0a0f24; flex: 1; }
    .ronda-time { font-size: 12px; color: #8B8FAD; }
    .ronda-total { font-size: 14px; font-weight: 700; color: #0a0f24; }
    .ronda-items { border-top: 1px solid #F0F2F8; padding-top: 10px; }
    .ronda-item-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 5px 0; font-size: 13px; color: #0a0f24;
    }
    .ronda-item-price { font-weight: 600; color: #0a0f24; }
    .ronda-status {
      margin-top: 10px; display: flex; justify-content: flex-end;
    }
    .chip-cocina {
      background: #fff7ed; color: #ea580c;
      font-size: 11px; font-weight: 600;
      padding: 4px 12px; border-radius: 20px;
    }
    .chip-servido {
      background: #dcfce7; color: #16a34a;
      font-size: 11px; font-weight: 600;
      padding: 4px 12px; border-radius: 20px;
    }
    .empty-state {
      text-align: center; padding: 48px 24px;
      color: #8B8FAD; font-size: 14px;
    }
    .empty-icon { font-size: 40px; margin-bottom: 12px; }

    /* BOTTOM CTA PAIR */
    .cta-pair {
      position: fixed; bottom: 64px;
      left: 50%; transform: translateX(-50%);
      width: calc(100% - 32px); max-width: 448px;
      display: flex; gap: 10px; z-index: 50;
    }
    .cta-btn {
      flex: 1; padding: 15px 10px;
      border: none; border-radius: 16px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px; font-weight: 700;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
      text-decoration: none;
    }
    .cta-btn:active { opacity: 0.85; }
    .cta-orange {
      background: linear-gradient(135deg, #ef520f, #df2c05);
      color: white;
      box-shadow: 0 4px 16px rgba(239,82,15,0.4);
    }
    .cta-dark { background: #0a0f24; color: white; }

    /* BOTTOM NAV */
    .bottom-nav {
      position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 100%; max-width: 480px;
      background: white;
      display: flex; justify-content: space-around;
      padding: 8px 0; padding-bottom: max(8px, env(safe-area-inset-bottom));
      box-shadow: 0 -2px 16px rgba(0,0,0,0.08); z-index: 100;
    }
    .nav-item {
      display: flex; flex-direction: column; align-items: center; gap: 2px;
      color: #8B8FAD; text-decoration: none; font-size: 10px; font-weight: 500;
    }
    .nav-item.active { color: #ef520f; }
    .nav-icon { font-size: 22px; }
  </style>
</head>
<body>
<div class="app-shell">

  <!-- HEADER -->
  <header class="app-header">
    <div class="header-row">
      <a href="/pedidos" class="back-btn">&#8592;</a>
      <div class="header-main">
        <span class="header-title">Mesa <%= mesa.numero %></span>
        <span class="pill-abierta">&#9679; Abierta</span>
        <span class="timer" id="timerEl">&#9203; --</span>
      </div>
    </div>
    <div class="header-subtitle">
      <% if (mesa.capacidad) { %><%= mesa.capacidad %> personas &middot; <% } %>
      Mozo: <%= pedido && pedido.mesero_nombre ? pedido.mesero_nombre : (user.nombre || 'Sin asignar') %>
    </div>
  </header>

  <!-- TOTAL ACUMULADO -->
  <div class="total-banner">
    <span class="total-label">Total acumulado</span>
    <span class="total-amount">S/ <%= Number(total_acumulado).toFixed(2) %></span>
  </div>

  <!-- RONDAS -->
  <div class="content-area">
    <% if (!pedido) { %>
      <div class="empty-state">
        <div class="empty-icon">🍽️</div>
        <div>No hay pedido abierto para esta mesa.</div>
      </div>
    <% } else if (rondas.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📋</div>
        <div>Sin items todavía. Agrega la primera ronda.</div>
      </div>
    <% } else { %>
      <% rondas.forEach(function(ronda) { %>
        <div class="ronda-card">
          <div class="ronda-header">
            <div class="ronda-badge"><%= ronda.num %></div>
            <span class="ronda-title">Ronda <%= ronda.num %></span>
            <span class="ronda-time">
              <%= new Date(ronda.created_at).toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' }) %>
            </span>
            <span class="ronda-total">S/ <%= Number(ronda.total).toFixed(2) %></span>
          </div>
          <div class="ronda-items">
            <% ronda.items.forEach(function(item) { %>
              <div class="ronda-item-row">
                <span><%= item.cantidad %>x <%= item.producto_nombre %></span>
                <span class="ronda-item-price">S/ <%= Number(item.subtotal).toFixed(2) %></span>
              </div>
            <% }); %>
          </div>
          <div class="ronda-status">
            <% if (ronda.estado_display === 'en_cocina') { %>
              <span class="chip-cocina">En cocina</span>
            <% } else { %>
              <span class="chip-servido">Servido</span>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>

  <!-- BOTTOM CTAs -->
  <div class="cta-pair">
    <a href="/mesa/<%= mesa.id %>/ronda" class="cta-btn cta-orange">+ Agregar ronda</a>
    <a href="/mesa/<%= mesa.id %>/cuenta" class="cta-btn cta-dark">Pedir cuenta</a>
  </div>

  <!-- BOTTOM NAV -->
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="nav-icon">🏠</span>INICIO</a>
    <a href="/pedidos" class="nav-item active"><span class="nav-icon">📋</span>PEDIDOS</a>
    <a href="/cocina-display" class="nav-item"><span class="nav-icon">🍳</span>COCINA</a>
    <a href="/caja" class="nav-item"><span class="nav-icon">💰</span>CAJA</a>
    <a href="/configuracion" class="nav-item"><span class="nav-icon">⋯</span>MÁS</a>
  </nav>
</div>

<script>
  (function() {
    // Timer: counts up from pedido.created_at
    const createdAt = '<%= pedido ? new Date(pedido.created_at).toISOString() : "" %>';
    const timerEl   = document.getElementById('timerEl');

    function updateTimer() {
      if (!createdAt) return;
      const diff = Math.floor((Date.now() - new Date(createdAt).getTime()) / 1000);
      if (diff < 0) return;
      const h = Math.floor(diff / 3600);
      const m = Math.floor((diff % 3600) / 60);
      timerEl.textContent = '\u23F1 ' + (h ? h + 'h ' : '') + m + 'm';
    }
    updateTimer();
    setInterval(updateTimer, 30000);
  })();
</script>
<script src="/js/dallia-fab.js"></script>
</body>
</html>
