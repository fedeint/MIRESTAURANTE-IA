<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>IGV del Mes · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #ef520f; --orange2: #df2c05;
      --dark: #0a0f24; --bg: #F0F2F8;
      --card: #ffffff; --text2: #8B8FAD;
      --success: #22C55E;
      --safe-bot: env(safe-area-inset-bottom, 0px);
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      min-height: 100dvh;
      max-width: 480px;
      margin: 0 auto;
      padding-bottom: calc(72px + var(--safe-bot));
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(170deg, #10152f 0%, #0a0f24 50%, #090d1d 100%);
      padding: 52px 20px 24px;
      border-radius: 0 0 20px 20px;
      color: #fff;
    }
    .header-top { display: flex; align-items: center; gap: 12px; margin-bottom: 4px; }
    .btn-back {
      background: rgba(255,255,255,0.12); border: none; color: #fff;
      width: 36px; height: 36px; border-radius: 10px;
      font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .header-title { font-size: 18px; font-weight: 700; }

    /* ── Main card ── */
    .main-card {
      background: var(--card);
      margin: 16px 16px 0;
      border-radius: 16px;
      padding: 24px 20px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .igv-periodo { font-size: 13px; color: var(--text2); margin-bottom: 6px; }
    .igv-monto {
      font-size: 40px; font-weight: 800;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      line-height: 1;
    }
    .igv-label { font-size: 14px; color: var(--text2); margin-top: 4px; }

    /* ── Desglose ── */
    .desglose {
      background: var(--card);
      margin: 12px 16px 0;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .desglose-title {
      padding: 14px 16px 10px;
      font-size: 13px; font-weight: 600;
      color: var(--text2); text-transform: uppercase; letter-spacing: 0.5px;
      border-bottom: 1px solid #F0F2F8;
    }
    .desglose-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 13px 16px;
      border-bottom: 1px solid #F0F2F8;
    }
    .desglose-row:last-child { border-bottom: none; }
    .row-label { font-size: 14px; color: var(--dark); }
    .row-sub   { font-size: 12px; color: var(--text2); margin-top: 1px; }
    .row-value { font-size: 15px; font-weight: 600; }
    .val-orange { color: var(--orange); }
    .val-green  { color: var(--success); }
    .val-dark   { color: var(--dark); }

    .desglose-neto {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px;
      background: #FFF8F5;
    }
    .neto-label { font-size: 14px; font-weight: 700; color: var(--dark); }
    .neto-value {
      font-size: 22px; font-weight: 800;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    /* ── CTA ── */
    .cta-btn {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      margin: 16px 16px 0;
      background: linear-gradient(135deg, #10152f, #090d1d);
      color: #fff;
      border: none; border-radius: 14px;
      padding: 16px; width: calc(100% - 32px);
      font-size: 15px; font-weight: 700;
      cursor: pointer; text-decoration: none;
    }

    /* ── Bottom nav ── */
    .bottom-nav {
      position: fixed; bottom: 0; left: 50%;
      transform: translateX(-50%);
      width: 100%; max-width: 480px;
      background: #fff; border-top: 1px solid #E8EAF2;
      display: flex; padding-bottom: var(--safe-bot); z-index: 100;
    }
    .nav-item {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; padding: 10px 4px 8px;
      text-decoration: none; color: var(--text2);
      font-size: 10px; font-weight: 500;
    }
    .nav-item .icon { font-size: 22px; margin-bottom: 2px; }
    .nav-item.active { color: var(--orange); }
  </style>
</head>
<body>

  <div class="header">
    <div class="header-top">
      <button class="btn-back" onclick="history.back()">‹</button>
      <span class="header-title">IGV del Mes</span>
    </div>
  </div>

  <div class="main-card">
    <div class="igv-periodo"><%= nombreMes %> <%= anio %></div>
    <div class="igv-monto">S/ <%= igvNeto.toFixed(2) %></div>
    <div class="igv-label">IGV neto a pagar</div>
  </div>

  <div class="desglose">
    <div class="desglose-title">Desglose</div>

    <div class="desglose-row">
      <div>
        <div class="row-label">Ventas del mes</div>
        <div class="row-sub">Incluye IGV</div>
      </div>
      <div class="row-value val-dark">S/ <%= totalVentas.toFixed(2) %></div>
    </div>

    <div class="desglose-row">
      <div>
        <div class="row-label">IGV ventas (18%)</div>
        <div class="row-sub">Débito fiscal</div>
      </div>
      <div class="row-value val-orange">S/ <%= igvVentas.toFixed(2) %></div>
    </div>

    <% if (totalCompras > 0) { %>
    <div class="desglose-row">
      <div>
        <div class="row-label">Compras del mes</div>
        <div class="row-sub">Registradas</div>
      </div>
      <div class="row-value val-dark">S/ <%= totalCompras.toFixed(2) %></div>
    </div>

    <div class="desglose-row">
      <div>
        <div class="row-label">IGV compras (crédito)</div>
        <div class="row-sub">Crédito fiscal</div>
      </div>
      <div class="row-value val-green">-S/ <%= igvCompras.toFixed(2) %></div>
    </div>
    <% } %>

    <div class="desglose-neto">
      <div class="neto-label">IGV NETO</div>
      <div class="neto-value">S/ <%= igvNeto.toFixed(2) %></div>
    </div>
  </div>

  <a href="https://www.sunat.gob.pe" target="_blank" rel="noopener" class="cta-btn">
    ↗ Ir a declarar en SUNAT
  </a>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="icon">🏠</span>Inicio</a>
    <a href="/pedidos" class="nav-item"><span class="icon">🧾</span>Pedidos</a>
    <a href="/cocina-display" class="nav-item"><span class="icon">👨‍🍳</span>Cocina</a>
    <a href="/caja" class="nav-item"><span class="icon">💰</span>Caja</a>
    <a href="/mas" class="nav-item active"><span class="icon">☰</span>Más</a>
  </nav>

  <script src="/js/dallia-fab.js"></script>
</body>
</html>
