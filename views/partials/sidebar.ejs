<% const u = (typeof user !== 'undefined' && user) ? user : null; %>
<% const rol = u ? String(u.rol || '').toLowerCase() : ''; %>
<% const currentPath = (typeof reqPath !== 'undefined') ? reqPath : ''; %>

<!-- Mobile top bar -->
<div class="dg-mobile-bar d-lg-none">
  <button class="dg-mobile-toggle" id="sidebarToggle" type="button">
    <i class="bi bi-list"></i>
  </button>
  <a class="dg-mobile-brand" href="/">
    <span class="dg-brand-icon"><i class="bi bi-fire"></i></span>
    dignita<span style="color:#22d3ee;">.tech</span>
  </a>
  <% if (u) { %>
    <span class="dg-mobile-user"><i class="bi bi-person-circle"></i></span>
  <% } %>
</div>

<!-- Sidebar overlay (mobile) -->
<div class="dg-sidebar-overlay d-lg-none" id="sidebarOverlay"></div>

<!-- Sidebar -->
<aside class="dg-sidebar" id="sidebar">
  <!-- Brand -->
  <div class="dg-sidebar-brand">
    <a href="/" class="d-flex align-items-center text-decoration-none gap-2">
      <span class="dg-brand-icon"><i class="bi bi-fire"></i></span>
      <div>
        <div class="dg-sidebar-brand-name">dignita<span style="color:#22d3ee;">.tech</span></div>
        <div class="dg-sidebar-brand-sub">Restaurante</div>
      </div>
    </a>
  </div>

  <!-- Nav links -->
  <nav class="dg-sidebar-nav">
    <div class="dg-sidebar-section">Menu principal</div>

    <% if (rol === 'administrador') { %>
      <a href="/" class="dg-sidebar-link <%= currentPath === '/' ? 'active' : '' %>">
        <i class="bi bi-house-door-fill"></i><span>Inicio</span>
      </a>
      <a href="/facturacion" class="dg-sidebar-link <%= currentPath === '/facturacion' ? 'active' : '' %>">
        <i class="bi bi-receipt-cutoff"></i><span>Facturacion</span>
      </a>
      <a href="/mesas" class="dg-sidebar-link <%= currentPath === '/mesas' ? 'active' : '' %>">
        <i class="bi bi-grid-3x3-gap-fill"></i><span>Mesas</span>
      </a>
      <a href="/cocina" class="dg-sidebar-link <%= currentPath === '/cocina' ? 'active' : '' %>">
        <i class="bi bi-fire"></i><span>Cocina</span>
      </a>
      <a href="/ventas" class="dg-sidebar-link <%= currentPath === '/ventas' ? 'active' : '' %>">
        <i class="bi bi-graph-up-arrow"></i><span>Ventas</span>
      </a>

      <div class="dg-sidebar-section">Gestion</div>
      <a href="/productos" class="dg-sidebar-link <%= currentPath === '/productos' ? 'active' : '' %>">
        <i class="bi bi-box-seam-fill"></i><span>Productos</span>
      </a>
      <a href="/clientes" class="dg-sidebar-link <%= currentPath === '/clientes' ? 'active' : '' %>">
        <i class="bi bi-people-fill"></i><span>Clientes</span>
      </a>
      <a href="/ranking" class="dg-sidebar-link <%= currentPath === '/ranking' ? 'active' : '' %>">
        <i class="bi bi-trophy-fill"></i><span>Ranking</span>
      </a>

      <div class="dg-sidebar-section">Marketing</div>
      <a href="/redes-sociales" class="dg-sidebar-link <%= currentPath === '/redes-sociales' ? 'active' : '' %>">
        <i class="bi bi-share-fill"></i><span>Mis Redes</span>
      </a>
      <a href="/competencia" class="dg-sidebar-link <%= currentPath === '/competencia' ? 'active' : '' %>">
        <i class="bi bi-binoculars-fill"></i><span>Competencia</span>
      </a>

      <div class="dg-sidebar-section">Inteligencia</div>
      <a href="/chat" class="dg-sidebar-link <%= currentPath === '/chat' ? 'active' : '' %>" style="<%= currentPath === '/chat' ? '' : 'background:linear-gradient(135deg,rgba(99,102,241,0.08),rgba(6,182,212,0.06));' %>">
        <i class="bi bi-robot" style="color:#6366f1;"></i><span>Asistente IA</span>
        <span style="font-size:0.6rem;background:linear-gradient(135deg,#6366f1,#06b6d4);color:#fff;padding:0.15rem 0.4rem;border-radius:1rem;margin-left:auto;font-weight:700;">NUEVO</span>
      </a>

      <div class="dg-sidebar-section">Sistema</div>
      <a href="/usuarios" class="dg-sidebar-link <%= currentPath === '/usuarios' ? 'active' : '' %>">
        <i class="bi bi-person-gear"></i><span>Usuarios</span>
      </a>
      <a href="/configuracion" class="dg-sidebar-link <%= currentPath === '/configuracion' ? 'active' : '' %>">
        <i class="bi bi-gear-fill"></i><span>Configuracion</span>
      </a>
    <% } %>

    <% if (rol === 'mesero') { %>
      <a href="/mesas" class="dg-sidebar-link <%= currentPath === '/mesas' ? 'active' : '' %>">
        <i class="bi bi-grid-3x3-gap-fill"></i><span>Mesas</span>
      </a>
      <a href="/cocina" class="dg-sidebar-link <%= currentPath === '/cocina' ? 'active' : '' %>">
        <i class="bi bi-fire"></i><span>Cocina</span>
      </a>
    <% } %>

    <% if (rol === 'cocinero') { %>
      <a href="/cocina" class="dg-sidebar-link <%= currentPath === '/cocina' ? 'active' : '' %>">
        <i class="bi bi-fire"></i><span>Cocina</span>
      </a>
    <% } %>
  </nav>

  <!-- User footer -->
  <% if (u) { %>
    <div class="dg-sidebar-footer">
      <div class="dg-sidebar-user">
        <div class="dg-sidebar-avatar">
          <i class="bi bi-person-fill"></i>
        </div>
        <div class="dg-sidebar-user-info">
          <div class="dg-sidebar-user-name"><%= u.usuario %></div>
          <div class="dg-sidebar-user-role"><%= rol %></div>
        </div>
      </div>
      <form method="POST" action="/logout" class="m-0">
        <button type="submit" class="dg-sidebar-logout" title="Cerrar sesion">
          <i class="bi bi-box-arrow-right"></i>
        </button>
      </form>
    </div>
  <% } %>
</aside>

<script>
(function(){
  var toggle = document.getElementById('sidebarToggle');
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebarOverlay');
  function open(){ sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow='hidden'; }
  function close(){ sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow=''; }
  if(toggle) toggle.addEventListener('click', open);
  if(overlay) overlay.addEventListener('click', close);
  // Close sidebar on link click (mobile)
  document.querySelectorAll('.dg-sidebar-link').forEach(function(l){ l.addEventListener('click', close); });
})();
</script>
