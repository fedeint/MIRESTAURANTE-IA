            <!-- Aplicar clases al sidebar element inmediatamente -->
            <script>
              (function () {
                var s = parseInt(localStorage.getItem('dg-sidebar-state')) || 1;
                var sidebar = document.getElementById('sidebar');
                var navExp = document.getElementById('navExpanded');
                var navIco = document.getElementById('navIcons');
                if (sidebar) {
                  if (s === 1) {
                    sidebar.setAttribute('data-state', 'expanded');
                    sidebar.classList.add('dg-sidebar-expanded');
                  } else {
                    sidebar.setAttribute('data-state', s === 2 ? 'semi' : 'collapsed');
                    sidebar.classList.add('dg-sidebar-collapsed');
                  }
                }
                if (navExp) navExp.style.display = s === 1 ? '' : 'none';
                if (navIco) navIco.style.display = s === 1 ? 'none' : '';
              })();
            </script>

            <script>
              document.addEventListener('DOMContentLoaded', function () {
                var sidebar = document.getElementById('sidebar');
                var navExpanded = document.getElementById('navExpanded');
                var navIcons = document.getElementById('navIcons');
                var panel = document.getElementById('sidebarPanel');
                var toggleBtn = document.getElementById('sidebarToggleState');
                var toggleIcon = document.getElementById('toggleIcon');
                var mainEl = document.querySelector('.dg-main');
                var overlay = document.getElementById('sidebarOverlay');
                var mobileToggle = document.getElementById('sidebarToggle');

                // 3 states: expanded (1), semi (2), collapsed (3)
                var state = parseInt(localStorage.getItem('dg-sidebar-state')) || 1;

                // Al navegar a una pagina con submodulos, resetear panel-hidden
                if (panel) localStorage.setItem('dg-panel-hidden', '0');

                function updatePanel() {
                  var panelHidden = localStorage.getItem('dg-panel-hidden') === '1';
                  if (panel) panel.style.display = panelHidden ? 'none' : '';
                  if (mainEl) {
                    if (panel && !panelHidden) {
                      mainEl.classList.add('has-panel');
                      document.body.classList.add('body-has-panel');
                      document.body.classList.remove('panel-hidden');
                    } else {
                      mainEl.classList.remove('has-panel');
                      document.body.classList.remove('body-has-panel');
                      document.body.classList.add('panel-hidden');
                    }
                  }
                }

                function applyState(s) {
                  state = s;
                  localStorage.setItem('dg-sidebar-state', s);
                  document.body.classList.remove('sidebar-expanded', 'sidebar-semi', 'sidebar-collapsed');

                  updatePanel();

                  if (s === 1) {
                    sidebar.setAttribute('data-state', 'expanded');
                    sidebar.classList.add('dg-sidebar-expanded');
                    sidebar.classList.remove('dg-sidebar-collapsed');
                    if (navExpanded) navExpanded.style.display = '';
                    if (navIcons) navIcons.style.display = 'none';
                    if (toggleIcon) toggleIcon.className = 'bi bi-chevron-left';
                    document.body.classList.add('sidebar-expanded');
                  } else if (s === 2) {
                    sidebar.setAttribute('data-state', 'semi');
                    sidebar.classList.remove('dg-sidebar-expanded');
                    sidebar.classList.add('dg-sidebar-collapsed');
                    if (navExpanded) navExpanded.style.display = 'none';
                    if (navIcons) navIcons.style.display = '';
                    if (toggleIcon) toggleIcon.className = 'bi bi-chevron-right';
                    document.body.classList.add('sidebar-semi');
                  } else {
                    sidebar.setAttribute('data-state', 'collapsed');
                    sidebar.classList.remove('dg-sidebar-expanded');
                    sidebar.classList.add('dg-sidebar-collapsed');
                    if (navExpanded) navExpanded.style.display = 'none';
                    if (navIcons) navIcons.style.display = '';
                    if (toggleIcon) toggleIcon.className = 'bi bi-chevron-right';
                    document.body.classList.add('sidebar-collapsed');
                  }
                }

                applyState(state);

                if (toggleBtn) toggleBtn.addEventListener('click', function () {
                  // Cycle: 1 -> 2 -> 3 -> 1
                  applyState(state >= 3 ? 1 : state + 1);
                });

                // === Click en categorias con submodulos (Almacen, Productos, Admin) ===
                // Si ya estas en esa pagina, cada click cicla:
                //   1er click (ya ahi): sidebar colapsa a iconos, panel sigue visible
                //   2do click: oculta panel de submodulos
                //   3er click: restaura todo (sidebar expandido + panel visible)
                var catLinks = document.querySelectorAll('.dg-sidebar-link[href="/almacen"], .dg-sidebar-link[href="/productos"], .dg-sidebar-link[href="/administracion"]');
                var catIcons = document.querySelectorAll('.dg-sidebar-icon-item[href="/almacen"], .dg-sidebar-icon-item[href="/productos"], .dg-sidebar-icon-item[href="/administracion"]');
                var allCatLinks = [];
                catLinks.forEach(function (l) { allCatLinks.push(l); });
                catIcons.forEach(function (l) { allCatLinks.push(l); });

                allCatLinks.forEach(function (link) {
                  link.addEventListener('click', function (e) {
                    // Solo interceptar si ya estamos en esa seccion (link esta activo)
                    var isActive = link.classList.contains('active') || link.classList.contains('active-glow');
                    if (!isActive) return; // Navegar normalmente

                    e.preventDefault(); // No navegar, ciclar estados

                    var panelHidden = localStorage.getItem('dg-panel-hidden') === '1';

                    if (state === 1 && !panelHidden) {
                      // 1er click: colapsar sidebar a iconos, panel sigue visible
                      applyState(2);
                    } else if (!panelHidden) {
                      // 2do click: ocultar panel de submodulos
                      localStorage.setItem('dg-panel-hidden', '1');
                      updatePanel();
                    } else {
                      // 3er click: restaurar todo (expandido + panel visible)
                      localStorage.setItem('dg-panel-hidden', '0');
                      applyState(1);
                    }
                  });
                });

                // Mobile
                if (mobileToggle) mobileToggle.addEventListener('click', function () { sidebar.classList.add('open'); if (overlay) overlay.classList.add('open'); });
                if (overlay) overlay.addEventListener('click', function () { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

                // SEGURIDAD: En desktop, siempre limpiar el overlay al cargar
                function limpiarOverlayDesktop() {
                  if (window.innerWidth >= 992 && overlay) {
                    overlay.classList.remove('open');
                    overlay.style.pointerEvents = 'none';
                    overlay.style.opacity = '0';
                    overlay.style.display = 'none';
                  }
                }
                limpiarOverlayDesktop();
                window.addEventListener('resize', limpiarOverlayDesktop);

                // SEGURIDAD: Limpiar cualquier modal-backdrop huérfano al cargar
                document.querySelectorAll('.modal-backdrop').forEach(function (el) { el.remove(); });
                document.body.classList.remove('modal-open');
                document.body.style.removeProperty('overflow');
                document.body.style.removeProperty('padding-right');
              });
            </script>

