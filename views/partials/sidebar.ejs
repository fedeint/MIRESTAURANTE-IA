          body.sidebar-collapsed .sidebar-submenu-panel {
            left: 64px;
          }

          @media(min-width:992px){
            body.sidebar-semi .sidebar-submenu-panel,
            body.sidebar-collapsed .sidebar-submenu-panel {
              left: 134px; /* 70 + 64 */
            }
          }

          .sidebar-submenu-panel.open {
            transform: translateX(0);
            opacity: 1;
            pointer-events: all;
            transition: transform 500ms cubic-bezier(0.34, 1.8, 0.64, 1), opacity 280ms ease-out;
          }

          .sidebar-submenu-panel .submenu-title {
            padding: 0.6rem 1.25rem 0.5rem;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            color: #f97316;
            display: flex;
            align-items: center;
            gap: 0.45rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            margin-bottom: 0.4rem;
          }

          .sidebar-submenu-panel .submenu-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1.25rem 0.5rem 1.6rem;
            color: rgba(255,255,255,0.58);
            font-size: 0.84rem;
            text-decoration: none;
            transition: all 0.15s ease;
            position: relative;
          }

          .sidebar-submenu-panel .submenu-item::before {
            content: '';
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: rgba(255,255,255,0.25);
            transition: background 0.15s;
          }

          .sidebar-submenu-panel .submenu-item:hover {
            color: #fff;
            background: rgba(249,115,22,0.1);
          }

          .sidebar-submenu-panel .submenu-item:hover::before {
            background: #f97316;
          }

          .sidebar-submenu-panel .submenu-item.active-sub {
            color: #f97316;
            background: rgba(249,115,22,0.08);
            font-weight: 600;
          }

          .sidebar-submenu-panel .submenu-item.active-sub::before {
            background: #f97316;
          }

          /* Hide on mobile — mobile has its own nav */
          @media (max-width: 991.98px) {
            .sidebar-submenu-panel { display: none !important; }
          }
