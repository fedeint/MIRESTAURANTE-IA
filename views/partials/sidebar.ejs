<% const u = (typeof user !== 'undefined' && user) ? user : null; %>
<% const rol = u ? String(u.rol || '').toLowerCase() : ''; %>
<% const currentPath = (typeof reqPath !== 'undefined') ? reqPath : ''; %>

<%
  // Determinar que panel desplegable mostrar
  const panelAlmacen = currentPath.startsWith('/almacen');
  const panelProductos = currentPath === '/productos';
  const panelAdmin = currentPath.startsWith('/administracion') || currentPath === '/sunat';
  const panelActivo = panelAlmacen || panelProductos || panelAdmin;
%>

<!-- Mobile top bar -->
<div class="dg-mobile-bar d-lg-none">
  <button class="dg-mobile-toggle" id="sidebarToggle" type="button"><i class="bi bi-list"></i></button>
  <a class="dg-mobile-brand" href="/">
    <span class="dg-brand-icon"><i class="bi bi-fire"></i></span>
    dignita<span style="color:#FF6B35;">.tech</span>
  </a>
</div>
<div class="dg-sidebar-overlay d-lg-none" id="sidebarOverlay"></div>

<!-- Sidebar Icons (colapsado) -->
<aside class="dg-sidebar" id="sidebar">
  <!-- Logo -->
  <div class="dg-sidebar-icon-item dg-sidebar-logo">
    <a href="/" style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;background:#FF6B35;border-radius:10px;text-decoration:none;">
      <i class="bi bi-fire" style="color:#fff;font-size:1.1rem;"></i>
    </a>
  </div>

  <% if (rol === 'administrador') { %>
    <!-- IA -->
    <a href="/chat" class="dg-sidebar-icon-item <%= currentPath === '/chat' ? 'active-glow' : '' %>" title="Asistente IA">
      <i class="bi bi-stars" style="color:#FF6B35;"></i>
    </a>

    <div class="dg-sidebar-sep"></div>

    <!-- Menu principal -->
    <a href="/" class="dg-sidebar-icon-item <%= currentPath === '/' ? 'active' : '' %>" title="Inicio">
      <i class="bi bi-columns-gap"></i>
    </a>
    <a href="/caja" class="dg-sidebar-icon-item <%= currentPath === '/caja' ? 'active' : '' %>" title="Caja">
      <i class="bi bi-wallet2"></i>
    </a>
    <a href="/facturacion" class="dg-sidebar-icon-item <%= currentPath === '/facturacion' ? 'active' : '' %>" title="Facturacion">
      <i class="bi bi-receipt-cutoff"></i>
    </a>
    <a href="/mesas" class="dg-sidebar-icon-item <%= currentPath === '/mesas' ? 'active' : '' %>" title="Mesas">
      <i class="bi bi-grid-3x3-gap-fill"></i>
    </a>
    <a href="/cocina" class="dg-sidebar-icon-item <%= currentPath === '/cocina' ? 'active' : '' %>" title="Cocina">
      <i class="bi bi-fire"></i>
    </a>
    <a href="/ventas" class="dg-sidebar-icon-item <%= currentPath === '/ventas' ? 'active' : '' %>" title="Ventas">
      <i class="bi bi-graph-up-arrow"></i>
    </a>

    <div class="dg-sidebar-sep"></div>

    <!-- Operaciones (con panel) -->
    <a href="/almacen" class="dg-sidebar-icon-item <%= panelAlmacen ? 'active' : '' %>" title="Almacen">
      <i class="bi bi-box-seam"></i>
    </a>

    <!-- Gestion (con panel) -->
    <a href="/productos" class="dg-sidebar-icon-item <%= panelProductos ? 'active' : '' %>" title="Productos">
      <i class="bi bi-egg-fried"></i>
    </a>
    <a href="/clientes" class="dg-sidebar-icon-item <%= currentPath === '/clientes' ? 'active' : '' %>" title="Clientes">
      <i class="bi bi-people-fill"></i>
    </a>

    <div class="dg-sidebar-sep"></div>

    <!-- Administracion (con panel) -->
    <a href="/administracion" class="dg-sidebar-icon-item <%= panelAdmin ? 'active' : '' %>" title="Administracion">
      <i class="bi bi-bar-chart-line-fill"></i>
    </a>

    <!-- Canales -->
    <a href="/canales" class="dg-sidebar-icon-item <%= currentPath === '/canales' ? 'active' : '' %>" title="Canales">
      <i class="bi bi-chat-dots-fill"></i>
    </a>

    <div class="dg-sidebar-sep"></div>

    <!-- Sistema -->
    <a href="/usuarios" class="dg-sidebar-icon-item <%= currentPath === '/usuarios' ? 'active' : '' %>" title="Usuarios">
      <i class="bi bi-person-gear"></i>
    </a>
    <a href="/configuracion" class="dg-sidebar-icon-item <%= currentPath === '/configuracion' ? 'active' : '' %>" title="Config">
      <i class="bi bi-gear-fill"></i>
    </a>
  <% } %>

  <% if (rol === 'mesero') { %>
    <a href="/mesas" class="dg-sidebar-icon-item <%= currentPath === '/mesas' ? 'active' : '' %>" title="Mesas"><i class="bi bi-grid-3x3-gap-fill"></i></a>
    <a href="/cocina" class="dg-sidebar-icon-item <%= currentPath === '/cocina' ? 'active' : '' %>" title="Cocina"><i class="bi bi-fire"></i></a>
  <% } %>

  <% if (rol === 'cocinero') { %>
    <a href="/cocina" class="dg-sidebar-icon-item <%= currentPath === '/cocina' ? 'active' : '' %>" title="Cocina"><i class="bi bi-fire"></i></a>
  <% } %>

  <!-- User at bottom -->
  <% if (u) { %>
    <div class="dg-sidebar-icon-bottom">
      <form method="POST" action="/logout" style="margin:0;">
        <button type="submit" class="dg-sidebar-icon-item" title="Salir" style="border:none;cursor:pointer;">
          <i class="bi bi-box-arrow-right"></i>
        </button>
      </form>
    </div>
  <% } %>
</aside>

<!-- Panel desplegable (solo si el modulo tiene submodulos) -->
<% if (panelActivo) { %>
<div class="dg-panel">
  <% if (panelAlmacen) { %>
    <div class="dg-panel-title"><i class="bi bi-box-seam"></i> Almacen</div>
    <a href="/almacen/inventario" class="dg-panel-item <%= currentPath === '/almacen/inventario' || currentPath === '/almacen' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Inventario</a>
    <a href="/almacen/entradas" class="dg-panel-item <%= currentPath === '/almacen/entradas' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Ingreso diario</a>
    <a href="/almacen/salidas" class="dg-panel-item <%= currentPath === '/almacen/salidas' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Salida insumos</a>
    <a href="/almacen/que-comprar" class="dg-panel-item <%= currentPath === '/almacen/que-comprar' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Que comprar</a>
    <a href="/almacen/proveedores" class="dg-panel-item <%= currentPath === '/almacen/proveedores' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Proveedores</a>
    <a href="/almacen/historial" class="dg-panel-item <%= currentPath === '/almacen/historial' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Historial</a>
  <% } %>

  <% if (panelProductos) { %>
    <div class="dg-panel-title"><i class="bi bi-egg-fried"></i> Productos</div>
    <a href="/productos" class="dg-panel-item active"><span class="dg-panel-dot"></span>Carta</a>
    <a href="/ranking" class="dg-panel-item"><span class="dg-panel-dot"></span>Ranking disponibilidad</a>
  <% } %>

  <% if (panelAdmin) { %>
    <div class="dg-panel-title"><i class="bi bi-bar-chart-line-fill"></i> Administracion</div>
    <a href="/administracion" class="dg-panel-item <%= currentPath === '/administracion' ? 'active' : '' %>"><span class="dg-panel-dot"></span>P&L / Finanzas</a>
    <a href="/administracion/planilla" class="dg-panel-item <%= currentPath === '/administracion/planilla' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Planilla</a>
    <a href="/administracion/gastos" class="dg-panel-item <%= currentPath === '/administracion/gastos' ? 'active' : '' %>"><span class="dg-panel-dot"></span>Gastos</a>
    <a href="/sunat" class="dg-panel-item <%= currentPath === '/sunat' ? 'active' : '' %>"><span class="dg-panel-dot"></span>SUNAT</a>
  <% } %>
</div>
<% } %>

<script>
(function(){
  var toggle = document.getElementById('sidebarToggle');
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebarOverlay');
  function open(){ sidebar.classList.add('open'); overlay.classList.add('open'); }
  function close(){ sidebar.classList.remove('open'); overlay.classList.remove('open'); }
  if(toggle) toggle.addEventListener('click', open);
  if(overlay) overlay.addEventListener('click', close);
  // Add has-panel class if panel exists
  if(document.querySelector('.dg-panel')){
    var main = document.querySelector('.dg-main');
    if(main) main.classList.add('has-panel');
  }
})();
</script>
