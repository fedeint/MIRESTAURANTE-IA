        <!-- Sliding Submenu Panel (desktop only) -->
        <div class="sidebar-submenu-panel" id="sidebarSubmenuPanel" role="navigation" aria-label="Subnavegacion">
          <div class="submenu-title" id="sidebarSubmenuTitle"></div>
          <div class="submenu-items" id="sidebarSubmenuItems"></div>
        </div>

        <script>
        (function() {
          var panel = document.getElementById('sidebarSubmenuPanel');
          var panelTitle = document.getElementById('sidebarSubmenuTitle');
          var panelItems = document.getElementById('sidebarSubmenuItems');
          if (!panel) return;

          var closeTimer = null;
          var currentPath = window.location.pathname;

          function openSubmenu(link) {
            if (window.innerWidth < 992) return;
            var raw = link.getAttribute('data-submenu');
            if (!raw) return;
            var items;
            try { items = JSON.parse(raw); } catch(e) { return; }
            var title = link.getAttribute('data-submenu-title') || '';
            var icon  = link.getAttribute('data-submenu-icon') || 'grid';

            panelTitle.innerHTML = '<i class="bi bi-' + icon + '"></i> ' + title;
            panelItems.innerHTML = items.map(function(item) {
              var isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
              return '<a href="' + item.href + '" class="submenu-item' + (isActive ? ' active-sub' : '') + '">' + item.label + '</a>';
            }).join('');
            panel.classList.add('open');
          }

          function closeSubmenu() {
            panel.classList.remove('open');
          }

          // Attach mouseenter/mouseleave to all submenu-capable links
          document.querySelectorAll('.dg-has-submenu').forEach(function(link) {
            link.addEventListener('mouseenter', function() {
              if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
              openSubmenu(link);
            });
            link.addEventListener('mouseleave', function() {
              closeTimer = setTimeout(closeSubmenu, 120);
            });
          });

          // Keep panel open while hovering it
          panel.addEventListener('mouseenter', function() {
            if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
          });
          panel.addEventListener('mouseleave', function() {
            closeTimer = setTimeout(closeSubmenu, 120);
          });

          // Close on sidebar toggle (state change) — clean up
          document.addEventListener('click', function(e) {
            if (!e.target.closest('.dg-has-submenu') && !e.target.closest('#sidebarSubmenuPanel')) {
              closeSubmenu();
            }
          });

          // Ensure submenu panel always starts closed on page load
          panel.classList.remove('open');
        })();
        </script>

