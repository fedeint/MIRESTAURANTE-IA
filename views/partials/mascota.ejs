<script>
(function () {
  'use strict';

  /* ------------------------------------------------------------------ */
  /* 1. Module-aware tips                                                 */
  /* ------------------------------------------------------------------ */
  /* Role injected server-side so the JS can branch per user */
  var _ROL = '<%= _mascotaUser ? (user.rol || "") : "" %>';

  var MASCOTA_TIPS = {
    '/': (function() {
      if (_ROL === 'cajero')   return [
        'Verifica que la caja este abierta antes de empezar el turno.',
        'La caja lleva un registro de todos los metodos de pago del dia.',
        'Al cerrar, cuenta el efectivo fisico primero, luego ingresa el monto en el sistema.'
      ];
      if (_ROL === 'mesero')   return [
        'Bienvenido! Ve a Mesas para ver el estado del salon.',
        'Recuerda sonreir: un buen servicio genera mas propinas y clientes felices.',
        'Si una mesa tarda, verifica en Cocina el estado de sus pedidos.'
      ];
      if (_ROL === 'cocinero') return [
        'Revisa los pedidos en cola al iniciar tu turno.',
        'Mantente al dia con el stock de ingredientes para no sorprenderte a media orden.',
        'Marca los platos como "Listo" en cuanto esten preparados para que el mesero los recoja a tiempo.'
      ];
      /* administrador / default */
      return [
        'Bienvenido jefe! Desde aqui puedes ver el resumen de tu dia: ventas, mesas ocupadas y alertas de stock.',
        'Revisa las pendientes del dia antes de abrir el restaurante.',
        'Los KPIs de la derecha te muestran las ventas, mesas y platos del dia en tiempo real.'
      ];
    })(),
    '/caja': [
      'Recuerda abrir la caja antes de que los meseros empiecen a tomar pedidos.',
      'Al cerrar caja, cuenta bien los billetes y monedas. El sistema te ayuda con el desglose.',
      'Si usas Yape o Plin, registra el monto en la seccion correspondiente al cerrar.',
      'Cuadra el efectivo fisico con el sistema antes de cerrar: diferencias pequenas se acumulan.'
    ],
    '/facturacion': [
      'Aqui generas facturas y boletas. Asegurate de tener el RUC del cliente para facturas.',
      'Las facturas se envian automaticamente a SUNAT si esta configurado.',
      'Puedes reimprimir cualquier comprobante desde el historial.'
    ],
    '/mesas': (function() {
      if (_ROL === 'mesero') return [
        'Recuerda saludar al cliente al sentarlo. Una primera impresion vale mucho!',
        'Si una mesa lleva mucho tiempo esperando, revisa su estado en Cocina.',
        'Mesas en naranja tienen pedidos activos. En rojo estan listas para cobrar.',
        'Agrega productos rapido buscando el nombre del plato en la mesa activa.',
        'Al enviar a cocina, los insumos se descuentan del almacen automaticamente.'
      ];
      return [
        'Cada mesa muestra su estado: libre (verde), ocupada (naranja), por cobrar (roja).',
        'Para agregar productos a una mesa, haz clic en ella y busca el plato.',
        'Los pedidos se envian a cocina automaticamente cuando presionas "Enviar a cocina".',
        'Al enviar a cocina, los insumos se descuentan del almacen automaticamente.'
      ];
    })(),
    '/cocina': (function() {
      if (_ROL === 'cocinero') return [
        'Atiende primero los pedidos con mas tiempo esperando. Estan marcados en rojo.',
        'Marca "Listo" en cuanto el plato salga de la cocina para que el mesero no espere.',
        'Revisa el stock de ingredientes al inicio del turno para anticipar faltantes.',
        'Si un ingrediente se acaba, avisa al administrador para que lo registre en Almacen.',
        'El timer muestra cuanto lleva cada pedido. Objetivo: menos de 15 minutos por plato.'
      ];
      return [
        'Los pedidos aparecen en orden. Los que tienen mas de 8 minutos se marcan como prioritarios.',
        'Marca "Listo" cuando el plato este preparado para que el mesero lo recoja.',
        'El timer te ayuda a controlar los tiempos de preparacion.'
      ];
    })(),
    '/ventas': [
      'Aqui ves el historico de ventas por dia, semana o mes.',
      'Puedes filtrar por metodo de pago: efectivo, Yape, Plin o tarjeta.',
      'Los graficos te muestran tendencias para planificar mejor tu inventario.'
    ],
    '/almacen': [
      'El inventario se actualiza automaticamente cuando se preparan platos.',
      'Revisa las alertas de stock bajo para saber que comprar.',
      'Registra tus ingresos diarios de insumos en "Ingreso diario".'
    ],
    '/almacen/inventario': [
      'Cada ingrediente tiene un stock minimo. Cuando baja de ahi, aparece una alerta.',
      'El costo unitario es por kg, litro o unidad segun el insumo.'
    ],
    '/almacen/entradas': [
      'Registra aqui todo lo que compras. Selecciona el proveedor y el precio.',
      'El stock se actualiza automaticamente al registrar una entrada.'
    ],
    '/almacen/salidas': [
      'Las salidas se registran automaticamente al preparar platos.',
      'Tambien puedes registrar salidas manuales por merma o desperdicio.'
    ],
    '/almacen/que-comprar': [
      'Esta lista te dice exactamente que comprar basado en el stock minimo de cada insumo.',
      'Puedes exportar la lista para llevarla al mercado.'
    ],
    '/almacen/proveedores': [
      'Registra tus proveedores con nombre, telefono y productos que ofrecen.',
      'Tener proveedores organizados te ayuda a hacer compras mas rapido.'
    ],
    '/almacen/historial': [
      'Aqui ves todos los movimientos: entradas, salidas y ajustes de inventario.',
      'Usa los filtros de fecha para auditar periodos especificos.'
    ],
    '/productos': [
      'Cada producto tiene una receta con ingredientes y cantidades exactas.',
      'La disponibilidad se calcula automaticamente segun el stock de ingredientes.',
      'Puedes ver cuantos platos puedes preparar con el stock actual.'
    ],
    '/ranking': [
      'El ranking muestra que platos tienen mas disponibilidad segun tu inventario actual.',
      'Los platos con 0 disponibles aparecen como agotados en el sistema.'
    ],
    '/clientes': [
      'Registra clientes frecuentes para facturacion rapida.',
      'El RUC o DNI del cliente se usa para generar facturas electronicas.'
    ],
    '/administracion': [
      'Aqui ves las finanzas del restaurante: ingresos, gastos y utilidad.',
      'Revisa el P&L (Ganancias y Perdidas) para entender si el negocio es rentable.'
    ],
    '/administracion/planilla': [
      'Registra a tu personal y sus sueldos diarios o mensuales.',
      'No olvides registrar los pagos del dia para llevar el control.'
    ],
    '/administracion/gastos': [
      'Registra gastos como luz, agua, internet, alquiler, gas.',
      'Los gastos se reflejan automaticamente en el P&L del restaurante.'
    ],
    '/sunat': [
      'Configura tu conexion con SUNAT para enviar comprobantes electronicos.',
      'Necesitas tu certificado digital y clave SOL para la facturacion electronica.'
    ],
    '/canales': [
      'Conecta tus redes sociales para ver las publicaciones de tu competencia.',
      'Puedes monitorear Facebook e Instagram desde aqui.'
    ],
    '/usuarios': [
      'Gestiona quien tiene acceso a cada modulo del sistema.',
      'Cada rol tiene permisos por defecto, pero puedes personalizarlos.',
      'Un mesero solo ve Mesas y Cocina. Un cocinero solo ve Cocina.'
    ],
    '/configuracion': [
      'Configura los datos de tu restaurante: nombre, RUC, direccion.',
      'Aqui puedes cambiar el tema visual y las preferencias del sistema.'
    ],
    '/chat': [
      'Preguntale cualquier cosa sobre tu negocio a la IA.',
      'Puedes preguntar: cuanto vendi hoy?, que plato se vende mas?, etc.'
    ]
  };

  /* Fallback tips for unknown paths */
  var TIPS_FALLBACK = [
    'Recuerda revisar el stock de insumos periodicamente.',
    'Un buen control de costos marca la diferencia en la rentabilidad.',
    'Mantener el sistema actualizado te ayuda a tomar mejores decisiones.'
  ];

  /* ------------------------------------------------------------------ */
  /* 2. DOM references                                                    */
  /* ------------------------------------------------------------------ */
  var container   = document.getElementById('mascotaContainer');
  var circle      = document.getElementById('mascotaCircle');
  var bubble      = document.getElementById('mascotaBubble');
  var bubbleText  = document.getElementById('mascotaBubbleText');
  var bubbleClose = document.getElementById('mascotaBubbleClose');
  var bubbleBtn   = document.getElementById('mascotaBubbleBtn');
  var emojiEl     = document.getElementById('mascotaEmoji');
  var zzzEl       = document.getElementById('mascotaZzz');
  var toggle      = document.getElementById('mascotaToggle');

  if (!container || !circle) return; /* Safety guard */

  /* ------------------------------------------------------------------ */
  /* 3. State                                                             */
  /* ------------------------------------------------------------------ */
  var isOpen        = false;   /* Is bubble currently visible?          */
  var isSleeping    = false;
  var isShaking     = false;
  var clickCount    = 0;
  var clickTimer    = null;
  var idleTimer     = null;
  var greetingTimer = null;
  var tipIndex      = -1;      /* Tracks last shown tip to avoid repeat  */

  /* ------------------------------------------------------------------ */
  /* 4. Helper: get tips for current page                                 */
  /* ------------------------------------------------------------------ */
  function getTipsForPage() {
    var path = window.location.pathname.replace(/\/$/, '') || '/';
    /* Exact match first */
    if (MASCOTA_TIPS[path]) return MASCOTA_TIPS[path];
    /* Prefix match (e.g. /almacen/xyz -> /almacen) */
    var parts = path.split('/');
    while (parts.length > 1) {
      parts.pop();
      var candidate = parts.join('/') || '/';
      if (MASCOTA_TIPS[candidate]) return MASCOTA_TIPS[candidate];
    }
    return TIPS_FALLBACK;
  }

  /* ------------------------------------------------------------------ */
  /* 5. Helper: pick next tip (sequential rotation, skip last shown)     */
  /* ------------------------------------------------------------------ */
  function pickNextTip() {
    var tips = getTipsForPage();
    if (tips.length === 1) return tips[0];
    var next;
    do {
      next = Math.floor(Math.random() * tips.length);
    } while (next === tipIndex && tips.length > 1);
    tipIndex = next;
    return tips[next];
  }

  /* ------------------------------------------------------------------ */
  /* 6. Bubble open / close                                               */
  /* ------------------------------------------------------------------ */
  function showBubble(text) {
    bubbleText.textContent = text;
    /* Re-trigger animation */
    bubble.classList.remove('show');
    void bubble.offsetHeight; /* reflow */
    bubble.classList.add('show');
    isOpen = true;
  }

  function closeBubble() {
    bubble.classList.remove('show');
    isOpen = false;
  }

  /* ------------------------------------------------------------------ */
  /* 7. Greeting based on time of day + user role                        */
  /* ------------------------------------------------------------------ */
  function getGreeting() {
    var h = new Date().getHours();
    var saludo = h < 12 ? 'Buenos dias' : h < 18 ? 'Buenas tardes' : 'Buenas noches';
    var rol = '<%= _mascotaUser ? (user.rol || "") : "" %>';

    if (rol === 'mesero')        return saludo + '! Tus mesas te esperan. Recuerda sonreir y dar un gran servicio!';
    if (rol === 'cocinero')      return saludo + ', chef! Revisa los pedidos en cola y mantente al dia con el stock.';
    if (rol === 'cajero')        return saludo + '! Verifica que la caja este abierta antes de empezar.';
    if (rol === 'administrador') return saludo + ', jefe! Aqui tienes el resumen de tu dia.';
    return saludo + '!';
  }

  /* ------------------------------------------------------------------ */
  /* 8. Sleep / wake                                                      */
  /* ------------------------------------------------------------------ */
  function goToSleep() {
    if (isSleeping) return;
    isSleeping = true;
    container.classList.add('mascota-state-sleep');
    closeBubble();
  }

  function wakeUp() {
    if (!isSleeping) return;
    isSleeping = false;
    container.classList.remove('mascota-state-sleep');
    resetIdleTimer();
  }

  /* ------------------------------------------------------------------ */
  /* 9. Idle timer (2 minutes to fall asleep)                            */
  /* ------------------------------------------------------------------ */
  function resetIdleTimer() {
    clearTimeout(idleTimer);
    idleTimer = setTimeout(goToSleep, 2 * 60 * 1000);
  }

  /* ------------------------------------------------------------------ */
  /* 10. Animation helpers                                               */
  /* ------------------------------------------------------------------ */
  function triggerAnim(cls, durationMs) {
    container.classList.remove('mascota-bounce', 'mascota-shake');
    void container.offsetHeight;
    container.classList.add(cls);
    setTimeout(function () { container.classList.remove(cls); }, durationMs);
  }

  /* ------------------------------------------------------------------ */
  /* 11. Click handler on the circle                                     */
  /* ------------------------------------------------------------------ */
  circle.addEventListener('click', function () {
    /* Wake up if sleeping */
    if (isSleeping) {
      wakeUp();
      showBubble(pickNextTip());
      triggerAnim('mascota-bounce', 1200);
      return;
    }

    resetIdleTimer();

    /* Rapid-click detection */
    clickCount++;
    clearTimeout(clickTimer);
    clickTimer = setTimeout(function () { clickCount = 0; }, 2000);

    if (clickCount >= 5) {
      clickCount = 0;
      closeBubble();
      showBubble('Dejame trabajar tranquilo!');
      triggerAnim('mascota-shake', 1000);
      return;
    }

    /* Normal behaviour: toggle bubble */
    if (isOpen) {
      closeBubble();
    } else {
      showBubble(pickNextTip());
      triggerAnim('mascota-bounce', 1100);
    }
  });

  /* Keyboard accessibility */
  circle.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      circle.click();
    }
  });

  /* ------------------------------------------------------------------ */
  /* 12. Close buttons                                                   */
  /* ------------------------------------------------------------------ */
  bubbleClose.addEventListener('click', closeBubble);
  bubbleBtn.addEventListener('click', closeBubble);

  /* ------------------------------------------------------------------ */
  /* 12b. Chat input: send question to AI                               */
  /* ------------------------------------------------------------------ */
  var chatInput   = document.getElementById('mascotaInput');
  var chatSendBtn = document.getElementById('mascotaSendBtn');

  function sendChatMessage() {
    var msg = (chatInput.value || '').trim();
    if (!msg) return;
    chatInput.value = '';
    bubbleText.textContent = 'Pensando...';
    bubbleText.classList.add('mascota-loading');
    if (!isOpen) openBubble(msg);

    fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mensaje: msg, rol: '<%= _mascotaUser ? (user.rol || "") : "" %>' })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      bubbleText.classList.remove('mascota-loading');
      var respuesta = data.respuesta || data.response || data.reply || data.message || 'No tengo respuesta para eso, jefe.';
      // Truncate if too long for the small bubble
      if (respuesta.length > 250) respuesta = respuesta.substring(0, 247) + '...';
      bubbleText.textContent = respuesta;
    })
    .catch(function(err) {
      bubbleText.classList.remove('mascota-loading');
      bubbleText.textContent = 'Ay, no pude conectarme. Intenta de nuevo, jefe.';
    });
  }

  if (chatSendBtn) {
    chatSendBtn.addEventListener('click', sendChatMessage);
  }
  if (chatInput) {
    chatInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        sendChatMessage();
      }
    });
  }

  /* ------------------------------------------------------------------ */
  /* 13. Mouse proximity: wake up when cursor is close                  */
  /* ------------------------------------------------------------------ */
  document.addEventListener('mousemove', function (e) {
    if (!isSleeping) return;
    var rect = circle.getBoundingClientRect();
    var cx = rect.left + rect.width / 2;
    var cy = rect.top  + rect.height / 2;
    var dist = Math.sqrt(Math.pow(e.clientX - cx, 2) + Math.pow(e.clientY - cy, 2));
    if (dist < 120) wakeUp();
  });

  /* ------------------------------------------------------------------ */
  /* 14. Toggle switch (show / hide mascot)                             */
  /* ------------------------------------------------------------------ */
  function applyToggleState(enabled) {
    if (enabled) {
      container.classList.remove('mascota-hidden');
    } else {
      container.classList.add('mascota-hidden');
      closeBubble();
    }
    localStorage.setItem('mascota-enabled', enabled ? '1' : '0');
  }

  toggle.addEventListener('change', function () {
    applyToggleState(toggle.checked);
  });

  /* Restore saved preference */
  var saved = localStorage.getItem('mascota-enabled');
  if (saved === '0') {
    toggle.checked = false;
    applyToggleState(false);
  }

  /* ------------------------------------------------------------------ */
  /* 15. Initial greeting on page load                                  */
  /* ------------------------------------------------------------------ */
  greetingTimer = setTimeout(function () {
    /* Only show greeting if mascot is visible */
    if (toggle.checked) {
      showBubble(getGreeting());
      triggerAnim('mascota-bounce', 1100);

      /* Auto-close greeting after 3 s */
      setTimeout(function () {
        if (isOpen && bubbleText.textContent === getGreeting()) {
          closeBubble();
        }
      }, 3000);
    }

    resetIdleTimer();
  }, 1200);

  /* ------------------------------------------------------------------ */
  /* 16. Public API (other modules can call window.mascota.*)           */
  /* ------------------------------------------------------------------ */
  window.mascota = {
    /**
     * Show a custom message in the bubble (called from other pages).
     * @param {string} mensaje
     */
    notificar: function (mensaje) {
      if (!toggle.checked) return;
      wakeUp();
      showBubble(mensaje || 'Hay algo que revisar!');
      triggerAnim('mascota-bounce', 1100);
      resetIdleTimer();
    },

    /**
     * Show a success/celebration message.
     * @param {string} mensaje
     */
    celebrar: function (mensaje) {
      if (!toggle.checked) return;
      wakeUp();
      showBubble(mensaje || 'Todo va de maravilla!');
      triggerAnim('mascota-bounce', 1100);
      resetIdleTimer();
    },

    /** Programmatically close the bubble */
    cerrar: closeBubble,

    /** Wake the mascot */
    despertar: wakeUp
  };

})();
</script>

<% } /* end if _mascotaUser */ %>
