<%
  /* Only render the mascot when a user session exists */
  const _mascotaUser = (typeof user !== 'undefined' && user);
  const _mascotaName = _mascotaUser ? (user.nombre || user.usuario || 'Jefe') : '';
%>
<% if (_mascotaUser) { %>

<!-- ============================================================
     MASCOTA CHEF IA - Floating widget
     Rendered by: views/partials/mascota.ejs
     Included from: views/partials/sidebar.ejs
