<!-- Toggle switch: fixed top-right, always visible when logged in -->
<div class="mascota-module-toggle" id="mascotaModuleToggle">
  <span style="font-size:16px;line-height:1;"><img src="/uploads/dalia.png" alt="DalIA" style="width:18px;height:18px;object-fit:cover;border-radius:50%;vertical-align:middle;"></span>
  <span class="mascota-toggle-label">DalIA</span>
  <label class="form-check form-switch mb-0" style="padding-left:2.5em;">
    <input class="form-check-input" type="checkbox" id="mascotaToggle" checked style="cursor:pointer;">
  </label>
</div>

<!-- Floating mascot container -->
<div class="mascota-container" id="mascotaContainer">

  <!-- Speech bubble (shown above the circle) -->
  <div class="mascota-bubble" id="mascotaBubble" role="dialog" aria-label="Mensaje del DalIA">
    <!-- Arrow pointing down toward the circle -->
    <div class="mascota-bubble-arrow"></div>

    <!-- Bubble header -->
    <div class="mascota-bubble-header">
      <span class="mascota-bubble-title"><img src="/uploads/dalia.png" alt="DalIA" style="width:18px;height:18px;object-fit:cover;border-radius:50%;vertical-align:middle;margin-right:4px;"> DalIA dice:</span>
      <button class="mascota-bubble-close" id="mascotaBubbleClose" aria-label="Cerrar">&times;</button>
    </div>

    <!-- Bubble message -->
    <p class="mascota-bubble-text" id="mascotaBubbleText"></p>

    <!-- Chat input -->
    <div class="mascota-chat-input" id="mascotaChatInput">
      <div class="mascota-input-wrap">
        <input type="text" id="mascotaInput" placeholder="Preguntale a DalIA..." autocomplete="off">
        <button id="mascotaSendBtn" title="Enviar" aria-label="Enviar">
          <i class="bi bi-send-fill"></i>
        </button>
      </div>
    </div>

    <!-- Dismiss button -->
    <button class="mascota-bubble-btn" id="mascotaBubbleBtn">Entendido</button>
  </div>

  <!-- The chef circle -->
  <div class="mascota-circle" id="mascotaCircle" title="DalIA - tu asistente inteligente" role="button" tabindex="0" aria-label="DalIA">
    <span id="mascotaEmoji"><img src="/uploads/dalia.png" alt="DalIA" style="width:54px;height:54px;object-fit:cover;border-radius:50%;"></span>
    <!-- Zzz indicator (sleep mode) -->
    <span class="mascota-zzz" id="mascotaZzz">zzz</span>
  </div>

</div>

<!-- ============================================================
     STYLES
============================================================ -->
<style>
/* ---------- CSS custom properties ---------- */
:root {
  --mascota-orange: #FF6B35;
  --mascota-orange-shadow: rgba(255, 107, 53, 0.35);
  --mascota-bubble-bg: #ffffff;
  --mascota-text: #1A1A1A;
  --mascota-text-muted: #6B7280;
  --mascota-radius: 16px;
}

/* ---------- Toggle switch ---------- */
.mascota-module-toggle {
  position: fixed;
  top: 38px;
  right: 58px;
  z-index: 9998;
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  padding: 6px 14px;
  border-radius: 100px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid #E5E7EB;
  transition: opacity 0.2s;
}

.mascota-toggle-label {
  font-size: 12px;
  font-family: 'DM Sans', sans-serif;
  color: #6B7280;
  font-weight: 500;
  white-space: nowrap;
}

/* Orange accent on the Bootstrap switch */
.mascota-module-toggle .form-check-input:checked {
  background-color: var(--mascota-orange);
  border-color: var(--mascota-orange);
}
.mascota-module-toggle .form-check-input:focus {
  box-shadow: 0 0 0 0.2rem rgba(255, 107, 53, 0.25);
  border-color: var(--mascota-orange);
}

/* ---------- Floating container ---------- */
.mascota-container {
  position: fixed;
  bottom: 48px;
  right: 58px;
  z-index: 9998;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0;
  transition: opacity 0.3s, transform 0.3s;
}

/* ---------- Chef circle ---------- */
.mascota-circle {
  position: relative;
  width: 60px;
  height: 60px;
  background: var(--mascota-orange);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 32px;
  line-height: 1;
  box-shadow: 0 4px 16px var(--mascota-orange-shadow);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  user-select: none;
  flex-shrink: 0;
}

.mascota-circle:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 24px var(--mascota-orange-shadow);
}

.mascota-circle:active {
  transform: scale(0.97);
}

/* Zzz text (sleep mode) */
.mascota-zzz {
  position: absolute;
  top: -6px;
  right: -6px;
  font-size: 11px;
  font-weight: 700;
  font-family: 'DM Sans', sans-serif;
  color: var(--mascota-orange);
  background: #fff;
  border-radius: 8px;
  padding: 1px 4px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.12);
  opacity: 0;
  transition: opacity 0.4s;
  pointer-events: none;
  letter-spacing: 1px;
}

/* ---------- Speech bubble ---------- */
.mascota-bubble {
  position: absolute;
  bottom: 72px;
  right: 0;
  width: 300px;
  max-width: calc(100vw - 48px);
  background: var(--mascota-bubble-bg);
  border-radius: var(--mascota-radius);
  border-top: 3px solid var(--mascota-orange);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  padding: 14px 16px 12px;
  display: none;
  animation: mascotaFadeIn 0.3s ease forwards;
}

.mascota-bubble.show {
  display: block;
}

/* Down-pointing arrow toward the circle */
.mascota-bubble-arrow {
  position: absolute;
  bottom: -9px;
  right: 22px;
  width: 18px;
  height: 18px;
  background: var(--mascota-bubble-bg);
  transform: rotate(45deg);
  box-shadow: 3px 3px 6px rgba(0, 0, 0, 0.06);
  border-radius: 2px;
  z-index: -1;
}

/* Bubble header */
.mascota-bubble-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.mascota-bubble-title {
  font-size: 13px;
  font-weight: 700;
  font-family: 'DM Sans', sans-serif;
  color: var(--mascota-text);
}

.mascota-bubble-close {
  background: none;
  border: none;
  font-size: 18px;
  line-height: 1;
  color: var(--mascota-text-muted);
  cursor: pointer;
  padding: 0 2px;
  transition: color 0.15s;
}
.mascota-bubble-close:hover { color: var(--mascota-text); }

/* Bubble message text */
.mascota-bubble-text {
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  color: var(--mascota-text);
  line-height: 1.55;
  margin: 0 0 12px;
}

/* Chat input */
.mascota-chat-input {
  margin: 0 0 10px;
}
.mascota-input-wrap {
  display: flex;
  gap: 6px;
  align-items: center;
  background: #F5F5F5;
  border-radius: 10px;
  padding: 4px 4px 4px 12px;
  border: 1px solid #E5E7EB;
  transition: border-color 0.2s;
}
.mascota-input-wrap:focus-within {
  border-color: var(--mascota-orange);
}
.mascota-input-wrap input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 12px;
  font-family: 'DM Sans', sans-serif;
  color: var(--mascota-text);
  outline: none;
  padding: 4px 0;
}
.mascota-input-wrap input::placeholder {
  color: #9CA3AF;
}
.mascota-input-wrap button {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  border: none;
  background: var(--mascota-orange);
  color: #fff;
  font-size: 13px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
  flex-shrink: 0;
}
.mascota-input-wrap button:hover { opacity: 0.85; }
.mascota-bubble-text.mascota-loading::after {
  content: '';
  display: inline-block;
  width: 12px;
  height: 12px;
  border: 2px solid #E5E7EB;
  border-top-color: var(--mascota-orange);
  border-radius: 50%;
  animation: mascotaSpin 0.6s linear infinite;
  margin-left: 6px;
  vertical-align: middle;
}
@keyframes mascotaSpin { to { transform: rotate(360deg); } }

/* Dismiss button */
.mascota-bubble-btn {
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  color: #fff;
  background: var(--mascota-orange);
  border: none;
  border-radius: 8px;
  padding: 5px 14px;
  cursor: pointer;
  transition: opacity 0.2s;
}
.mascota-bubble-btn:hover { opacity: 0.88; }

/* ---------- Animations ---------- */
@keyframes mascotaFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes mascotaBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  40%       { transform: translateY(-10px) scale(1.05); }
  70%       { transform: translateY(-4px) scale(1.02); }
}

@keyframes mascotaShake {
  0%,  100% { transform: rotate(0deg); }
  15%        { transform: rotate(-10deg); }
  30%        { transform: rotate(10deg); }
  45%        { transform: rotate(-8deg); }
  60%        { transform: rotate(8deg); }
  75%        { transform: rotate(-4deg); }
  90%        { transform: rotate(4deg); }
}

@keyframes mascotaSleepPulse {
  0%, 100% { opacity: 0.5; transform: rotate(10deg) scale(0.97); }
  50%       { opacity: 0.55; transform: rotate(10deg) scale(1); }
}

/* ---------- State classes applied via JS ---------- */
.mascota-state-sleep .mascota-circle {
  animation: mascotaSleepPulse 2.5s ease infinite;
}
.mascota-state-sleep .mascota-zzz {
  opacity: 1;
}

.mascota-bounce .mascota-circle {
  animation: mascotaBounce 0.55s ease 2;
}

.mascota-shake .mascota-circle {
  animation: mascotaShake 0.45s ease 2;
}

/* ---------- Hidden state (toggle OFF) ---------- */
.mascota-container.mascota-hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.85);
}

/* ---------- Responsive: push bubble left on small screens ---------- */
@media (max-width: 480px) {
  .mascota-bubble {
    right: auto;
    left: 0;
    width: 260px;
  }
  .mascota-bubble-arrow {
    right: auto;
    left: 22px;
  }
  .mascota-module-toggle {
    right: 12px;
    top: 8px;
  }
}
</style>

<!-- ============================================================
     JAVASCRIPT
