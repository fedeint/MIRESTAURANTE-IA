<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asistente IA - dignita.tech</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
    <style>
        .chat-container {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 2rem);
            max-height: calc(100vh - 2rem);
        }
        @media (max-width: 991.98px) {
            .chat-container { height: calc(100vh - 56px - 1rem); }
        }

        .chat-header {
            flex-shrink: 0;
            padding: 1.25rem;
            background: var(--dg-surface);
            backdrop-filter: blur(16px);
            border: 1px solid var(--dg-surface-border);
            border-radius: var(--dg-radius-lg);
            margin-bottom: 1rem;
        }

        .chat-header-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #6366f1, #06b6d4);
            border-radius: 0.875rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #fff;
            box-shadow: 0 4px 16px rgba(99,102,241,0.3);
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 0.5rem 0;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .chat-msg {
            max-width: 85%;
            padding: 0.85rem 1.1rem;
            border-radius: 1rem;
            font-size: 0.925rem;
            line-height: 1.6;
            animation: dg-fadeInUp 0.25s ease-out;
            word-wrap: break-word;
        }

        .chat-msg-user {
            align-self: flex-end;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            border-bottom-right-radius: 0.25rem;
            box-shadow: 0 4px 12px rgba(99,102,241,0.25);
        }

        .chat-msg-ai {
            align-self: flex-start;
            background: var(--dg-surface);
            backdrop-filter: blur(12px);
            border: 1px solid var(--dg-surface-border);
            color: var(--dg-text);
            border-bottom-left-radius: 0.25rem;
            box-shadow: var(--dg-shadow-sm);
        }

        .chat-msg-ai strong { color: var(--dg-primary); }
        .chat-msg-ai code {
            background: rgba(99,102,241,0.08);
            padding: 0.15rem 0.4rem;
            border-radius: 0.3rem;
            font-size: 0.85em;
        }

        .chat-msg-error {
            align-self: center;
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.15);
            color: #dc2626;
            border-radius: 0.75rem;
            font-size: 0.85rem;
            max-width: 90%;
        }

        .chat-typing {
            align-self: flex-start;
            padding: 0.75rem 1.1rem;
            background: var(--dg-surface);
            border: 1px solid var(--dg-surface-border);
            border-radius: 1rem;
            border-bottom-left-radius: 0.25rem;
            display: flex;
            gap: 0.3rem;
            align-items: center;
        }

        .chat-typing-dot {
            width: 8px;
            height: 8px;
            background: #94a3b8;
            border-radius: 50%;
            animation: typingBounce 1.4s ease-in-out infinite;
        }
        .chat-typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .chat-typing-dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typingBounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-6px); }
        }

        .chat-input-area {
            flex-shrink: 0;
            padding-top: 0.75rem;
        }

        .chat-input-wrap {
            display: flex;
            gap: 0.5rem;
            background: var(--dg-surface);
            backdrop-filter: blur(16px);
            border: 1.5px solid var(--dg-surface-border);
            border-radius: 1rem;
            padding: 0.5rem 0.5rem 0.5rem 1rem;
            transition: border-color 0.2s;
            box-shadow: var(--dg-shadow-sm);
        }

        .chat-input-wrap:focus-within {
            border-color: var(--dg-primary-light);
            box-shadow: 0 0 0 3px var(--dg-primary-glow);
        }

        .chat-input {
            flex: 1;
            border: none;
            outline: none;
            background: transparent;
            font-size: 0.95rem;
            color: var(--dg-text);
            font-family: inherit;
            resize: none;
            max-height: 120px;
            line-height: 1.5;
        }

        .chat-input::placeholder { color: var(--dg-text-muted); }

        .chat-send-btn {
            width: 42px;
            height: 42px;
            border-radius: 0.75rem;
            border: none;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(99,102,241,0.3);
        }

        .chat-send-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(99,102,241,0.4);
        }

        .chat-send-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .chat-suggestions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            margin-top: 0.5rem;
        }

        .chat-suggestion {
            background: var(--dg-surface);
            border: 1px solid var(--dg-surface-border);
            border-radius: 2rem;
            padding: 0.4rem 1rem;
            font-size: 0.8rem;
            color: var(--dg-text-secondary);
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }

        .chat-suggestion:hover {
            background: rgba(99,102,241,0.06);
            border-color: var(--dg-primary-light);
            color: var(--dg-primary);
        }

        /* Markdown-like formatting in AI messages */
        .chat-msg-ai p { margin: 0 0 0.5rem 0; }
        .chat-msg-ai p:last-child { margin-bottom: 0; }
        .chat-msg-ai ul, .chat-msg-ai ol { margin: 0.25rem 0; padding-left: 1.25rem; }
        .chat-msg-ai li { margin-bottom: 0.2rem; }
    </style>
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
        <div class="container">
            <div class="chat-container">
                <!-- Header -->
                <div class="chat-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="chat-header-icon">
                            <i class="bi bi-robot"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Asistente IA</h5>
                            <div class="text-muted small">Pregunta cualquier cosa sobre tu negocio</div>
                        </div>
                        <div class="ms-auto">
                            <span class="badge" style="background:rgba(16,185,129,0.1);color:#059669;border:1px solid rgba(16,185,129,0.2);">
                                <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>En linea
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Messages -->
                <div class="chat-messages" id="chatMessages">
                    <!-- Welcome message -->
                    <div class="chat-msg chat-msg-ai">
                        <strong>Hola!</strong> Soy tu asistente de IA para <strong>dignita.tech</strong>. Puedo ayudarte con:<br><br>
                        <ul>
                            <li>Resumen de ventas y rendimiento</li>
                            <li>Informacion sobre productos y precios</li>
                            <li>Datos de clientes y mesas</li>
                            <li>Sugerencias para mejorar tu negocio</li>
                            <li>Cualquier pregunta sobre tu restaurante</li>
                        </ul>
                        Preguntame lo que necesites!
                    </div>

                    <!-- Suggestions -->
                    <div class="chat-suggestions" id="chatSuggestions">
                        <a class="chat-suggestion" data-q="Como van las ventas de hoy?"><i class="bi bi-graph-up me-1"></i>Ventas de hoy</a>
                        <a class="chat-suggestion" data-q="Cuales son los productos mas vendidos?"><i class="bi bi-trophy me-1"></i>Mas vendidos</a>
                        <a class="chat-suggestion" data-q="Dame un resumen general del negocio"><i class="bi bi-clipboard-data me-1"></i>Resumen general</a>
                        <a class="chat-suggestion" data-q="Que sugerencias tienes para mejorar las ventas?"><i class="bi bi-lightbulb me-1"></i>Sugerencias</a>
                    </div>
                </div>

                <!-- Input -->
                <div class="chat-input-area">
                    <div class="chat-input-wrap">
                        <textarea class="chat-input" id="chatInput" rows="1" placeholder="Escribe tu pregunta..." maxlength="2000"></textarea>
                        <button class="chat-send-btn" id="chatSend" type="button" title="Enviar">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div class="text-center mt-2">
                        <span class="text-muted" style="font-size:0.72rem;">Powered by Claude AI &middot; Los datos se consultan en tiempo real de tu base de datos</span>
                    </div>
                </div>
            </div>
        </div>
    </main>
    </div>

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
    (function() {
        const messagesEl = document.getElementById('chatMessages');
        const inputEl = document.getElementById('chatInput');
        const sendBtn = document.getElementById('chatSend');
        const suggestionsEl = document.getElementById('chatSuggestions');
        let historial = [];
        let sending = false;

        function scrollBottom() {
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function addMessage(role, content, isError) {
            const div = document.createElement('div');
            div.className = 'chat-msg ' + (isError ? 'chat-msg-error' : (role === 'user' ? 'chat-msg-user' : 'chat-msg-ai'));
            div.innerHTML = role === 'user' ? escapeHtml(content) : formatAI(content);
            messagesEl.appendChild(div);
            scrollBottom();
        }

        function showTyping() {
            const div = document.createElement('div');
            div.className = 'chat-typing';
            div.id = 'typingIndicator';
            div.innerHTML = '<div class="chat-typing-dot"></div><div class="chat-typing-dot"></div><div class="chat-typing-dot"></div>';
            messagesEl.appendChild(div);
            scrollBottom();
        }

        function hideTyping() {
            const el = document.getElementById('typingIndicator');
            if (el) el.remove();
        }

        function escapeHtml(s) {
            const d = document.createElement('div');
            d.textContent = s;
            return d.innerHTML;
        }

        function formatAI(text) {
            // Basic markdown-like formatting
            let html = escapeHtml(text);
            // Bold
            html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            // Inline code
            html = html.replace(/`(.*?)`/g, '<code>$1</code>');
            // Line breaks to paragraphs
            html = html.replace(/\n\n/g, '</p><p>');
            html = html.replace(/\n- /g, '</p><ul><li>');
            html = html.replace(/\n(\d+)\. /g, '</p><ol><li>');
            // Simple line breaks
            html = html.replace(/\n/g, '<br>');
            html = '<p>' + html + '</p>';
            return html;
        }

        async function sendMessage(text) {
            if (sending || !text.trim()) return;
            sending = true;
            sendBtn.disabled = true;

            // Hide suggestions
            if (suggestionsEl) suggestionsEl.style.display = 'none';

            // Add user message
            addMessage('user', text);
            historial.push({ role: 'user', content: text });

            // Show typing
            showTyping();

            try {
                const resp = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        mensaje: text,
                        historial: historial.slice(-20)
                    })
                });

                hideTyping();

                const data = await resp.json();
                if (!resp.ok) throw new Error(data.error || 'Error del servidor');

                addMessage('assistant', data.respuesta);
                historial.push({ role: 'assistant', content: data.respuesta });
            } catch (err) {
                hideTyping();
                addMessage('error', err.message || 'Error al comunicarse con la IA', true);
            }

            sending = false;
            sendBtn.disabled = false;
            inputEl.focus();
        }

        // Send on click
        sendBtn.addEventListener('click', function() {
            const text = inputEl.value.trim();
            if (text) {
                inputEl.value = '';
                inputEl.style.height = 'auto';
                sendMessage(text);
            }
        });

        // Send on Enter (Shift+Enter for newline)
        inputEl.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendBtn.click();
            }
        });

        // Auto-resize textarea
        inputEl.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });

        // Suggestions
        document.querySelectorAll('.chat-suggestion').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const q = this.getAttribute('data-q');
                if (q) sendMessage(q);
            });
        });

        inputEl.focus();
    })();
    </script>
</body>
</html>
