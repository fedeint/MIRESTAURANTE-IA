<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1e1b4b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dignita">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
    <title>Asistente IA - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
    <style>
        .chat-container {
            display: flex;
            flex-direction: column;
            height: 100%;
            max-height: 100%;
            overflow: hidden;
        }
        .dg-main { display: flex; flex-direction: column; }
        .dg-main > main { flex: 1; overflow: hidden; display: flex; flex-direction: column; }
        .dg-main > main > .container { flex: 1; overflow: hidden; display: flex; flex-direction: column; padding-top: 0.5rem !important; padding-bottom: 0.5rem !important; }

        .chat-header {
            flex-shrink: 0;
            padding: 1.25rem;
            background: var(--dg-surface);
            backdrop-filter: blur(16px);
            border: 1px solid var(--dg-surface-border);
            border-radius: var(--dg-radius-lg);
            margin-bottom: 1rem;
        }

        .chat-header-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #6366f1, #06b6d4);
            border-radius: 0.875rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #fff;
            box-shadow: 0 4px 16px rgba(99,102,241,0.3);
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 0.5rem 0;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .chat-msg {
            max-width: 85%;
            padding: 0.85rem 1.1rem;
            border-radius: 1rem;
            font-size: 0.925rem;
            line-height: 1.6;
            animation: dg-fadeInUp 0.25s ease-out;
            word-wrap: break-word;
        }

        .chat-msg-user {
            align-self: flex-end;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            border-bottom-right-radius: 0.25rem;
            box-shadow: 0 4px 12px rgba(99,102,241,0.25);
        }

        .chat-msg-ai {
            align-self: flex-start;
            background: var(--dg-surface);
            backdrop-filter: blur(12px);
            border: 1px solid var(--dg-surface-border);
            color: var(--dg-text);
            border-bottom-left-radius: 0.25rem;
            box-shadow: var(--dg-shadow-sm);
        }

        .chat-msg-ai strong { color: var(--dg-primary); }
        .chat-msg-ai code {
            background: rgba(99,102,241,0.08);
            padding: 0.15rem 0.4rem;
            border-radius: 0.3rem;
            font-size: 0.85em;
        }

        .chat-msg-error {
            align-self: center;
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.15);
            color: #dc2626;
            border-radius: 0.75rem;
            font-size: 0.85rem;
            max-width: 90%;
        }

        .chat-typing {
            align-self: flex-start;
            padding: 0.75rem 1.1rem;
            background: var(--dg-surface);
            border: 1px solid var(--dg-surface-border);
            border-radius: 1rem;
            border-bottom-left-radius: 0.25rem;
            display: flex;
            gap: 0.3rem;
            align-items: center;
        }

        .chat-typing-dot {
            width: 8px;
            height: 8px;
            background: #94a3b8;
            border-radius: 50%;
            animation: typingBounce 1.4s ease-in-out infinite;
        }
        .chat-typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .chat-typing-dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typingBounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-6px); }
        }

        /* ─── Input area moderno ─── */
        .chat-input-area {
            flex-shrink: 0;
            padding-top: 0.75rem;
        }

        .chat-input-wrap {
            background: var(--dg-surface);
            backdrop-filter: blur(16px);
            border: 1.5px solid var(--dg-surface-border);
            border-radius: 1.5rem;
            padding: 0.5rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            box-shadow: var(--dg-shadow-sm);
        }

        .chat-input-wrap:focus-within {
            border-color: var(--dg-primary-light);
            box-shadow: 0 0 0 3px var(--dg-primary-glow);
        }

        .chat-input-wrap.recording {
            border-color: rgba(239, 68, 68, 0.5);
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
        }

        .chat-input {
            flex: 1;
            border: none;
            outline: none;
            background: transparent;
            font-size: 0.95rem;
            color: var(--dg-text);
            font-family: inherit;
            resize: none;
            max-height: 120px;
            line-height: 1.5;
            width: 100%;
            padding: 0.4rem 0.5rem;
        }

        .chat-input::placeholder { color: var(--dg-text-muted); }

        .chat-input-bottom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.25rem 0.25rem 0;
        }

        .chat-input-actions {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .chat-action-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background: transparent;
            color: var(--dg-text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .chat-action-btn:hover {
            background: rgba(99,102,241,0.08);
            color: var(--dg-primary);
        }

        .chat-action-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .chat-send-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(99,102,241,0.3);
        }

        .chat-send-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(99,102,241,0.4);
        }

        .chat-send-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .chat-send-btn.mic-mode {
            background: transparent;
            color: var(--dg-text-muted);
            box-shadow: none;
        }

        .chat-send-btn.mic-mode:hover {
            background: rgba(99,102,241,0.08);
            color: var(--dg-primary);
        }

        .chat-send-btn.stop-mode {
            background: transparent;
            color: #ef4444;
            box-shadow: none;
        }

        .chat-send-btn.stop-mode:hover {
            background: rgba(239,68,68,0.08);
        }

        /* ─── Recording visualizer ─── */
        .voice-recorder {
            display: none;
            flex-direction: column;
            align-items: center;
            padding: 0.75rem 0.5rem;
            animation: fadeIn 0.3s ease;
        }

        .voice-recorder.active {
            display: flex;
        }

        .voice-recorder-timer {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .voice-recorder-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #ef4444;
            animation: pulseDot 1s ease-in-out infinite;
        }

        @keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }

        .voice-recorder-time {
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.85rem;
            color: var(--dg-text-secondary);
        }

        .voice-visualizer {
            width: 100%;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2px;
            padding: 0 1rem;
        }

        .voice-bar {
            width: 2.5px;
            border-radius: 2px;
            background: linear-gradient(to top, rgba(99,102,241,0.4), rgba(99,102,241,0.8));
            transition: height 0.1s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ─── Suggestions ─── */
        .chat-suggestions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            margin-top: 0.5rem;
        }

        .chat-suggestion {
            background: var(--dg-surface);
            border: 1px solid var(--dg-surface-border);
            border-radius: 2rem;
            padding: 0.4rem 1rem;
            font-size: 0.8rem;
            color: var(--dg-text-secondary);
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }

        .chat-suggestion:hover {
            background: rgba(99,102,241,0.06);
            border-color: var(--dg-primary-light);
            color: var(--dg-primary);
        }

        /* ─── Historial panel ─── */
        .chat-history-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1px solid var(--dg-surface-border);
            background: var(--dg-surface);
            color: var(--dg-text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .chat-history-btn:hover {
            background: rgba(99,102,241,0.06);
            border-color: var(--dg-primary-light);
            color: var(--dg-primary);
        }

        .chat-history-panel {
            position: fixed;
            top: 0;
            right: -360px;
            width: 340px;
            max-width: 90vw;
            height: 100vh;
            background: var(--dg-surface);
            border-left: 1px solid var(--dg-surface-border);
            z-index: 1035;
            transition: right 0.3s ease;
            display: flex;
            flex-direction: column;
            box-shadow: -4px 0 24px rgba(0,0,0,0.15);
        }

        .chat-history-panel.open {
            right: 0;
        }

        .chat-history-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 1034;
            display: none;
        }

        .chat-history-overlay.open {
            display: block;
        }

        .chat-history-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--dg-surface-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .chat-history-list {
            flex: 1;
            overflow-y: auto;
            padding: 0.75rem;
        }

        .chat-history-item {
            padding: 0.75rem;
            border-radius: 0.75rem;
            cursor: pointer;
            transition: background 0.2s;
            margin-bottom: 0.25rem;
        }

        .chat-history-item:hover {
            background: rgba(99,102,241,0.06);
        }

        .chat-history-item-q {
            font-size: 0.85rem;
            color: var(--dg-text);
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .chat-history-item-date {
            font-size: 0.7rem;
            color: var(--dg-text-muted);
            margin-top: 0.15rem;
        }

        .chat-history-empty {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--dg-text-muted);
            font-size: 0.85rem;
        }

        .chat-history-actions {
            padding: 0.75rem 1.25rem;
            border-top: 1px solid var(--dg-surface-border);
            flex-shrink: 0;
        }

        /* Markdown formatting in AI messages */
        .chat-msg-ai p { margin: 0 0 0.5rem 0; }
        .chat-msg-ai p:last-child { margin-bottom: 0; }
        .chat-msg-ai ul, .chat-msg-ai ol { margin: 0.25rem 0; padding-left: 1.25rem; }
        .chat-msg-ai li { margin-bottom: 0.2rem; }

        /* Divider between action buttons */
        .chat-action-divider {
            width: 1.5px;
            height: 20px;
            margin: 0 0.15rem;
            background: linear-gradient(to bottom, transparent, var(--dg-surface-border), transparent);
            border-radius: 1px;
        }

        /* ── DallIA Action Cards ─────────────────── */
        .action-card {
            background: linear-gradient(135deg, #fff8f0 0%, #fafaf7 100%);
            border: 2px solid #ef520f;
            border-radius: 16px;
            padding: 16px;
            margin: 12px 0;
            box-shadow: 0 4px 12px rgba(239, 82, 15, 0.15);
        }
        .action-card-header {
            font-size: 1.1em;
            color: #ef520f;
            margin-bottom: 12px;
            border-bottom: 1px solid rgba(239, 82, 15, 0.2);
            padding-bottom: 8px;
        }
        .action-card-proveedor {
            background: white;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 8px;
        }
        .prov-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        .prov-message {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 6px;
            font-family: 'DM Sans', sans-serif;
            white-space: pre-wrap;
            font-size: 0.9em;
            margin: 0;
        }
        .action-card-warning {
            background: #fff4e5;
            border-left: 4px solid #F97316;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 8px;
            font-size: 0.9em;
        }
        .action-card-warning ul { margin: 4px 0 0 16px; }
        .action-card-buttons { display: flex; gap: 8px; margin-top: 12px; }
        .action-card-status { margin-top: 10px; font-size: 0.9em; }
        .action-card-status.success { color: #22C55E; }
        .action-card-status.error { color: #EF4444; }
        /* ─────────────────────────────────────────── */
    </style>
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
        <div class="container">
            <div class="chat-container">
                <!-- Header -->
                <div class="chat-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="chat-header-icon">
                            <i class="bi bi-robot"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold"><%= typeof dalliaNombre !== 'undefined' ? dalliaNombre : 'Asistente IA' %></h5>
                            <div class="text-muted small">Hola <%= typeof userName !== 'undefined' ? userName : 'Usuario' %> &middot; Pregunta cualquier cosa sobre tu negocio</div>
                        </div>
                        <div class="ms-auto d-flex align-items-center gap-2">
                            <span class="badge" style="background:rgba(16,185,129,0.1);color:#059669;border:1px solid rgba(16,185,129,0.2);">
                                <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>En linea
                            </span>
                            <button class="chat-history-btn" id="historyToggle" title="Historial de preguntas">
                                <i class="bi bi-clock-history"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Messages -->
                <div class="chat-messages" id="chatMessages">
                </div>

                <!-- Suggestions (dynamic by time + context) -->
                <div id="suggestionsWrap">
                    <div class="chat-suggestions" id="chatSuggestions">
                        <!-- Filled by JS below -->
                    </div>
                </div>

                <!-- Input -->
                <div class="chat-input-area">
                    <div class="chat-input-wrap" id="inputWrap">
                        <!-- Recording visualizer (hidden by default) -->
                        <div class="voice-recorder" id="voiceRecorder">
                            <div class="voice-recorder-timer">
                                <div class="voice-recorder-dot"></div>
                                <span class="voice-recorder-time" id="recorderTime">00:00</span>
                            </div>
                            <div class="voice-visualizer" id="voiceVisualizer"></div>
                        </div>

                        <!-- Text input (hidden while recording) -->
                        <div id="textInputArea">
                            <textarea class="chat-input" id="chatInput" rows="1" placeholder="Escribe o habla tu pregunta..." maxlength="2000"></textarea>
                        </div>

                        <!-- Bottom actions -->
                        <div class="chat-input-bottom">
                            <div class="chat-input-actions" id="inputActions">
                                <div class="form-check form-switch" style="font-size:0.72rem;margin:0;">
                                    <input class="form-check-input" type="checkbox" id="voiceAutoRead" checked style="transform:scale(0.8);">
                                    <label class="form-check-label text-muted" for="voiceAutoRead">Leer en voz alta</label>
                                </div>
                                <!-- Stop TTS button -->
                                <button class="chat-action-btn" id="stopTtsBtn" type="button" title="Parar de hablar" style="display:none;">
                                    <i class="bi bi-volume-mute-fill" style="color:#EF4444;"></i>
                                </button>
                            </div>

                            <!-- Send / Mic / Stop button -->
                            <button class="chat-send-btn mic-mode" id="mainActionBtn" type="button" title="Grabar audio">
                                <i class="bi bi-mic-fill" id="mainActionIcon"></i>
                            </button>
                        </div>
                    </div>
                    <div class="text-center mt-1">
                        <span class="text-muted" id="chatProvider" style="font-size:0.72rem;">Los datos se consultan en tiempo real de tu base de datos</span>
                    </div>
                </div>
            </div>
        </div>
    </main>
    </div>

    <!-- History panel -->
    <div class="chat-history-overlay" id="historyOverlay"></div>
    <div class="chat-history-panel" id="historyPanel">
        <div class="chat-history-header">
            <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Historial</h6>
            <button class="chat-action-btn" id="historyClose" title="Cerrar">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="chat-history-list" id="historyList">
            <div class="chat-history-empty" id="historyEmpty">
                <i class="bi bi-chat-dots" style="font-size:2rem;display:block;margin-bottom:0.5rem;opacity:0.4;"></i>
                Aun no tienes preguntas en el historial
            </div>
        </div>
        <div class="chat-history-actions">
            <button class="btn btn-sm btn-outline-danger w-100" id="historyClear" style="border-radius:0.75rem;">
                <i class="bi bi-trash3 me-1"></i>Limpiar historial
            </button>
        </div>
    </div>

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
    (function() {
        // ─── User role from session (no need to ask) ───
        var userRol      = '<%= typeof userRol !== "undefined" ? userRol : "administrador" %>';
        var userName     = '<%= typeof userName !== "undefined" ? userName : "Usuario" %>';
        var dalliaNombre = '<%= typeof dalliaNombre !== "undefined" ? dalliaNombre : "DalIA" %>';
        var DALLIA_VOZ    = '<%= typeof dalliaVoz !== "undefined" ? dalliaVoz : "Aoede" %>';
        var DALLIA_ESTILO = '<%= typeof dalliaEstilo !== "undefined" ? dalliaEstilo.replace(/'/g, "\\'") : "" %>';

        var messagesEl = document.getElementById('chatMessages');
        var inputEl = document.getElementById('chatInput');
        var mainBtn = document.getElementById('mainActionBtn');
        var mainIcon = document.getElementById('mainActionIcon');
        var suggestionsEl = document.getElementById('chatSuggestions');
        var suggestionsWrap = document.getElementById('suggestionsWrap');
        var inputWrap = document.getElementById('inputWrap');
        var textInputArea = document.getElementById('textInputArea');
        var inputActions = document.getElementById('inputActions');
        var historial = [];
        var sending = false;

        // ─── Chat history (localStorage) ───
        var HISTORY_KEY = 'dg-chat-history';

        function getHistory() {
            try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; }
            catch { return []; }
        }

        function saveToHistory(question, answer) {
            var h = getHistory();
            h.unshift({
                q: question.substring(0, 200),
                a: answer.substring(0, 300),
                ts: Date.now()
            });
            // Keep last 50
            if (h.length > 50) h = h.slice(0, 50);
            localStorage.setItem(HISTORY_KEY, JSON.stringify(h));
            renderHistory();
        }

        function renderHistory() {
            var list = document.getElementById('historyList');
            var empty = document.getElementById('historyEmpty');
            var h = getHistory();

            // Remove old items (keep empty placeholder)
            list.querySelectorAll('.chat-history-item').forEach(function(el) { el.remove(); });

            if (h.length === 0) {
                empty.style.display = 'block';
                return;
            }

            empty.style.display = 'none';

            h.forEach(function(item) {
                var div = document.createElement('div');
                div.className = 'chat-history-item';
                var date = new Date(item.ts);
                var dateStr = date.toLocaleDateString('es-PE', { day: '2-digit', month: 'short' }) + ' ' + date.toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' });
                div.innerHTML = '<div class="chat-history-item-q">' + escapeHtml(item.q) + '</div><div class="chat-history-item-date">' + dateStr + '</div>';
                div.addEventListener('click', function() {
                    sendMessage(item.q);
                    closeHistory();
                });
                list.appendChild(div);
            });
        }

        // History panel toggle
        var historyToggle = document.getElementById('historyToggle');
        var historyPanel = document.getElementById('historyPanel');
        var historyOverlay = document.getElementById('historyOverlay');
        var historyClose = document.getElementById('historyClose');
        var historyClear = document.getElementById('historyClear');

        function openHistory() {
            historyPanel.classList.add('open');
            historyOverlay.classList.add('open');
            renderHistory();
        }

        function closeHistory() {
            historyPanel.classList.remove('open');
            historyOverlay.classList.remove('open');
        }

        historyToggle.addEventListener('click', openHistory);
        historyOverlay.addEventListener('click', closeHistory);
        historyClose.addEventListener('click', closeHistory);
        historyClear.addEventListener('click', function() {
            localStorage.removeItem(HISTORY_KEY);
            renderHistory();
        });

        // ─── Welcome message (natural, context-aware) ───
        var hora = new Date().getHours();
        var saludo = hora < 12 ? 'Buenos dias' : hora < 18 ? 'Buenas tardes' : 'Buenas noches';
        var _urlParams  = new URLSearchParams(window.location.search);
        var _agent      = _urlParams.get('agent')   || '';
        var _contexto   = _urlParams.get('contexto') || '';
        var _autoPrompt = _urlParams.get('prompt')  || '';

        // Contextual welcome when opened as Agente Salva
        var welcomeMsg;
        if (_agent === 'salva' && _contexto === 'caja') {
            welcomeMsg = '**' + saludo + ', ' + userName + '!** Soy Salva, tu agente de caja.\n\nEstoy monitoreando tu efectivo, movimientos y metas en tiempo real. ¿En qué te ayudo?';
        } else {
            welcomeMsg = '**' + saludo + ', ' + userName + '!** Soy ' + dalliaNombre + ', tu asistente.\n\nRecuerda que para iniciar operaciones necesitas **abrir caja** primero. Si necesitas ayuda con cualquier cosa sobre la gestion del restaurante, aqui estoy para ti.';
        }
        addMessage('assistant', welcomeMsg);
        inputEl.focus();

        // Auto-send ?prompt= query param after a short delay (gives page time to paint)
        if (_autoPrompt) {
            setTimeout(function() { sendMessage(_autoPrompt); }, 600);
        }

        // ─── Message helpers ───
        function scrollBottom() {
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function addMessage(role, content, isError) {
            var div = document.createElement('div');
            div.className = 'chat-msg ' + (isError ? 'chat-msg-error' : (role === 'user' ? 'chat-msg-user' : 'chat-msg-ai'));
            div.innerHTML = role === 'user' ? escapeHtml(content) : formatAI(content);
            messagesEl.appendChild(div);
            scrollBottom();

            // Auto-read AI responses
            if (role === 'assistant' && !isError) leerEnVozAlta(content);
        }

        function showTyping() {
            var div = document.createElement('div');
            div.className = 'chat-typing';
            div.id = 'typingIndicator';
            div.innerHTML = '<div class="chat-typing-dot"></div><div class="chat-typing-dot"></div><div class="chat-typing-dot"></div>';
            messagesEl.appendChild(div);
            scrollBottom();
        }

        function hideTyping() {
            var el = document.getElementById('typingIndicator');
            if (el) el.remove();
        }

        function formatAI(text) {
            var html = escapeHtml(text);
            html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/`(.*?)`/g, '<code>$1</code>');
            html = html.replace(/\n\n/g, '</p><p>');
            html = html.replace(/\n- /g, '</p><ul><li>');
            html = html.replace(/\n(\d+)\. /g, '</p><ol><li>');
            html = html.replace(/\n/g, '<br>');
            html = '<p>' + html + '</p>';
            return html;
        }

        // ─── Send message ───
        async function sendMessage(text) {
            if (sending || !text.trim()) return;
            sending = true;
            updateMainButton();

            if (suggestionsEl) suggestionsEl.style.display = 'none';

            addMessage('user', text);
            historial.push({ role: 'user', content: text });

            showTyping();

            try {
                var resp = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        mensaje: text,
                        historial: historial.slice(-20),
                        rol: userRol
                    })
                });

                hideTyping();

                var data = await resp.json();
                if (!resp.ok) throw new Error(data.error || 'Error del servidor');

                if (data.type === 'action_card') {
                    renderActionCard(data);
                } else {
                    addMessage('assistant', data.respuesta);
                    historial.push({ role: 'assistant', content: data.respuesta });
                    saveToHistory(text, data.respuesta);
                }

                var prov = document.getElementById('chatProvider');
                if (prov && data.provider) {
                    prov.textContent = 'Los datos se consultan en tiempo real de tu base de datos';
                }
            } catch (err) {
                hideTyping();
                addMessage('error', err.message || 'Error al comunicarse con la IA', true);
            }

            sending = false;
            updateMainButton();
            inputEl.focus();
        }

        // ─── Dynamic main button (mic / send / stop) ───
        function updateMainButton() {
            var hasContent = inputEl.value.trim() !== '';

            if (sending) {
                mainBtn.className = 'chat-send-btn';
                mainBtn.disabled = true;
                mainIcon.className = 'bi bi-hourglass-split';
                mainBtn.title = 'Enviando...';
                return;
            }

            if (isRecording) {
                mainBtn.className = 'chat-send-btn stop-mode';
                mainBtn.disabled = false;
                mainIcon.className = 'bi bi-stop-circle-fill';
                mainBtn.title = 'Detener grabacion';
                return;
            }

            if (hasContent) {
                mainBtn.className = 'chat-send-btn';
                mainBtn.disabled = false;
                mainIcon.className = 'bi bi-arrow-up';
                mainBtn.title = 'Enviar mensaje';
            } else {
                mainBtn.className = 'chat-send-btn mic-mode';
                mainBtn.disabled = false;
                mainIcon.className = 'bi bi-mic-fill';
                mainBtn.title = 'Grabar audio';
            }
        }

        // Main button click handler
        mainBtn.addEventListener('click', function() {
            if (isRecording) {
                stopRecording();
                return;
            }

            var text = inputEl.value.trim();
            if (text) {
                inputEl.value = '';
                inputEl.style.height = 'auto';
                updateMainButton();
                sendMessage(text);
            } else {
                startRecording();
            }
        });

        // Update button on input change
        inputEl.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
            updateMainButton();
        });

        // Send on Enter
        inputEl.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                mainBtn.click();
            }
        });

        // Suggestions
        document.querySelectorAll('.chat-suggestion').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var q = this.getAttribute('data-q');
                if (q) sendMessage(q);
            });
        });

        // ─── Voice Recording with visualizer ───
        var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        var isRecording = false;
        var recordingTimer = null;
        var recordingSeconds = 0;
        var analyserInterval = null;
        var audioContext = null;
        var analyser = null;
        var mediaStream = null;
        var voiceRecorderEl = document.getElementById('voiceRecorder');
        var recorderTimeEl = document.getElementById('recorderTime');
        var visualizerEl = document.getElementById('voiceVisualizer');

        // Build visualizer bars
        var NUM_BARS = 40;
        for (var i = 0; i < NUM_BARS; i++) {
            var bar = document.createElement('div');
            bar.className = 'voice-bar';
            bar.style.height = '4px';
            visualizerEl.appendChild(bar);
        }

        function formatTime(sec) {
            var m = Math.floor(sec / 60);
            var s = sec % 60;
            return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        }

        function startRecording() {
            if (!SpeechRecognition) {
                addMessage('error', 'Tu navegador no soporta grabacion de voz. Usa Chrome o Edge.', true);
                return;
            }

            isRecording = true;
            recordingSeconds = 0;
            recorderTimeEl.textContent = '00:00';

            // Show recorder, hide text input
            voiceRecorderEl.classList.add('active');
            textInputArea.style.display = 'none';
            inputActions.style.visibility = 'hidden';
            inputWrap.classList.add('recording');
            updateMainButton();

            // Timer
            recordingTimer = setInterval(function() {
                recordingSeconds++;
                recorderTimeEl.textContent = formatTime(recordingSeconds);
            }, 1000);

            // Audio context for visualizer
            navigator.mediaDevices.getUserMedia({ audio: true }).then(function(stream) {
                mediaStream = stream;
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                var source = audioContext.createMediaStreamSource(stream);
                analyser = audioContext.createAnalyser();
                analyser.fftSize = 128;
                source.connect(analyser);

                var bufferLength = analyser.frequencyBinCount;
                var dataArray = new Uint8Array(bufferLength);
                var bars = visualizerEl.querySelectorAll('.voice-bar');

                analyserInterval = setInterval(function() {
                    analyser.getByteFrequencyData(dataArray);
                    for (var j = 0; j < bars.length; j++) {
                        var idx = Math.floor(j * bufferLength / bars.length);
                        var val = dataArray[idx] || 0;
                        var height = Math.max(4, (val / 255) * 36);
                        bars[j].style.height = height + 'px';
                    }
                }, 50);
            }).catch(function() {
                // Microphone denied — fall back to random bars
                analyserInterval = setInterval(function() {
                    var bars = visualizerEl.querySelectorAll('.voice-bar');
                    for (var j = 0; j < bars.length; j++) {
                        bars[j].style.height = Math.max(4, Math.random() * 36) + 'px';
                    }
                }, 100);
            });

            // Start speech recognition with interim results for live feedback
            var recognition = new SpeechRecognition();
            recognition.lang = 'es-PE';
            recognition.interimResults = true;
            recognition.maxAlternatives = 1;
            recognition.continuous = true;

            window._activeRecognition = recognition;
            window._recognizedText = '';
            window._interimText = '';

            recognition.onresult = function(event) {
                var final = '';
                var interim = '';
                for (var i = 0; i < event.results.length; i++) {
                    if (event.results[i].isFinal) {
                        final += event.results[i][0].transcript + ' ';
                    } else {
                        interim += event.results[i][0].transcript;
                    }
                }
                window._recognizedText = final.trim();
                window._interimText = interim;
                // Show live text in the recorder area
                if (recorderTimeEl) {
                    var display = (window._recognizedText + ' ' + interim).trim();
                    if (display) {
                        recorderTimeEl.textContent = display.substring(0, 60) + (display.length > 60 ? '...' : '');
                    }
                }
            };

            recognition.onerror = function(e) {
                // "no-speech" is normal — don't stop, just wait
                if (e.error === 'no-speech' || e.error === 'aborted') return;
                stopRecording();
            };

            recognition.onend = function() {
                // If still recording, restart recognition (browser stops after ~60s)
                if (isRecording) {
                    try { recognition.start(); } catch (_) { stopRecording(); }
                }
            };

            try { recognition.start(); } catch (_) { stopRecording(); }
        }

        function stopRecording() {
            isRecording = false;

            // Stop timer
            if (recordingTimer) {
                clearInterval(recordingTimer);
                recordingTimer = null;
            }

            // Stop visualizer
            if (analyserInterval) {
                clearInterval(analyserInterval);
                analyserInterval = null;
            }

            // Stop audio context
            if (mediaStream) {
                mediaStream.getTracks().forEach(function(t) { t.stop(); });
                mediaStream = null;
            }
            if (audioContext) {
                audioContext.close();
                audioContext = null;
            }

            // Stop speech recognition
            if (window._activeRecognition) {
                window._activeRecognition.stop();
            }

            // Reset visualizer bars
            visualizerEl.querySelectorAll('.voice-bar').forEach(function(b) {
                b.style.height = '4px';
            });

            // Hide recorder, show text input
            voiceRecorderEl.classList.remove('active');
            textInputArea.style.display = 'block';
            inputActions.style.visibility = 'visible';
            inputWrap.classList.remove('recording');
            updateMainButton();

            // Send recognized text
            var text = (window._recognizedText || '').trim();
            window._recognizedText = '';
            window._activeRecognition = null;

            if (text) {
                sendMessage(text);
            }
        }

        // Hide mic button if unsupported
        if (!SpeechRecognition) {
            // Button will show but show error on click (handled in startRecording)
        }

        // ─── Text-to-Speech with stop button ───
        var voiceAutoRead = document.getElementById('voiceAutoRead');
        var stopTtsBtn = document.getElementById('stopTtsBtn');
        var isSpeaking = false;

        var _ttsAudio = null;

        function leerEnVozAlta(texto) {
            if (!voiceAutoRead || !voiceAutoRead.checked) return;
            var clean = texto.replace(/\*\*/g, '').replace(/`/g, '').trim();
            if (!clean) return;
            var speakable = clean.length > 300 ? clean.substring(0, 297) + '...' : clean;

            isSpeaking = true;
            if (stopTtsBtn) stopTtsBtn.style.display = 'flex';

            fetch('/api/tts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ texto: speakable, voz: DALLIA_VOZ, estilo: DALLIA_ESTILO || undefined })
            }).then(function(r) {
                if (!r.ok) throw new Error('tts-http-' + r.status);
                return r.blob();
            }).then(function(blob) {
                var url = URL.createObjectURL(blob);
                _ttsAudio = new Audio(url);
                _ttsAudio.onended = function() {
                    URL.revokeObjectURL(url);
                    isSpeaking = false;
                    if (stopTtsBtn) stopTtsBtn.style.display = 'none';
                };
                _ttsAudio.onerror = function() {
                    URL.revokeObjectURL(url);
                    isSpeaking = false;
                    if (stopTtsBtn) stopTtsBtn.style.display = 'none';
                };
                _ttsAudio.play();
            }).catch(function() {
                // Fallback: browser Web Speech API
                if (!window.speechSynthesis) {
                    isSpeaking = false;
                    if (stopTtsBtn) stopTtsBtn.style.display = 'none';
                    return;
                }
                window.speechSynthesis.cancel();
                var utt = new SpeechSynthesisUtterance(speakable);
                utt.lang = 'es-PE';
                utt.rate = 1.1;
                utt.onend = function() {
                    isSpeaking = false;
                    if (stopTtsBtn) stopTtsBtn.style.display = 'none';
                };
                utt.onerror = function() {
                    isSpeaking = false;
                    if (stopTtsBtn) stopTtsBtn.style.display = 'none';
                };
                window.speechSynthesis.speak(utt);
            });
        }

        if (stopTtsBtn) {
            stopTtsBtn.addEventListener('click', function() {
                if (_ttsAudio) {
                    _ttsAudio.pause();
                    _ttsAudio = null;
                }
                if (window.speechSynthesis) window.speechSynthesis.cancel();
                isSpeaking = false;
                stopTtsBtn.style.display = 'none';
            });
        }

        // Initialize button state
        updateMainButton();
    })();

        // ── DallIA Action Card rendering ──────────────────────────────────────
        function escapeHtml(s) {
            return String(s || '').replace(/[&<>"']/g, function(c) {
                return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
            });
        }

        var ACTION_TITLES = {
            'enviar_pedido_proveedor': 'DalIA propone enviar pedidos',
            'vencimiento_ingredientes': 'Alerta de vencimiento — Almacén',
            'resumen_cierre_dia': 'Resumen del día',
            'recordatorio_cerrar_caja': 'Recordatorio de cierre de caja',
            'meta_alcanzada': '🌟 ¡Meta de ventas alcanzada!'
        };
        var ACTION_APPROVE_LABELS = {
            'enviar_pedido_proveedor': '<i class="bi bi-check-circle"></i> Aprobar y enviar',
            'vencimiento_ingredientes': '<i class="bi bi-check-circle"></i> Entendido',
            'resumen_cierre_dia': '<i class="bi bi-check-circle"></i> Aceptar resumen',
            'recordatorio_cerrar_caja': '<i class="bi bi-check-circle"></i> Voy a cerrar la caja',
            'meta_alcanzada': '<i class="bi bi-star-fill"></i> ¡Excelente! Registrar logro'
        };

        function renderActionCard(data) {
            var card = data.action_card;
            var draft = card.draft;
            var actionName = card.actionName || 'enviar_pedido_proveedor';
            var container = document.createElement('div');
            container.className = 'message dallia-message action-card';
            container.dataset.logId = card.logId;
            container.dataset.actionName = actionName;

            var title = ACTION_TITLES[actionName] || 'DalIA propone una acción';
            var html = '<div class="action-card-header"><i class="bi bi-robot"></i> <strong>' + escapeHtml(title) + '</strong></div>';

            if (data.respuesta) {
                html += '<p style="margin-bottom:10px;white-space:pre-wrap;">' + escapeHtml(data.respuesta) + '</p>';
            }

            // Generic text-based actions (vencimiento, resumen, caja reminder)
            if (draft.texto && actionName !== 'enviar_pedido_proveedor') {
                html += '<pre class="prov-message" style="max-height:300px;overflow-y:auto;">' + escapeHtml(draft.texto) + '</pre>';
            }

            // enviar_pedido_proveedor specific rendering
            if (actionName === 'enviar_pedido_proveedor' && Array.isArray(draft.messages)) {
                for (var i = 0; i < draft.messages.length; i++) {
                    var msg = draft.messages[i];
                    html += '<div class="action-card-proveedor">' +
                        '<div class="prov-header">' +
                            '<strong>' + escapeHtml(msg.proveedor_nombre) + '</strong>' +
                            '<span class="badge bg-secondary">' + msg.items.length + ' item(s)</span>' +
                        '</div>' +
                        '<pre class="prov-message">' + escapeHtml(msg.texto) + '</pre>' +
                    '</div>';
                }
                if (draft.sinProveedor && draft.sinProveedor.length > 0) {
                    html += '<div class="action-card-warning"><strong>Sin proveedor asignado:</strong><ul>';
                    for (var j = 0; j < draft.sinProveedor.length; j++) {
                        var it = draft.sinProveedor[j];
                        html += '<li>' + escapeHtml(it.nombre) + ' (' + escapeHtml(it.razon) + ')</li>';
                    }
                    html += '</ul></div>';
                }
            }

            var approveLabel = ACTION_APPROVE_LABELS[actionName] || '<i class="bi bi-check-circle"></i> Aprobar';
            html += '<div class="action-card-buttons">' +
                '<button class="btn btn-primary" onclick="approveAction(this)">' + approveLabel + '</button>' +
                '<button class="btn btn-outline-secondary" onclick="rejectAction(this)">Cancelar</button>' +
            '</div>' +
            '<div class="action-card-status"></div>';

            container.innerHTML = html;
            var chatMessages = document.querySelector('#chat-messages');
            if (chatMessages) {
                chatMessages.appendChild(container);
                container.scrollIntoView({ behavior: 'smooth' });
            }
        }

        async function approveAction(btn) {
            var card = btn.closest('.action-card');
            var logId = card.dataset.logId;
            var actionName = card.dataset.actionName || 'enviar_pedido_proveedor';
            var statusDiv = card.querySelector('.action-card-status');
            btn.disabled = true;
            statusDiv.textContent = 'Procesando…';
            try {
                var res = await fetch('/api/chat/action/' + logId + '/approve', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                var data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error desconocido');
                var result = data.result || {};
                var msg;
                if (result.acknowledged) {
                    msg = result.mensaje || '¡Entendido! Acción registrada.';
                } else if (Array.isArray(result.sent)) {
                    msg = 'Listo! Envié ' + result.sent.length + ' mensaje(s)';
                    if (result.failed && result.failed.length > 0) {
                        msg += '. Fallaron ' + result.failed.length + ': ' + result.failed.map(function(f){return f.proveedor_nombre;}).join(', ');
                    }
                } else {
                    msg = '¡Acción completada!';
                }
                statusDiv.textContent = msg;
                statusDiv.className = 'action-card-status success';
                card.querySelectorAll('.action-card-buttons button').forEach(function(b){b.remove();});
            } catch(err) {
                statusDiv.textContent = 'Error: ' + err.message;
                statusDiv.className = 'action-card-status error';
                btn.disabled = false;
            }
        }

        async function rejectAction(btn) {
            var card = btn.closest('.action-card');
            var logId = card.dataset.logId;
            var statusDiv = card.querySelector('.action-card-status');
            try {
                await fetch('/api/chat/action/' + logId + '/reject', { method: 'POST' });
                statusDiv.textContent = 'Cancelado.';
                card.querySelectorAll('.action-card-buttons button').forEach(function(b){b.remove();});
            } catch(err) {
                statusDiv.textContent = 'Error al cancelar: ' + err.message;
            }
        }
        // ─── Dynamic suggestions by time of day and URL context ─────────────
        (function initSuggestions() {
            var hora = new Date().getHours(); // local time
            var params = new URLSearchParams(window.location.search);
            var agent   = params.get('agent')   || '';
            var contexto = params.get('contexto') || '';

            // Time-of-day buckets (Lima time, close enough with local)
            var isManana  = hora >= 6  && hora < 12;
            var isTarde   = hora >= 12 && hora < 18;
            var isNoche   = hora >= 18 || hora < 6;

            // Base pools by time
            var sugerencias;
            if (agent === 'salva' && contexto === 'caja') {
                sugerencias = [
                    { icon: 'bi-cash-coin',    q: 'Cuánto efectivo hay en caja ahora?', label: 'Efectivo actual' },
                    { icon: 'bi-arrow-down-up', q: 'Resumen de movimientos de hoy',      label: 'Movimientos' },
                    { icon: 'bi-lock',          q: 'Debo cerrar la caja ahora?',          label: 'Cerrar caja?' },
                    { icon: 'bi-bell',          q: 'Hay alguna alerta de caja?',          label: 'Alertas caja' }
                ];
            } else if (isManana) {
                sugerencias = [
                    { icon: 'bi-sunrise',       q: 'Buenos días! Qué pasa si no abro la caja?', label: 'Abrir caja' },
                    { icon: 'bi-box-seam',      q: 'Revisa mi stock, qué me falta comprar hoy?', label: 'Stock del día' },
                    { icon: 'bi-calendar-check', q: 'Cuál es el plan operativo para hoy?',       label: 'Plan del día' },
                    { icon: 'bi-graph-up',       q: 'Como van las ventas de hoy?',               label: 'Ventas hoy' }
                ];
            } else if (isTarde) {
                sugerencias = [
                    { icon: 'bi-graph-up',      q: 'Como van las ventas de hoy?',               label: 'Ventas hoy' },
                    { icon: 'bi-trophy',        q: 'Cuales son los productos mas vendidos?',     label: 'Más vendidos' },
                    { icon: 'bi-people',        q: 'Cuántas mesas activas hay ahora?',           label: 'Mesas activas' },
                    { icon: 'bi-clock-history', q: 'Cual es el tiempo promedio de cocina hoy?', label: 'Tiempo cocina' }
                ];
            } else {
                // Noche
                sugerencias = [
                    { icon: 'bi-bar-chart',     q: 'Resumen de ventas de hoy vs ayer',          label: 'Resumen del día' },
                    { icon: 'bi-cash-stack',    q: 'Debo cerrar la caja ahora?',                label: 'Cerrar caja' },
                    { icon: 'bi-box-seam',      q: 'Hay insumos próximos a vencerse?',          label: 'Vencimientos' },
                    { icon: 'bi-star',          q: 'Cuál fue el plato más vendido hoy?',        label: 'Estrella del día' }
                ];
            }

            var container = document.getElementById('chatSuggestions');
            if (!container) return;
            container.innerHTML = sugerencias.map(function(s) {
                return '<a class="chat-suggestion" data-q="' + s.q.replace(/"/g, '&quot;') + '">' +
                    '<i class="bi ' + s.icon + ' me-1"></i>' + s.label + '</a>';
            }).join('');

            // Attach click handlers to the newly created elements
            container.querySelectorAll('.chat-suggestion').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    var q = this.getAttribute('data-q');
                    if (q) sendMessage(q);
                });
            });
        })();
        // ─────────────────────────────────────────────────────────────────────
    </script>
