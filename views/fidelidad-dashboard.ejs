<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Fidelidad Dashboard · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--orange:#ef520f;--orange2:#df2c05;--dark:#0a0f24;--bg:#F0F2F8;--card:#fff;--text2:#8B8FAD;--verde:#22C55E;--safe-bot:env(safe-area-inset-bottom,0px);}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100dvh;max-width:480px;margin:0 auto;padding-bottom:calc(80px + var(--safe-bot));}
    .header{background:linear-gradient(170deg,#10152f 0%,#0a0f24 50%,#090d1d 100%);padding:52px 20px 20px;border-radius:0 0 20px 20px;color:#fff;display:flex;align-items:center;gap:12px;}
    .btn-back{background:rgba(255,255,255,.12);border:none;color:#fff;width:36px;height:36px;border-radius:10px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
    .header-title{font-size:18px;font-weight:700;}
    .stats-row{display:flex;gap:10px;padding:16px 16px 0;}
    .stat-chip{flex:1;background:var(--card);border-radius:12px;padding:10px 12px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.05);}
    .stat-num{font-size:22px;font-weight:800;}
    .stat-lbl{font-size:11px;color:var(--text2);margin-top:1px;}
    .num-d{color:var(--dark);} .num-v{color:var(--verde);} .num-o{color:var(--orange);}
    .retencion-chip{margin:12px 16px 0;background:var(--card);border-radius:12px;padding:12px 16px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 8px rgba(0,0,0,.05);}
    .ret-label{font-size:13px;color:var(--text2);}
    .ret-val{font-size:20px;font-weight:800;color:var(--verde);}
    .section-label{font-size:13px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;padding:20px 16px 10px;}
    .cliente-card{background:var(--card);margin:0 16px 10px;border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 8px rgba(0,0,0,.05);}
    .rank-num{font-size:16px;font-weight:800;color:var(--text2);width:20px;text-align:center;flex-shrink:0;}
    .rank-1{color:var(--orange);}
    .cli-avatar{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--orange),var(--orange2));display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;font-weight:700;flex-shrink:0;}
    .cli-info{flex:1;min-width:0;}
    .cli-nombre{font-size:14px;font-weight:600;color:var(--dark);}
    .cli-sub{font-size:12px;color:var(--text2);margin-top:2px;}
    .cli-right{text-align:right;flex-shrink:0;}
    .cli-pts{font-size:14px;font-weight:700;color:var(--dark);}
    .canje-badge{font-size:10px;font-weight:700;background:#FFF3E0;color:var(--orange);padding:2px 6px;border-radius:6px;margin-top:2px;display:inline-block;}
    .config-link{display:flex;align-items:center;justify-content:center;gap:6px;margin:8px 16px 0;font-size:13px;color:var(--text2);text-decoration:none;padding:10px;}
    .bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:#fff;border-top:1px solid #E8EAF2;display:flex;padding-bottom:var(--safe-bot);z-index:100;}
    .nav-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 4px 8px;text-decoration:none;color:var(--text2);font-size:10px;font-weight:500;}
    .nav-item .icon{font-size:22px;margin-bottom:2px;}
    .nav-item.active{color:var(--orange);}
  </style>
</head>
<body>
  <div class="header">
    <button class="btn-back" onclick="history.back()">‹</button>
    <span class="header-title">Fidelidad · Dashboard</span>
  </div>

  <div class="stats-row">
    <div class="stat-chip"><div class="stat-num num-d"><%= registrados %></div><div class="stat-lbl">Registrados</div></div>
    <div class="stat-chip"><div class="stat-num num-v"><%= activos %></div><div class="stat-lbl">Activos</div></div>
    <div class="stat-chip"><div class="stat-num num-o"><%= canjeados.toLocaleString() %></div><div class="stat-lbl">Canjeados</div></div>
  </div>

  <div class="retencion-chip">
    <span class="ret-label">Retención 90 días</span>
    <span class="ret-val"><%= retencion %>% ↗</span>
  </div>

  <div class="section-label">Top clientes</div>

  <% if (clientes.length === 0) { %>
  <div style="text-align:center;padding:32px 24px;color:#8B8FAD;font-size:14px;">Sin clientes registrados aún.</div>
  <% } %>

  <% clientes.forEach(function(c) { %>
  <div class="cliente-card">
    <div class="rank-num <%= c.rank===1?'rank-1':'' %>"><%= c.rank %></div>
    <div class="cli-avatar"><%= c.iniciales %></div>
    <div class="cli-info">
      <div class="cli-nombre"><%= c.nombre %></div>
      <div class="cli-sub"><%= c.puntos %> pts · <%= c.visitas %> visitas</div>
    </div>
    <div class="cli-right">
      <div class="cli-pts"><%= c.puntos %> pts</div>
      <% if(c.cercaCanje){%><span class="canje-badge">Cerca del canje</span><% } %>
    </div>
  </div>
  <% }); %>

  <a href="/sprint4/fidelidad/config" class="config-link">⚙ Configurar reglas de puntos</a>

  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="icon">🏠</span>Inicio</a>
    <a href="/pedidos" class="nav-item"><span class="icon">🧾</span>Pedidos</a>
    <a href="/cocina-display" class="nav-item"><span class="icon">👨‍🍳</span>Cocina</a>
    <a href="/caja" class="nav-item"><span class="icon">💰</span>Caja</a>
    <a href="/mas" class="nav-item active"><span class="icon">☰</span>Más</a>
  </nav>
  <script src="/js/dallia-fab.js"></script>
</body>
</html>
