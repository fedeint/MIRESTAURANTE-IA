<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1e1b4b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dignita">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
    <title>Mis Redes Sociales - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-share-fill me-2" style="color:var(--dg-primary);"></i>Mis Redes Sociales</h4>
                <p class="text-muted small mb-0">Conecta tus redes via API y ve seguidores, likes y publicaciones reales</p>
            </div>
        </div>

        <div class="alert alert-info small mb-4">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Configuracion necesaria en <code>.env</code>:</strong>
            <ul class="mb-0 mt-1">
                <li><strong>Facebook:</strong> <code>META_APP_ID</code> + <code>META_APP_SECRET</code> &rarr; <a href="https://developers.facebook.com/apps/" target="_blank">developers.facebook.com</a></li>
                <li><strong>Instagram:</strong> Ademas <code>META_USER_TOKEN</code> (cuenta Business vinculada)</li>
                <li><strong>TikTok:</strong> <code>TIKTOK_ACCESS_TOKEN</code> &rarr; <a href="https://developers.tiktok.com/" target="_blank">developers.tiktok.com</a></li>
            </ul>
        </div>

        <!-- Mis Paginas de Facebook (automatico) -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:52px;height:52px;background:linear-gradient(135deg,#1877f2,#0d65d9);border-radius:1rem;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.5rem;flex-shrink:0;"><i class="bi bi-facebook"></i></div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-0">Mis Paginas de Facebook</h5>
                        <small class="text-muted">Tus paginas conectadas automaticamente via API</small>
                    </div>
                    <button class="btn btn-sm btn-primary" id="fbLoadPages"><i class="bi bi-arrow-clockwise me-1"></i>Cargar mis paginas</button>
                </div>
                <div id="fbPagesResult"></div>
            </div>
        </div>

        <!-- Instagram -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:52px;height:52px;background:linear-gradient(135deg,#e1306c,#c13584,#833ab4);border-radius:1rem;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.5rem;flex-shrink:0;"><i class="bi bi-instagram"></i></div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-0">Instagram</h5>
                        <small class="text-muted">Username de cuenta Business</small>
                    </div>
                    <span class="badge" id="ig-status" style="background:rgba(100,116,139,0.1);color:#64748b;">Sin conectar</span>
                </div>
                <div class="row g-2 align-items-end">
                    <div class="col"><div class="input-group"><span class="input-group-text">@</span><input type="text" class="form-control" id="igUsername" placeholder="tu_restaurante"></div></div>
                    <div class="col-auto"><button class="btn btn-primary" id="igConnect"><i class="bi bi-plug-fill me-1"></i>Conectar</button></div>
                </div>
                <div id="igResult" class="mt-3" style="display:none;"></div>
            </div>
        </div>

        <!-- TikTok -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:52px;height:52px;background:linear-gradient(135deg,#010101,#25f4ee);border-radius:1rem;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.5rem;flex-shrink:0;"><i class="bi bi-tiktok"></i></div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-0">TikTok</h5>
                        <small class="text-muted">Username de tu cuenta</small>
                    </div>
                    <span class="badge" id="tt-status" style="background:rgba(100,116,139,0.1);color:#64748b;">Sin conectar</span>
                </div>
                <div class="row g-2 align-items-end">
                    <div class="col"><div class="input-group"><span class="input-group-text">@</span><input type="text" class="form-control" id="ttUsername" placeholder="tu_restaurante"></div></div>
                    <div class="col-auto"><button class="btn btn-primary" id="ttConnect"><i class="bi bi-plug-fill me-1"></i>Conectar</button></div>
                </div>
                <div id="ttResult" class="mt-3" style="display:none;"></div>
            </div>
        </div>
    </div>
    </main>
    <%- include('partials/footer') %>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
    (function(){
        function fmt(n){ n=Number(n)||0; if(n>=1e6) return (n/1e6).toFixed(1)+'M'; if(n>=1e3) return (n/1e3).toFixed(1)+'K'; return n.toLocaleString(); }

        function setStatus(id,ok,t){ var e=document.getElementById(id); if(!e)return; e.textContent=t||(ok?'Conectado':'Error'); e.style.background=ok?'rgba(16,185,129,0.1)':'rgba(239,68,68,0.1)'; e.style.color=ok?'#059669':'#dc2626'; }

        function renderData(cid, d){
            var el=document.getElementById(cid); el.style.display='block';
            var h='<div class="d-flex align-items-center gap-3 mb-3">';
            if(d.foto) h+='<img src="'+d.foto+'" style="width:56px;height:56px;border-radius:1rem;object-fit:cover;">';
            h+='<div><h6 class="fw-bold mb-0">'+(d.nombre||'')+'</h6>';
            if(d.bio||d.descripcion) h+='<small class="text-muted">'+(d.bio||d.descripcion||'').substring(0,120)+'</small>';
            h+='</div></div>';
            h+='<div class="row g-3 text-center">';
            h+='<div class="col"><div style="font-size:1.8rem;font-weight:900;color:#6366f1;">'+fmt(d.seguidores)+'</div><small class="text-muted fw-bold">Seguidores</small></div>';
            if(d.likes!==undefined) h+='<div class="col"><div style="font-size:1.8rem;font-weight:900;color:#ef4444;">'+fmt(d.likes)+'</div><small class="text-muted fw-bold">Likes</small></div>';
            if(d.publicaciones!==undefined) h+='<div class="col"><div style="font-size:1.8rem;font-weight:900;color:#10b981;">'+fmt(d.publicaciones)+'</div><small class="text-muted fw-bold">Posts</small></div>';
            if(d.videos!==undefined) h+='<div class="col"><div style="font-size:1.8rem;font-weight:900;color:#10b981;">'+fmt(d.videos)+'</div><small class="text-muted fw-bold">Videos</small></div>';
            if(d.siguiendo!==undefined) h+='<div class="col"><div style="font-size:1.8rem;font-weight:900;color:#06b6d4;">'+fmt(d.siguiendo)+'</div><small class="text-muted fw-bold">Siguiendo</small></div>';
            h+='</div>';
            if(d.ultimos_posts&&d.ultimos_posts.length){
                h+='<hr style="border-color:rgba(0,0,0,0.04);"><h6 class="fw-bold small"><i class="bi bi-clock-history me-1"></i>Ultimas 3 publicaciones</h6>';
                d.ultimos_posts.forEach(function(p){
                    h+='<div class="d-flex align-items-center gap-2 py-2 border-bottom" style="border-color:rgba(0,0,0,0.04)!important;">';
                    if(p.imagen) h+='<img src="'+p.imagen+'" style="width:44px;height:44px;border-radius:.5rem;object-fit:cover;">';
                    h+='<div class="flex-grow-1 small">'+(p.caption||'Sin descripcion')+'</div>';
                    h+='<span class="small" style="color:#ef4444;"><i class="bi bi-heart-fill"></i> '+fmt(p.likes)+'</span>';
                    h+='<span class="small text-muted"><i class="bi bi-chat-fill"></i> '+fmt(p.comments)+'</span>';
                    h+='</div>';
                });
            }
            el.innerHTML=h;
        }

        function renderErr(cid,msg){ var el=document.getElementById(cid); el.style.display='block'; el.innerHTML='<div class="alert alert-danger small mb-0"><i class="bi bi-exclamation-triangle me-1"></i>'+msg+'</div>'; }

        async function connect(btn,endpoint,resultId,statusId,storageKey){
            btn.disabled=true; var old=btn.innerHTML; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Conectando...';
            try{
                var r=await fetch(endpoint); var d=await r.json();
                if(!r.ok) throw new Error(d.error||d.help||'Error');
                setStatus(statusId,true); renderData(resultId,d);
            }catch(e){ setStatus(statusId,false); renderErr(resultId,e.message); }
            btn.disabled=false; btn.innerHTML=old;
        }

        // Load my Facebook pages
        document.getElementById('fbLoadPages').addEventListener('click', async function(){
            var btn=this;var old=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Cargando...';
            try{
                var r=await fetch('/api/social/mis-paginas');var d=await r.json();
                if(!r.ok)throw new Error(d.error||'Error');
                var el=document.getElementById('fbPagesResult');
                if(!d.paginas||d.paginas.length===0){el.innerHTML='<div class="alert alert-info small mb-0">No tienes paginas de Facebook</div>';return;}
                var h='<div class="row g-3">';
                d.paginas.forEach(function(p){
                    h+='<div class="col-md-6 col-lg-4"><div class="d-flex align-items-center gap-2 p-2 rounded" style="background:rgba(24,119,242,0.04);border:1px solid rgba(24,119,242,0.1);border-radius:.75rem!important;">';
                    if(p.foto) h+='<img src="'+p.foto+'" style="width:40px;height:40px;border-radius:.5rem;object-fit:cover;">';
                    h+='<div class="flex-grow-1 small"><strong>'+p.nombre+'</strong><br><span class="text-muted">'+p.categoria+'</span></div>';
                    h+='<div class="text-end"><div style="font-weight:800;color:#1877f2;">'+fmt(p.seguidores)+'</div><div class="text-muted" style="font-size:.65rem;">seguidores</div></div>';
                    h+='</div></div>';
                });
                h+='</div>';
                el.innerHTML=h;
            }catch(e){document.getElementById('fbPagesResult').innerHTML='<div class="alert alert-danger small mb-0">'+e.message+'</div>';}
            btn.disabled=false;btn.innerHTML=old;
        });
        document.getElementById('igConnect').addEventListener('click',function(){ var v=document.getElementById('igUsername').value.trim().replace('@',''); if(v){ localStorage.setItem('dg-ig-user',v); connect(this,'/api/social/instagram/'+encodeURIComponent(v),'igResult','ig-status','dg-ig-user'); }});
        document.getElementById('ttConnect').addEventListener('click',function(){ var v=document.getElementById('ttUsername').value.trim().replace('@',''); if(v){ localStorage.setItem('dg-tt-user',v); connect(this,'/api/social/tiktok/'+encodeURIComponent(v),'ttResult','tt-status','dg-tt-user'); }});

        // Restore
        var s; if(s=localStorage.getItem('dg-fb-page')) document.getElementById('fbPageId').value=s;
        if(s=localStorage.getItem('dg-ig-user')) document.getElementById('igUsername').value=s;
        if(s=localStorage.getItem('dg-tt-user')) document.getElementById('ttUsername').value=s;
    })();
    </script>
</body>
</html>
