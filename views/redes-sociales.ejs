<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Redes Sociales - dignita.tech</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-share-fill me-2" style="color:var(--dg-primary);"></i>Mis Redes Sociales</h4>
                <p class="text-muted small mb-0">Monitorea tus metricas: seguidores, likes y ultimas publicaciones</p>
            </div>
            <button class="btn btn-primary" id="btnGuardar"><i class="bi bi-save me-1"></i>Guardar todo</button>
        </div>

        <div id="networkList"></div>
    </div>
    </main>
    <%- include('partials/footer') %>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
    (function(){
        var KEY = 'dg-mis-redes';
        var networks = [
            { id:'instagram', name:'Instagram', icon:'bi-instagram', gradient:'linear-gradient(135deg,#e1306c,#833ab4)', placeholder:'@tu_restaurante' },
            { id:'facebook', name:'Facebook', icon:'bi-facebook', gradient:'linear-gradient(135deg,#1877f2,#0d65d9)', placeholder:'facebook.com/tu-pagina' },
            { id:'tiktok', name:'TikTok', icon:'bi-tiktok', gradient:'linear-gradient(135deg,#010101,#25f4ee)', placeholder:'@tu_tiktok' },
            { id:'youtube', name:'YouTube', icon:'bi-youtube', gradient:'linear-gradient(135deg,#ff0000,#cc0000)', placeholder:'youtube.com/@tu-canal' },
            { id:'whatsapp', name:'WhatsApp', icon:'bi-whatsapp', gradient:'linear-gradient(135deg,#25d366,#128c7e)', placeholder:'+51 999 999 999' },
            { id:'googlemaps', name:'Google Maps', icon:'bi-geo-alt-fill', gradient:'linear-gradient(135deg,#4285f4,#34a853)', placeholder:'Link de Google Maps' }
        ];

        var saved = {};
        try { saved = JSON.parse(localStorage.getItem(KEY)) || {}; } catch(e){}

        var container = document.getElementById('networkList');

        networks.forEach(function(net){
            var data = saved[net.id] || { url:'', seguidores:'', likes:'', posts:['','',''] };
            var card = document.createElement('div');
            card.className = 'card mb-3';
            card.innerHTML = `
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div style="width:48px;height:48px;background:${net.gradient};border-radius:.875rem;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.3rem;flex-shrink:0;"><i class="bi ${net.icon}"></i></div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-0">${net.name}</h6>
                            <input type="text" class="form-control form-control-sm mt-1" data-net="${net.id}" data-field="url" value="${data.url||''}" placeholder="${net.placeholder}">
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-3">
                            <label class="form-label small fw-bold"><i class="bi bi-people-fill me-1"></i>Seguidores</label>
                            <input type="text" class="form-control" data-net="${net.id}" data-field="seguidores" value="${data.seguidores||''}" placeholder="Ej: 1,250">
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label small fw-bold"><i class="bi bi-heart-fill me-1"></i>Likes promedio</label>
                            <input type="text" class="form-control" data-net="${net.id}" data-field="likes" value="${data.likes||''}" placeholder="Ej: 85">
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-bold"><i class="bi bi-clock-history me-1"></i>Ultimas 3 publicaciones</label>
                            <input type="text" class="form-control mb-1" data-net="${net.id}" data-field="post0" value="${(data.posts&&data.posts[0])||''}" placeholder="1ra publicacion (descripcion breve)">
                            <input type="text" class="form-control mb-1" data-net="${net.id}" data-field="post1" value="${(data.posts&&data.posts[1])||''}" placeholder="2da publicacion">
                            <input type="text" class="form-control" data-net="${net.id}" data-field="post2" value="${(data.posts&&data.posts[2])||''}" placeholder="3ra publicacion">
                        </div>
                    </div>
                </div>
            `;
            container.appendChild(card);
        });

        document.getElementById('btnGuardar').addEventListener('click', function(){
            var data = {};
            networks.forEach(function(net){
                var url = (document.querySelector('[data-net="'+net.id+'"][data-field="url"]')||{}).value||'';
                var seguidores = (document.querySelector('[data-net="'+net.id+'"][data-field="seguidores"]')||{}).value||'';
                var likes = (document.querySelector('[data-net="'+net.id+'"][data-field="likes"]')||{}).value||'';
                var p0 = (document.querySelector('[data-net="'+net.id+'"][data-field="post0"]')||{}).value||'';
                var p1 = (document.querySelector('[data-net="'+net.id+'"][data-field="post1"]')||{}).value||'';
                var p2 = (document.querySelector('[data-net="'+net.id+'"][data-field="post2"]')||{}).value||'';
                data[net.id] = { url:url.trim(), seguidores:seguidores.trim(), likes:likes.trim(), posts:[p0.trim(),p1.trim(),p2.trim()] };
            });
            localStorage.setItem(KEY, JSON.stringify(data));
            Swal.fire({icon:'success',title:'Guardado',text:'Metricas de redes actualizadas',timer:2000,showConfirmButton:false});
        });
    })();
    </script>
</body>
</html>