<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1e1b4b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dignita">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <title>Backups - mirestconia.com</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    .backup-card {
      background: var(--dg-surface, #1e1e2e);
      border: 1px solid var(--dg-surface-border, rgba(255,255,255,0.07));
      border-radius: 12px;
      transition: border-color 0.2s;
    }
    .backup-card:hover { border-color: var(--dg-primary, #FF6B35); }

    .badge-manual   { background: rgba(99,102,241,0.15); color: #818cf8; }
    .badge-auto     { background: rgba(34,197,94,0.12);  color: #4ade80; }
    .badge-pre      { background: rgba(245,158,11,0.12); color: #fbbf24; }
    .badge-estado   { background: rgba(16,185,129,0.12); color: #34d399; font-size: 0.72rem; }
    .badge-error    { background: rgba(239,68,68,0.12);  color: #f87171; }

    .stat-box {
      background: var(--dg-surface, #1e1e2e);
      border: 1px solid var(--dg-surface-border, rgba(255,255,255,0.07));
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
    }
    .stat-box .stat-value { font-size: 1.6rem; font-weight: 700; color: var(--dg-text, #e2e8f0); }
    .stat-box .stat-label { font-size: 0.8rem; color: var(--dg-text-muted, #94a3b8); margin-top: 2px; }
    .stat-box .stat-icon  { font-size: 1.5rem; opacity: 0.7; }

    .backup-row { font-size: 0.9rem; }
    .backup-row td { vertical-align: middle; padding: 0.85rem 1rem; }

    .size-pill {
      background: rgba(99,102,241,0.08);
      border-radius: 6px;
      padding: 2px 8px;
      font-size: 0.78rem;
      color: #818cf8;
      font-variant-numeric: tabular-nums;
    }

    .btn-create {
      background: linear-gradient(135deg, #FF6B35, #E55A2B);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 0.55rem 1.4rem;
      font-weight: 600;
      transition: opacity 0.2s;
    }
    .btn-create:hover { opacity: 0.88; color: #fff; }
    .btn-create:disabled { opacity: 0.5; }

    .btn-download {
      background: rgba(99,102,241,0.1);
      border: 1px solid rgba(99,102,241,0.2);
      color: #818cf8;
      border-radius: 8px;
      padding: 4px 12px;
      font-size: 0.82rem;
      transition: background 0.2s;
    }
    .btn-download:hover { background: rgba(99,102,241,0.18); color: #818cf8; }

    .btn-restore {
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.2);
      color: #fbbf24;
      border-radius: 8px;
      padding: 4px 12px;
      font-size: 0.82rem;
      transition: background 0.2s;
    }
    .btn-restore:hover { background: rgba(245,158,11,0.18); color: #fbbf24; }

    #spinnerCreate { display: none; }
  </style>
</head>
<body>
  <%- include('partials/sidebar') %>
  <div class="dg-main">
  <main class="flex-grow-1">
  <div class="container py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <div>
        <h4 class="mb-0 fw-bold" style="color:var(--dg-text,#e2e8f0);">
          <i class="bi bi-archive-fill me-2" style="color:#FF6B35;"></i>Backups del Sistema
        </h4>
        <p class="text-muted mb-0 mt-1" style="font-size:0.88rem;">
          Exporta y gestiona copias de seguridad de tus datos en formato JSON.
        </p>
      </div>
      <button class="btn btn-create" id="btnCreate" onclick="crearBackup()">
        <span id="spinnerCreate" class="spinner-border spinner-border-sm me-1"></span>
        <i class="bi bi-plus-lg me-1"></i>Crear Backup Ahora
      </button>
    </div>

    <!-- Stats -->
    <% const total = backups.length; %>
    <% const totalMB = backups.reduce((s, b) => s + Number(b.tamano_bytes || 0), 0) / 1024 / 1024; %>
    <% const totalRows = backups.reduce((s, b) => s + Number(b.registros_total || 0), 0); %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-box">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <div class="stat-value"><%= total %></div>
              <div class="stat-label">Backups totales</div>
            </div>
            <i class="bi bi-archive stat-icon" style="color:#6366f1;"></i>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-box">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <div class="stat-value"><%= totalMB.toFixed(2) %> MB</div>
              <div class="stat-label">Almacenamiento total</div>
            </div>
            <i class="bi bi-hdd stat-icon" style="color:#FF6B35;"></i>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-box">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <div class="stat-value"><%= totalRows.toLocaleString('es-PE') %></div>
              <div class="stat-label">Registros respaldados</div>
            </div>
            <i class="bi bi-table stat-icon" style="color:#22c55e;"></i>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-box">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <div class="stat-value">
                <% if (backups.length > 0) { %>
                  <%= new Date(backups[0].created_at).toLocaleDateString('es-PE') %>
                <% } else { %>
                  —
                <% } %>
              </div>
              <div class="stat-label">Ultimo backup</div>
            </div>
            <i class="bi bi-clock-history stat-icon" style="color:#06b6d4;"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla de backups -->
    <div class="backup-card">
      <div class="p-3 border-bottom d-flex align-items-center gap-2" style="border-color:var(--dg-surface-border,rgba(255,255,255,0.07)) !important;">
        <i class="bi bi-list-ul" style="color:#FF6B35;"></i>
        <span class="fw-semibold" style="color:var(--dg-text,#e2e8f0);">Historial de Backups</span>
        <span class="ms-auto text-muted" style="font-size:0.82rem;">Mostrando los ultimos <%= backups.length %> registros</span>
      </div>

      <% if (backups.length === 0) { %>
        <div class="text-center py-5" style="color:var(--dg-text-muted,#94a3b8);">
          <i class="bi bi-archive" style="font-size:3rem; opacity:0.3;"></i>
          <p class="mt-3 mb-1 fw-semibold">Sin backups todavia</p>
          <p style="font-size:0.85rem;">Crea tu primer backup con el boton de arriba.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr style="font-size:0.78rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--dg-text-muted,#94a3b8);">
                <th class="ps-4">ID</th>
                <% if (isSuperadmin) { %><th>Tenant</th><% } %>
                <th>Tipo</th>
                <th>Descripcion</th>
                <th class="text-end">Registros</th>
                <th class="text-end">Tamano</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Creado por</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% backups.forEach(function(b) { %>
                <% const mb = (Number(b.tamano_bytes || 0) / 1024 / 1024).toFixed(2); %>
                <% const kb = (Number(b.tamano_bytes || 0) / 1024).toFixed(1); %>
                <% const sizeLabel = Number(b.tamano_bytes) > 1024*1024 ? mb + ' MB' : kb + ' KB'; %>
                <tr class="backup-row">
                  <td class="ps-4 text-muted" style="font-size:0.8rem;">#<%= b.id %></td>
                  <% if (isSuperadmin) { %>
                    <td><span style="font-size:0.82rem; color:var(--dg-text,#e2e8f0);"><%= b.tenant_nombre || ('Tenant ' + b.tenant_id) %></span></td>
                  <% } %>
                  <td>
                    <% if (b.tipo === 'manual') { %>
                      <span class="badge badge-manual rounded-pill px-2"><i class="bi bi-hand-index me-1"></i>Manual</span>
                    <% } else if (b.tipo === 'automatico') { %>
                      <span class="badge badge-auto rounded-pill px-2"><i class="bi bi-clock me-1"></i>Auto</span>
                    <% } else { %>
                      <span class="badge badge-pre rounded-pill px-2"><i class="bi bi-arrow-counterclockwise me-1"></i>Pre-restore</span>
                    <% } %>
                  </td>
                  <td style="max-width:220px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--dg-text,#e2e8f0);">
                    <%= b.descripcion || '—' %>
                  </td>
                  <td class="text-end">
                    <span style="color:var(--dg-text,#e2e8f0); font-variant-numeric:tabular-nums;">
                      <%= Number(b.registros_total || 0).toLocaleString('es-PE') %>
                    </span>
                  </td>
                  <td class="text-end">
                    <span class="size-pill"><%= sizeLabel %></span>
                  </td>
                  <td>
                    <% if (b.estado === 'completado') { %>
                      <span class="badge badge-estado rounded-pill px-2"><i class="bi bi-check-circle me-1"></i>Completado</span>
                    <% } else { %>
                      <span class="badge badge-error rounded-pill px-2"><i class="bi bi-x-circle me-1"></i><%= b.estado %></span>
                    <% } %>
                  </td>
                  <td style="font-size:0.82rem; white-space:nowrap; color:var(--dg-text-muted,#94a3b8);">
                    <%= new Date(b.created_at).toLocaleString('es-PE', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                  </td>
                  <td style="font-size:0.82rem; color:var(--dg-text-muted,#94a3b8);">
                    <%= b.creado_por_nombre || '—' %>
                  </td>
                  <td>
                    <div class="d-flex gap-2">
                      <a href="/api/backups/<%= b.id %>/download"
                         class="btn btn-download"
                         title="Descargar JSON">
                        <i class="bi bi-download me-1"></i>JSON
                      </a>
                      <% if (isSuperadmin) { %>
                        <button class="btn btn-restore"
                                onclick="restaurarBackup(<%= b.id %>, '<%= (b.tenant_nombre || 'Tenant ' + b.tenant_id).replace(/'/g, '') %>')"
                                title="Restaurar">
                          <i class="bi bi-arrow-counterclockwise me-1"></i>Restaurar
                        </button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Info panel -->
    <div class="mt-4 p-3 rounded-3" style="background:rgba(99,102,241,0.06); border:1px solid rgba(99,102,241,0.12);">
      <div class="d-flex gap-2 align-items-start">
        <i class="bi bi-info-circle-fill mt-1" style="color:#6366f1; flex-shrink:0;"></i>
        <div style="font-size:0.85rem; color:var(--dg-text-muted,#94a3b8); line-height:1.6;">
          <strong style="color:var(--dg-text,#e2e8f0);">Que incluye el backup:</strong>
          Productos, mesas, clientes, configuracion, usuarios (sin contrasenas), recetas, almacen,
          facturas y detalles (ultimos 30 dias), pedidos (ultimos 7 dias).
          El archivo JSON puede importarse manualmente si es necesario.
        </div>
      </div>
    </div>

  </div>
  </main>
  </div>

  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>

  <script>
    async function crearBackup() {
      const btn = document.getElementById('btnCreate');
      const spinner = document.getElementById('spinnerCreate');

      btn.disabled = true;
      spinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/backups/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Error creando backup');

        await Swal.fire({
          icon: 'success',
          title: 'Backup creado',
          text: 'El backup se creo exitosamente. La pagina se recargara.',
          confirmButtonColor: '#FF6B35',
          timer: 2000,
          timerProgressBar: true,
        });
        location.reload();
      } catch (e) {
        Swal.fire({ icon: 'error', title: 'Error', text: e.message, confirmButtonColor: '#EF4444' });
        btn.disabled = false;
        spinner.style.display = 'none';
      }
    }

    async function restaurarBackup(id, tenantNombre) {
      const confirm = await Swal.fire({
        icon: 'warning',
        title: 'Restaurar Backup #' + id,
        html: `<p>Esta accion restaurara datos del backup para <strong>${tenantNombre}</strong>.</p>
               <p class="text-warning mb-0">Se creara un backup previo automaticamente.</p>`,
        showCancelButton: true,
        confirmButtonText: 'Si, restaurar',
        cancelButtonText: 'Cancelar',
        confirmButtonColor: '#F59E0B',
        cancelButtonColor: '#6B7280',
      });

      if (!confirm.isConfirmed) return;

      try {
        const res = await fetch('/api/backups/restore/' + id, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error restaurando backup');

        await Swal.fire({
          icon: 'success',
          title: 'Restauracion completada',
          text: data.stats?.nota || 'Proceso finalizado.',
          confirmButtonColor: '#FF6B35',
        });
        location.reload();
      } catch (e) {
        Swal.fire({ icon: 'error', title: 'Error', text: e.message, confirmButtonColor: '#EF4444' });
      }
    }
  </script>
</body>
</html>
