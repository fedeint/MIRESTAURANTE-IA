<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>P&L - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
    <style>
        .pl-row { border-bottom: 1px solid rgba(255,255,255,0.05); }
        .pl-row:hover { background: rgba(255,255,255,0.03); }
        .pl-label { font-weight: 500; }
        .pl-amount { text-align: right; font-family: 'Courier New', monospace; font-weight: 600; }
        .pl-positive { color: #22c55e; }
        .pl-negative { color: #ef4444; }
        .pl-subtotal { background: rgba(255,255,255,0.05); font-weight: 700; }
        .pl-prefix { color: #6b7280; font-weight: 400; width: 30px; display: inline-block; }
        .pl-indent { padding-left: 2.5rem !important; }

        /* KPI Cards */
        .kpi-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 1.25rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .kpi-card:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }
        .kpi-value { font-size: 1.6rem; font-weight: 700; font-family: 'Courier New', monospace; }
        .kpi-label { font-size: 0.78rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; }
        .kpi-badge { font-size: 0.72rem; }

        /* Historial */
        .historial-card { background: rgba(255,255,255,0.03); border-radius: 8px; }
        .historial-badge-pos { background: rgba(34,197,94,0.15); color: #22c55e; border-radius: 6px; padding: 2px 8px; font-size: 0.8rem; }
        .historial-badge-neg { background: rgba(239,68,68,0.15); color: #ef4444; border-radius: 6px; padding: 2px 8px; font-size: 0.8rem; }
        .month-bar { height: 6px; border-radius: 3px; background: #374151; overflow: hidden; }
        .month-bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }

        /* Nav tabs */
        .admin-nav { border-bottom: 2px solid rgba(255,255,255,0.08); margin-bottom: 1.5rem; }
        .admin-nav .nav-link { color: #9ca3af; border: none; padding: 0.6rem 1.2rem; }
        .admin-nav .nav-link:hover { color: #FF6B35; background: rgba(255,107,53,0.05); border-radius: 8px 8px 0 0; }
        .admin-nav .nav-link.active { color: #FF6B35; font-weight: 600; border-bottom: 2px solid #FF6B35; margin-bottom: -2px; }
    </style>
</head>
<body>
    <%- include('../partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-3 mt-3 flex-wrap gap-2">
            <div class="d-flex align-items-center">
                <i class="bi bi-bar-chart-line fs-2 me-2"></i>
                <div>
                    <h2 class="mb-0">Administración</h2>
                    <small class="text-muted">P&L · Estado de Resultados</small>
                </div>
            </div>
            <form method="GET" class="d-flex align-items-center gap-2">
                <% const meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre']; %>
                <select name="mes" class="form-select form-select-sm" style="width:auto;">
                    <% for (let i = 1; i <= 12; i++) { %>
                        <option value="<%= i %>" <%= (typeof mes !== 'undefined' && mes == i) ? 'selected' : '' %>><%= meses[i-1] %></option>
                    <% } %>
                </select>
                <select name="anio" class="form-select form-select-sm" style="width:auto;">
                    <% const anioActual = new Date().getFullYear(); %>
                    <% for (let a = anioActual - 2; a <= anioActual + 1; a++) { %>
                        <option value="<%= a %>" <%= (typeof anio !== 'undefined' && anio == a) ? 'selected' : '' %>><%= a %></option>
                    <% } %>
                </select>
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="bi bi-funnel"></i> Filtrar
                </button>
            </form>
        </div>

        <!-- Nav de submódulos -->
        <ul class="nav admin-nav">
            <li class="nav-item">
                <a class="nav-link active" href="/administracion"><i class="bi bi-bar-chart-line me-1"></i> P&L</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/administracion/gastos"><i class="bi bi-wallet2 me-1"></i> Gastos</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/administracion/planilla"><i class="bi bi-people me-1"></i> Planilla</a>
            </li>
        </ul>

        <!-- KPI Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <div class="kpi-label mb-1"><i class="bi bi-shop me-1"></i> Ventas Netas</div>
                    <div class="kpi-value pl-positive">S/ <%= Number(pl.ventas_netas || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                    <small class="text-muted"><%= pl.facturas_cantidad || 0 %> facturas</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <div class="kpi-label mb-1"><i class="bi bi-graph-up me-1"></i> Margen Bruto<span data-bs-toggle="tooltip" data-bs-placement="top" title="Ventas menos el costo de ingredientes. Indica cuánto queda después de cubrir materia prima"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></div>
                    <div class="kpi-value <%= (pl.margen_bruto || 0) >= 0 ? 'pl-positive' : 'pl-negative' %>">S/ <%= Number(pl.margen_bruto || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                    <small class="<%= (pl.margen_bruto_pct || 0) >= 30 ? 'text-success' : 'text-warning' %>"><%= pl.margen_bruto_pct || 0 %>% del total</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <div class="kpi-label mb-1"><i class="bi bi-people me-1"></i> Planilla Total</div>
                    <div class="kpi-value pl-negative">S/ <%= Number(pl.planilla_total || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                    <small class="text-muted">Incl. EsSalud y SCTR</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <div class="kpi-label mb-1"><i class="bi bi-lightning me-1"></i> EBITDA<span data-bs-toggle="tooltip" data-bs-placement="top" title="Ganancia operativa antes de impuestos, depreciación y amortización"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></div>
                    <div class="kpi-value <%= (pl.ebitda || 0) >= 0 ? 'pl-positive' : 'pl-negative' %>">S/ <%= Number(pl.ebitda || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                    <small class="<%= (pl.ebitda_pct || 0) >= 15 ? 'text-success' : 'text-warning' %>"><%= pl.ebitda_pct || 0 %>% margen</small>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <!-- P&L Card -->
            <div class="col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h6 class="card-title mb-0"><i class="bi bi-receipt-cutoff me-2"></i>Estado de Resultados — <%= meses[(mes||1)-1] %> <%= anio %></h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0">
                            <tbody>
                                <tr class="pl-row">
                                    <td class="pl-label"><span class="pl-prefix">(+)</span> Ventas brutas</td>
                                    <td class="pl-amount pl-positive">S/ <%= Number(pl.ventas_brutas || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label"><span class="pl-prefix">(-)</span> IGV ventas</td>
                                    <td class="pl-amount pl-negative">S/ <%= Number(pl.igv_ventas || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-row pl-subtotal">
                                    <td class="pl-label"><span class="pl-prefix">(=)</span> Ventas netas</td>
                                    <td class="pl-amount <%= (pl.ventas_netas || 0) >= 0 ? 'pl-positive' : 'pl-negative' %>">S/ <%= Number(pl.ventas_netas || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label"><span class="pl-prefix">(-)</span> COGS teórico<span data-bs-toggle="tooltip" data-bs-placement="top" title="Costo de los ingredientes usados en los platos vendidos, calculado según las recetas"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></td>
                                    <td class="pl-amount pl-negative">S/ <%= Number(pl.cogs_teorico || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-row pl-subtotal">
                                    <td class="pl-label"><span class="pl-prefix">(=)</span> Margen bruto<span data-bs-toggle="tooltip" data-bs-placement="top" title="Ventas menos el costo de ingredientes. Indica cuánto queda después de cubrir materia prima"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></td>
                                    <td class="pl-amount <%= (pl.margen_bruto || 0) >= 0 ? 'pl-positive' : 'pl-negative' %>">S/ <%= Number(pl.margen_bruto || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %> <small>(<%= pl.margen_bruto_pct || 0 %>%)</small></td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label pl-indent">Varianza COGS<span data-bs-toggle="tooltip" data-bs-placement="top" title="Diferencia entre lo que debería haberse gastado (teórico) y lo que se gastó (real). Positivo = desperdicio"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></td>
                                    <td class="pl-amount <%= (pl.varianza || 0) >= 0 ? 'pl-negative' : 'pl-positive' %>">S/ <%= Number(pl.varianza || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %> <small>(teórico vs real)</small></td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label"><span class="pl-prefix">(-)</span> Planilla</td>
                                    <td class="pl-amount pl-negative">S/ <%= Number(pl.planilla_total || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label pl-indent" colspan="2">
                                        <small class="text-muted">
                                            (Bruta: S/ <%= Number(pl.planilla_bruta || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %>,
                                             Aportes: S/ <%= Number(pl.planilla_aportes || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %>)
                                        </small>
                                    </td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label"><span class="pl-prefix">(-)</span> Gastos fijos<span data-bs-toggle="tooltip" data-bs-placement="top" title="Gastos que no cambian con las ventas: alquiler, internet, seguros"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></td>
                                    <td class="pl-amount pl-negative">S/ <%= Number(pl.gastos_fijos || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-row">
                                    <td class="pl-label"><span class="pl-prefix">(-)</span> Gastos variables<span data-bs-toggle="tooltip" data-bs-placement="top" title="Gastos que varían con las ventas: insumos, envases, delivery"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></td>
                                    <td class="pl-amount pl-negative">S/ <%= Number(pl.gastos_variables || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                </tr>
                                <tr class="pl-subtotal" style="border-top: 2px solid rgba(255,255,255,0.15);">
                                    <td class="pl-label"><span class="pl-prefix">(=)</span> <strong>EBITDA</strong><span data-bs-toggle="tooltip" data-bs-placement="top" title="Ganancia operativa antes de impuestos, depreciación y amortización"><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></td>
                                    <td class="pl-amount <%= (pl.ebitda || 0) >= 0 ? 'pl-positive' : 'pl-negative' %>">
                                        <strong>S/ <%= Number(pl.ebitda || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></strong>
                                        <small>(<%= pl.ebitda_pct || 0 %>%)</small>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Reconciliacion Ventas vs Caja -->
            <div class="col-lg-5">
                <div class="card shadow-sm mb-3" style="border-left:4px solid <%= pl.reconciliacion_ok ? '#22C55E' : '#EF4444' %>;">
                    <div class="card-header">
                        <h6 class="card-title mb-0">
                            <i class="bi bi-arrow-left-right me-2"></i>Reconciliacion
                            <span data-bs-toggle="tooltip" data-bs-placement="top" title="Compara lo facturado vs lo registrado en caja. Si hay diferencia, puede indicar ventas sin registrar o efectivo faltante">
                                <i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i>
                            </span>
                            <% if (pl.reconciliacion_ok) { %>
                                <span class="badge bg-success ms-2" style="font-size:0.65rem;">OK</span>
                            <% } else { %>
                                <span class="badge bg-danger ms-2" style="font-size:0.65rem;">Diferencia</span>
                            <% } %>
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 text-center">
                            <div class="col-4">
                                <div class="small text-muted">Facturado</div>
                                <div class="fw-bold" style="color:#6366F1;">S/ <%= Number(pl.ventas_brutas || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">Caja ingresos</div>
                                <div class="fw-bold" style="color:#22C55E;">S/ <%= Number(pl.caja_ingresos || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">Diferencia</div>
                                <div class="fw-bold" style="color:<%= Math.abs(pl.diferencia_ventas_caja || 0) < 1 ? '#22C55E' : '#EF4444' %>;">
                                    S/ <%= Number(pl.diferencia_ventas_caja || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %>
                                </div>
                            </div>
                        </div>
                        <hr style="opacity:0.1;">
                        <div class="row g-3 text-center">
                            <div class="col-4">
                                <div class="small text-muted">Caja egresos</div>
                                <div class="fw-bold" style="color:#EF4444;">S/ <%= Number(pl.caja_egresos || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">Saldo caja</div>
                                <div class="fw-bold" style="color:<%= (pl.caja_saldo || 0) >= 0 ? '#22C55E' : '#EF4444' %>;">
                                    S/ <%= Number(pl.caja_saldo || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">Otros egresos</div>
                                <div class="fw-bold text-muted">S/ <%= Number(pl.caja_egresos_extra || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div>
                            </div>
                        </div>
                        <% if (!pl.reconciliacion_ok) { %>
                            <div class="alert alert-warning mt-3 mb-0 py-2" style="font-size:0.8rem;">
                                <i class="bi bi-exclamation-triangle me-1"></i>Hay una diferencia de S/ <%= Math.abs(pl.diferencia_ventas_caja || 0).toFixed(2) %> entre lo facturado y lo registrado en caja. Revisa si hay ventas sin registrar o efectivo faltante.
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <!-- Gastos por Grupo + Presupuesto -->
            <div class="col-lg-5">
                <div class="card shadow-sm mb-3">
                    <div class="card-header">
                        <h6 class="card-title mb-0"><i class="bi bi-pie-chart me-2"></i>Gastos por Grupo<span data-bs-toggle="tooltip" data-bs-placement="top" title="Gastos clasificados por categoría: compras, servicios, marketing, sueldos, etc."><i class="bi bi-info-circle ms-1" style="font-size:0.75rem;color:#9CA3AF;cursor:help;"></i></span></h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 table-sm">
                                <thead>
                                    <tr>
                                        <th>Categoría</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (gastosPorGrupo && gastosPorGrupo.length > 0) { %>
                                        <% gastosPorGrupo.forEach(function(g) { %>
                                            <tr>
                                                <td>
                                                    <span class="badge bg-secondary me-1"><%= g.grupo %></span>
                                                    <small><%= g.nombre %></small>
                                                </td>
                                                <td class="text-end fw-semibold">S/ <%= Number(g.total).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="2" class="text-center text-muted py-3">Sin gastos registrados</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header">
                        <h6 class="card-title mb-0"><i class="bi bi-clipboard-data me-2"></i>Presupuesto vs Real</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 table-sm">
                                <thead><tr><th>Categoría</th><th class="text-end">Presup.</th><th class="text-end">Real</th></tr></thead>
                                <tbody>
                                    <% if (presupuesto && presupuesto.length > 0) { %>
                                        <% presupuesto.forEach(function(p) { %>
                                            <% const pct = p.monto_presupuestado > 0 ? (p.gasto_real / p.monto_presupuestado * 100).toFixed(0) : 0; %>
                                            <tr>
                                                <td><%= p.nombre %></td>
                                                <td class="text-end text-muted">S/ <%= Number(p.monto_presupuestado || 0).toLocaleString('es-PE', {minimumFractionDigits:0}) %></td>
                                                <td class="text-end fw-semibold <%= pct >= 100 ? 'text-danger' : pct >= 80 ? 'text-warning' : 'text-success' %>">
                                                    S/ <%= Number(p.gasto_real || 0).toLocaleString('es-PE', {minimumFractionDigits:0}) %>
                                                    <small>(<%= pct %>%)</small>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="3" class="text-center text-muted py-3">Sin datos de presupuesto</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== HISTORIAL DE MESES ANTERIORES ===== -->
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="card-title mb-0">
                    <i class="bi bi-clock-history me-2 text-info"></i>
                    Historial P&L — Últimos 6 Meses
                </h6>
                <span class="badge bg-info bg-opacity-20 text-info">Evolución mensual</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Mes</th>
                                <th class="text-end">Ventas Netas</th>
                                <th class="text-end">Margen Bruto</th>
                                <th class="text-end">Planilla</th>
                                <th class="text-end">EBITDA</th>
                                <th class="text-end">Margen %</th>
                                <th class="text-end">Facturas</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (historialMeses && historialMeses.length > 0) { %>
                                <% const mesesNombres = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic']; %>
                                <% const maxVentas = Math.max(...historialMeses.map(h => h.ventas_netas || 0), 1); %>
                                <% historialMeses.forEach(function(h) { %>
                                    <% const esMesActual = (h.mes == mes && h.anio == anio); %>
                                    <tr class="<%= esMesActual ? 'table-active' : '' %>">
                                        <td>
                                            <a href="/administracion?mes=<%= h.mes %>&anio=<%= h.anio %>" class="text-decoration-none">
                                                <strong><%= mesesNombres[h.mes - 1] %> <%= h.anio %></strong>
                                            </a>
                                            <% if (esMesActual) { %><span class="badge bg-primary ms-1" style="font-size:0.65rem;">Actual</span><% } %>
                                            <div class="month-bar mt-1" style="width:100px;">
                                                <div class="month-bar-fill" style="width:<%= Math.round((h.ventas_netas || 0) / maxVentas * 100) %>%; background: <%= (h.ebitda || 0) >= 0 ? '#22c55e' : '#ef4444' %>;"></div>
                                            </div>
                                        </td>
                                        <td class="text-end fw-semibold">S/ <%= Number(h.ventas_netas || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                        <td class="text-end <%= (h.margen_bruto || 0) >= 0 ? 'text-success' : 'text-danger' %>">S/ <%= Number(h.margen_bruto || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                        <td class="text-end text-danger">S/ <%= Number(h.planilla_total || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                                        <td class="text-end">
                                            <span class="<%= (h.ebitda || 0) >= 0 ? 'historial-badge-pos' : 'historial-badge-neg' %>">
                                                S/ <%= Number(h.ebitda || 0).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}) %>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <span class="badge <%= (h.ebitda_pct || 0) >= 15 ? 'bg-success' : (h.ebitda_pct || 0) >= 5 ? 'bg-warning text-dark' : 'bg-danger' %> bg-opacity-25">
                                                <%= h.ebitda_pct || 0 %>%
                                            </span>
                                        </td>
                                        <td class="text-end text-muted"><%= h.facturas_cantidad || 0 %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="7" class="text-center text-muted py-4">Sin datos históricos disponibles</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
    </main>
    <%- include('../partials/footer') %>
    </div>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });
    </script>
</body>
</html>
