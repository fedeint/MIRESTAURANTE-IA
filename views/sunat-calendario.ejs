<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>SUNAT · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #ef520f;
      --orange2: #df2c05;
      --dark:   #0a0f24;
      --bg:     #F0F2F8;
      --card:   #ffffff;
      --text2:  #8B8FAD;
      --success:#22C55E;
      --warn:   #F97316;
      --danger: #EF4444;
      --safe-bot: env(safe-area-inset-bottom, 0px);
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      min-height: 100dvh;
      max-width: 480px;
      margin: 0 auto;
      padding-bottom: calc(72px + var(--safe-bot));
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(170deg, #10152f 0%, #0a0f24 50%, #090d1d 100%);
      padding: 52px 20px 24px;
      border-radius: 0 0 20px 20px;
      color: #fff;
    }
    .header-top { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .btn-back {
      background: rgba(255,255,255,0.12);
      border: none; color: #fff;
      width: 36px; height: 36px;
      border-radius: 10px;
      font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .header-title { font-size: 18px; font-weight: 700; }
    .ruc-badge {
      background: rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 12px 16px;
      display: flex; justify-content: space-between; align-items: center;
    }
    .ruc-label { font-size: 11px; color: rgba(255,255,255,0.6); margin-bottom: 2px; }
    .ruc-value { font-size: 16px; font-weight: 700; }
    .ruc-digito { text-align: right; }
    .ruc-digito-num {
      font-size: 28px; font-weight: 800;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    /* ── Alert chip ── */
    .alert-chip {
      margin: 16px 16px 0;
      background: #FFF3E0;
      border-left: 3px solid var(--warn);
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 13px; color: #92400E;
    }

    /* ── Section ── */
    .section-label {
      font-size: 13px; font-weight: 600;
      color: var(--text2); letter-spacing: 0.5px;
      text-transform: uppercase;
      padding: 20px 16px 10px;
    }

    /* ── Vencimiento card ── */
    .card {
      background: var(--card);
      margin: 0 16px 10px;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .card-inner {
      display: flex; align-items: center; gap: 14px;
      padding: 14px 16px;
      border-left: 4px solid transparent;
      text-decoration: none; color: inherit;
    }
    .card-inner.urgente   { border-left-color: var(--danger); }
    .card-inner.pronto    { border-left-color: var(--warn); }
    .card-inner.ok        { border-left-color: var(--success); }
    .card-inner.neutral   { border-left-color: #C7CAD8; }

    .card-icon {
      width: 42px; height: 42px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    .icon-igv   { background: #FFF3E0; }
    .icon-plame { background: #EDE9FE; }
    .icon-cts   { background: #DCFCE7; }
    .icon-grat  { background: #DCFCE7; }

    .card-body { flex: 1; min-width: 0; }
    .card-titulo { font-size: 15px; font-weight: 600; color: var(--dark); }
    .card-sub    { font-size: 13px; color: var(--text2); margin-top: 2px; }

    .card-right { text-align: right; flex-shrink: 0; }
    .card-fecha  { font-size: 13px; font-weight: 600; color: var(--dark); }
    .dias-badge  {
      display: inline-block; margin-top: 4px;
      font-size: 11px; font-weight: 700;
      padding: 2px 8px; border-radius: 20px;
    }
    .dias-urgente { background: #FEE2E2; color: var(--danger); }
    .dias-pronto  { background: #FFF3E0; color: var(--warn); }
    .dias-ok      { background: #DCFCE7; color: #166534; }
    .dias-pasado  { background: #F3F4F6; color: var(--text2); }

    .chevron { color: var(--text2); font-size: 18px; margin-left: 8px; }

    /* ── Bottom nav ── */
    .bottom-nav {
      position: fixed; bottom: 0; left: 50%;
      transform: translateX(-50%);
      width: 100%; max-width: 480px;
      background: #fff;
      border-top: 1px solid #E8EAF2;
      display: flex;
      padding-bottom: var(--safe-bot);
      z-index: 100;
    }
    .nav-item {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; padding: 10px 4px 8px;
      text-decoration: none; color: var(--text2);
      font-size: 10px; font-weight: 500;
      transition: color .2s;
    }
    .nav-item .icon { font-size: 22px; margin-bottom: 2px; }
    .nav-item.active { color: var(--orange); }
  </style>
</head>
<body>

  <div class="header">
    <div class="header-top">
      <button class="btn-back" onclick="history.back()">‹</button>
      <span class="header-title">SUNAT</span>
    </div>

    <% if (ruc) { %>
    <div class="ruc-badge">
      <div>
        <div class="ruc-label">RUC</div>
        <div class="ruc-value"><%= ruc %></div>
      </div>
      <div class="ruc-digito">
        <div class="ruc-label">Dígito verificador</div>
        <div class="ruc-digito-num"><%= digito !== null ? digito : '—' %></div>
      </div>
    </div>
    <% } else { %>
    <div class="ruc-badge" style="opacity:.6;">
      <div>
        <div class="ruc-label">RUC no configurado</div>
        <div class="ruc-value">— — —</div>
      </div>
    </div>
    <% } %>
  </div>

  <% if (urgente.length > 0) { %>
  <div class="alert-chip">
    ⚠️ <%= urgente.map(u => u.titulo).join(' y ') %> vence<%= urgente.length > 1 ? 'n' : '' %> pronto. Prepara tu declaración.
  </div>
  <% } %>

  <div class="section-label">Próximos vencimientos</div>

  <% vencimientos.forEach(function(v) {
    const dias  = v.diasRestantes;
    let borderClass = 'neutral';
    let diasClass   = 'dias-pasado';
    let diasLabel   = dias < 0 ? 'Vencido' : `${dias} días`;
    if (dias > 0 && dias <= 7)  { borderClass = 'urgente'; diasClass = 'dias-urgente'; }
    else if (dias > 7 && dias <= 15) { borderClass = 'pronto'; diasClass = 'dias-pronto'; }
    else if (dias > 15) { borderClass = 'ok'; diasClass = 'dias-ok'; }
    const iconClass = 'icon-' + v.tipo;
    const icones = { igv: '📊', plame: '👥', cts: '💰', grat: '🎁' };
  %>
  <div class="card">
    <% if (v.url) { %>
    <a class="card-inner <%= borderClass %>" href="<%= v.url %>">
    <% } else { %>
    <div class="card-inner <%= borderClass %>">
    <% } %>
      <div class="card-icon <%= iconClass %>"><%= icones[v.tipo] || '📋' %></div>
      <div class="card-body">
        <div class="card-titulo"><%= v.titulo %></div>
        <div class="card-sub"><%= v.subtitulo %></div>
      </div>
      <div class="card-right">
        <div class="card-fecha"><%= v.fecha %></div>
        <span class="dias-badge <%= diasClass %>"><%= diasLabel %></span>
      </div>
      <% if (v.url) { %><span class="chevron">›</span><% } %>
    <% if (v.url) { %>
    </a>
    <% } else { %>
    </div>
    <% } %>
  </div>
  <% }); %>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="icon">🏠</span>Inicio</a>
    <a href="/pedidos" class="nav-item"><span class="icon">🧾</span>Pedidos</a>
    <a href="/cocina-display" class="nav-item"><span class="icon">👨‍🍳</span>Cocina</a>
    <a href="/caja" class="nav-item"><span class="icon">💰</span>Caja</a>
    <a href="/mas" class="nav-item active"><span class="icon">☰</span>Más</a>
  </nav>

  <script src="/js/dallia-fab.js"></script>
</body>
</html>
