<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body style="align-items:center;justify-content:center;">
    <div class="text-center p-4" style="max-width:600px;animation:dg-fadeInUp 0.5s ease-out;">
        <div style="width:80px;height:80px;background:linear-gradient(135deg,#ef4444,#dc2626);border-radius:1.25rem;display:inline-flex;align-items:center;justify-content:center;font-size:2rem;color:#fff;box-shadow:0 12px 32px rgba(239,68,68,0.3);margin-bottom:1.5rem;">
            <i class="bi bi-x-circle-fill"></i>
        </div>
        <h1 style="font-size:1.75rem;font-weight:800;color:#1e293b;margin-bottom:0.5rem;">Ha ocurrido un error</h1>
        <p style="color:#64748b;margin-bottom:1rem;">Lo sentimos, ha ocurrido un error inesperado.</p>
        <% if (error && error.stack) { %>
            <div style="background:rgba(241,245,249,0.8);backdrop-filter:blur(8px);padding:1rem;border-radius:0.75rem;margin-bottom:1.5rem;text-align:left;font-family:'JetBrains Mono',monospace;font-size:0.8rem;white-space:pre-wrap;word-break:break-all;color:#475569;border:1px solid rgba(0,0,0,0.06);">
                <%= error.stack %>
            </div>
        <% } %>
        <a href="/" class="btn btn-primary px-4 py-2">
            <i class="bi bi-house-door-fill me-2"></i>Volver al inicio
        </a>
    </div>
</body>
</html>
