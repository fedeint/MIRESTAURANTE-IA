    <!-- ==========================================
         CARD GRID: Filter tabs + Search
         Client-side filtering by category and name
         ========================================== -->
    <script>
    (function() {
        var activeFilter = 'todos';
        var searchTerm = '';

        function applyFilters() {
            var cards = document.querySelectorAll('#productosGrid .producto-card');
            var visibleCount = 0;

            cards.forEach(function(card) {
                var cat = (card.dataset.categoria || '').toUpperCase();
                var nombre = (card.dataset.nombre || '');
                var codigo = (card.dataset.codigo || '');

                var matchFilter = activeFilter === 'todos'
                    || (activeFilter === 'sin-categoria' && cat === 'SIN-CATEGORIA')
                    || (activeFilter !== 'sin-categoria' && cat === activeFilter.toUpperCase());

                var matchSearch = !searchTerm
                    || nombre.includes(searchTerm)
                    || codigo.includes(searchTerm);

                if (matchFilter && matchSearch) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });

            var emptyState = document.getElementById('cartaEmptyState');
            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        // Filter tabs
        document.getElementById('filtrosTabs').addEventListener('click', function(e) {
            var tab = e.target.closest('.carta-filter-tab');
            if (!tab) return;

            document.querySelectorAll('.carta-filter-tab').forEach(function(t) {
                t.classList.remove('active');
            });
            tab.classList.add('active');
            activeFilter = tab.dataset.filter || 'todos';
            applyFilters();
        });

        // Search input - overrides the productos.js handler for cards
        var searchInput = document.getElementById('buscarProducto');
        if (searchInput) {
            var debounceTimer;
            searchInput.addEventListener('input', function() {
                clearTimeout(debounceTimer);
                var val = this.value.toLowerCase().trim();
                debounceTimer = setTimeout(function() {
                    searchTerm = val;
                    applyFilters();
                }, 200);
            });
        }
    })();
    </script>

    <!-- ==========================================
         Card action delegation (edit / delete / hijos)
         Replaces the old table-based delegation
         ========================================== -->
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Event delegation on the grid
        document.getElementById('productosGrid').addEventListener('click', function(e) {
            var button = e.target.closest('button[data-action]');
            if (!button) return;

            var id = button.dataset.id;
            var action = button.dataset.action;

            if (action === 'editar') {
                editarProducto(id);
            } else if (action === 'hijos') {
                var nombre = button.dataset.nombre || '';
                if (typeof gestionarHijosProducto === 'function') {
                    gestionarHijosProducto(id, nombre);
                } else {
                    alert('No se pudo abrir la gestion de hijos (funcion no encontrada).');
                }
            } else if (action === 'eliminar') {
                if (confirm('Estas seguro de que deseas eliminar este producto?')) {
                    eliminarProducto(id);
                }
            }
        });

        // Descargar plantilla Excel
        document.getElementById('btnDescargarPlantilla').addEventListener('click', function() {
            window.open('/api/productos/plantilla', '_blank');
        });

        // Importar productos desde Excel
        var inputImport = document.getElementById('archivoImport');
        document.getElementById('btnImportarProductos').addEventListener('click', function() {
            inputImport.click();
        });

        inputImport.addEventListener('change', async function() {
            if (!this.files.length) return;
            var fd = new FormData();
            fd.append('archivo', this.files[0]);
            var btn = document.getElementById('btnImportarProductos');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Importando...';
            try {
                var resp = await fetch('/api/productos/importar', { method: 'POST', body: fd });
                var data = await resp.json();
                if (!resp.ok) throw new Error(data.error || 'Error al importar');
                alert('Importacion completa: ' + data.inserted + ' filas.');
                location.reload();
            } catch (err) {
                alert(err.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-upload"></i> <span class="d-none d-sm-inline">Importar</span>';
                this.value = '';
            }
        });
    });
    </script>

    <!-- ==========================================
         RECETA MANAGEMENT
         Handles ingredient recipe for each product
         ========================================== -->
    <script>
    (function() {
        var recetaItems = [];
        var ingredientesDisponibles = [];

        // Cargar ingredientes del almacen
        async function cargarIngredientes() {
            try {
                var r = await fetch('/almacen/api/ingredientes');
                if (!r.ok) { return; }
                var data = await r.json();
                ingredientesDisponibles = Array.isArray(data) ? data : (data.ingredientes || []);
                var sel = document.getElementById('recetaIngredienteSelect');
                if (!sel) return;
                sel.innerHTML = '<option value="">-- Seleccionar ingrediente --</option>';
                ingredientesDisponibles.forEach(function(i) {
                    var opt = document.createElement('option');
                    opt.value = i.id;
                    opt.textContent = i.nombre + ' (' + i.unidad_medida + ' - S/' + Number(i.costo_unitario || 0).toFixed(2) + ')';
                    opt.dataset.costo = i.costo_unitario || 0;
                    opt.dataset.unidad = i.unidad_medida || 'g';
                    opt.dataset.nombre = i.nombre;
                    sel.appendChild(opt);
                });
            } catch (e) {
                console.error('Error cargando ingredientes:', e);
            }
        }

        fetch('/almacen/api/ingredientes')
            .then(function(r) { return r.ok ? r.json() : Promise.resolve([]); })
            .then(function(data) { ingredientesDisponibles = Array.isArray(data) ? data : []; })
            .catch(function() {});
        cargarIngredientes();

        // Render receta (solo lectura - sin botones de edicion)
        function renderReceta() {
            var body = document.getElementById('recetaBody');
            if (!body) return;
            body.innerHTML = '';
            var total = 0;
            recetaItems.forEach(function(item) {
                var costoUnit = item.costo || 0;
                var cant = item.cantidad || 0;
                var costo;
                if ((item.unidad_medida === 'g' || item.unidad_medida === 'ml') && costoUnit > 1) {
                    costo = (costoUnit / 1000) * cant;
                } else {
                    costo = costoUnit * cant;
                }
                total += costo;
                var tr = document.createElement('tr');
                tr.innerHTML = '<td>' + item.nombre + '</td>'
                    + '<td class="text-end">' + item.cantidad + '</td>'
                    + '<td>' + item.unidad_medida + '</td>'
                    + '<td class="text-end">S/ ' + costo.toFixed(2) + '</td>';
                body.appendChild(tr);
            });
            document.getElementById('recetaCostoTotal').textContent = 'S/ ' + total.toFixed(2);
        }

        // Mostrar receta section cuando se abre modal para editar
        var origEditarProducto = window.editarProducto;
        window.editarProducto = async function(id) {
            origEditarProducto(id);
            document.getElementById('recetaSection').style.display = 'block';
            try {
                var r = await fetch('/api/recetas/' + id);
                var data = await r.json();
                recetaItems = [];
                if (data.items && data.items.length > 0) {
                    data.items.forEach(function(it) {
                        recetaItems.push({
                            ingrediente_id: it.ingrediente_id,
                            nombre: it.ingrediente_nombre || 'Ingrediente ' + it.ingrediente_id,
                            cantidad: Number(it.cantidad),
                            unidad_medida: it.unidad_medida || 'g',
                            costo: Number(it.ingrediente_costo) || 0
                        });
                    });
                }
                renderReceta();
            } catch (e) {
                recetaItems = [];
                renderReceta();
            }
        };

        // Al abrir modal para nuevo producto, ocultar receta
        document.getElementById('nuevoProductoModal')?.addEventListener('show.bs.modal', function(ev) {
            if (ev.relatedTarget) {
                document.getElementById('recetaSection').style.display = 'none';
                recetaItems = [];
                renderReceta();
            }
        });

        // Guardar receta despues de guardar producto
        // Receta se gestiona desde /recetas (solo lectura aqui)
    })();
    </script>

</body>
