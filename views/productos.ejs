<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos - dignita.tech</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-box-fill me-2"></i>
                    Gestión de Productos
                </div>
                <div class="btn-group">
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#nuevoProductoModal">
                        <i class="bi bi-plus-lg me-1"></i>
                        Nuevo Producto
                    </button>
                    <button id="btnDescargarPlantilla" class="btn btn-outline-success">
                        <i class="bi bi-file-earmark-excel"></i> Plantilla Excel
                    </button>
                    <button id="btnImportarProductos" class="btn btn-outline-primary">
                        <i class="bi bi-upload"></i> Importar Excel
                    </button>
                    <input type="file" id="archivoImport" accept=".xlsx" class="d-none">
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col">
                        <div class="input-group search-box ms-auto">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control" id="buscarProducto" placeholder="Buscar producto...">
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th style="width:50px"></th>
                                <th>Codigo</th>
                                <th>Nombre</th>
                                <th class="text-end">Precio</th>
                                <th class="text-center">Disponible</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="productosTabla">
                            <% productos.forEach(function(producto) { %>
                                <tr>
                                    <td>
                                      <% if (producto.imagen) { %>
                                        <img src="<%= producto.imagen %>" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:0.5rem;">
                                      <% } else { %>
                                        <div style="width:40px;height:40px;background:rgba(99,102,241,0.08);border-radius:0.5rem;display:flex;align-items:center;justify-content:center;color:#94a3b8;"><i class="bi bi-image"></i></div>
                                      <% } %>
                                    </td>
                                    <td><%= producto.codigo %></td>
                                    <td><%= producto.nombre %></td>
                                    <td class="text-end">S/ <%= (Number(producto.precio_unidad) || 0).toFixed(2) %></td>
                                    <td class="text-center">
                                        <% if (producto.sinReceta) { %>
                                            <span class="badge bg-secondary" title="Sin receta configurada">-</span>
                                        <% } else if (producto.disponible === 0) { %>
                                            <span class="badge bg-danger" title="Agotado - <%= producto.ingrediente_limitante %>">AGOTADO</span>
                                        <% } else if (producto.disponible <= 5) { %>
                                            <span class="badge bg-warning text-dark" title="Bajo - <%= producto.ingrediente_limitante %>"><%= producto.disponible %> platos</span>
                                        <% } else { %>
                                            <span class="badge bg-success"><%= producto.disponible %> platos</span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <div class="action-buttons">
                                            <!-- Gestión de productos hijos (Padre -> Hijos) -->
                                            <!-- Relacionado con: database.sql (producto_hijos), routes/productos.js (/:padreId/hijos), public/js/productos.js -->
                                            <button class="btn btn-sm btn-outline-secondary me-1"
                                                    data-id="<%= producto.id %>"
                                                    data-nombre="<%= producto.nombre %>"
                                                    data-action="hijos"
                                                    title="Gestionar hijos (combo/variantes)">
                                                <i class="bi bi-diagram-3"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary me-1" 
                                                    data-id="<%= producto.id %>" 
                                                    data-action="editar">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    data-id="<%= producto.id %>"
                                                    data-action="eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    </main>

    <!-- Modal Nuevo/Editar Producto -->
    <div class="modal fade" id="nuevoProductoModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-box-fill me-2"></i>
                        <span id="modalTitle">Nuevo Producto</span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formProducto">
                        <input type="hidden" id="productoId">
                        <div class="mb-3 text-center">
                            <label class="form-label d-block">Imagen del producto</label>
                            <div id="imagenPreviewWrap" style="width:100px;height:100px;margin:0 auto .5rem;border-radius:.75rem;overflow:hidden;background:rgba(99,102,241,0.06);display:flex;align-items:center;justify-content:center;border:2px dashed #e2e8f0;cursor:pointer;transition:all .2s;" onclick="document.getElementById('imagenInput').click()">
                                <img id="imagenPreview" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;">
                                <i id="imagenPlaceholder" class="bi bi-camera-fill" style="font-size:1.5rem;color:#94a3b8;"></i>
                            </div>
                            <input type="file" id="imagenInput" accept="image/*" class="d-none">
                            <input type="hidden" id="imagenBase64">
                            <div class="form-text">Click para subir foto (max 500KB)</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Código</label>
                            <input type="text" class="form-control" id="codigo" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" id="nombre" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Precio de venta (S/)</label>
                            <input type="number" class="form-control" id="precioUnidad" step="0.01" min="0" required placeholder="Ej: 35.00">
                            <input type="hidden" id="precioKg" value="0">
                            <input type="hidden" id="precioLibra" value="0">
                        </div>
                    </form>

                    <!-- RECETA / INGREDIENTES -->
                    <div id="recetaSection" style="display:none;">
                        <hr>
                        <h6 class="fw-bold"><i class="bi bi-egg-fried me-1" style="color:#6366f1;"></i>Receta / Ingredientes</h6>
                        <p class="small text-muted">Define que ingredientes del almacen necesita este platillo. Se descuentan automaticamente al vender.</p>

                        <div class="row g-2 mb-2 align-items-end">
                            <div class="col">
                                <select id="recetaIngredienteSelect" class="form-select form-select-sm">
                                    <option value="">-- Seleccionar ingrediente --</option>
                                </select>
                            </div>
                            <div class="col-3">
                                <input type="number" id="recetaCantidad" class="form-control form-control-sm" placeholder="Cantidad" step="0.1" min="0">
                            </div>
                            <div class="col-2">
                                <select id="recetaUnidad" class="form-select form-select-sm">
                                    <option value="g">g</option>
                                    <option value="kg">kg</option>
                                    <option value="ml">ml</option>
                                    <option value="lt">lt</option>
                                    <option value="und">und</option>
                                </select>
                            </div>
                            <div class="col-auto">
                                <button type="button" class="btn btn-sm btn-success" id="btnAgregarIngrediente"><i class="bi bi-plus-lg"></i></button>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm" id="recetaTabla">
                                <thead class="table-light">
                                    <tr><th>Ingrediente</th><th class="text-end">Cantidad</th><th>Unidad</th><th class="text-end">Costo</th><th></th></tr>
                                </thead>
                                <tbody id="recetaBody"></tbody>
                                <tfoot>
                                    <tr class="fw-bold"><td colspan="3">Costo total receta</td><td class="text-end" id="recetaCostoTotal">S/ 0.00</td><td></td></tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="guardarProducto">
                        <i class="bi bi-save me-1"></i>
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Gestión de Hijos (Padre -> Hijos) -->
    <!-- Permite configurar qué productos se pueden elegir como "hijos" al montar el pedido del producto padre -->
    <!-- Relacionado con: routes/productos.js (GET/POST/DELETE /api/productos/:padreId/hijos) y public/js/mesas.js (guarda selección en pedido_items.nota) -->
    <div class="modal fade" id="hijosProductoModal" tabindex="-1" aria-labelledby="hijosProductoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="hijosProductoModalLabel">
                        <i class="bi bi-diagram-3 me-2"></i>
                        Hijos de: <span id="hijosPadreNombre" class="fw-semibold"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="hijosPadreId" value="">

                    <div class="alert alert-info py-2 small mb-3">
                        Los hijos son <strong>opciones/descripción</strong> del producto padre. <strong>No cambian el precio</strong> del padre.
                        Al montar el pedido, la selección se guarda en <code>pedido_items.nota</code> para que llegue a cocina.
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <div class="mb-2">
                                <label class="form-label fw-semibold mb-1">Agregar ítem</label>
                                <!-- Hijos como "items" de texto (NO son productos) -->
                                <!-- Relacionado con: routes/productos.js (/:padreId/hijos-items) y public/js/productos.js (agregar/quitar items) -->
                                <div class="input-group mb-2">
                                    <span class="input-group-text"><i class="bi bi-plus-lg"></i></span>
                                    <input id="nuevoItemHijoNombre" type="text" class="form-control" placeholder="Ej: Goulash de cerdo, Crema, Ensalada...">
                                    <button id="btnAgregarItemHijo" class="btn btn-primary" type="button">
                                        Agregar ítem
                                    </button>
                                </div>
                                <div class="form-text mb-2">
                                    Puedes agregar varios separados por <strong>,</strong> (coma). Ej: <strong>Goulash, Crema</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label fw-semibold mb-1">Ítems configurados</label>
                            <!-- Lista de items hijos (texto) -->
                            <!-- Relacionado con: database.sql -> producto_hijos_items -->
                            <div id="listaItemsHijosConfigurados" class="list-group mb-2"></div>
                            <div id="emptyItemsHijosConfigurados" class="text-muted small mt-2 d-none">
                                Aún no hay ítems hijos configurados para este producto.
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
    </div><!-- dg-main -->

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/productos.js"></script>
    <script>
    // === RECETA MANAGEMENT ===
    (function(){
        var recetaItems = [];
        var ingredientesDisponibles = [];

        // Cargar ingredientes del almacen
        async function cargarIngredientes() {
            try {
                var r = await fetch('/almacen/api/ingredientes');
                if (!r.ok) { var rj = await r.json().catch(()=>({})); return; }
                var data = await r.json();
                ingredientesDisponibles = Array.isArray(data) ? data : (data.ingredientes || []);
                var sel = document.getElementById('recetaIngredienteSelect');
                if (!sel) return;
                sel.innerHTML = '<option value="">-- Seleccionar ingrediente --</option>';
                ingredientesDisponibles.forEach(function(i){
                    var opt = document.createElement('option');
                    opt.value = i.id;
                    opt.textContent = i.nombre + ' (' + i.unidad_medida + ' - S/' + Number(i.costo_unitario||0).toFixed(2) + ')';
                    opt.dataset.costo = i.costo_unitario || 0;
                    opt.dataset.unidad = i.unidad_medida || 'g';
                    opt.dataset.nombre = i.nombre;
                    sel.appendChild(opt);
                });
            } catch(e) { console.error('Error cargando ingredientes:', e); }
        }

        // Fetch ingredientes al cargar
        fetch('/almacen/api/ingredientes').then(r=>r.ok?r.json():Promise.resolve([])).then(data => {
            ingredientesDisponibles = Array.isArray(data) ? data : [];
        }).catch(()=>{});
        cargarIngredientes();

        // Agregar ingrediente a receta
        document.getElementById('btnAgregarIngrediente')?.addEventListener('click', function(){
            var sel = document.getElementById('recetaIngredienteSelect');
            var opt = sel.options[sel.selectedIndex];
            if (!opt || !opt.value) return;
            var cant = Number(document.getElementById('recetaCantidad').value) || 0;
            if (cant <= 0) return alert('Ingresa una cantidad');
            var unidad = document.getElementById('recetaUnidad').value || 'g';

            recetaItems.push({
                ingrediente_id: Number(opt.value),
                nombre: opt.dataset.nombre,
                cantidad: cant,
                unidad_medida: unidad,
                costo: Number(opt.dataset.costo) || 0
            });
            renderReceta();
            document.getElementById('recetaCantidad').value = '';
            sel.selectedIndex = 0;
        });

        function renderReceta() {
            var body = document.getElementById('recetaBody');
            if (!body) return;
            body.innerHTML = '';
            var total = 0;
            recetaItems.forEach(function(item, idx){
                var costo = item.costo * item.cantidad;
                total += costo;
                var tr = document.createElement('tr');
                tr.innerHTML = '<td>' + item.nombre + '</td><td class="text-end">' + item.cantidad + '</td><td>' + item.unidad_medida + '</td><td class="text-end">S/ ' + costo.toFixed(2) + '</td><td><button type="button" class="btn btn-sm btn-outline-danger btn-quitar-ingr" data-idx="' + idx + '"><i class="bi bi-x"></i></button></td>';
                body.appendChild(tr);
            });
            document.getElementById('recetaCostoTotal').textContent = 'S/ ' + total.toFixed(2);
        }

        // Quitar ingrediente
        document.getElementById('recetaBody')?.addEventListener('click', function(e){
            var btn = e.target.closest('.btn-quitar-ingr');
            if (!btn) return;
            recetaItems.splice(Number(btn.dataset.idx), 1);
            renderReceta();
        });

        // Mostrar receta section cuando se abre modal para editar
        var origEditarProducto = window.editarProducto;
        window.editarProducto = async function(id) {
            origEditarProducto(id);
            document.getElementById('recetaSection').style.display = 'block';
            // Cargar receta existente
            try {
                var r = await fetch('/api/recetas/' + id);
                var data = await r.json();
                recetaItems = [];
                if (data.items && data.items.length > 0) {
                    data.items.forEach(function(it){
                        recetaItems.push({
                            ingrediente_id: it.ingrediente_id,
                            nombre: it.ingrediente_nombre || 'Ingrediente ' + it.ingrediente_id,
                            cantidad: Number(it.cantidad),
                            unidad_medida: it.unidad_medida || 'g',
                            costo: Number(it.ingrediente_costo) || 0
                        });
                    });
                }
                renderReceta();
            } catch(e) { recetaItems = []; renderReceta(); }
        };

        // Al mostrar modal nuevo producto, ocultar receta (se muestra al guardar primero)
        document.getElementById('nuevoProductoModal')?.addEventListener('show.bs.modal', function(ev){
            if (ev.relatedTarget) {
                document.getElementById('recetaSection').style.display = 'none';
                recetaItems = [];
                renderReceta();
            }
        });

        // Guardar receta despues de guardar producto
        var origGuardar = document.getElementById('guardarProducto');
        if (origGuardar) {
            var origClick = origGuardar.onclick;
            origGuardar.addEventListener('click', async function(){
                // Esperar a que el producto se guarde (el reload lo hace productos.js)
                // Interceptamos: si hay recetaItems y productoId, guardamos la receta
                setTimeout(async function(){
                    var pid = document.getElementById('productoId').value;
                    if (pid && recetaItems.length > 0) {
                        try {
                            await fetch('/api/recetas/' + pid, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    items: recetaItems.map(function(it){ return { ingrediente_id: it.ingrediente_id, cantidad: it.cantidad, unidad_medida: it.unidad_medida }; })
                                })
                            });
                        } catch(e) { console.error('Error guardando receta:', e); }
                    }
                }, 500);
            });
        }
    })();
    </script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Delegación de eventos para los botones de acción
        document.querySelector('.table').addEventListener('click', function(e) {
            const button = e.target.closest('button');
            if (!button) return;

            const id = button.dataset.id;
            const action = button.dataset.action;

            if (action === 'editar') {
                editarProducto(id);
            } else if (action === 'hijos') {
                // Gestión de hijos: usa función global definida en /js/productos.js
                // Relacionado con: routes/productos.js (/:padreId/hijos)
                const nombre = button.dataset.nombre || '';
                if (typeof gestionarHijosProducto === 'function') {
                    gestionarHijosProducto(id, nombre);
                } else {
                    alert('No se pudo abrir la gestión de hijos (función no encontrada).');
                }
            } else if (action === 'eliminar') {
                if (confirm('¿Está seguro de que desea eliminar este producto?')) {
                    eliminarProducto(id);
                }
            }
        });

        // Descargar plantilla
        document.getElementById('btnDescargarPlantilla').addEventListener('click', function(){
            window.open('/api/productos/plantilla','_blank');
        });

        // Importar productos
        const input = document.getElementById('archivoImport');
        document.getElementById('btnImportarProductos').addEventListener('click', ()=> input.click());
        input.addEventListener('change', async function(){
            if (!this.files.length) return;
            const fd = new FormData();
            fd.append('archivo', this.files[0]);
            const btn = document.getElementById('btnImportarProductos');
            btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Importando...';
            try{
                const resp = await fetch('/api/productos/importar', { method:'POST', body: fd });
                const data = await resp.json();
                if(!resp.ok) throw new Error(data.error||'Error al importar');
                alert('Importación completa: ' + data.inserted + ' filas.');
                location.reload();
            }catch(err){ alert(err.message); }
            finally{ btn.disabled=false; btn.innerHTML = '<i class="bi bi-upload"></i> Importar Excel'; this.value=''; }
        });
    });
    </script>
</body>
</html> 