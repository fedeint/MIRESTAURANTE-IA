<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Permisos y Legal · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #ef520f; --orange2: #df2c05;
      --dark: #0a0f24; --bg: #F0F2F8;
      --card: #ffffff; --text2: #8B8FAD;
      --verde:   #22C55E;
      --naranja: #F97316;
      --rojo:    #EF4444;
      --safe-bot: env(safe-area-inset-bottom, 0px);
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      min-height: 100dvh;
      max-width: 480px;
      margin: 0 auto;
      padding-bottom: calc(80px + var(--safe-bot));
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(170deg, #10152f 0%, #0a0f24 50%, #090d1d 100%);
      padding: 52px 20px 20px;
      border-radius: 0 0 20px 20px;
      color: #fff;
      display: flex; align-items: center; justify-content: space-between;
    }
    .header-left { display: flex; align-items: center; gap: 12px; }
    .btn-back {
      background: rgba(255,255,255,0.12); border: none; color: #fff;
      width: 36px; height: 36px; border-radius: 10px;
      font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .header-title { font-size: 18px; font-weight: 700; }
    .btn-add {
      background: rgba(255,255,255,0.15); border: none; color: #fff;
      width: 36px; height: 36px; border-radius: 10px;
      font-size: 20px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }

    /* ── Stats row ── */
    .stats-row {
      display: flex; gap: 10px;
      padding: 16px 16px 0;
    }
    .stat-chip {
      flex: 1; background: var(--card);
      border-radius: 12px; padding: 10px 12px;
      text-align: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .stat-num  { font-size: 22px; font-weight: 800; }
    .stat-lbl  { font-size: 11px; color: var(--text2); margin-top: 1px; }
    .num-verde   { color: var(--verde); }
    .num-naranja { color: var(--naranja); }
    .num-rojo    { color: var(--rojo); }

    /* ── Permit cards ── */
    .list { padding: 14px 16px 0; }

    .permiso-card {
      background: var(--card);
      border-radius: 14px;
      margin-bottom: 10px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      display: flex; align-items: stretch;
      cursor: pointer;
      transition: transform .15s;
    }
    .permiso-card:active { transform: scale(0.98); }

    .border-strip {
      width: 4px; flex-shrink: 0;
    }
    .strip-verde   { background: var(--verde); }
    .strip-naranja { background: var(--naranja); }
    .strip-rojo    { background: var(--rojo); }
    .strip-sin     { background: #C7CAD8; }

    .permiso-inner {
      flex: 1; padding: 14px 14px 14px 14px;
      display: flex; align-items: center; gap: 12px;
    }
    .permiso-info { flex: 1; min-width: 0; }
    .permiso-nombre {
      font-size: 15px; font-weight: 600; color: var(--dark);
      display: flex; align-items: center; gap: 8px;
    }
    .vencido-badge {
      font-size: 10px; font-weight: 700;
      background: #FEE2E2; color: var(--rojo);
      padding: 2px 6px; border-radius: 6px;
      text-transform: uppercase;
    }
    .permiso-sub {
      font-size: 12px; margin-top: 3px;
    }
    .sub-verde   { color: var(--text2); }
    .sub-naranja { color: var(--naranja); }
    .sub-rojo    { color: var(--rojo); }

    .chevron { color: var(--text2); font-size: 18px; flex-shrink: 0; }

    /* ── Empty state ── */
    .empty {
      text-align: center; padding: 48px 24px;
      color: var(--text2); font-size: 14px;
    }
    .empty-icon { font-size: 40px; margin-bottom: 12px; }

    /* ── Bottom sheet (add permiso) ── */
    .sheet-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.45); z-index: 200;
      align-items: flex-end; justify-content: center;
    }
    .sheet-overlay.show { display: flex; }
    .sheet {
      background: var(--card);
      border-radius: 20px 20px 0 0;
      width: 100%; max-width: 480px;
      max-height: 88dvh;
      overflow-y: auto;
      padding: 8px 20px calc(20px + var(--safe-bot));
      animation: slideUp .25s ease;
    }
    @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
    .sheet-handle {
      width: 40px; height: 4px;
      background: #E0E2EE; border-radius: 2px;
      margin: 12px auto 20px;
    }
    .sheet-title { font-size: 17px; font-weight: 700; color: var(--dark); margin-bottom: 20px; }

    .field-label { font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 6px; }
    .field-input {
      width: 100%; border: 1.5px solid #E0E2EE;
      border-radius: 12px; padding: 11px 14px;
      font-size: 14px; font-family: 'DM Sans', sans-serif;
      outline: none; color: var(--dark);
      transition: border-color .2s;
      margin-bottom: 14px;
    }
    .field-input:focus { border-color: var(--orange); }
    select.field-input { appearance: none; background-color: #fff; }
    .row-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .sheet-cta {
      width: 100%; margin-top: 4px;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      color: #fff; border: none; border-radius: 14px;
      padding: 15px; font-size: 15px; font-weight: 700;
      cursor: pointer; font-family: 'DM Sans', sans-serif;
    }

    /* ── Detalle sheet ── */
    .detalle-nombre { font-size: 17px; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
    .detalle-row {
      display: flex; justify-content: space-between;
      padding: 11px 0; border-bottom: 1px solid #F0F2F8;
      font-size: 14px;
    }
    .detalle-row:last-of-type { border-bottom: none; }
    .dt-label { color: var(--text2); }
    .dt-value { font-weight: 500; color: var(--dark); }
    .delete-btn {
      width: 100%; margin-top: 16px;
      background: #FEE2E2; color: var(--rojo);
      border: none; border-radius: 12px;
      padding: 13px; font-size: 14px; font-weight: 600;
      cursor: pointer; font-family: 'DM Sans', sans-serif;
    }

    /* ── Bottom nav ── */
    .bottom-nav {
      position: fixed; bottom: 0; left: 50%;
      transform: translateX(-50%);
      width: 100%; max-width: 480px;
      background: #fff; border-top: 1px solid #E8EAF2;
      display: flex; padding-bottom: var(--safe-bot); z-index: 100;
    }
    .nav-item {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; padding: 10px 4px 8px;
      text-decoration: none; color: var(--text2);
      font-size: 10px; font-weight: 500;
    }
    .nav-item .icon { font-size: 22px; margin-bottom: 2px; }
    .nav-item.active { color: var(--orange); }
  </style>
</head>
<body>

  <div class="header">
    <div class="header-left">
      <button class="btn-back" onclick="history.back()">‹</button>
      <span class="header-title">Permisos y Legal</span>
    </div>
    <button class="btn-add" onclick="abrirAgregar()" title="Agregar permiso">+</button>
  </div>

  <div class="stats-row">
    <div class="stat-chip">
      <div class="stat-num num-verde"><%= vigentes %></div>
      <div class="stat-lbl">Vigentes</div>
    </div>
    <div class="stat-chip">
      <div class="stat-num num-naranja"><%= porVencer %></div>
      <div class="stat-lbl">Por vencer</div>
    </div>
    <div class="stat-chip">
      <div class="stat-num num-rojo"><%= vencidos %></div>
      <div class="stat-lbl">Vencidos</div>
    </div>
  </div>

  <div class="list">
    <% if (permisos.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">📋</div>
      No hay permisos registrados.<br>Agrega tu licencia de funcionamiento.
    </div>
    <% } %>

    <% permisos.forEach(function(p) {
      const stripClass = { verde: 'strip-verde', naranja: 'strip-naranja', rojo: 'strip-rojo', sin_fecha: 'strip-sin' }[p.estado] || 'strip-sin';
      const subClass   = { verde: 'sub-verde',   naranja: 'sub-naranja',   rojo: 'sub-rojo',   sin_fecha: 'sub-verde' }[p.estado] || 'sub-verde';
      let subTexto = '';
      if (p.estado === 'rojo')     subTexto = 'VENCIDO · ' + p.fechaFmt;
      else if (p.estado === 'naranja') subTexto = 'Vence: ' + p.fechaFmt + ' · ' + p.dias + ' días';
      else if (p.estado === 'verde')   subTexto = 'Vence: ' + p.fechaFmt;
      else                              subTexto = 'Sin fecha de vencimiento';
      if (p.empleado_nombre) subTexto = p.empleado_nombre + ' · ' + subTexto;
    %>
    <div class="permiso-card" onclick="abrirDetalle(<%= JSON.stringify(p) %>)">
      <div class="border-strip <%= stripClass %>"></div>
      <div class="permiso-inner">
        <div class="permiso-info">
          <div class="permiso-nombre">
            <%= p.nombre %>
            <% if (p.estado === 'rojo') { %><span class="vencido-badge">VENCIDO</span><% } %>
          </div>
          <div class="permiso-sub <%= subClass %>"><%= subTexto %></div>
        </div>
        <span class="chevron">›</span>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- ── Sheet Agregar permiso ── -->
  <div class="sheet-overlay" id="agregarSheet" onclick="cerrarSheet('agregarSheet', event)">
    <div class="sheet">
      <div class="sheet-handle"></div>
      <div class="sheet-title">Agregar permiso</div>

      <div class="field-label">Nombre del permiso *</div>
      <select class="field-input" id="nombreSelect" onchange="actualizarNombreCustom()">
        <option value="">Seleccionar…</option>
        <option value="Licencia de funcionamiento">Licencia de funcionamiento</option>
        <option value="Defensa Civil">Defensa Civil</option>
        <option value="Carnet de sanidad">Carnet de sanidad</option>
        <option value="Fumigación">Fumigación</option>
        <option value="Extintor">Extintor</option>
        <option value="Certificado DIGESA">Certificado DIGESA</option>
        <option value="Habilitación sanitaria">Habilitación sanitaria</option>
        <option value="Certificado de zonificación">Certificado de zonificación</option>
        <option value="otro">Otro…</option>
      </select>
      <input class="field-input" id="nombreCustom" placeholder="Nombre del permiso" style="display:none;" autocomplete="off">

      <div class="field-label">Empleado (solo para carnets)</div>
      <input class="field-input" id="empleadoNombre" placeholder="Ej: Carlos García" autocomplete="off">

      <div class="row-fields">
        <div>
          <div class="field-label">Fecha emisión</div>
          <input class="field-input" type="date" id="fechaEmision">
        </div>
        <div>
          <div class="field-label">Fecha vencimiento</div>
          <input class="field-input" type="date" id="fechaVencimiento">
        </div>
      </div>

      <div class="field-label">Proveedor / Entidad</div>
      <input class="field-input" id="proveedor" placeholder="Ej: Municipalidad de Miraflores" autocomplete="off">

      <div class="field-label">Notas</div>
      <input class="field-input" id="notas" placeholder="Observaciones…" autocomplete="off">

      <button class="sheet-cta" onclick="guardarPermiso()">Guardar permiso</button>
    </div>
  </div>

  <!-- ── Sheet Detalle permiso ── -->
  <div class="sheet-overlay" id="detalleSheet" onclick="cerrarSheet('detalleSheet', event)">
    <div class="sheet">
      <div class="sheet-handle"></div>
      <div class="detalle-nombre" id="detalleNombre">—</div>
      <div id="detalleBody"></div>
      <button class="delete-btn" id="deleteBtn">🗑 Eliminar permiso</button>
    </div>
  </div>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="icon">🏠</span>Inicio</a>
    <a href="/pedidos" class="nav-item"><span class="icon">🧾</span>Pedidos</a>
    <a href="/cocina-display" class="nav-item"><span class="icon">👨‍🍳</span>Cocina</a>
    <a href="/caja" class="nav-item"><span class="icon">💰</span>Caja</a>
    <a href="/mas" class="nav-item active"><span class="icon">☰</span>Más</a>
  </nav>

  <script>
    function abrirAgregar() {
      document.getElementById('agregarSheet').classList.add('show');
    }

    function cerrarSheet(id, e) {
      if (e.target.classList.contains('sheet-overlay')) {
        document.getElementById(id).classList.remove('show');
      }
    }

    function actualizarNombreCustom() {
      const sel = document.getElementById('nombreSelect').value;
      const custom = document.getElementById('nombreCustom');
      custom.style.display = sel === 'otro' ? 'block' : 'none';
    }

    async function guardarPermiso() {
      const selVal = document.getElementById('nombreSelect').value;
      const nombre = selVal === 'otro'
        ? document.getElementById('nombreCustom').value.trim()
        : selVal;
      if (!nombre) { alert('Selecciona o escribe el nombre del permiso'); return; }

      const body = {
        nombre,
        empleado_nombre:   document.getElementById('empleadoNombre').value.trim() || null,
        fecha_emision:     document.getElementById('fechaEmision').value     || null,
        fecha_vencimiento: document.getElementById('fechaVencimiento').value  || null,
        proveedor:         document.getElementById('proveedor').value.trim()  || null,
        notas:             document.getElementById('notas').value.trim()      || null,
        categoria: 'general'
      };

      try {
        const r = await fetch('/legal-pwa/permisos', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await r.json();
        if (data.ok) location.reload();
        else alert(data.error || 'Error guardando');
      } catch (e) { alert('Error de conexión'); }
    }

    let detallePermisoId = null;

    function abrirDetalle(p) {
      detallePermisoId = p.id;
      document.getElementById('detalleNombre').textContent = p.nombre;

      const rows = [
        { label: 'Estado',     value: { verde: '🟢 Vigente', naranja: '🟡 Por vencer', rojo: '🔴 Vencido', sin_fecha: '⚪ Sin fecha' }[p.estado] || p.estado },
        { label: 'Vencimiento', value: p.fechaFmt || '—' },
        { label: 'Empleado',   value: p.empleado_nombre || '—' },
        { label: 'Proveedor',  value: p.proveedor || '—' }
      ];

      document.getElementById('detalleBody').innerHTML = rows.map(r =>
        `<div class="detalle-row"><span class="dt-label">${r.label}</span><span class="dt-value">${r.value}</span></div>`
      ).join('');

      document.getElementById('deleteBtn').onclick = eliminarPermiso;
      document.getElementById('detalleSheet').classList.add('show');
    }

    async function eliminarPermiso() {
      if (!detallePermisoId) return;
      if (!confirm('¿Eliminar este permiso?')) return;
      try {
        const r = await fetch('/legal-pwa/permisos/' + detallePermisoId, { method: 'DELETE' });
        const data = await r.json();
        if (data.ok) location.reload();
        else alert(data.error || 'Error eliminando');
      } catch (e) { alert('Error de conexión'); }
    }
  </script>
  <script src="/js/dallia-fab.js"></script>
</body>
</html>
