<%# @variant: pwa %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title><%= feature %> — Próximamente</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      background: linear-gradient(160deg, #10152f 0%, #0a0f24 55%, #090d1d 100%);
      font-family: 'DM Sans', sans-serif;
      color: #fff;
      overflow: hidden;
    }
    .page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100dvh;
      padding: 32px 24px;
      padding-top: env(safe-area-inset-top, 16px);
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
      text-align: center;
    }

    /* Icon orb */
    .ec-orb {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: rgba(239,82,15,0.12);
      border: 1px solid rgba(239,82,15,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 44px;
      margin-bottom: 28px;
      position: relative;
    }
    .ec-orb::before {
      content: '';
      position: absolute;
      inset: -12px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(239,82,15,0.1) 0%, transparent 70%);
    }

    /* Text */
    .ec-badge {
      background: rgba(239,82,15,0.15);
      border: 1px solid rgba(239,82,15,0.35);
      color: #ef7435;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 16px;
    }
    .ec-title {
      font-size: 26px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 12px;
      line-height: 1.2;
    }
    .ec-desc {
      font-size: 15px;
      color: rgba(255,255,255,0.5);
      line-height: 1.55;
      max-width: 300px;
      margin-bottom: 32px;
    }
    .ec-eta {
      font-size: 13px;
      color: rgba(255,255,255,0.3);
      margin-bottom: 40px;
    }
    .ec-eta strong {
      color: rgba(255,255,255,0.55);
    }

    /* Back button */
    .ec-btn-back {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      padding: 14px 28px;
      border-radius: 14px;
      text-decoration: none;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: background 0.15s ease;
    }
    .ec-btn-back:active { background: rgba(255,255,255,0.12); }
    .ec-btn-back svg { width: 18px; height: 18px; }

    /* Dots decoration */
    .ec-dots {
      display: flex;
      gap: 8px;
      margin-top: 40px;
      opacity: 0.25;
    }
    .ec-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #ef520f;
      animation: pulse-dot 1.8s ease-in-out infinite;
    }
    .ec-dot:nth-child(2) { animation-delay: 0.3s; }
    .ec-dot:nth-child(3) { animation-delay: 0.6s; }
    @keyframes pulse-dot {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50%       { opacity: 1;   transform: scale(1.3); }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="ec-orb"><%= icon || '🚧' %></div>

    <div class="ec-badge">En construcción</div>

    <h1 class="ec-title"><%= feature %></h1>
    <p class="ec-desc">
      Esta función llegará pronto. Estamos trabajando en ella para darte la mejor experiencia.
    </p>

    <% if (eta) { %>
      <p class="ec-eta">Disponible: <strong><%= eta %></strong></p>
    <% } %>

    <a href="<%= backUrl || '/mas' %>" class="ec-btn-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
      Volver
    </a>

    <div class="ec-dots">
      <div class="ec-dot"></div>
      <div class="ec-dot"></div>
      <div class="ec-dot"></div>
    </div>
  </div>
</body>
</html>
