<%# @variant: pwa — Finanzas Pro: cash-flow overview, category breakdown, projection. %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#10152f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Finanzas Pro</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #F0F2F8;
      color: #0a0f24;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
      overscroll-behavior: none;
    }
    .shell {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      padding-bottom: calc(90px + env(safe-area-inset-bottom, 0px));
    }

    /* HEADER */
    .fn-header {
      background: linear-gradient(180deg, #10152f 0%, #0a0f24 100%);
      border-radius: 0 0 20px 20px;
      padding: calc(52px + env(safe-area-inset-top, 0px)) 20px 24px;
    }
    .fn-header-row { display: flex; align-items: center; justify-content: space-between; }
    .fn-header h1 { font-size: 22px; font-weight: 700; color: #fff; }
    .fn-header p { font-size: 13px; color: #8B8FAD; margin-top: 4px; }
    .fn-icon {
      width: 44px; height: 44px; border-radius: 14px;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      display: flex; align-items: center; justify-content: center; font-size: 22px; color: #fff; flex-shrink: 0;
    }

    /* TABS */
    .fn-tabs { display: flex; gap: 6px; padding: 16px 16px 4px; overflow-x: auto; scrollbar-width: none; }
    .fn-tabs::-webkit-scrollbar { display: none; }
    .fn-tab {
      padding: 8px 16px; border-radius: 99px; border: none; cursor: pointer;
      font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif;
      background: #fff; color: #8B8FAD; white-space: nowrap; transition: all .2s;
    }
    .fn-tab.active { background: linear-gradient(135deg, #ef520f, #df2c05); color: #fff; }

    /* SECTION */
    .section { padding: 12px 16px 4px; }
    .section-title { font-size: 12px; font-weight: 700; color: #8B8FAD; text-transform: uppercase; letter-spacing: .7px; margin-bottom: 10px; }

    /* KPI TRIO */
    .kpi-trio { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: 4px; }
    .kpi-mini {
      background: #fff; border-radius: 14px; padding: 14px 10px;
      text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    .kpi-mini .kpi-label { font-size: 10px; font-weight: 600; color: #8B8FAD; text-transform: uppercase; letter-spacing: .5px; }
    .kpi-mini .kpi-val { font-size: 18px; font-weight: 700; margin-top: 4px; line-height: 1; }
    .kpi-mini .kpi-val.green { color: #16a34a; }
    .kpi-mini .kpi-val.red { color: #ef4444; }
    .kpi-mini .kpi-val.orange { color: #f97316; }
    .kpi-mini .kpi-val.muted { color: #8B8FAD; }

    /* PROJECTION CARD */
    .proj-card {
      background: linear-gradient(135deg, #10152f, #0a0f24);
      border-radius: 16px; padding: 18px; margin-bottom: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,.12);
    }
    .proj-card .proj-label { font-size: 11px; font-weight: 700; color: #8B8FAD; text-transform: uppercase; letter-spacing: .7px; margin-bottom: 8px; }
    .proj-card .proj-val { font-size: 32px; font-weight: 700; color: #fff; line-height: 1; }
    .proj-card .proj-val span { font-size: 14px; font-weight: 400; color: #8B8FAD; }
    .proj-meta { display: flex; gap: 16px; margin-top: 10px; }
    .proj-meta-item { font-size: 11px; color: #8B8FAD; }
    .proj-meta-item strong { color: #fff; }

    /* CONCEPTO ROWS */
    .concepto-card {
      background: #fff; border-radius: 16px; padding: 14px 16px;
      margin-bottom: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.05);
      display: flex; align-items: center; gap: 12px;
    }
    .concepto-icon {
      width: 36px; height: 36px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0;
    }
    .concepto-icon.ingreso { background: #f0fdf4; color: #16a34a; }
    .concepto-icon.egreso  { background: #fef2f2; color: #ef4444; }
    .concepto-info { flex: 1; min-width: 0; }
    .concepto-name { font-size: 13px; font-weight: 600; color: #0a0f24; text-transform: capitalize; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .concepto-qty { font-size: 11px; color: #8B8FAD; }
    .concepto-val { font-size: 15px; font-weight: 700; flex-shrink: 0; }
    .concepto-val.green { color: #16a34a; }
    .concepto-val.red { color: #ef4444; }

    /* HISTORIAL */
    .hist-row {
      background: #fff; border-radius: 12px; padding: 12px 14px;
      margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;
    }
    .hist-fecha { font-size: 12px; font-weight: 600; color: #0a0f24; }
    .hist-caja-name { font-size: 11px; color: #8B8FAD; }
    .hist-val { text-align: right; }
    .hist-neto { font-size: 14px; font-weight: 700; }
    .hist-neto.pos { color: #16a34a; }
    .hist-neto.neg { color: #ef4444; }
    .hist-diff { font-size: 10px; color: #8B8FAD; }

    /* Panel visibility */
    .fn-panel { display: none; }
    .fn-panel.active { display: block; }
  </style>
</head>
<body>
<div class="shell">

  <!-- HEADER -->
  <div class="fn-header">
    <div class="fn-header-row">
      <div>
        <h1>Finanzas Pro</h1>
        <p>Flujo de caja · Proyecciones · Historial</p>
      </div>
      <a href="/chat?prompt=Analiza+mis+finanzas+de+hoy+y+dame+recomendaciones" class="fn-icon" style="text-decoration:none;display:flex;align-items:center;gap:6px;background:rgba(239,82,15,.12);border-radius:12px;padding:8px 12px;color:#ef520f;font-size:11px;font-weight:700;">
        <i class="bi bi-robot" style="font-size:16px;"></i><span>DalIA</span>
      </a>
    </div>
  </div>

  <!-- TABS -->
  <div class="fn-tabs">
    <button class="fn-tab active" onclick="switchTab('flujo', this)">Flujo</button>
    <button class="fn-tab" onclick="switchTab('conceptos', this)">Categorías</button>
    <button class="fn-tab" onclick="switchTab('historial', this)">Historial</button>
  </div>

  <%
    function fmt(n) { return 'S/' + Number(n||0).toFixed(0); }
    function netoClass(n) { return Number(n) >= 0 ? 'green' : 'red'; }

    // Concepto labels
    const conceptoLabels = {
      'venta_factura': 'Venta / Factura',
      'propina': 'Propinas',
      'retiro_caja_fuerte': 'Retiro Caja Fuerte',
      'retiro_banco': 'Retiro Banco',
      'retiro_propietario': 'Retiro Propietario',
      'gasto_compra_almacen': 'Compra Almacén',
      'gasto_servicio': 'Gasto Servicio',
      'gasto_otro': 'Gasto Otro',
      'pago_planilla': 'Pago Planilla',
      'devolucion_cliente': 'Devolución Cliente',
      'fondo_inicial': 'Fondo Inicial',
      'ajuste': 'Ajuste'
    };
    const conceptoIcon = {
      'venta_factura': '🧾', 'propina': '💵', 'retiro_caja_fuerte': '🔐',
      'retiro_banco': '🏦', 'retiro_propietario': '👤', 'gasto_compra_almacen': '🛒',
      'gasto_servicio': '💡', 'gasto_otro': '📦', 'pago_planilla': '👷',
      'devolucion_cliente': '↩️', 'fondo_inicial': '💰', 'ajuste': '⚖️'
    };
  %>

  <!-- PANEL: FLUJO -->
  <div class="fn-panel active" id="panel-flujo">
    <div class="section">
      <div class="section-title">Hoy</div>
      <div class="kpi-trio">
        <div class="kpi-mini">
          <div class="kpi-label">Ingresos</div>
          <div class="kpi-val green"><%= fmt(hoy.ingresos) %></div>
        </div>
        <div class="kpi-mini">
          <div class="kpi-label">Egresos</div>
          <div class="kpi-val red"><%= fmt(hoy.egresos) %></div>
        </div>
        <div class="kpi-mini">
          <div class="kpi-label">Neto</div>
          <div class="kpi-val <%= netoClass(hoy.neto) %>"><%= fmt(hoy.neto) %></div>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Esta semana</div>
      <div class="kpi-trio">
        <div class="kpi-mini">
          <div class="kpi-label">Ingresos</div>
          <div class="kpi-val green"><%= fmt(semana.ingresos) %></div>
        </div>
        <div class="kpi-mini">
          <div class="kpi-label">Egresos</div>
          <div class="kpi-val red"><%= fmt(semana.egresos) %></div>
        </div>
        <div class="kpi-mini">
          <div class="kpi-label">Neto</div>
          <div class="kpi-val <%= netoClass(semana.neto) %>"><%= fmt(semana.neto) %></div>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Este mes</div>
      <div class="kpi-trio">
        <div class="kpi-mini">
          <div class="kpi-label">Ingresos</div>
          <div class="kpi-val green"><%= fmt(mes.ingresos) %></div>
        </div>
        <div class="kpi-mini">
          <div class="kpi-label">Egresos</div>
          <div class="kpi-val red"><%= fmt(mes.egresos) %></div>
        </div>
        <div class="kpi-mini">
          <div class="kpi-label">Neto</div>
          <div class="kpi-val <%= netoClass(mes.neto) %>"><%= fmt(mes.neto) %></div>
        </div>
      </div>
    </div>

    <!-- PROYECCION -->
    <div class="section">
      <div class="section-title">Proyección fin de mes</div>
      <div class="proj-card">
        <div class="proj-label">Ingresos proyectados</div>
        <div class="proj-val"><%= fmt(proyeccion.fin_de_mes) %> <span>estimado</span></div>
        <div class="proj-meta">
          <div class="proj-meta-item">Promedio diario: <strong><%= fmt(proyeccion.promedio_diario) %></strong></div>
          <div class="proj-meta-item">Días restantes: <strong><%= proyeccion.dias_restantes %></strong></div>
        </div>
      </div>
    </div>
  </div>

  <!-- PANEL: CATEGORÍAS -->
  <div class="fn-panel" id="panel-conceptos">
    <div class="section">
      <div class="section-title">Categorías este mes</div>
      <% if (!conceptos || conceptos.length === 0) { %>
        <p style="color:#8B8FAD;font-size:13px;padding:20px 0;text-align:center">Sin movimientos este mes.</p>
      <% } else { %>
        <% for (const c of conceptos) { %>
          <div class="concepto-card">
            <div class="concepto-icon <%= c.tipo %>"><%= conceptoIcon[c.concepto] || '💳' %></div>
            <div class="concepto-info">
              <div class="concepto-name"><%= conceptoLabels[c.concepto] || c.concepto %></div>
              <div class="concepto-qty"><%= c.cantidad %> movimiento<%= c.cantidad != 1 ? 's' : '' %></div>
            </div>
            <div class="concepto-val <%= c.tipo === 'ingreso' ? 'green' : 'red' %>">
              <%= c.tipo === 'ingreso' ? '+' : '-' %><%= fmt(c.total) %>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>
  </div>

  <!-- PANEL: HISTORIAL -->
  <div class="fn-panel" id="panel-historial">
    <div class="section">
      <div class="section-title">Últimas cajas cerradas</div>
      <% if (!histCajas || histCajas.length === 0) { %>
        <p style="color:#8B8FAD;font-size:13px;padding:20px 0;text-align:center">No hay cajas cerradas aún.</p>
      <% } else { %>
        <% for (const c of histCajas) { %>
          <%
            const neto = Number(c.monto_cierre_real || 0) - Number(c.monto_apertura || 0);
            const diff = Number(c.diferencia || 0);
            const fecha = c.fecha_cierre ? new Date(c.fecha_cierre).toLocaleDateString('es-PE', { day:'2-digit', month:'short', year:'numeric' }) : '—';
          %>
          <div class="hist-row">
            <div>
              <div class="hist-fecha"><%= fecha %></div>
              <div class="hist-caja-name"><%= c.nombre_caja || 'Caja' %></div>
            </div>
            <div class="hist-val">
              <div class="hist-neto <%= neto >= 0 ? 'pos' : 'neg' %>"><%= fmt(Number(c.monto_cierre_real || 0)) %></div>
              <% if (Math.abs(diff) > 0.01) { %>
                <div class="hist-diff" style="color: <%= diff < 0 ? '#ef4444' : '#16a34a' %>">
                  Dif: <%= diff < 0 ? '' : '+' %><%= fmt(diff) %>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>
  </div>

</div>

<%- include('partials/limelight-nav', { reqPath: '/finanzas' }) %>

<script>
function switchTab(panel, btn) {
  document.querySelectorAll('.fn-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.fn-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-' + panel).classList.add('active');
}
// Auto-refresh every 60 seconds so KPIs stay current during the day
setInterval(function() { window.location.reload(); }, 60 * 1000);
</script>
<script src="/js/dallia-fab.js"></script>
<script src="/js/salva-alerts.js"></script>
</body>
</html>
