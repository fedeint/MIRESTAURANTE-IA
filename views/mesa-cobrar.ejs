<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= step === 'cobrar' ? 'Cobrar' : 'Cuenta' %> · Mesa <%= mesa.numero %> — MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #F0F2F8;
      height: 100dvh;
      overflow: hidden;
      max-width: 480px;
      margin: 0 auto;
    }
    .app-shell { display: flex; flex-direction: column; height: 100dvh; }

    /* HEADER */
    .app-header {
      background: linear-gradient(180deg, #10152f 0%, #0a0f24 60%, #090d1d 100%);
      border-radius: 0 0 20px 20px;
      padding: 48px 20px 20px;
      color: white; flex-shrink: 0;
    }
    .header-row { display: flex; align-items: center; gap: 10px; }
    .back-btn {
      background: rgba(255,255,255,0.12); border: none; color: white;
      width: 36px; height: 36px; border-radius: 10px;
      cursor: pointer; font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; text-decoration: none;
    }
    .header-title { font-size: 18px; font-weight: 700; flex: 1; }
    .header-right { font-size: 13px; color: rgba(255,255,255,0.7); white-space: nowrap; }
    .timer-orange { color: #ef520f; font-weight: 700; }

    /* CONTENT */
    .content-area {
      flex: 1; overflow-y: auto;
      padding: 16px 16px 180px;
      -webkit-overflow-scrolling: touch;
    }

    /* SECTION TITLE */
    .section-title { font-size: 12px; font-weight: 700; color: #8B8FAD; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px; }

    /* ITEM LIST */
    .item-card { background: white; border-radius: 16px; padding: 14px 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .item-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 7px 0; border-bottom: 1px solid #F0F2F8; font-size: 13px; color: #0a0f24;
    }
    .item-row:last-child { border-bottom: none; }
    .item-row.en-cocina { color: #ea580c; }
    .item-qty { color: #8B8FAD; }
    .item-price { font-weight: 600; }

    /* ALERT CHIP */
    .alert-cocina {
      background: #fff7ed; border: 1px solid #fed7aa;
      color: #c2410c; font-size: 12px; font-weight: 600;
      padding: 10px 14px; border-radius: 12px;
      margin-bottom: 12px; display: flex; align-items: center; gap: 8px;
    }

    /* TOTALES */
    .totales-card { background: white; border-radius: 16px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 12px; }
    .totales-row { display: flex; justify-content: space-between; padding: 5px 0; }
    .totales-label { font-size: 14px; color: #8B8FAD; }
    .totales-value { font-size: 14px; color: #0a0f24; font-weight: 500; }
    .totales-divider { height: 1px; background: #F0F2F8; margin: 8px 0; }
    .totales-total-label { font-size: 16px; font-weight: 700; color: #0a0f24; }
    .totales-total-value { font-size: 20px; font-weight: 700; color: #ef520f; }

    /* ── COBRAR SECTION ── */
    .cobrar-card { background: white; border-radius: 16px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .cobrar-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 0; border-bottom: 1px solid #F0F2F8; cursor: pointer;
    }
    .cobrar-row:last-child { border-bottom: none; }
    .cobrar-row-label { font-size: 14px; color: #0a0f24; font-weight: 500; }
    .cobrar-row-chevron { font-size: 18px; color: #8B8FAD; }

    /* PROPINA PILLS */
    .propina-label { font-size: 13px; font-weight: 600; color: #8B8FAD; margin-bottom: 8px; }
    .pills-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .pill-btn {
      padding: 8px 16px; border-radius: 20px; border: 1.5px solid #e2e5f0;
      background: white; color: #0a0f24; font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 600; cursor: pointer;
      transition: all 0.15s; -webkit-tap-highlight-color: transparent;
    }
    .pill-btn.active { background: #0a0f24; color: white; border-color: #0a0f24; }
    .propina-monto { font-size: 13px; color: #16a34a; font-weight: 600; margin-top: 8px; }
    .propina-custom-input {
      margin-top: 8px; padding: 10px 14px; border: 1.5px solid #e2e5f0;
      border-radius: 10px; font-family: 'DM Sans', sans-serif;
      font-size: 14px; width: 100%; outline: none;
    }
    .propina-custom-input:focus { border-color: #ef520f; }

    /* METODO DE PAGO */
    .metodo-grid { display: flex; gap: 8px; }
    .metodo-btn {
      flex: 1; padding: 10px 8px; border-radius: 12px; border: 1.5px solid #e2e5f0;
      background: white; color: #8B8FAD; font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 600; cursor: pointer; text-align: center;
      transition: all 0.15s; -webkit-tap-highlight-color: transparent;
    }
    .metodo-btn.active { background: #ef520f; color: white; border-color: #ef520f; }

    /* COMPROBANTE */
    .comp-grid { display: flex; gap: 8px; }
    .comp-btn {
      flex: 1; padding: 10px 8px; border-radius: 12px; border: 1.5px solid #e2e5f0;
      background: white; color: #8B8FAD; font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 600; cursor: pointer; text-align: center;
      transition: all 0.15s; -webkit-tap-highlight-color: transparent;
    }
    .comp-btn.active { background: #0a0f24; color: white; border-color: #0a0f24; }

    /* RESUMEN COBRAR */
    .resumen-card { background: white; border-radius: 16px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 12px; }
    .resumen-row { display: flex; justify-content: space-between; padding: 5px 0; }
    .resumen-label { font-size: 14px; color: #8B8FAD; }
    .resumen-value { font-size: 14px; color: #0a0f24; font-weight: 500; }
    .resumen-divider { height: 1px; background: #F0F2F8; margin: 8px 0; }
    .resumen-total-label { font-size: 15px; font-weight: 700; color: #0a0f24; }
    .resumen-total-value { font-size: 22px; font-weight: 700; color: #ef520f; }

    /* CTA PAIR */
    .cta-pair {
      position: fixed; bottom: 64px; left: 50%; transform: translateX(-50%);
      width: calc(100% - 32px); max-width: 448px;
      display: flex; gap: 10px; z-index: 50;
    }
    .cta-btn {
      flex: 1; padding: 15px 10px; border: none; border-radius: 16px;
      font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 700;
      cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: opacity 0.15s; -webkit-tap-highlight-color: transparent; text-decoration: none;
    }
    .cta-btn:active { opacity: 0.85; }
    .cta-full { flex: none; width: 100%; }
    .cta-orange { background: linear-gradient(135deg, #ef520f, #df2c05); color: white; box-shadow: 0 4px 16px rgba(239,82,15,0.4); }
    .cta-outline { background: white; color: #0a0f24; border: 2px solid #0a0f24; }
    .sticky-cta-single {
      position: fixed; bottom: 64px; left: 50%; transform: translateX(-50%);
      width: calc(100% - 32px); max-width: 448px; z-index: 50;
    }

    /* DESCUENTO MODAL */
    .desc-modal-bg {
      position: fixed; inset: 0; background: rgba(10,15,36,0.65);
      display: flex; align-items: flex-end; justify-content: center;
      z-index: 400; opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .desc-modal-bg.open { opacity: 1; pointer-events: auto; }
    .desc-modal {
      background: white; border-radius: 20px 20px 0 0;
      width: 100%; max-width: 480px;
      padding: 20px 20px calc(20px + env(safe-area-inset-bottom, 0px));
      transform: translateY(100%); transition: transform 0.25s ease;
    }
    .desc-modal-bg.open .desc-modal { transform: translateY(0); }
    .desc-modal-handle { width: 36px; height: 4px; background: #e2e5f0; border-radius: 2px; margin: 0 auto 20px; }
    .desc-modal-title { font-size: 16px; font-weight: 700; color: #0a0f24; margin-bottom: 16px; }
    .desc-input-row { display: flex; gap: 8px; }
    .desc-input {
      flex: 1; padding: 12px 14px; border: 1.5px solid #e2e5f0;
      border-radius: 12px; font-family: 'DM Sans', sans-serif;
      font-size: 15px; font-weight: 600; letter-spacing: 0.05em;
      text-transform: uppercase; outline: none;
    }
    .desc-input:focus { border-color: #ef520f; }
    .desc-apply-btn {
      padding: 12px 20px; background: linear-gradient(135deg,#ef520f,#df2c05);
      color: white; border: none; border-radius: 12px;
      font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 700;
      cursor: pointer; white-space: nowrap;
    }
    .desc-feedback {
      margin-top: 12px; font-size: 14px; font-weight: 600;
      display: none; padding: 10px 14px; border-radius: 10px;
    }
    .desc-feedback.ok  { display: block; background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .desc-feedback.err { display: block; background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .desc-done-btn {
      width: 100%; margin-top: 16px; padding: 14px;
      background: #0a0f24; color: white; border: none; border-radius: 14px;
      font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700;
      cursor: pointer; display: none;
    }
    .desc-skip-btn {
      width: 100%; margin-top: 10px; padding: 12px;
      background: transparent; color: #8B8FAD; border: none;
      font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500;
      cursor: pointer;
    }
    /* Cobrar-row clickable */
    #descuentoRow { cursor: pointer; user-select: none; -webkit-tap-highlight-color: transparent; }
    #descuentoRow:active { opacity: 0.75; }

    /* TOAST */
    .toast {
      position: fixed; top: 80px; left: 50%;
      transform: translateX(-50%) translateY(-20px);
      background: #0a0f24; color: white;
      padding: 12px 20px; border-radius: 12px;
      font-size: 14px; font-weight: 500;
      opacity: 0; transition: opacity 0.3s, transform 0.3s;
      z-index: 200; white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.success { background: #16a34a; }
    .toast.error { background: #dc2626; }

    .loading-overlay {
      position: fixed; inset: 0; background: rgba(10,15,36,0.7);
      display: flex; align-items: center; justify-content: center; z-index: 300;
    }
    .spinner {
      width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.2);
      border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none !important; }
  </style>
</head>
<body>
<div class="app-shell">

  <!-- HEADER -->
  <header class="app-header">
    <div class="header-row">
      <% if (step === 'cobrar') { %>
        <a href="/mesa/<%= mesa.id %>/cuenta" class="back-btn">&#8592;</a>
        <span class="header-title">Cobrar &middot; Mesa <%= mesa.numero %></span>
        <span class="header-right">S/ <%= Number(total).toFixed(2) %></span>
      <% } else { %>
        <a href="/mesa/<%= mesa.id %>" class="back-btn">&#8592;</a>
        <span class="header-title">Cuenta &middot; Mesa <%= mesa.numero %></span>
        <span class="header-right timer-orange" id="timerEl">&#9203; --</span>
      <% } %>
    </div>
  </header>

  <!-- CONTENT -->
  <div class="content-area">

    <% if (step === 'cuenta') { %>
      <!-- ── CUENTA MODE ── -->

      <%
        const itemsEnCocina = items.filter(function(i) {
          return i.estado_display === 'en_cocina';
        });
      %>

      <% if (itemsEnCocina.length > 0) { %>
        <div class="alert-cocina">
          &#9888;
          Ronda en cocina: <%= itemsEnCocina.map(function(i){ return i.cantidad + 'x ' + i.producto_nombre; }).join(', ') %>
        </div>
      <% } %>

      <div class="section-title">Detalle completo</div>
      <div class="item-card">
        <% items.forEach(function(item) { %>
          <div class="item-row <%= item.estado_display === 'en_cocina' ? 'en-cocina' : '' %>">
            <span>
              <span class="item-qty"><%= item.cantidad %>x</span>
              <%= item.producto_nombre %>
              <% if (item.estado_display === 'en_cocina') { %> &#9200;<% } %>
            </span>
            <span class="item-price">S/ <%= Number(item.subtotal).toFixed(2) %></span>
          </div>
        <% }); %>
      </div>

      <div class="totales-card">
        <div class="totales-row">
          <span class="totales-label">Subtotal</span>
          <span class="totales-value">S/ <%= Number(subtotal).toFixed(2) %></span>
        </div>
        <div class="totales-row">
          <span class="totales-label">IGV 18%</span>
          <span class="totales-value">S/ <%= Number(igv).toFixed(2) %></span>
        </div>
        <div class="totales-divider"></div>
        <div class="totales-row">
          <span class="totales-total-label">TOTAL</span>
          <span class="totales-total-value">S/ <%= Number(total).toFixed(2) %></span>
        </div>
      </div>

    <% } else { %>
      <!-- ── COBRAR MODE ── -->

      <!-- Discount row -->
      <div class="cobrar-card" id="descuentoRow" onclick="abrirDescuentoModal()">
        <div class="cobrar-row" style="border-bottom:none;">
          <span class="cobrar-row-label" id="descuentoLabel">&#127381; ¿Tiene código de descuento?</span>
          <span class="cobrar-row-chevron" id="descuentoChevron">›</span>
        </div>
      </div>

      <!-- Propina -->
      <div class="cobrar-card">
        <div class="propina-label">Propina</div>
        <div class="pills-row" id="propinaPills">
          <button class="pill-btn active" data-pct="0"   onclick="selectPropina(this,0)">Sin</button>
          <button class="pill-btn"        data-pct="5"   onclick="selectPropina(this,5)">5%</button>
          <button class="pill-btn"        data-pct="10"  onclick="selectPropina(this,10)">10%</button>
          <button class="pill-btn"        data-pct="15"  onclick="selectPropina(this,15)">15%</button>
          <button class="pill-btn"        data-pct="-1"  onclick="selectPropina(this,-1)">Otro</button>
        </div>
        <input type="number" class="propina-custom-input hidden" id="propinaCustInput"
               placeholder="%" min="0" max="100" oninput="updateCustomPropina(this.value)">
        <div class="propina-monto" id="propinaMontoEl" style="display:none"></div>
      </div>

      <!-- Método de pago -->
      <div class="cobrar-card">
        <div class="propina-label">Método de pago</div>
        <div class="metodo-grid">
          <button class="metodo-btn active" data-metodo="efectivo"  onclick="selectMetodo(this,'efectivo')">Efectivo</button>
          <button class="metodo-btn"        data-metodo="tarjeta"   onclick="selectMetodo(this,'tarjeta')">Tarjeta</button>
          <button class="metodo-btn"        data-metodo="yape"      onclick="selectMetodo(this,'yape')">Yape</button>
        </div>
      </div>

      <!-- Comprobante -->
      <div class="cobrar-card">
        <div class="propina-label">Comprobante</div>
        <div class="comp-grid">
          <button class="comp-btn active" data-comp="boleta"  onclick="selectComp(this,'boleta')">Boleta</button>
          <button class="comp-btn"        data-comp="factura" onclick="selectComp(this,'factura')">Factura</button>
        </div>
      </div>

      <!-- Resumen -->
      <div class="resumen-card" id="resumenCard">
        <div class="resumen-row">
          <span class="resumen-label">Consumo</span>
          <span class="resumen-value">S/ <%= Number(total).toFixed(2) %></span>
        </div>
        <div class="resumen-row" id="descuentoResumenRow" style="display:none;">
          <span class="resumen-label" style="color:#16a34a;">Descuento <span id="descuentoLabelPct"></span></span>
          <span class="resumen-value" style="color:#16a34a;" id="descuentoResumen">- S/ 0.00</span>
        </div>
        <div class="resumen-row">
          <span class="resumen-label">Propina <span id="propinaLabelPct">0%</span></span>
          <span class="resumen-value" id="propinaResumen">S/ 0.00</span>
        </div>
        <div class="resumen-divider"></div>
        <div class="resumen-row">
          <span class="resumen-total-label">TOTAL A COBRAR</span>
          <span class="resumen-total-value" id="totalFinalEl">S/ <%= Number(total).toFixed(2) %></span>
        </div>
      </div>

    <% } %>
  </div>

  <!-- CTAs -->
  <% if (step === 'cuenta') { %>
    <div class="cta-pair">
      <button class="cta-btn cta-outline">Dividir cuenta</button>
      <a href="/mesa/<%= mesa.id %>/cobrar" class="cta-btn cta-orange">
        Cobrar S/ <%= Number(total).toFixed(2) %>
      </a>
    </div>
  <% } else { %>
    <div class="sticky-cta-single">
      <button class="cta-btn cta-orange cta-full" id="ctaCobrar" onclick="procesarCobro()">
        &#10003; Cobrar y emitir boleta
      </button>
    </div>
  <% } %>

  <%- include('partials/limelight-nav', { reqPath: '/pedidos' }) %>
</div>

<!-- DISCOUNT MODAL -->
<div class="desc-modal-bg" id="descModalBg">
  <div class="desc-modal">
    <div class="desc-modal-handle"></div>
    <div class="desc-modal-title">&#127381; Código de descuento</div>
    <div class="desc-input-row">
      <input type="text" class="desc-input" id="descCodigoInput"
             placeholder="Ej: VERANO10" maxlength="50"
             oninput="this.value=this.value.toUpperCase()">
      <button class="desc-apply-btn" onclick="aplicarDescuento()">Aplicar</button>
    </div>
    <div class="desc-feedback" id="descFeedback"></div>
    <button class="desc-done-btn" id="descDoneBtn" onclick="cerrarDescuentoModal()">Confirmar descuento</button>
    <button class="desc-skip-btn" onclick="saltarDescuento()">Continuar sin descuento</button>
  </div>
</div>

<div class="toast" id="toast"></div>
<div class="loading-overlay hidden" id="loadingOverlay"><div class="spinner"></div></div>

<script>
  const MESA_ID       = <%= mesa.id %>;
  const BASE_TOTAL    = <%= Number(total) %>;
  const STEP          = '<%= step %>';

  // ── Timer for cuenta mode ───────────────────────────────────────────
  if (STEP === 'cuenta') {
    (function() {
      const createdAt = '<%= pedido ? new Date(pedido.created_at).toISOString() : "" %>';
      const timerEl   = document.getElementById('timerEl');
      function updateTimer() {
        if (!createdAt) return;
        const diff = Math.floor((Date.now() - new Date(createdAt).getTime()) / 1000);
        if (diff < 0) return;
        const h = Math.floor(diff / 3600);
        const m = Math.floor((diff % 3600) / 60);
        if (timerEl) timerEl.textContent = '\u23F1 ' + (h ? h + 'h ' : '') + m + 'm';
      }
      updateTimer();
      setInterval(updateTimer, 30000);
    })();
  }

  // ── Cobrar mode logic ───────────────────────────────────────────────
  let propinaPct       = 0;
  let metodoPago       = 'efectivo';
  let comprobante      = 'boleta';
  let descuentoMonto   = 0;
  let descuentoCodigo  = '';
  let descuentoPromoId = null;

  // ── Descuento modal ─────────────────────────────────────────────────
  function abrirDescuentoModal() {
    document.getElementById('descModalBg').classList.add('open');
  }
  function cerrarDescuentoModal() {
    document.getElementById('descModalBg').classList.remove('open');
    recalcTotal();
  }
  function saltarDescuento() {
    descuentoMonto   = 0;
    descuentoCodigo  = '';
    descuentoPromoId = null;
    document.getElementById('descModalBg').classList.remove('open');
    recalcTotal();
    updateDescuentoRow();
  }
  function updateDescuentoRow() {
    const lbl = document.getElementById('descuentoLabel');
    const chv = document.getElementById('descuentoChevron');
    if (descuentoMonto > 0) {
      lbl.textContent = '✅ Descuento: ' + descuentoCodigo + ' (- S/ ' + descuentoMonto.toFixed(2) + ')';
      lbl.style.color = '#16a34a';
      chv.textContent = '✕';
    } else {
      lbl.textContent = '🏷️ ¿Tiene código de descuento?';
      lbl.style.color = '';
      chv.textContent = '›';
    }
  }
  async function aplicarDescuento() {
    const codigo = document.getElementById('descCodigoInput').value.trim();
    const fb     = document.getElementById('descFeedback');
    if (!codigo) { fb.textContent = 'Ingresa un código'; fb.className = 'desc-feedback err'; return; }
    fb.textContent = ''; fb.className = 'desc-feedback';

    try {
      const resp = await fetch('/mesa/descuento/validar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ codigo, total_actual: BASE_TOTAL })
      });
      const data = await resp.json();
      if (data.valido) {
        descuentoMonto   = data.descuento_monto;
        descuentoCodigo  = codigo;
        descuentoPromoId = data.promo_id || null;
        fb.innerHTML = '✅ ' + (data.nombre || 'Descuento aplicado') + ': - S/ ' + descuentoMonto.toFixed(2);
        fb.className = 'desc-feedback ok';
        document.getElementById('descDoneBtn').style.display = '';
      } else {
        descuentoMonto = 0; descuentoCodigo = ''; descuentoPromoId = null;
        fb.textContent = '❌ ' + (data.motivo || 'Código inválido');
        fb.className = 'desc-feedback err';
        document.getElementById('descDoneBtn').style.display = 'none';
      }
    } catch (e) {
      fb.textContent = 'Error de conexión'; fb.className = 'desc-feedback err';
    }
  }
  document.getElementById('descCodigoInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') aplicarDescuento();
  });

  function selectPropina(el, pct) {
    document.querySelectorAll('.pill-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    const custInput = document.getElementById('propinaCustInput');
    if (pct === -1) {
      custInput.classList.remove('hidden');
      propinaPct = 0;
    } else {
      custInput.classList.add('hidden');
      propinaPct = pct;
    }
    recalcTotal();
  }

  function updateCustomPropina(val) {
    propinaPct = Math.max(0, Math.min(100, Number(val) || 0));
    recalcTotal();
  }

  function selectMetodo(el, val) {
    document.querySelectorAll('.metodo-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    metodoPago = val;
  }

  function selectComp(el, val) {
    document.querySelectorAll('.comp-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    comprobante = val;
    const btn = document.getElementById('ctaCobrar');
    if (btn) btn.textContent = '\u2713 Cobrar y emitir ' + val;
  }

  function recalcTotal() {
    const afterDiscount = Math.max(0, BASE_TOTAL - descuentoMonto);
    const propinaMonto  = Math.round(afterDiscount * (propinaPct / 100) * 100) / 100;
    const totalFinal    = Math.round((afterDiscount + propinaMonto) * 100) / 100;
    const montoEl       = document.getElementById('propinaMontoEl');
    const resumenEl     = document.getElementById('propinaResumen');
    const totalEl       = document.getElementById('totalFinalEl');
    const labelEl       = document.getElementById('propinaLabelPct');
    const descRow       = document.getElementById('descuentoResumenRow');
    const descVal       = document.getElementById('descuentoResumen');
    const descPct       = document.getElementById('descuentoLabelPct');

    if (descuentoMonto > 0) {
      if (descRow) descRow.style.display = '';
      if (descVal) descVal.textContent = '- S/ ' + descuentoMonto.toFixed(2);
      if (descPct) descPct.textContent = descuentoCodigo ? '(' + descuentoCodigo + ')' : '';
    } else {
      if (descRow) descRow.style.display = 'none';
    }
    if (propinaMonto > 0) {
      if (montoEl) { montoEl.style.display = ''; montoEl.textContent = '+ S/ ' + propinaMonto.toFixed(2); }
    } else {
      if (montoEl) montoEl.style.display = 'none';
    }
    if (resumenEl) resumenEl.textContent = 'S/ ' + propinaMonto.toFixed(2);
    if (totalEl)   totalEl.textContent   = 'S/ ' + totalFinal.toFixed(2);
    if (labelEl)   labelEl.textContent   = (propinaPct > 0 ? propinaPct + '%' : '0%');
    updateDescuentoRow();
  }

  function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = 'toast ' + (type || '');
    t.classList.add('show');
    setTimeout(function() { t.classList.remove('show'); }, 3000);
  }

  async function procesarCobro() {
    document.getElementById('loadingOverlay').classList.remove('hidden');
    try {
      const res  = await fetch('/mesa/' + MESA_ID + '/cobrar', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          propina_pct:       propinaPct,
          metodo_pago:       metodoPago,
          tipo_comprobante:  comprobante,
          codigo_descuento:  descuentoCodigo || null,
          descuento_monto:   descuentoMonto  || 0,
          promo_id:          descuentoPromoId || null
        })
      });
      const data = await res.json();
      if (data.ok) {
        showToast('Cobro registrado correctamente', 'success');
        setTimeout(function() { window.location.href = data.redirect || '/pedidos'; }, 1200);
      } else {
        showToast(data.error || 'Error al cobrar', 'error');
      }
    } catch (e) {
      showToast('Error de conexión', 'error');
    } finally {
      document.getElementById('loadingOverlay').classList.add('hidden');
    }
  }
</script>
<script src="/js/dallia-fab.js"></script>
</body>
</html>
