<%# @variant: pwa %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Mesas">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <title>Mesas</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #0f172a;
      color: #fff;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
      overscroll-behavior: none;
    }
    .shell {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    }

    /* FILTER TABS */
    .m-filters {
      display: flex;
      gap: 6px;
      padding: 14px 16px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .m-filters::-webkit-scrollbar { display: none; }
    .m-filter-btn {
      background: #1e293b;
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.55);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      padding: 8px 14px;
      border-radius: 20px;
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
      transition: all 0.15s ease;
    }
    .m-filter-btn.active {
      background: linear-gradient(135deg,#ef520f,#df2c05);
      color: #fff;
      border-color: transparent;
    }

    /* GRID */
    .m-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      padding: 0 12px;
    }

    /* MESA CARD */
    .m-card {
      border-radius: 16px;
      padding: 16px 14px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: transform 0.1s, opacity 0.1s;
      border: 1px solid rgba(255,255,255,0.07);
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .m-card:active { transform: scale(0.96); opacity: 0.85; }

    /* Status colors */
    .m-card.libre     { background: #1e293b; }
    .m-card.ocupada   { background: linear-gradient(135deg, rgba(239,82,15,0.18), rgba(223,44,5,0.1)); border-color: rgba(239,82,15,0.25); }
    .m-card.reservada { background: linear-gradient(135deg, rgba(99,102,241,0.18), rgba(99,102,241,0.08)); border-color: rgba(99,102,241,0.25); }
    .m-card.bloqueada { background: linear-gradient(135deg, rgba(107,114,128,0.18), rgba(107,114,128,0.08)); border-color: rgba(107,114,128,0.2); }

    /* Status dot */
    .m-status-dot {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .libre     .m-status-dot { background: #22c55e; }
    .ocupada   .m-status-dot { background: #ef520f; }
    .reservada .m-status-dot { background: #6366f1; }
    .bloqueada .m-status-dot { background: #6b7280; }

    /* Mesa number */
    .m-number {
      font-size: 28px;
      font-weight: 800;
      color: #fff;
      line-height: 1;
    }
    .m-number-label {
      font-size: 10px;
      color: rgba(255,255,255,0.4);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 2px;
    }

    /* Status label */
    .m-status-label {
      font-size: 12px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 8px;
      width: fit-content;
    }
    .libre     .m-status-label { background: rgba(34,197,94,0.15);  color: #86efac; }
    .ocupada   .m-status-label { background: rgba(239,82,15,0.2);   color: #fda574; }
    .reservada .m-status-label { background: rgba(99,102,241,0.2);  color: #a5b4fc; }
    .bloqueada .m-status-label { background: rgba(107,114,128,0.2); color: #d1d5db; }

    /* Mesero / items info */
    .m-meta {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      line-height: 1.4;
    }

    /* Empty state */
    .m-empty {
      grid-column: 1/-1;
      padding: 48px 16px;
      text-align: center;
      color: rgba(255,255,255,0.3);
      font-size: 14px;
    }

    /* Summary badge in header */
    .m-badge {
      background: rgba(239,82,15,0.2);
      color: #fda574;
      font-size: 11px;
      font-weight: 700;
      padding: 2px 9px;
      border-radius: 10px;
    }
  </style>
</head>
<body>
<% var mesas = locals.mesas || []; var currentUserRol = locals.currentUserRol || ''; %>
<% var ocupadas = mesas.filter(function(m){ return m.estado === 'ocupada'; }).length; %>
<div class="shell">

  <%- include('partials/pwa-header', {
    title: 'Mesas',
    subtitle: ocupadas + ' mesa' + (ocupadas !== 1 ? 's' : '') + ' ocupada' + (ocupadas !== 1 ? 's' : '')
  }) %>

  <!-- FILTER TABS -->
  <div class="m-filters">
    <button class="m-filter-btn active" data-filter="todas">Todas <span id="cntTodas"><%= mesas.length %></span></button>
    <button class="m-filter-btn" data-filter="libre">Libres <span id="cntLibre"><%= mesas.filter(function(m){return m.estado==='libre';}).length %></span></button>
    <button class="m-filter-btn" data-filter="ocupada">Ocupadas <span id="cntOcupada"><%= ocupadas %></span></button>
    <button class="m-filter-btn" data-filter="reservada">Reservadas <span id="cntReservada"><%= mesas.filter(function(m){return m.estado==='reservada';}).length %></span></button>
    <% if (currentUserRol === 'mesero') { %>
    <button class="m-filter-btn" data-filter="mis">Mis mesas</button>
    <% } %>
  </div>

  <!-- GRID -->
  <div class="m-grid" id="mesasGrid">
    <% mesas.forEach(function(mesa) { %>
    <div class="m-card <%= mesa.estado %>" data-estado="<%= mesa.estado %>"
         data-mesa-id="<%= mesa.id %>"
         onclick="abrirMesa(<%= mesa.id %>, '<%= mesa.numero %>', '<%= mesa.estado %>')">
      <div class="m-status-dot"></div>
      <div>
        <div class="m-number"><%= mesa.numero %></div>
        <div class="m-number-label">Mesa</div>
      </div>
      <div class="m-status-label">
        <% if (mesa.estado === 'libre') { %>Libre
        <% } else if (mesa.estado === 'ocupada') { %>Ocupada
        <% } else if (mesa.estado === 'reservada') { %>Reservada
        <% } else { %>Bloqueada<% } %>
      </div>
      <% if (mesa.estado === 'ocupada' && mesa.items_activos > 0) { %>
      <div class="m-meta"><%= mesa.items_activos %> ítem<%= mesa.items_activos !== 1 ? 's' : '' %> activo<%= mesa.items_activos !== 1 ? 's' : '' %></div>
      <% } else if (mesa.mesero_asignado_nombre) { %>
      <div class="m-meta">👤 <%= mesa.mesero_asignado_nombre.split(' ')[0] %></div>
      <% } %>
    </div>
    <% }); %>
    <% if (mesas.length === 0) { %>
    <div class="m-empty">No hay mesas configuradas</div>
    <% } %>
  </div>

</div>

<%- include('partials/limelight-nav', { reqPath: '/mesas' }) %>

<script>
(function() {
  // Filter
  var currentFilter = 'todas';
  var currentUserId = <%= JSON.stringify(locals.currentUserId) %>;
  var allCards = Array.from(document.querySelectorAll('.m-card[data-mesa-id]'));

  document.querySelectorAll('.m-filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentFilter = btn.dataset.filter;
      document.querySelectorAll('.m-filter-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      applyFilter();
    });
  });

  function applyFilter() {
    allCards.forEach(function(card) {
      var estado = card.dataset.estado;
      var show = true;
      if (currentFilter === 'libre')    show = estado === 'libre';
      else if (currentFilter === 'ocupada')   show = estado === 'ocupada';
      else if (currentFilter === 'reservada') show = estado === 'reservada';
      // 'mis' and 'todas': show all for now (mis mesa filtering would need server-side data)
      card.style.display = show ? '' : 'none';
    });
  }
})();

// Navigate to mesa detail / order page
function abrirMesa(mesaId, numero, estado) {
  if (estado === 'bloqueada') return;
  // Navigate to new order flow for this mesa
  window.location.href = '/pedido-nuevo?mesa=' + mesaId;
}

// Auto-refresh every 30s to reflect table state changes
setInterval(function() { window.location.reload(); }, 30 * 1000);
</script>
<script src="/js/dallia-fab.js"></script>
<script src="/js/salva-alerts.js"></script>
</body>
</html>
