<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary-dark: #10152f;
            --primary-darker: #0a0f24;
            --orange: #ef520f;
            --secondary: #8B8FAD;
        }

        body {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-darker) 100%);
            color: #fff;
            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--primary-darker);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 1.5rem;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            background: linear-gradient(135deg, var(--orange), #df2c05);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .container-fluid {
            padding: 2rem;
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .page-header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .page-header p {
            color: var(--secondary);
            font-size: 1.1rem;
        }

        .filter-section {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .filter-section select {
            background-color: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.95rem;
        }

        .filter-section select option {
            background-color: var(--primary-darker);
            color: #fff;
        }

        .stat-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            backdrop-filter: blur(10px);
        }

        .stat-label {
            color: var(--secondary);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .stat-trend {
            color: #22C55E;
            font-size: 0.85rem;
        }

        .stat-trend.negative {
            color: #EF4444;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(600px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .dashboard-panel {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .dashboard-panel-header {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            font-weight: 600;
            font-size: 1.1rem;
        }

        .dashboard-panel-body {
            padding: 1.5rem;
            min-height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--secondary);
        }

        .iframe-container {
            width: 100%;
            height: 100%;
            min-height: 600px;
        }

        .iframe-container iframe {
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 8px;
        }

        .loading {
            text-align: center;
            padding: 2rem;
            color: var(--secondary);
        }

        .loading-spinner {
            border: 2px solid rgba(255,255,255,0.1);
            border-top: 2px solid var(--orange);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 1rem;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .alert-badge {
            display: inline-block;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-right: 1rem;
            margin-bottom: 1rem;
        }

        .alert-badge.error {
            background-color: rgba(239, 68, 68, 0.2);
            color: #FCA5A5;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .alert-badge.warning {
            background-color: rgba(249, 115, 22, 0.2);
            color: #FDBA74;
            border: 1px solid rgba(249, 115, 22, 0.3);
        }

        .back-link {
            color: var(--orange);
            text-decoration: none;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .back-link:hover {
            color: #df2c05;
        }

        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .page-header h1 {
                font-size: 1.8rem;
            }

            .filter-section {
                flex-direction: column;
            }

            .filter-section select {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/superadmin">
                <i class="bi bi-robot"></i> MiRestcon IA
            </a>
            <div class="navbar-text" style="color: var(--secondary); font-size: 0.9rem;">
                <i class="bi bi-shield-check"></i> Superman Panel
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid">
        <!-- Back Button -->
        <a href="/superadmin" class="back-link">
            <i class="bi bi-arrow-left"></i> Volver a Dashboard
        </a>

        <!-- Page Header -->
        <div class="page-header">
            <h1><%= pageTitle %></h1>
            <p>Comportamiento de usuarios con asistente IA DallIA</p>
        </div>

        <!-- Filters -->
        <div class="filter-section">
            <select id="dateRangeSelect" onchange="updateDashboard()">
                <option value="7d" <%= dateRange === '7d' ? 'selected' : '' %>>Últimos 7 días</option>
                <option value="30d" <%= dateRange === '30d' ? 'selected' : '' %>>Últimos 30 días</option>
                <option value="90d" <%= dateRange === '90d' ? 'selected' : '' %>>Últimos 90 días</option>
            </select>
            <select id="tenantSelect" onchange="updateDashboard()">
                <option value="all" <%= tenantId === 'all' ? 'selected' : '' %>>Todos los tenants</option>
                <option value="42">Corkys Restaurant</option>
                <option value="15">La Pólvora</option>
                <!-- Cargar dinámicamente -->
            </select>
        </div>

        <!-- Alert Section -->
        <div id="alertsContainer"></div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Preguntas totales</div>
                    <div class="stat-value" id="totalQuestions">-</div>
                    <div class="stat-trend">Ultimos 7 días</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Rating positivo</div>
                    <div class="stat-value" id="positiveRating">-</div>
                    <div class="stat-trend">Excelente 📈</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Tenants usando DallIA</div>
                    <div class="stat-value" id="tenantsActive">-</div>
                    <div class="stat-trend">Adoption %</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Tiempo respuesta (p95)</div>
                    <div class="stat-value" id="latencyP95">-</div>
                    <div class="stat-trend">< 3s óptimo</div>
                </div>
            </div>
        </div>

        <!-- Dashboards Grid -->
        <div class="dashboard-grid">
            <!-- PostHog Overview -->
            <div class="dashboard-panel">
                <div class="dashboard-panel-header">
                    <i class="bi bi-graph-up"></i> Tendencia Preguntas
                </div>
                <div class="dashboard-panel-body">
                    <div class="loading">
                        <div class="loading-spinner"></div>
                        <p>Cargando datos de PostHog...</p>
                        <small style="color: var(--secondary); margin-top: 1rem; display: block;">
                            Si PostHog no está configurado, ConfigURA <code>POSTHOG_API_KEY</code> en .env
                        </small>
                    </div>
                </div>
            </div>

            <!-- Categories Top -->
            <div class="dashboard-panel">
                <div class="dashboard-panel-header">
                    <i class="bi bi-tags"></i> Categorías Top
                </div>
                <div class="dashboard-panel-body">
                    <div style="width: 100%;">
                        <div style="display: flex; align-items: center; margin-bottom: 1rem; justify-content: space-between;">
                            <span>propinas</span>
                            <div style="flex-grow: 1; margin: 0 1rem; background: rgba(255,255,255,0.1); height: 6px; border-radius: 3px;">
                                <div style="background: linear-gradient(90deg, var(--orange), #df2c05); height: 100%; width: 35%; border-radius: 3px;"></div>
                            </div>
                            <span style="color: var(--secondary); font-size: 0.85rem;">14%</span>
                        </div>
                        <div style="display: flex; align-items: center; margin-bottom: 1rem; justify-content: space-between;">
                            <span>legal</span>
                            <div style="flex-grow: 1; margin: 0 1rem; background: rgba(255,255,255,0.1); height: 6px; border-radius: 3px;">
                                <div style="background: linear-gradient(90deg, var(--orange), #df2c05); height: 100%; width: 22%; border-radius: 3px;"></div>
                            </div>
                            <span style="color: var(--secondary); font-size: 0.85rem;">8.6%</span>
                        </div>
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <span>personal</span>
                            <div style="flex-grow: 1; margin: 0 1rem; background: rgba(255,255,255,0.1); height: 6px; border-radius: 3px;">
                                <div style="background: linear-gradient(90deg, var(--orange), #df2c05); height: 100%; width: 18%; border-radius: 3px;"></div>
                            </div>
                            <span style="color: var(--secondary); font-size: 0.85rem;">7.3%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Session Replay -->
        <div class="dashboard-panel" style="margin-bottom: 2rem;">
            <div class="dashboard-panel-header">
                <i class="bi bi-play-circle"></i> Session Replay (PostHog)
            </div>
            <div class="dashboard-panel-body">
                <div style="width: 100%; text-align: center;">
                    <p>Filtros: usuarios que no escribieron pregunta en 1 minuto</p>
                    <p style="color: var(--secondary); margin-top: 1rem;">
                        <a href="<%= posthogHost %>/projects/<%= posthogProjectId %>/sessions" target="_blank" style="color: var(--orange); text-decoration: none;">
                            Ver todas las sesiones en PostHog →
                        </a>
                    </p>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div style="text-align: center; padding: 2rem; color: var(--secondary); border-top: 1px solid rgba(255,255,255,0.1);">
            <p style="margin: 0;">
                <small>
                    Dashboard automático • Datos actualizados cada 5 minutos
                    <br>
                    <a href="/superadmin" style="color: var(--orange); text-decoration: none;">← Volver a Superman</a>
                </small>
            </p>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        function updateDashboard() {
            const dateRange = document.getElementById('dateRangeSelect').value;
            const tenantId = document.getElementById('tenantSelect').value;
            window.location.href = `/superadmin/analytics/dallia?date=${dateRange}&tenant=${tenantId}`;
        }

        // Auto-refresh every 5 minutes
        setTimeout(() => {
            location.reload();
        }, 5 * 60 * 1000);
    </script>

  <%- include('../partials/superadmin-mobile-nav', { activeTab: 'mas' }) %>
</body>
</html>
