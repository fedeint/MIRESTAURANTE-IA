<%# @variant: pwa %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bóveda — MiRestcon</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: #0f172a; font-family: 'DM Sans', sans-serif; }
    .dg-main { background: #0f172a; min-height: 100vh; }

    /* LOCK SCREEN */
    .lock-screen {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; min-height: 80vh; gap: 20px; padding: 32px;
      text-align: center;
    }
    .lock-icon {
      width: 80px; height: 80px; border-radius: 24px;
      background: linear-gradient(135deg, #1e2235, #2a3050);
      border: 2px solid rgba(249,115,22,0.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 36px;
    }
    .lock-title { font-size: 22px; font-weight: 700; color: #fff; margin: 0; }
    .lock-sub { font-size: 13px; color: #64748b; margin: 0; }
    .biometric-btn {
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      padding: 20px 32px; border-radius: 20px;
      background: linear-gradient(135deg, rgba(249,115,22,0.1), rgba(239,82,15,0.05));
      border: 2px solid rgba(249,115,22,0.3);
      color: #f97316; cursor: pointer; transition: all .2s;
      font-size: 14px; font-weight: 600;
    }
    .biometric-btn:hover { border-color: #f97316; background: rgba(249,115,22,0.15); transform: scale(1.02); }
    .biometric-btn i { font-size: 40px; }
    .biometric-btn .bio-label { font-size: 11px; color: #64748b; }

    /* VAULT */
    .vault-screen { display: none; }
    .vault-header {
      padding: 16px; background: #1e2235;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: center; gap: 10px;
    }
    .vault-search {
      flex: 1; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px; padding: 8px 12px; color: #fff; font-size: 13px;
      outline: none;
    }
    .vault-search::placeholder { color: #475569; }

    /* CATEGORIES */
    .cat-bar {
      display: flex; gap: 6px; padding: 10px 16px;
      background: #1a1f30; overflow-x: auto; scrollbar-width: none;
    }
    .cat-bar::-webkit-scrollbar { display: none; }
    .cat-chip {
      flex-shrink: 0; padding: 4px 12px; border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.1); background: transparent;
      color: #64748b; font-size: 11px; font-weight: 600; cursor: pointer;
      transition: all .15s;
    }
    .cat-chip.active { background: rgba(249,115,22,0.15); color: #f97316; border-color: rgba(249,115,22,0.4); }

    /* ITEMS */
    .vault-list { padding: 8px 0; }
    .vault-item {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.04);
      cursor: pointer; transition: background .15s;
    }
    .vault-item:hover { background: rgba(255,255,255,0.03); }
    .vault-item-icon {
      width: 40px; height: 40px; border-radius: 12px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center; font-size: 18px;
    }
    .vault-item-info { flex: 1; min-width: 0; }
    .vault-item-title { font-size: 13px; font-weight: 600; color: #e2e8f0; }
    .vault-item-user { font-size: 11px; color: #475569; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .vault-item-cat { font-size: 9px; font-weight: 700; text-transform: uppercase; padding: 1px 6px; border-radius: 6px; }

    /* FAB */
    .vault-fab {
      position: fixed; bottom: 80px; right: 20px;
      width: 52px; height: 52px; border-radius: 50%;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      border: none; color: #fff; font-size: 22px;
      box-shadow: 0 4px 20px rgba(239,82,15,0.4);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; z-index: 30;
    }

    /* MODAL DETALLE */
    .vault-modal-backdrop {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.7); z-index: 50; backdrop-filter: blur(4px);
      align-items: flex-end; justify-content: center;
    }
    .vault-modal-backdrop.show { display: flex; }
    .vault-modal {
      background: #1e2235; border-radius: 24px 24px 0 0;
      width: 100%; max-width: 480px; padding: 20px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .vault-modal-title { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 16px; }
    .vault-field { margin-bottom: 12px; }
    .vault-field-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #475569; margin-bottom: 4px; }
    .vault-field-value {
      display: flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.05); border-radius: 10px;
      padding: 10px 12px;
    }
    .vault-field-text { flex: 1; font-size: 13px; color: #e2e8f0; font-family: monospace; }
    .vault-field-text.masked { letter-spacing: 3px; }
    .copy-btn {
      padding: 4px 10px; border-radius: 6px; border: none;
      background: rgba(249,115,22,0.15); color: #f97316;
      font-size: 11px; cursor: pointer;
    }
    .toggle-btn {
      padding: 4px 8px; border-radius: 6px; border: none;
      background: rgba(255,255,255,0.05); color: #94a3b8;
      font-size: 11px; cursor: pointer;
    }

    /* EMPTY */
    .vault-empty {
      display: flex; flex-direction: column; align-items: center;
      padding: 60px 20px; gap: 8px; color: #475569; text-align: center;
    }
  </style>
</head>
<body>
<%- include('../partials/sidebar') %>
<div class="dg-main">

  <!-- LOCK SCREEN -->
  <div class="lock-screen" id="lockScreen">
    <div class="lock-icon">🔐</div>
    <h2 class="lock-title">Bóveda de contraseñas</h2>
    <p class="lock-sub">Verifica tu identidad con biometría<br>para acceder a las credenciales</p>

    <!-- Botón unlock (estado por defecto) -->
    <button class="biometric-btn" id="btnUnlock" onclick="autenticar()" style="display:none;">
      <i class="bi bi-fingerprint"></i>
      Usar Touch ID / Face ID
      <span class="bio-label">Huella dactilar · Face ID · Touch ID</span>
    </button>

    <!-- Botón registro (si no hay biometría) -->
    <button class="biometric-btn" id="btnRegistrar" onclick="registrar()" style="display:none;">
      <i class="bi bi-person-check-fill"></i>
      Registrar huella / Face ID
      <span class="bio-label">Primera vez — activa la biometría para esta bóveda</span>
    </button>

    <div id="lockStatus" style="font-size:12px;color:#64748b;display:none;">Verificando biometría…</div>
    <div id="lockError" style="font-size:12px;color:#ef4444;display:none;"></div>
  </div>

  <!-- VAULT SCREEN -->
  <div class="vault-screen" id="vaultScreen">
    <div class="vault-header">
      <input class="vault-search" id="searchInput" placeholder="🔍 Buscar credencial..." oninput="filtrar(this.value)">
      <button style="background:none;border:none;color:#475569;font-size:18px;" onclick="cerrarBoveda()">
        <i class="bi bi-lock"></i>
      </button>
    </div>

    <div class="cat-bar" id="catBar">
      <button class="cat-chip active" onclick="filtrarCat('todas', this)">Todas</button>
      <button class="cat-chip" onclick="filtrarCat('correos', this)">📧 Correos</button>
      <button class="cat-chip" onclick="filtrarCat('servidores', this)">🖥 Servidores</button>
      <button class="cat-chip" onclick="filtrarCat('apis', this)">🔑 APIs</button>
      <button class="cat-chip" onclick="filtrarCat('otros', this)">📁 Otros</button>
    </div>

    <div class="vault-list" id="vaultList"></div>
  </div>

  <button class="vault-fab" id="vaultFab" style="display:none;" onclick="abrirFormulario()">
    <i class="bi bi-plus-lg"></i>
  </button>
</div>

<!-- MODAL DETALLE -->
<div class="vault-modal-backdrop" id="modalDetalle" onclick="cerrarModal()">
  <div class="vault-modal" onclick="event.stopPropagation()" id="modalContent"></div>
</div>

<!-- MODAL FORM -->
<div class="vault-modal-backdrop" id="modalForm" onclick="cerrarForm()">
  <div class="vault-modal" onclick="event.stopPropagation()">
    <div class="vault-modal-title" id="formTitle">Nueva credencial</div>
    <div class="vault-field">
      <div class="vault-field-label">Título</div>
      <input class="vault-search" id="fTitulo" placeholder="Ej: Correo Legal">
    </div>
    <div class="vault-field">
      <div class="vault-field-label">Categoría</div>
      <select class="vault-search" id="fCategoria" style="background:#0f172a;">
        <option value="correos">📧 Correos</option>
        <option value="servidores">🖥 Servidores</option>
        <option value="apis">🔑 APIs</option>
        <option value="otros">📁 Otros</option>
      </select>
    </div>
    <div class="vault-field">
      <div class="vault-field-label">Usuario / Email</div>
      <input class="vault-search" id="fUsuario" placeholder="usuario@dominio.com">
    </div>
    <div class="vault-field">
      <div class="vault-field-label">Contraseña</div>
      <input class="vault-search" id="fPassword" type="password" placeholder="••••••••">
    </div>
    <div class="vault-field">
      <div class="vault-field-label">URL (opcional)</div>
      <input class="vault-search" id="fUrl" placeholder="https://...">
    </div>
    <div class="vault-field">
      <div class="vault-field-label">Notas (opcional)</div>
      <input class="vault-search" id="fNotas" placeholder="Notas adicionales">
    </div>
    <div style="display:flex;gap:8px;margin-top:8px;">
      <button class="copy-btn" style="flex:1;padding:10px;" onclick="cerrarForm()">Cancelar</button>
      <button class="biometric-btn" style="flex:1;padding:10px;flex-direction:row;gap:8px;" onclick="guardarItem()">
        <i class="bi bi-shield-lock" style="font-size:16px;"></i> Guardar
      </button>
    </div>
    <div id="formError" style="font-size:12px;color:#ef4444;margin-top:8px;display:none;"></div>
  </div>
</div>

<script>
let sessionToken = null;
let todosItems = [];
let catActual = 'todas';
let editId = null;

const CAT_ICONS = { correos:'📧', servidores:'🖥', apis:'🔑', otros:'📁' };
const CAT_COLORS = { correos:'rgba(99,102,241,0.2)', servidores:'rgba(249,115,22,0.2)', apis:'rgba(34,197,94,0.2)', otros:'rgba(100,116,139,0.2)' };

// Al cargar: detecta si hay biometría registrada
document.addEventListener('DOMContentLoaded', async () => {
  const statusEl = document.getElementById('lockStatus');
  statusEl.style.display = 'block';
  try {
    const r = await fetch('/superadmin/boveda/auth/options');
    statusEl.style.display = 'none';
    if (r.status === 404) {
      // Sin biometría registrada
      document.getElementById('btnRegistrar').style.display = 'flex';
    } else {
      document.getElementById('btnUnlock').style.display = 'flex';
    }
  } catch(e) {
    statusEl.style.display = 'none';
    document.getElementById('btnUnlock').style.display = 'flex';
  }
});

async function registrar() {
  const errEl = document.getElementById('lockError');
  errEl.style.display = 'none';
  try {
    const optRes = await fetch('/auth/webauthn/register/options');
    if (!optRes.ok) throw new Error((await optRes.json()).error || 'Error');
    const options = await optRes.json();

    options.challenge = base64ToBuffer(options.challenge);
    options.user.id = base64ToBuffer(options.user.id);
    if (options.excludeCredentials) {
      options.excludeCredentials = options.excludeCredentials.map(c => ({ ...c, id: base64ToBuffer(c.id) }));
    }

    const credential = await navigator.credentials.create({ publicKey: options });
    const body = {
      id: credential.id,
      rawId: bufferToBase64(credential.rawId),
      type: credential.type,
      response: {
        attestationObject: bufferToBase64(credential.response.attestationObject),
        clientDataJSON: bufferToBase64(credential.response.clientDataJSON),
      }
    };

    const verRes = await fetch('/auth/webauthn/register/verify', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
    });
    const verData = await verRes.json();
    if (!verRes.ok) throw new Error(verData.error || 'Registro fallido');

    // Registro exitoso — ahora desbloquea
    document.getElementById('btnRegistrar').style.display = 'none';
    document.getElementById('btnUnlock').style.display = 'flex';
    await autenticar();
  } catch(e) {
    errEl.textContent = e.name === 'NotAllowedError' ? 'Cancelado — vuelve a intentarlo' : e.message;
    errEl.style.display = 'block';
  }
}

async function autenticar() {
  const errEl = document.getElementById('lockError');
  errEl.style.display = 'none';
  try {
    const optRes = await fetch('/superadmin/boveda/auth/options');
    const options = await optRes.json();
    if (!optRes.ok) throw new Error(options.error || 'Error obteniendo opciones');

    options.challenge = base64ToBuffer(options.challenge);
    options.allowCredentials = (options.allowCredentials || []).map(c => ({
      ...c, id: base64ToBuffer(c.id)
    }));

    const assertion = await navigator.credentials.get({ publicKey: options });
    const body = {
      id: assertion.id,
      rawId: bufferToBase64(assertion.rawId),
      type: assertion.type,
      response: {
        authenticatorData: bufferToBase64(assertion.response.authenticatorData),
        clientDataJSON: bufferToBase64(assertion.response.clientDataJSON),
        signature: bufferToBase64(assertion.response.signature),
        userHandle: assertion.response.userHandle ? bufferToBase64(assertion.response.userHandle) : null,
      }
    };

    const verRes = await fetch('/superadmin/boveda/auth/verify', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const verData = await verRes.json();
    if (!verRes.ok) throw new Error(verData.error || 'Verificación fallida');

    sessionToken = verData.token;
    desbloquear();
  } catch(e) {
    if (e.name === 'NotAllowedError') {
      errEl.textContent = 'Autenticación cancelada o no disponible en este dispositivo';
    } else {
      errEl.textContent = e.message;
    }
    errEl.style.display = 'block';
  }
}

function desbloquear() {
  document.getElementById('lockScreen').style.display = 'none';
  document.getElementById('vaultScreen').style.display = 'block';
  document.getElementById('vaultFab').style.display = 'flex';
  cargarItems();
}

function cerrarBoveda() {
  sessionToken = null;
  document.getElementById('lockScreen').style.display = 'flex';
  document.getElementById('vaultScreen').style.display = 'none';
  document.getElementById('vaultFab').style.display = 'none';
}

async function cargarItems() {
  const r = await fetch('/superadmin/boveda/items', {
    headers: { 'x-vault-token': sessionToken }
  });
  const data = await r.json();
  if (!r.ok) { cerrarBoveda(); return; }
  todosItems = Array.isArray(data) ? data : (data.items || []);
  renderItems(todosItems);
}

function renderItems(items) {
  const list = document.getElementById('vaultList');
  if (!items.length) {
    list.innerHTML = '<div class="vault-empty"><div style="font-size:40px;">🔐</div><div style="font-size:13px;">Sin credenciales guardadas</div><div style="font-size:11px;">Toca + para agregar</div></div>';
    return;
  }
  list.innerHTML = items.map(item => `
    <div class="vault-item" onclick="verItem(${item.id})">
      <div class="vault-item-icon" style="background:${CAT_COLORS[item.categoria]||'rgba(100,116,139,0.2)'}">
        ${CAT_ICONS[item.categoria]||'📁'}
      </div>
      <div class="vault-item-info">
        <div class="vault-item-title">${escHtml(item.titulo)}</div>
        <div class="vault-item-user">${escHtml(item.usuario||'')}</div>
      </div>
      <i class="bi bi-chevron-right" style="color:#475569;font-size:12px;"></i>
    </div>
  `).join('');
}

async function verItem(id) {
  const r = await fetch(`/superadmin/boveda/items/${id}`, {
    headers: { 'x-vault-token': sessionToken }
  });
  const item = await r.json();
  if (!r.ok) return;

  document.getElementById('modalContent').innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <div class="vault-modal-title" style="margin:0;">${CAT_ICONS[item.categoria]||'📁'} ${escHtml(item.titulo)}</div>
      <button style="background:none;border:none;color:#475569;" onclick="cerrarModal()"><i class="bi bi-x-lg"></i></button>
    </div>
    ${item.usuario ? `
    <div class="vault-field">
      <div class="vault-field-label">Usuario</div>
      <div class="vault-field-value">
        <span class="vault-field-text">${escHtml(item.usuario)}</span>
        <button class="copy-btn" onclick="copiar('${escHtml(item.usuario)}', this)">Copiar</button>
      </div>
    </div>` : ''}
    <div class="vault-field">
      <div class="vault-field-label">Contraseña</div>
      <div class="vault-field-value">
        <span class="vault-field-text masked" id="passField">••••••••</span>
        <button class="toggle-btn" onclick="togglePass('${escAttr(item.password)}', this)">Ver</button>
        <button class="copy-btn" onclick="copiar('${escAttr(item.password)}', this)">Copiar</button>
      </div>
    </div>
    ${item.url ? `
    <div class="vault-field">
      <div class="vault-field-label">URL</div>
      <div class="vault-field-value">
        <span class="vault-field-text">${escHtml(item.url)}</span>
        <a href="${escHtml(item.url)}" target="_blank" class="copy-btn" style="text-decoration:none;">Abrir</a>
      </div>
    </div>` : ''}
    ${item.notas ? `
    <div class="vault-field">
      <div class="vault-field-label">Notas</div>
      <div class="vault-field-value"><span class="vault-field-text">${escHtml(item.notas)}</span></div>
    </div>` : ''}
    <div style="display:flex;gap:8px;margin-top:16px;">
      <button class="copy-btn" style="flex:1;padding:8px;color:#ef4444;background:rgba(239,68,68,0.1);" onclick="eliminarItem(${item.id})">
        <i class="bi bi-trash"></i> Eliminar
      </button>
      <button class="copy-btn" style="flex:1;padding:8px;" onclick="editarItem(${item.id})">
        <i class="bi bi-pencil"></i> Editar
      </button>
    </div>
  `;
  document.getElementById('modalDetalle').classList.add('show');
}

function togglePass(pass, btn) {
  const el = document.getElementById('passField');
  if (el.classList.contains('masked')) {
    el.textContent = pass; el.classList.remove('masked'); btn.textContent = 'Ocultar';
  } else {
    el.textContent = '••••••••'; el.classList.add('masked'); btn.textContent = 'Ver';
  }
}

async function copiar(text, btn) {
  await navigator.clipboard.writeText(text);
  const orig = btn.textContent;
  btn.textContent = '✓';
  setTimeout(() => btn.textContent = orig, 1500);
}

function filtrar(q) {
  const filtered = todosItems.filter(i =>
    i.titulo.toLowerCase().includes(q.toLowerCase()) ||
    (i.usuario||'').toLowerCase().includes(q.toLowerCase())
  );
  renderItems(catActual === 'todas' ? filtered : filtered.filter(i => i.categoria === catActual));
}

function filtrarCat(cat, btn) {
  catActual = cat;
  document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  renderItems(cat === 'todas' ? todosItems : todosItems.filter(i => i.categoria === cat));
}

function abrirFormulario(id = null) {
  editId = id;
  document.getElementById('formTitle').textContent = id ? 'Editar credencial' : 'Nueva credencial';
  if (!id) {
    ['fTitulo','fUsuario','fPassword','fUrl','fNotas'].forEach(f => document.getElementById(f).value = '');
  }
  cerrarModal();
  document.getElementById('modalForm').classList.add('show');
}

function editarItem(id) {
  abrirFormulario(id);
}

async function guardarItem() {
  const titulo = document.getElementById('fTitulo').value.trim();
  const password = document.getElementById('fPassword').value;
  if (!titulo || !password) {
    document.getElementById('formError').textContent = 'Título y contraseña son obligatorios';
    document.getElementById('formError').style.display = 'block';
    return;
  }
  const body = {
    titulo, password,
    categoria: document.getElementById('fCategoria').value,
    usuario: document.getElementById('fUsuario').value.trim(),
    url: document.getElementById('fUrl').value.trim(),
    notas: document.getElementById('fNotas').value.trim(),
  };
  const url = editId ? `/superadmin/boveda/items/${editId}` : '/superadmin/boveda/items';
  const method = editId ? 'PUT' : 'POST';
  const r = await fetch(url, {
    method, headers: { 'Content-Type': 'application/json', 'x-vault-token': sessionToken },
    body: JSON.stringify(body)
  });
  if (r.ok) { cerrarForm(); cargarItems(); }
  else {
    const d = await r.json();
    document.getElementById('formError').textContent = d.error || 'Error';
    document.getElementById('formError').style.display = 'block';
  }
}

async function eliminarItem(id) {
  if (!confirm('¿Eliminar esta credencial?')) return;
  await fetch(`/superadmin/boveda/items/${id}`, {
    method: 'DELETE', headers: { 'x-vault-token': sessionToken }
  });
  cerrarModal();
  cargarItems();
}

function cerrarModal() { document.getElementById('modalDetalle').classList.remove('show'); }
function cerrarForm() { document.getElementById('modalForm').classList.remove('show'); document.getElementById('formError').style.display = 'none'; }
function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escAttr(s) { return String(s||'').replace(/'/g,'&#39;').replace(/"/g,'&quot;'); }

function base64ToBuffer(b64) {
  const bin = atob(b64.replace(/-/g,'+').replace(/_/g,'/'));
  return Uint8Array.from(bin, c => c.charCodeAt(0)).buffer;
}
function bufferToBase64(buf) {
  return btoa(String.fromCharCode(...new Uint8Array(buf))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');
}
</script>
