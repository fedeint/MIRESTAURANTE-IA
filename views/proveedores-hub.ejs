<%# @variant: pwa — Proveedores Hub: supplier directory with purchase history and quick-contact. %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#10152f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title><%= detalleId ? (detalle.nombre + ' — Proveedor') : 'Proveedores' %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      font-family: 'DM Sans', sans-serif;
      background: #F0F2F8;
      color: #0a0f24;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
      overscroll-behavior: none;
    }
    .shell {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      padding-bottom: calc(90px + env(safe-area-inset-bottom, 0px));
    }

    /* HEADER */
    .pv-header {
      background: linear-gradient(180deg, #10152f 0%, #0a0f24 100%);
      border-radius: 0 0 20px 20px;
      padding: calc(52px + env(safe-area-inset-top, 0px)) 20px 20px;
    }
    .pv-header-row { display: flex; align-items: center; gap: 12px; }
    .pv-back-btn {
      width: 36px; height: 36px; border-radius: 10px; border: none; cursor: pointer;
      background: rgba(255,255,255,.12); color: #fff; display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .pv-header h1 { font-size: 20px; font-weight: 700; color: #fff; flex: 1; }
    .pv-header p { font-size: 12px; color: #8B8FAD; margin-top: 4px; }
    .pv-header-icon {
      width: 40px; height: 40px; border-radius: 12px;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff; flex-shrink: 0;
    }
    .pv-add-btn {
      width: 36px; height: 36px; border-radius: 10px; border: none; cursor: pointer;
      background: rgba(255,255,255,.12); color: #fff; display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }

    /* SEARCH */
    .pv-search {
      margin: 14px 16px 0;
      position: relative;
    }
    .pv-search input {
      width: 100%; padding: 11px 14px 11px 40px;
      border-radius: 12px; border: none; background: #fff;
      font-size: 14px; font-family: 'DM Sans', sans-serif;
      color: #0a0f24; outline: none;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    .pv-search i {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      color: #8B8FAD; font-size: 15px;
    }

    /* LIST */
    .section { padding: 14px 16px 4px; }

    .pv-card {
      background: #fff;
      border-radius: 14px; padding: 14px;
      margin-bottom: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,.05);
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; color: inherit;
      transition: transform .15s;
    }
    .pv-card:active { transform: scale(.98); }
    .pv-avatar {
      width: 44px; height: 44px; border-radius: 13px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 700;
      background: linear-gradient(135deg, #fff7ed, #fef3c7);
      color: #ef520f;
    }
    .pv-info { flex: 1; min-width: 0; }
    .pv-name { font-size: 14px; font-weight: 700; color: #0a0f24; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pv-sub { font-size: 12px; color: #8B8FAD; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pv-badge {
      font-size: 10px; padding: 3px 8px; border-radius: 99px; font-weight: 600; flex-shrink: 0;
    }
    .badge-mayorista { background: #dbeafe; color: #1d4ed8; }
    .badge-minorista { background: #f0fdf4; color: #15803d; }
    .badge-productor  { background: #fef3c7; color: #b45309; }
    .badge-distribuidor { background: #f5f3ff; color: #6d28d9; }

    /* DETAIL VIEW */
    .det-hero {
      background: linear-gradient(135deg, #10152f, #0a0f24);
      border-radius: 16px; margin: 14px 16px 10px;
      padding: 20px;
      box-shadow: 0 4px 16px rgba(0,0,0,.12);
    }
    .det-hero-row { display: flex; align-items: flex-start; gap: 14px; }
    .det-hero-avatar {
      width: 56px; height: 56px; border-radius: 16px; flex-shrink: 0;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; font-weight: 700; color: #fff;
    }
    .det-hero-name { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 3px; }
    .det-hero-tipo { font-size: 11px; color: #8B8FAD; }
    .det-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-top: 14px; }
    .det-stat { text-align: center; }
    .det-stat-val { font-size: 18px; font-weight: 700; color: #fff; line-height: 1; }
    .det-stat-label { font-size: 10px; color: #8B8FAD; margin-top: 3px; }

    /* Contact buttons */
    .contact-row { display: flex; gap: 8px; padding: 0 16px 10px; }
    .contact-btn {
      flex: 1; padding: 11px; border-radius: 12px; border: none; cursor: pointer;
      font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      text-decoration: none; transition: opacity .15s;
    }
    .contact-btn:active { opacity: .8; }
    .btn-wa { background: #22c55e; color: #fff; }
    .btn-call { background: #3b82f6; color: #fff; }
    .btn-email { background: #8b5cf6; color: #fff; }
    .btn-disabled { background: #F0F2F8; color: #8B8FAD; cursor: not-allowed; }

    /* Info rows */
    .info-row {
      display: flex; align-items: center; gap: 10px;
      background: #fff; border-radius: 12px; padding: 12px 14px; margin-bottom: 6px;
      box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }
    .info-row i { font-size: 16px; color: #8B8FAD; flex-shrink: 0; width: 20px; text-align: center; }
    .info-row-label { font-size: 11px; color: #8B8FAD; }
    .info-row-val { font-size: 13px; font-weight: 600; color: #0a0f24; }

    /* Order rows */
    .order-row {
      background: #fff; border-radius: 12px; padding: 12px 14px;
      margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;
    }
    .order-num { font-size: 13px; font-weight: 600; color: #0a0f24; }
    .order-date { font-size: 11px; color: #8B8FAD; margin-top: 2px; }
    .order-badge {
      font-size: 10px; padding: 3px 8px; border-radius: 99px; font-weight: 600;
    }
    .estado-recibida { background: #f0fdf4; color: #16a34a; }
    .estado-enviada  { background: #eff6ff; color: #2563eb; }
    .estado-borrador { background: #F0F2F8; color: #8B8FAD; }
    .estado-parcial  { background: #fff7ed; color: #f97316; }
    .estado-cancelada { background: #fef2f2; color: #ef4444; }

    .order-total { font-size: 14px; font-weight: 700; color: #0a0f24; }

    /* FAB nuevo proveedor */
    .fab-new {
      position: fixed; bottom: calc(84px + env(safe-area-inset-bottom, 0px)); right: 20px;
      width: 52px; height: 52px; border-radius: 16px;
      background: linear-gradient(135deg, #ef520f, #df2c05);
      border: none; cursor: pointer; color: #fff; font-size: 22px;
      box-shadow: 0 4px 16px rgba(239,82,15,.4);
      display: flex; align-items: center; justify-content: center;
    }

    /* Modal */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 100;
      display: flex; align-items: flex-end; justify-content: center;
    }
    .modal-sheet {
      background: #fff; border-radius: 24px 24px 0 0;
      padding: 24px 20px calc(24px + env(safe-area-inset-bottom, 0px));
      width: 100%; max-width: 480px; max-height: 90dvh; overflow-y: auto;
    }
    .modal-title { font-size: 17px; font-weight: 700; margin-bottom: 16px; }
    .modal-field { margin-bottom: 12px; }
    .modal-field label { font-size: 12px; font-weight: 600; color: #8B8FAD; display: block; margin-bottom: 5px; }
    .modal-field input, .modal-field select {
      width: 100%; padding: 10px 14px; border: 1.5px solid #e5e7eb; border-radius: 10px;
      font-size: 14px; font-family: 'DM Sans', sans-serif; background: #fafafa; color: #0a0f24; outline: none;
    }
    .modal-field input:focus, .modal-field select:focus { border-color: #ef520f; }
    .modal-actions { display: flex; gap: 8px; margin-top: 16px; }
    .btn-cancel { flex: 1; padding: 12px; background: #F0F2F8; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; color: #0a0f24; font-family: 'DM Sans', sans-serif; }
    .btn-save   { flex: 2; padding: 12px; background: linear-gradient(135deg, #ef520f, #df2c05); border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; color: #fff; font-family: 'DM Sans', sans-serif; }
    .hidden { display: none; }
  </style>
</head>
<body>
<div class="shell">

<% if (!detalleId) { %>
  <!-- ════════════════ LIST VIEW ════════════════ -->
  <div class="pv-header">
    <div class="pv-header-row">
      <div style="flex:1">
        <h1>Proveedores</h1>
        <p><%= proveedores.length %> proveedor<%= proveedores.length !== 1 ? 'es' : '' %> activo<%= proveedores.length !== 1 ? 's' : '' %></p>
      </div>
      <div class="pv-header-icon"><i class="bi bi-truck"></i></div>
      <button class="pv-add-btn" onclick="openModal()"><i class="bi bi-plus-lg"></i></button>
    </div>
  </div>

  <div class="pv-search">
    <i class="bi bi-search"></i>
    <input type="text" id="search-input" placeholder="Buscar proveedor…" oninput="filterCards()">
  </div>

  <div class="section" id="pv-list">
    <% if (!proveedores || proveedores.length === 0) { %>
      <div style="text-align:center;padding:40px 0;color:#8B8FAD">
        <div style="font-size:40px;margin-bottom:12px">🚚</div>
        <div style="font-size:14px;font-weight:600">Sin proveedores registrados</div>
        <div style="font-size:12px;margin-top:4px">Toca + para agregar el primero</div>
      </div>
    <% } else { %>
      <% for (const p of proveedores) { %>
        <a href="/proveedores-hub/<%= p.id %>" class="pv-card" data-name="<%= (p.nombre||'').toLowerCase() %>">
          <div class="pv-avatar"><%= (p.nombre||'?').charAt(0).toUpperCase() %></div>
          <div class="pv-info">
            <div class="pv-name"><%= p.nombre %></div>
            <div class="pv-sub">
              <% if (p.telefono) { %><i class="bi bi-phone-fill" style="font-size:10px"></i> <%= p.telefono %> · <% } %>
              <%= Number(p.total_ordenes||0) %> orden<%= p.total_ordenes != 1 ? 'es' : '' %>
              <% if (Number(p.total_comprado) > 0) { %> · S/<%= Number(p.total_comprado).toFixed(0) %><% } %>
            </div>
          </div>
          <span class="pv-badge badge-<%= p.tipo || 'mayorista' %>"><%= p.tipo || 'mayorista' %></span>
        </a>
      <% } %>
    <% } %>
  </div>

  <button class="fab-new" onclick="openModal()"><i class="bi bi-plus-lg"></i></button>

<% } else { %>
  <!-- ════════════════ DETAIL VIEW ════════════════ -->
  <%
    const p = detalle;
    const tipoLabels = { mayorista:'Mayorista', minorista:'Minorista', productor:'Productor', distribuidor:'Distribuidor' };
  %>
  <div class="pv-header">
    <div class="pv-header-row">
      <a href="/proveedores-hub" class="pv-back-btn"><i class="bi bi-arrow-left"></i></a>
      <h1 style="font-size:18px">Detalle proveedor</h1>
    </div>
  </div>

  <!-- Hero card -->
  <div class="det-hero">
    <div class="det-hero-row">
      <div class="det-hero-avatar"><%= p.nombre.charAt(0).toUpperCase() %></div>
      <div>
        <div class="det-hero-name"><%= p.nombre %></div>
        <div class="det-hero-tipo"><%= tipoLabels[p.tipo] || p.tipo %> · <%= p.dias_credito > 0 ? p.dias_credito + ' días crédito' : 'Pago inmediato' %></div>
      </div>
    </div>
    <div class="det-stats">
      <div class="det-stat">
        <div class="det-stat-val"><%= Number(p.stats?.total_ordenes||0) %></div>
        <div class="det-stat-label">Órdenes</div>
      </div>
      <div class="det-stat">
        <div class="det-stat-val">S/<%= Number(p.stats?.total_comprado||0).toFixed(0) %></div>
        <div class="det-stat-label">Total comprado</div>
      </div>
      <div class="det-stat">
        <div class="det-stat-val"><%= p.stats?.ultima_orden ? new Date(p.stats.ultima_orden).toLocaleDateString('es-PE',{day:'2-digit',month:'short'}) : '—' %></div>
        <div class="det-stat-label">Última orden</div>
      </div>
    </div>
  </div>

  <!-- Contact buttons -->
  <div class="contact-row">
    <% if (p.telefono) { %>
      <a href="https://wa.me/<%= p.telefono.replace(/\D/g,'') %>" target="_blank" class="contact-btn btn-wa">
        <i class="bi bi-whatsapp"></i> WhatsApp
      </a>
      <a href="tel:<%= p.telefono %>" class="contact-btn btn-call">
        <i class="bi bi-telephone-fill"></i> Llamar
      </a>
    <% } else { %>
      <span class="contact-btn btn-disabled"><i class="bi bi-telephone-x"></i> Sin teléfono</span>
    <% } %>
    <% if (p.email) { %>
      <a href="mailto:<%= p.email %>" class="contact-btn btn-email">
        <i class="bi bi-envelope-fill"></i>
      </a>
    <% } %>
  </div>

  <!-- Info rows -->
  <div class="section">
    <div class="section-title" style="font-size:11px;font-weight:700;color:#8B8FAD;text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px">Información</div>
    <% if (p.ruc) { %>
      <div class="info-row"><i class="bi bi-card-text"></i><div><div class="info-row-label">RUC</div><div class="info-row-val"><%= p.ruc %></div></div></div>
    <% } %>
    <% if (p.contacto_nombre) { %>
      <div class="info-row"><i class="bi bi-person-fill"></i><div><div class="info-row-label">Contacto</div><div class="info-row-val"><%= p.contacto_nombre %></div></div></div>
    <% } %>
    <% if (p.email) { %>
      <div class="info-row"><i class="bi bi-envelope-fill"></i><div><div class="info-row-label">Email</div><div class="info-row-val"><%= p.email %></div></div></div>
    <% } %>
    <% if (p.direccion) { %>
      <div class="info-row"><i class="bi bi-geo-alt-fill"></i><div><div class="info-row-label">Dirección</div><div class="info-row-val"><%= p.direccion %></div></div></div>
    <% } %>
    <% if (p.calificacion) { %>
      <div class="info-row"><i class="bi bi-star-fill"></i><div><div class="info-row-label">Calificación</div><div class="info-row-val"><%= '★'.repeat(p.calificacion) %><%= '☆'.repeat(5 - p.calificacion) %></div></div></div>
    <% } %>
  </div>

  <!-- Ingredientes provistos -->
  <% if (p.ingredientes && p.ingredientes.length > 0) { %>
  <div class="section">
    <div class="section-title" style="font-size:11px;font-weight:700;color:#8B8FAD;text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px">Ingredientes provistos (<%= p.ingredientes.length %>)</div>
    <% for (const ing of p.ingredientes.slice(0, 6)) { %>
      <div class="info-row">
        <i class="bi bi-box-seam"></i>
        <div style="flex:1">
          <div class="info-row-val"><%= ing.nombre %></div>
          <div class="info-row-label">Stock: <%= Number(ing.stock_actual||0).toFixed(1) %> <%= ing.unidad_medida %></div>
        </div>
        <div style="font-size:12px;font-weight:600;color:#8B8FAD">S/<%= Number(ing.costo_unitario||0).toFixed(2) %></div>
      </div>
    <% } %>
    <% if (p.ingredientes.length > 6) { %>
      <div style="text-align:center;font-size:12px;color:#8B8FAD;padding:8px 0">+ <%= p.ingredientes.length - 6 %> más</div>
    <% } %>
  </div>
  <% } %>

  <!-- Historial de órdenes -->
  <div class="section">
    <div class="section-title" style="font-size:11px;font-weight:700;color:#8B8FAD;text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px">Historial de órdenes</div>
    <% if (!p.ordenes || p.ordenes.length === 0) { %>
      <div style="text-align:center;padding:20px;color:#8B8FAD;font-size:13px">Sin órdenes registradas</div>
    <% } else { %>
      <% for (const o of p.ordenes) { %>
        <div class="order-row">
          <div>
            <div class="order-num">#<%= o.numero_orden || o.id %></div>
            <div class="order-date"><%= o.fecha_orden ? new Date(o.fecha_orden).toLocaleDateString('es-PE', {day:'2-digit',month:'short',year:'numeric'}) : '—' %></div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
            <span class="order-badge estado-<%= o.estado %>"><%= o.estado %></span>
            <span class="order-total">S/<%= Number(o.total||0).toFixed(0) %></span>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>

<% } %>
</div>

<%- include('partials/limelight-nav', { reqPath: '/proveedores-hub' }) %>

<!-- ADD MODAL -->
<div id="modal" class="modal-overlay hidden" onclick="if(event.target===this)closeModal()">
  <div class="modal-sheet">
    <div class="modal-title">Nuevo proveedor</div>
    <div class="modal-field"><label>Nombre *</label><input type="text" id="f-nombre" placeholder="Distribuidora San Martín"></div>
    <div class="modal-field"><label>RUC</label><input type="text" id="f-ruc" placeholder="20123456789" maxlength="11"></div>
    <div class="modal-field"><label>Teléfono / WhatsApp</label><input type="tel" id="f-telefono" placeholder="51987654321"></div>
    <div class="modal-field"><label>Email</label><input type="email" id="f-email" placeholder="contacto@proveedor.com"></div>
    <div class="modal-field"><label>Persona de contacto</label><input type="text" id="f-contacto" placeholder="Carlos Pérez"></div>
    <div class="modal-field"><label>Tipo</label>
      <select id="f-tipo">
        <option value="mayorista">Mayorista</option>
        <option value="minorista">Minorista</option>
        <option value="productor">Productor</option>
        <option value="distribuidor">Distribuidor</option>
      </select>
    </div>
    <div class="modal-field"><label>Días de crédito</label><input type="number" id="f-credito" placeholder="0" min="0" max="180"></div>
    <div id="modal-msg" style="font-size:12px;min-height:16px;margin-bottom:8px"></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
      <button class="btn-save" onclick="guardarProveedor()">Guardar</button>
    </div>
  </div>
</div>

<script>
function openModal()  { document.getElementById('modal').classList.remove('hidden'); }
function closeModal() { document.getElementById('modal').classList.add('hidden'); }

async function guardarProveedor() {
  const nombre = document.getElementById('f-nombre').value.trim();
  const msg = document.getElementById('modal-msg');
  if (!nombre) { msg.innerHTML = '<span style="color:#ef4444">El nombre es requerido.</span>'; return; }

  try {
    const r = await fetch('/proveedores-hub', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nombre,
        ruc:            document.getElementById('f-ruc').value || null,
        telefono:       document.getElementById('f-telefono').value || null,
        email:          document.getElementById('f-email').value || null,
        contacto_nombre: document.getElementById('f-contacto').value || null,
        tipo:           document.getElementById('f-tipo').value,
        dias_credito:   parseInt(document.getElementById('f-credito').value) || 0
      })
    });
    const data = await r.json();
    if (data.ok) {
      msg.innerHTML = '<span style="color:#16a34a">✓ Proveedor creado</span>';
      setTimeout(() => location.reload(), 600);
    } else {
      msg.innerHTML = '<span style="color:#ef4444">' + (data.error || 'Error') + '</span>';
    }
  } catch (e) {
    msg.innerHTML = '<span style="color:#ef4444">Error de conexión</span>';
  }
}

function filterCards() {
  const q = document.getElementById('search-input')?.value.toLowerCase() || '';
  document.querySelectorAll('.pv-card').forEach(c => {
    c.style.display = c.dataset.name.includes(q) ? '' : 'none';
  });
}
</script>
</body>
</html>
