<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1e1b4b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dignita">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
    <title>Generador de Contratos - MiRestconIA</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container" style="max-width:860px;">

        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#FF6B35,#E55A2B);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-file-earmark-text" style="font-size:1.5rem;color:#fff;"></i>
            </div>
            <div>
                <h4 class="mb-0" style="font-weight:700;">Generador de Contratos</h4>
                <small class="text-muted">Plan Enterprise — MiRestconIA por mirestconia.com</small>
            </div>
        </div>

        <form id="formContrato">

            <!-- Datos del Cliente -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                <div class="card-body p-4">
                    <h5 class="mb-3" style="font-weight:700;color:#FF6B35;">
                        <i class="bi bi-person-badge me-2"></i>Datos del Cliente
                    </h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Nombre Completo <span class="text-danger">*</span></label>
                            <input type="text" name="nombre_cliente" class="form-control" required placeholder="Nombre del representante o dueño">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Razón Social</label>
                            <input type="text" name="razon_social" class="form-control" placeholder="Ej: Restaurante El Sabor S.A.C.">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">DNI <span class="text-danger">*</span></label>
                            <input type="text" name="dni" class="form-control" required maxlength="8" pattern="[0-9]{8}" placeholder="12345678">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">RUC</label>
                            <input type="text" name="ruc" class="form-control" maxlength="11" pattern="[0-9]{11}" placeholder="20612345678">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Teléfono</label>
                            <input type="text" name="telefono" class="form-control" placeholder="987654321">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="cliente@email.com">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Dirección</label>
                            <input type="text" name="direccion" class="form-control" placeholder="Av. Principal 123, Lima">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Datos del Establecimiento -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                <div class="card-body p-4">
                    <h5 class="mb-3" style="font-weight:700;color:#FF6B35;">
                        <i class="bi bi-shop me-2"></i>Datos del Establecimiento
                    </h5>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">Nombre del Restaurante / Establecimiento</label>
                            <input type="text" name="nombre_establecimiento" class="form-control" placeholder="Ej: Restaurante El Sabor">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Representante Legal (opcional) -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                <div class="card-body p-4">
                    <h5 class="mb-3" style="font-weight:700;color:#FF6B35;">
                        <i class="bi bi-briefcase me-2"></i>Representante Legal <small class="text-muted fw-normal">(si es persona jurídica)</small>
                    </h5>

                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">Nombre del Representante</label>
                            <input type="text" name="nombre_representante" class="form-control" placeholder="Nombre completo">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Cargo</label>
                            <input type="text" name="cargo_representante" class="form-control" placeholder="Ej: Gerente General">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">DNI Representante</label>
                            <input type="text" name="dni_representante" class="form-control" maxlength="8" pattern="[0-9]{8}" placeholder="12345678">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview del contenido -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;background:linear-gradient(135deg,#FFF8F0,#fff);">
                <div class="card-body p-4">
                    <h5 class="mb-3" style="font-weight:700;color:#1a1a2e;">
                        <i class="bi bi-list-check me-2"></i>Contenido del Contrato Enterprise
                    </h5>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Licencia perpetua del Software MiRestconIA</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Flujo integrado: Mesas → Caja → Ventas → Admin</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Almacén con alertas inteligentes de stock</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Facturación electrónica SUNAT (NubeFact)</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Asistente IA DalIA (2M tokens/año)</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Timeline de implementación: 5 días hábiles</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Capacitación por roles incluida</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>SLA 99.5% + soporte técnico</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>Modo local (offline) + sincronización</small>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <small>WhatsApp Business para comprobantes</small>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 p-3 rounded-3" style="background:rgba(255,107,53,0.08);">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-currency-dollar" style="font-size:1.2rem;color:#FF6B35;"></i>
                            <div>
                                <strong style="color:#FF6B35;">Inversión: S/ 3,000.00</strong>
                                <small class="text-muted ms-1">(Licencia perpetua S/ 2,300 + Año 1 nube/soporte S/ 700)</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condiciones de Pago -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
                <div class="card-body p-4">
                    <h5 class="mb-3" style="font-weight:700;color:#FF6B35;">
                        <i class="bi bi-cash-stack me-2"></i>Condiciones de Pago
                    </h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Modalidad de Pago</label>
                            <select name="modalidad_pago" class="form-select" id="modalidadPago">
                                <option value="contado">Pago al contado (S/ 3,000)</option>
                                <option value="2_partes">2 cuotas</option>
                                <option value="3_partes">3 cuotas</option>
                                <option value="personalizado">Personalizado</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Monto Total</label>
                            <div class="input-group">
                                <span class="input-group-text">S/</span>
                                <input type="number" name="monto_total" class="form-control" value="3000" step="0.01" id="montoTotal">
                            </div>
                        </div>
                    </div>

                    <!-- Cuotas dinámicas -->
                    <div id="cuotasContainer" class="mt-3" style="display:none;">
                        <label class="form-label small fw-bold">Detalle de Cuotas</label>
                        <div id="cuotasList"></div>
                        <button type="button" class="btn btn-sm btn-outline-secondary mt-2" id="btnAddCuota" style="display:none;">
                            <i class="bi bi-plus-circle me-1"></i>Agregar cuota
                        </button>
                    </div>

                    <!-- Notas de pago -->
                    <div class="mt-3">
                        <label class="form-label small fw-bold">Notas de Pago <small class="text-muted fw-normal">(opcional)</small></label>
                        <textarea name="notas_pago" class="form-control" rows="2" placeholder="Ej: Primera cuota en efectivo, segunda en vale de comida..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Botón -->
            <div class="d-grid gap-2 mb-5">
                <button type="submit" class="btn btn-lg text-white fw-bold" style="background:linear-gradient(135deg,#FF6B35,#E55A2B);border:none;border-radius:14px;padding:0.9rem;">
                    <i class="bi bi-file-earmark-pdf me-2"></i>Generar Contrato PDF
                </button>
            </div>

            <!-- Resultado de generación -->
            <div id="resultado" style="display:none;"></div>

        </form>

        <!-- Contratos Enviados -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
            <div class="card-body p-4">
                <h5 class="mb-3" style="font-weight:700;">
                    <i class="bi bi-table me-2"></i>Contratos Enviados
                </h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Nro</th><th>Cliente</th><th>Email</th><th>Estado</th><th>Fecha</th><th>Acciones</th></tr>
                        </thead>
                        <tbody id="contratos-tbody">
                            <tr><td colspan="6" class="text-center text-muted py-4">Cargando...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
    </main>
    </div>

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
    // Auto-fill RUC prefix from DNI (for persona natural con negocio)
    document.querySelector('[name="dni"]').addEventListener('input', function() {
        const rucField = document.querySelector('[name="ruc"]');
        if (this.value.length === 8 && !rucField.value) {
            rucField.value = '10' + this.value + '1'; // sugerencia
            rucField.classList.add('border-warning');
            setTimeout(() => rucField.classList.remove('border-warning'), 2000);
        }
    });

    // Cuotas dinámicas
    const modalidadSelect = document.getElementById('modalidadPago');
    const cuotasContainer = document.getElementById('cuotasContainer');
    const cuotasList = document.getElementById('cuotasList');
    const btnAddCuota = document.getElementById('btnAddCuota');
    const montoTotal = document.getElementById('montoTotal');

    function renderCuotas(numCuotas, editable) {
        const total = parseFloat(montoTotal.value) || 3000;
        const montoPorCuota = (total / numCuotas).toFixed(2);
        cuotasList.innerHTML = '';
        for (let i = 0; i < numCuotas; i++) {
            const div = document.createElement('div');
            div.className = 'row g-2 mb-2 align-items-center';
            div.innerHTML = `
                <div class="col-auto"><span class="badge bg-secondary">Cuota ${i+1}</span></div>
                <div class="col">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">S/</span>
                        <input type="number" name="cuota_monto_${i}" class="form-control cuota-monto" value="${montoPorCuota}" step="0.01">
                    </div>
                </div>
                <div class="col">
                    <input type="text" name="cuota_desc_${i}" class="form-control form-control-sm" placeholder="Ej: Al firmar, A fin de mes, Vale de comida..." value="${i===0?'Al firmar contrato':''}">
                </div>
                <div class="col-auto">
                    <input type="date" name="cuota_fecha_${i}" class="form-control form-control-sm">
                </div>
                ${editable && i >= 2 ? `<div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.row').remove()"><i class="bi bi-x"></i></button></div>` : ''}
            `;
            cuotasList.appendChild(div);
        }
        cuotasContainer.style.display = 'block';
        btnAddCuota.style.display = editable ? 'inline-block' : 'none';
    }

    modalidadSelect.addEventListener('change', function() {
        const v = this.value;
        if (v === 'contado') {
            cuotasContainer.style.display = 'none';
            cuotasList.innerHTML = '';
        } else if (v === '2_partes') {
            renderCuotas(2, false);
        } else if (v === '3_partes') {
            renderCuotas(3, false);
        } else if (v === 'personalizado') {
            renderCuotas(2, true);
        }
    });

    btnAddCuota.addEventListener('click', () => {
        const idx = cuotasList.children.length;
        const div = document.createElement('div');
        div.className = 'row g-2 mb-2 align-items-center';
        div.innerHTML = `
            <div class="col-auto"><span class="badge bg-secondary">Cuota ${idx+1}</span></div>
            <div class="col">
                <div class="input-group input-group-sm">
                    <span class="input-group-text">S/</span>
                    <input type="number" name="cuota_monto_${idx}" class="form-control cuota-monto" value="0" step="0.01">
                </div>
            </div>
            <div class="col">
                <input type="text" name="cuota_desc_${idx}" class="form-control form-control-sm" placeholder="Descripción...">
            </div>
            <div class="col-auto">
                <input type="date" name="cuota_fecha_${idx}" class="form-control form-control-sm">
            </div>
            <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.row').remove()"><i class="bi bi-x"></i></button></div>
        `;
        cuotasList.appendChild(div);
    });

    montoTotal.addEventListener('change', () => {
        const v = modalidadSelect.value;
        if (v !== 'contado') modalidadSelect.dispatchEvent(new Event('change'));
    });

    // Form submit via fetch
    document.getElementById('formContrato').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        // Collect cuotas into array
        const cuotas = [];
        document.querySelectorAll('#cuotasList .row').forEach((row, i) => {
            const monto = row.querySelector(`[name="cuota_monto_${i}"]`)?.value;
            const desc = row.querySelector(`[name="cuota_desc_${i}"]`)?.value;
            const fecha = row.querySelector(`[name="cuota_fecha_${i}"]`)?.value;
            if (monto) cuotas.push({ monto: parseFloat(monto), descripcion: desc || '', fecha: fecha || '' });
        });
        if (cuotas.length) data.cuotas = cuotas;
        // Clean up individual cuota fields
        Object.keys(data).forEach(k => { if (k.startsWith('cuota_monto_') || k.startsWith('cuota_desc_') || k.startsWith('cuota_fecha_')) delete data[k]; });

        const btn = e.target.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Generando...';

        try {
            const resp = await fetch('/api/contratos/generar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await resp.json();
            if (result.error) throw new Error(result.error);

            // Show result
            document.getElementById('resultado').innerHTML = `
                <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;border-left:4px solid #22c55e !important;">
                    <div class="card-body p-4">
                        <h5 class="text-success"><i class="bi bi-check-circle me-2"></i>Contrato Generado</h5>
                        <p class="mb-1"><strong>Nro:</strong> ${result.nro_contrato}</p>
                        <p class="mb-2"><strong>Link de firma:</strong></p>
                        <div class="input-group mb-2">
                            <input type="text" class="form-control" value="${result.link}" readonly id="linkFirma">
                            <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText(document.getElementById('linkFirma').value); Swal.fire({toast:true,position:'top-end',icon:'success',title:'Link copiado',showConfirmButton:false,timer:1500});">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                        <span class="badge ${result.email_enviado ? 'bg-success' : 'bg-warning text-dark'}">
                            ${result.email_enviado ? 'Email enviado al cliente' : (result.email_reason || 'Email no enviado')}
                        </span>
                    </div>
                </div>
            `;
            document.getElementById('resultado').style.display = 'block';
            loadContratos(); // refresh table
        } catch (err) {
            Swal.fire({ icon: 'error', title: 'Error', text: err.message });
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-file-earmark-pdf me-2"></i>Generar Contrato PDF';
        }
    });

    // Load contracts table
    async function loadContratos() {
        try {
            const resp = await fetch('/api/contratos/lista');
            const contratos = await resp.json();
            const tbody = document.getElementById('contratos-tbody');
            if (!contratos.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">No hay contratos generados aún</td></tr>';
                return;
            }
            tbody.innerHTML = contratos.map(c => {
                const estadoBadge = c.estado === 'firmado' ? 'bg-success' : c.estado === 'expirado' ? 'bg-danger' : 'bg-warning text-dark';
                const fecha = new Date(c.created_at).toLocaleDateString('es-PE');
                const linkFirma = `${window.location.origin}/firmar/${c.token}`;
                return `<tr>
                    <td><small class="fw-bold">${c.nro_contrato}</small></td>
                    <td>${c.nombre_cliente}</td>
                    <td><small>${c.email || '-'}</small></td>
                    <td><span class="badge ${estadoBadge}">${c.estado}</span></td>
                    <td><small>${fecha}</small></td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-secondary" title="Copiar link" onclick="navigator.clipboard.writeText('${linkFirma}'); Swal.fire({toast:true,position:'top-end',icon:'success',title:'Link copiado',showConfirmButton:false,timer:1500});">
                                <i class="bi bi-clipboard"></i>
                            </button>
                            ${c.email ? `<button class="btn btn-outline-primary" title="Reenviar email" onclick="reenviar(${c.id})"><i class="bi bi-envelope"></i></button>` : ''}
                            <a href="/api/contratos/${c.id}/descargar/original" class="btn btn-outline-dark" title="Descargar original"><i class="bi bi-download"></i></a>
                            ${c.estado === 'firmado' ? `<a href="/api/contratos/${c.id}/descargar/firmado" class="btn btn-outline-success" title="Descargar firmado"><i class="bi bi-file-earmark-check"></i></a>` : ''}
                        </div>
                    </td>
                </tr>`;
            }).join('');
        } catch (err) {
            console.error('Error loading contratos:', err);
        }
    }

    async function reenviar(id) {
        try {
            const resp = await fetch(`/api/contratos/${id}/reenviar`, { method: 'POST' });
            const data = await resp.json();
            Swal.fire({ toast:true, position:'top-end', icon: data.ok ? 'success' : 'error', title: data.message, showConfirmButton:false, timer:2000 });
        } catch (err) {
            Swal.fire({ icon: 'error', title: 'Error', text: 'No se pudo reenviar' });
        }
    }

    loadContratos();
    </script>
</body>
</html>
