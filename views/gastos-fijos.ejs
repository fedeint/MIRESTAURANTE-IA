<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Gastos Fijos · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--orange:#ef520f;--orange2:#df2c05;--dark:#0a0f24;--bg:#F0F2F8;--card:#fff;--text2:#8B8FAD;--rojo:#EF4444;--safe-bot:env(safe-area-inset-bottom,0px);}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100dvh;max-width:480px;margin:0 auto;padding-bottom:calc(80px + var(--safe-bot));}
    .header{background:linear-gradient(170deg,#10152f 0%,#0a0f24 50%,#090d1d 100%);padding:52px 20px 20px;border-radius:0 0 20px 20px;color:#fff;display:flex;align-items:center;justify-content:space-between;}
    .header-left{display:flex;align-items:center;gap:12px;}
    .btn-back{background:rgba(255,255,255,.12);border:none;color:#fff;width:36px;height:36px;border-radius:10px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
    .header-title{font-size:18px;font-weight:700;}
    .btn-add{background:rgba(255,255,255,.15);border:none;color:#fff;width:36px;height:36px;border-radius:10px;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
    /* Summary */
    .summary{margin:16px 16px 0;background:var(--card);border-radius:16px;padding:20px;box-shadow:0 2px 12px rgba(0,0,0,.08);}
    .sum-label{font-size:13px;color:var(--text2);margin-bottom:4px;}
    .sum-total{font-size:32px;font-weight:800;color:var(--dark);}
    .sum-equil{font-size:14px;color:var(--orange);margin-top:4px;font-weight:600;}
    /* List */
    .list{padding:14px 16px 0;}
    .gasto-card{background:var(--card);border-radius:14px;margin-bottom:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.05);display:flex;align-items:stretch;}
    .gasto-card.alerta .gasto-inner{background:#FFF5F5;}
    .gasto-inner{flex:1;padding:14px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:background .15s;}
    .gasto-icon{width:40px;height:40px;border-radius:12px;background:#F0F2F8;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
    .gasto-info{flex:1;min-width:0;}
    .gasto-nombre{font-size:15px;font-weight:600;color:var(--dark);display:flex;align-items:center;gap:8px;}
    .alerta-badge{font-size:10px;font-weight:700;background:#FEE2E2;color:var(--rojo);padding:2px 6px;border-radius:6px;}
    .gasto-sub{font-size:12px;color:var(--text2);margin-top:2px;}
    .gasto-monto{font-size:17px;font-weight:700;color:var(--dark);}
    .gasto-monto.alerta-monto{color:var(--rojo);}
    .empty{text-align:center;padding:48px 24px;color:var(--text2);font-size:14px;}
    .empty-icon{font-size:40px;margin-bottom:12px;}
    /* sheet */
    .sheet-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:flex-end;justify-content:center;}
    .sheet-overlay.show{display:flex;}
    .sheet{background:var(--card);border-radius:20px 20px 0 0;width:100%;max-width:480px;max-height:88dvh;overflow-y:auto;padding:8px 20px calc(20px + var(--safe-bot));animation:slideUp .25s ease;}
    @keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
    .sheet-handle{width:40px;height:4px;background:#E0E2EE;border-radius:2px;margin:12px auto 20px;}
    .sheet-title{font-size:17px;font-weight:700;color:var(--dark);margin-bottom:20px;}
    .field-label{font-size:13px;font-weight:600;color:var(--text2);margin-bottom:6px;}
    .field-input{width:100%;border:1.5px solid #E0E2EE;border-radius:12px;padding:11px 14px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;color:var(--dark);margin-bottom:14px;transition:border-color .2s;}
    .field-input:focus{border-color:var(--orange);}
    .row-fields{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .icono-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:14px;}
    .icono-opt{width:42px;height:42px;border:2px solid #E0E2EE;border-radius:10px;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
    .icono-opt.sel{border-color:var(--orange);background:#FFF8F5;}
    .sheet-cta{width:100%;background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;border:none;border-radius:14px;padding:15px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;}
    .bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:#fff;border-top:1px solid #E8EAF2;display:flex;padding-bottom:var(--safe-bot);z-index:100;}
    .nav-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 4px 8px;text-decoration:none;color:var(--text2);font-size:10px;font-weight:500;}
    .nav-item .icon{font-size:22px;margin-bottom:2px;}
    .nav-item.active{color:var(--orange);}
  </style>
</head>
<body>
  <div class="header">
    <div class="header-left">
      <button class="btn-back" onclick="history.back()">‹</button>
      <span class="header-title">Gastos Fijos</span>
    </div>
    <button class="btn-add" onclick="abrirSheet()">+</button>
  </div>

  <div class="summary">
    <div class="sum-label">Gastos fijos mensuales</div>
    <div class="sum-total">S/ <%= totalMensual.toLocaleString('es-PE',{minimumFractionDigits:0}) %></div>
    <div class="sum-equil">Punto equilibrio: S/ <%= equilibrioDia.toLocaleString('es-PE') %>/día</div>
  </div>

  <div class="list">
    <% if (gastos.length === 0) { %>
    <div class="empty"><div class="empty-icon">💳</div>Agrega tus gastos fijos para calcular el punto de equilibrio.</div>
    <% } %>
    <% gastos.forEach(function(g) { %>
    <div class="gasto-card <%= g.venceProx ? 'alerta' : '' %>">
      <div class="gasto-inner" onclick="eliminarGasto(<%= g.id %>)">
        <div class="gasto-icon"><%= g.icono || '💳' %></div>
        <div class="gasto-info">
          <div class="gasto-nombre">
            <%= g.nombre %>
            <% if(g.venceProx){%><span class="alerta-badge">VENCE PRONTO</span><% } %>
          </div>
          <% if(g.dia_vence){%><div class="gasto-sub">Vence <%= g.dia_vence %>/mes</div><% } %>
        </div>
        <div class="gasto-monto <%= g.venceProx?'alerta-monto':'' %>">S/ <%= Number(g.monto).toLocaleString('es-PE',{minimumFractionDigits:0}) %></div>
      </div>
    </div>
    <% }); %>
  </div>

  <div class="sheet-overlay" id="agregarSheet" onclick="cerrar(event)">
    <div class="sheet">
      <div class="sheet-handle"></div>
      <div class="sheet-title">Agregar gasto fijo</div>
      <div class="field-label">Ícono</div>
      <div class="icono-grid" id="iconoGrid">
        <% ['🏠','⚡','💧','🔥','📶','💳','🚛','🧹','📦','💊','🔧','🎵'].forEach(function(ic){ %>
        <div class="icono-opt" data-ic="<%= ic %>" onclick="selIcono(this)"><%= ic %></div>
        <% }); %>
      </div>
      <input type="hidden" id="iconoVal" value="💳">
      <div class="field-label">Nombre *</div>
      <input class="field-input" id="gNombre" placeholder="Ej: Alquiler" autocomplete="off">
      <div class="row-fields">
        <div>
          <div class="field-label">Monto S/ *</div>
          <input class="field-input" type="number" id="gMonto" placeholder="0.00">
        </div>
        <div>
          <div class="field-label">Día de vencimiento</div>
          <input class="field-input" type="number" id="gDiaVence" placeholder="1–31" min="1" max="31">
        </div>
      </div>
      <button class="sheet-cta" onclick="guardarGasto()">Agregar gasto</button>
    </div>
  </div>

  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="icon">🏠</span>Inicio</a>
    <a href="/pedidos" class="nav-item"><span class="icon">🧾</span>Pedidos</a>
    <a href="/cocina-display" class="nav-item"><span class="icon">👨‍🍳</span>Cocina</a>
    <a href="/caja" class="nav-item"><span class="icon">💰</span>Caja</a>
    <a href="/mas" class="nav-item active"><span class="icon">☰</span>Más</a>
  </nav>

  <script>
    function abrirSheet(){ document.getElementById('agregarSheet').classList.add('show'); }
    function cerrar(e){ if(e.target.classList.contains('sheet-overlay')) document.getElementById('agregarSheet').classList.remove('show'); }
    function selIcono(el){
      document.querySelectorAll('.icono-opt').forEach(o=>o.classList.remove('sel'));
      el.classList.add('sel');
      document.getElementById('iconoVal').value = el.dataset.ic;
    }
    async function guardarGasto(){
      const nombre = document.getElementById('gNombre').value.trim();
      const monto  = document.getElementById('gMonto').value;
      if(!nombre||!monto){ alert('Nombre y monto requeridos'); return; }
      const body = { nombre, monto, icono: document.getElementById('iconoVal').value, dia_vence: document.getElementById('gDiaVence').value || null };
      const r = await fetch('/sprint4/gastos-fijos',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      const d = await r.json();
      if(d.ok) location.reload(); else alert(d.error||'Error');
    }
    async function eliminarGasto(id){
      if(!confirm('¿Eliminar este gasto?')) return;
      const r = await fetch('/sprint4/gastos-fijos/'+id,{method:'DELETE'});
      const d = await r.json();
      if(d.ok) location.reload(); else alert('Error');
    }
  </script>
  <script src="/js/dallia-fab.js"></script>
</body>
</html>
