<%# @variant: pwa — Pedidos consolidated view (Mesa + Delivery + Para Llevar) mobile-first. Reference: spec 2026-04-08-pedidos-consolidation-design.md %>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#10152f">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MiRestconIA">
    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <title>Pedidos - mirestconia.com</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            font-family: 'DM Sans', sans-serif;
            background: #F0F2F8;
            color: #0a0f24;
            min-height: 100dvh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overscroll-behavior: none;
        }

        .shell {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100dvh;
            position: relative;
            padding-bottom: calc(90px + env(safe-area-inset-bottom, 0px));
        }

        /* ===== HEADER ===== */
        .ped-header {
            background: linear-gradient(180deg, #10152f 0%, #0a0f24 100%);
            border-radius: 0 0 20px 20px;
            padding: calc(52px + env(safe-area-inset-top, 0px)) 20px 24px;
        }
        .ped-header h1 {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }
        .ped-header p {
            font-size: 13px;
            color: #8B8FAD;
            margin: 4px 0 0;
        }

        /* ===== TABS ===== */
        .ped-tabs {
            display: flex;
            gap: 6px;
            padding: 16px;
            background: #F0F2F8;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .ped-tab {
            flex: 1;
            padding: 10px 8px;
            border: none;
            background: #FFFFFF;
            color: #8B8FAD;
            font-family: inherit;
            font-size: 13px;
            font-weight: 600;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
        }
        .ped-tab i { font-size: 18px; }
        .ped-tab__count {
            font-size: 11px;
            font-weight: 700;
            padding: 1px 8px;
            background: #E8ECF5;
            border-radius: 999px;
        }
        .ped-tab.active {
            background: linear-gradient(180deg, #ef520f 0%, #df2c05 100%);
            color: #FFFFFF;
            box-shadow: 0 8px 16px rgba(239, 82, 15, 0.25);
        }
        .ped-tab.active .ped-tab__count {
            background: rgba(255, 255, 255, 0.25);
            color: #fff;
        }

        /* ===== CONTENT ===== */
        .ped-content {
            padding: 0 16px 20px;
        }
        .ped-tab-content { display: none; }
        .ped-tab-content.active { display: block; }

        /* Mesa cards */
        .mesa-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }
        .mesa-card {
            background: #FFFFFF;
            border-radius: 16px;
            padding: 18px 12px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
            border: 2px solid transparent;
        }
        .mesa-card--occupied { border-color: #F97316; }
        .mesa-card__num { font-size: 22px; font-weight: 800; color: #0a0f24; }
        .mesa-card__label { font-size: 10px; color: #8B8FAD; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 3px; }
        .mesa-card__status {
            font-size: 10px;
            font-weight: 700;
            margin-top: 8px;
            padding: 3px 8px;
            border-radius: 999px;
            display: inline-block;
        }
        .mesa-card__status--libre { background: #dcfce7; color: #166534; }
        .mesa-card__status--ocupada { background: #ffedd5; color: #c2410c; }

        /* Delivery / Para-llevar cards */
        .ped-card {
            background: #FFFFFF;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
            display: flex;
            gap: 12px;
            margin-bottom: 10px;
        }
        .ped-card__icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: #ffedd5;
            color: #ef520f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }
        .ped-card__body { flex: 1; min-width: 0; }
        .ped-card__name { font-size: 14px; font-weight: 700; color: #0a0f24; }
        .ped-card__sub { font-size: 12px; color: #8B8FAD; margin-top: 2px; }
        .ped-card__time { font-size: 11px; font-weight: 500; margin-top: 2px; }
        .ped-card__time--fresh { color: #22C55E; }
        .ped-card__time--warn { color: #F97316; }
        .ped-card__time--late { color: #EF4444; }
        .ped-card__total { font-size: 15px; font-weight: 800; color: #0a0f24; align-self: center; flex-shrink: 0; }
        .ped-card__status {
            font-size: 10px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 999px;
            align-self: center;
            flex-shrink: 0;
            white-space: nowrap;
        }
        .ped-card__status--pending { background: #FFF7ED; color: #c2410c; }
        .ped-card__status--ready { background: #dcfce7; color: #166534; }
        .ped-card__status--delivered { background: #EEF2FF; color: #4338CA; }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: #8B8FAD;
        }
        .empty-state__icon { font-size: 48px; color: #DDE2ED; margin-bottom: 12px; }
        .empty-state__title { font-size: 15px; font-weight: 700; color: #8B8FAD; }
        .empty-state__subtitle { font-size: 12px; margin-top: 4px; }

        /* FAB + Nuevo pedido */
        .ped-fab {
            position: fixed;
            bottom: calc(90px + env(safe-area-inset-bottom, 0px));
            right: 20px;
            width: 56px;
            height: 56px;
            border: none;
            border-radius: 50%;
            background: linear-gradient(180deg, #f08a4f 0%, #d9501f 100%);
            color: #fff;
            font-size: 24px;
            box-shadow: 0 12px 24px rgba(239, 82, 15, 0.4);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 20;
        }

    </style>
</head>
<body>
    <div class="shell">
        <header class="ped-header">
            <h1>Pedidos</h1>
            <p>Mesa, delivery y para llevar</p>
        </header>

        <% const activeTab = (typeof tab !== 'undefined' && tab) ? tab : 'mesa'; %>
        <% const tabCounts = (typeof counts !== 'undefined' && counts) ? counts : { mesa: 0, delivery: 0, para_llevar: 0 }; %>

        <nav class="ped-tabs">
            <button class="ped-tab <%= activeTab === 'mesa' ? 'active' : '' %>" data-tab="mesa">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                Mesa
                <span class="ped-tab__count"><%= tabCounts.mesa %></span>
            </button>
            <button class="ped-tab <%= activeTab === 'delivery' ? 'active' : '' %>" data-tab="delivery">
                <i class="bi bi-bicycle"></i>
                Delivery
                <span class="ped-tab__count"><%= tabCounts.delivery %></span>
            </button>
            <button class="ped-tab <%= activeTab === 'para_llevar' ? 'active' : '' %>" data-tab="para_llevar">
                <i class="bi bi-bag-fill"></i>
                Llevar
                <span class="ped-tab__count"><%= tabCounts.para_llevar %></span>
            </button>
        </nav>

        <div class="ped-content">
            <!-- MESA -->
            <div class="ped-tab-content <%= activeTab === 'mesa' ? 'active' : '' %>" id="tab-mesa">
                <% const mesas = (typeof mesaPedidos !== 'undefined' && mesaPedidos && mesaPedidos.length) ? mesaPedidos : []; %>
                <% if (mesas.length === 0) { %>
                    <div class="empty-state">
                        <div class="empty-state__icon"><i class="bi bi-grid-3x3-gap"></i></div>
                        <div class="empty-state__title">Sin mesas activas</div>
                        <div class="empty-state__subtitle">Las comandas abiertas apareceran aqui.</div>
                    </div>
                <% } else { %>
                    <div class="mesa-grid">
                        <% mesas.forEach(function(m){ %>
                            <div class="mesa-card <%= m.estado === 'ocupada' ? 'mesa-card--occupied' : '' %>">
                                <div class="mesa-card__num"><%= m.numero || m.mesa_id %></div>
                                <div class="mesa-card__label">Mesa</div>
                                <div class="mesa-card__status <%= m.estado === 'ocupada' ? 'mesa-card__status--ocupada' : 'mesa-card__status--libre' %>">
                                    <%= m.estado === 'ocupada' ? 'Ocupada' : 'Libre' %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- DELIVERY -->
            <div class="ped-tab-content <%= activeTab === 'delivery' ? 'active' : '' %>" id="tab-delivery">
                <% const deliveries = (typeof deliveryPedidos !== 'undefined' && deliveryPedidos && deliveryPedidos.length) ? deliveryPedidos : []; %>
                <% if (deliveries.length === 0) { %>
                    <div class="empty-state">
                        <div class="empty-state__icon"><i class="bi bi-bicycle"></i></div>
                        <div class="empty-state__title">Sin deliveries</div>
                        <div class="empty-state__subtitle">Toca el boton + para registrar uno nuevo.</div>
                    </div>
                <% } else { %>
                    <% deliveries.forEach(function(d){
                        var minutos = d.created_at ? Math.round((Date.now() - new Date(d.created_at).getTime()) / 60000) : null;
                        var timeClass = minutos === null ? '' : minutos < 20 ? 'ped-card__time--fresh' : minutos < 40 ? 'ped-card__time--warn' : 'ped-card__time--late';
                        var statusClass = d.estado === 'entregado' ? 'ped-card__status--delivered' : d.estado === 'listo' ? 'ped-card__status--ready' : 'ped-card__status--pending';
                        var statusLabel = d.estado === 'entregado' ? 'Entregado' : d.estado === 'listo' ? 'Listo' : 'En camino';
                    %>
                        <div class="ped-card">
                            <div class="ped-card__icon"><i class="bi bi-bicycle"></i></div>
                            <div class="ped-card__body">
                                <div class="ped-card__name"><%= d.cliente_nombre || 'Sin nombre' %></div>
                                <div class="ped-card__sub">Pedido #<%= d.id || '' %> · S/ <%= Number(d.total || 0).toFixed(2) %></div>
                                <% if (minutos !== null) { %><div class="ped-card__time <%= timeClass %>">hace <%= minutos %> min</div><% } %>
                            </div>
                            <div class="ped-card__status <%= statusClass %>"><%= statusLabel %></div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <!-- PARA LLEVAR -->
            <div class="ped-tab-content <%= activeTab === 'para_llevar' ? 'active' : '' %>" id="tab-para_llevar">
                <% const paraLlevar = (typeof paraLlevarPedidos !== 'undefined' && paraLlevarPedidos && paraLlevarPedidos.length) ? paraLlevarPedidos : []; %>
                <% if (paraLlevar.length === 0) { %>
                    <div class="empty-state">
                        <div class="empty-state__icon"><i class="bi bi-bag"></i></div>
                        <div class="empty-state__title">Sin pedidos para llevar</div>
                        <div class="empty-state__subtitle">Registra aqui las ordenes a recoger.</div>
                    </div>
                <% } else { %>
                    <% paraLlevar.forEach(function(p){
                        var minutos = p.created_at ? Math.round((Date.now() - new Date(p.created_at).getTime()) / 60000) : null;
                        var timeClass = minutos === null ? '' : minutos < 20 ? 'ped-card__time--fresh' : minutos < 40 ? 'ped-card__time--warn' : 'ped-card__time--late';
                        var isListo = p.listo_para_recojo;
                    %>
                        <div class="ped-card">
                            <div class="ped-card__icon"><i class="bi bi-bag-fill"></i></div>
                            <div class="ped-card__body">
                                <div class="ped-card__name"><%= p.cliente_nombre_recojo || 'Sin nombre' %></div>
                                <div class="ped-card__sub">Pedido #<%= p.id || '' %> · S/ <%= Number(p.total || 0).toFixed(2) %></div>
                                <% if (minutos !== null) { %><div class="ped-card__time <%= timeClass %>">hace <%= minutos %> min</div><% } %>
                            </div>
                            <div class="ped-card__status <%= isListo ? 'ped-card__status--ready' : 'ped-card__status--pending' %>"><%= isListo ? 'Listo' : 'Preparando' %></div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <button class="ped-fab" aria-label="Nuevo pedido">
            <i class="bi bi-plus-lg"></i>
        </button>

        <%- include('partials/limelight-nav', { reqPath: '/pedidos' }) %>
    </div>

    <script src="/js/dallia-fab.js"></script>
    <script src="/js/salva-alerts.js"></script>
    <script>
        document.querySelectorAll('.ped-tab').forEach(function(btn){
            btn.addEventListener('click', function(){
                var target = this.dataset.tab;
                document.querySelectorAll('.ped-tab').forEach(function(b){ b.classList.remove('active'); });
                document.querySelectorAll('.ped-tab-content').forEach(function(c){ c.classList.remove('active'); });
                this.classList.add('active');
                var content = document.getElementById('tab-' + target);
                if (content) content.classList.add('active');
                var url = new URL(window.location);
                url.searchParams.set('tab', target);
                history.replaceState(null, '', url);
            });
        });

        // Auto-refresh every 30s so new orders appear without manual reload
        setInterval(function() { window.location.reload(); }, 30 * 1000);
    </script>
</body>
</html>
