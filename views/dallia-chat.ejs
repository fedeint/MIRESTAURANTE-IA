<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#10152f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>DallIA · Chat</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange: #ef520f;
      --orange-dark: #df2c05;
      --dark: #0a0f24;
      --dark-2: #10152f;
      --bg: #F0F2F8;
      --white: #ffffff;
      --text-sec: #8B8FAD;
      --success: #22C55E;
      --error: #EF4444;
    }

    html, body {
      height: 100%;
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      overflow: hidden;
    }

    /* ── Shell ─────────────────────────────────── */
    .chat-shell {
      display: flex;
      flex-direction: column;
      height: 100dvh;
      max-width: 480px;
      margin: 0 auto;
      position: relative;
    }

    /* ── Header ────────────────────────────────── */
    .chat-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 16px;
      padding-top: max(env(safe-area-inset-top), 12px);
      padding-bottom: 12px;
      height: calc(70px + env(safe-area-inset-top, 0px));
      background: linear-gradient(135deg, #10152f 0%, #0a0f24 100%);
      flex-shrink: 0;
      z-index: 10;
    }

    .back-btn {
      background: none;
      border: none;
      color: white;
      font-size: 22px;
      cursor: pointer;
      padding: 6px;
      line-height: 1;
      flex-shrink: 0;
    }

    .dallia-info {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
    }

    .dallia-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), var(--orange-dark));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }

    .dallia-name {
      font-size: 15px;
      font-weight: 700;
      color: white;
      line-height: 1.2;
    }

    .dallia-status {
      font-size: 11px;
      color: #9CA3AF;
      line-height: 1.2;
    }

    .dallia-status.online { color: var(--success); }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .header-actions button {
      background: none;
      border: none;
      color: white;
      font-size: 20px;
      cursor: pointer;
      padding: 6px 7px;
      line-height: 1;
    }

    /* ── Voice banner ──────────────────────────── */
    .voice-banner {
      display: none;
      align-items: center;
      gap: 10px;
      background: var(--orange);
      padding: 10px 16px;
      border-radius: 0 0 12px 12px;
      flex-shrink: 0;
      animation: slideDown 0.25s ease-out;
    }

    @keyframes slideDown {
      from { transform: translateY(-100%); opacity: 0; }
      to   { transform: translateY(0);     opacity: 1; }
    }

    .waveform {
      display: flex;
      align-items: center;
      gap: 3px;
      height: 20px;
    }

    .waveform span {
      width: 3px;
      background: white;
      border-radius: 2px;
      animation: wave 0.8s infinite;
    }

    .waveform span:nth-child(1) { height: 6px;  animation-delay: 0s; }
    .waveform span:nth-child(2) { height: 14px; animation-delay: 0.1s; }
    .waveform span:nth-child(3) { height: 20px; animation-delay: 0.2s; }
    .waveform span:nth-child(4) { height: 12px; animation-delay: 0.3s; }
    .waveform span:nth-child(5) { height: 7px;  animation-delay: 0.4s; }

    @keyframes wave {
      0%,100% { transform: scaleY(1); }
      50%      { transform: scaleY(0.35); }
    }

    .voice-time {
      flex: 1;
      color: white;
      font-size: 13px;
      font-weight: 600;
    }

    .fin-btn {
      background: none;
      border: 1.5px solid rgba(255,255,255,0.7);
      color: white;
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
    }

    /* ── Chat area ─────────────────────────────── */
    .chat-area {
      flex: 1;
      overflow-y: auto;
      padding: 12px 16px;
      padding-bottom: 8px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
    }

    /* ── Bubble wrappers ───────────────────────── */
    .bubble-wrap {
      display: flex;
      align-items: flex-start;
      max-width: 100%;
    }

    .dallia-wrap {
      flex-direction: row;
      align-self: flex-start;
      max-width: 86%;
    }

    .user-wrap {
      flex-direction: row-reverse;
      align-self: flex-end;
      max-width: 78%;
    }

    /* ── DallIA avatar (small) ─────────────────── */
    .dallia-avatar-sm {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), var(--orange-dark));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* ── Bubbles ───────────────────────────────── */
    .bubble {
      padding: 10px 14px;
      font-size: 14px;
      line-height: 1.5;
    }

    .dallia-bubble {
      background: var(--white);
      color: var(--dark);
      border-radius: 4px 16px 16px 16px;
      margin-left: 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }

    .user-bubble {
      background: linear-gradient(135deg, var(--orange), var(--orange-dark));
      color: white;
      border-radius: 16px 4px 16px 16px;
      font-weight: 500;
    }

    /* ── Typing indicator ──────────────────────── */
    .typing-dots {
      display: flex;
      gap: 5px;
      padding: 4px 2px;
      align-items: center;
    }

    .typing-dots span {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--text-sec);
      animation: bounce 1.2s infinite;
    }

    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes bounce {
      0%,80%,100% { transform: translateY(0); }
      40%          { transform: translateY(-7px); }
    }

    /* ── Alert chips ───────────────────────────── */
    .alert-chips { margin-bottom: 8px; }

    .alert-chip {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #FFF3E0;
      border-left: 3px solid var(--orange);
      border-radius: 6px;
      padding: 7px 10px;
      font-size: 13px;
      margin-bottom: 6px;
    }

    .alert-chip.agotado  { border-color: var(--error);  background: #FEF2F2; }
    .alert-chip.demorado { border-color: #F97316; background: #FFF7ED; }

    /* ── Action chips ──────────────────────────── */
    .action-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 6px;
    }

    .action-chip {
      background: white;
      border: 1.5px solid var(--orange);
      color: var(--orange);
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.12s ease;
      font-family: 'DM Sans', sans-serif;
    }

    .action-chip:active { background: var(--orange); color: white; }

    /* ── DallIA full-width action button ───────── */
    .dallia-action-btn {
      width: 100%;
      background: linear-gradient(135deg, var(--orange), var(--orange-dark));
      color: white;
      border: none;
      border-radius: 12px;
      height: 44px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
      font-family: 'DM Sans', sans-serif;
      transition: opacity 0.15s;
    }

    .dallia-action-btn:active { opacity: 0.85; }

    /* ── Ranking row ───────────────────────────── */
    .rank-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 0;
      border-bottom: 1px solid #F0F2F8;
      font-size: 13px;
    }

    .rank-row:last-child { border-bottom: none; }
    .rank-name { flex: 1; color: var(--dark); }
    .rank-count { font-weight: 700; color: var(--dark); }

    /* ── DallIA list ───────────────────────────── */
    .dallia-list {
      margin: 4px 0;
      padding-left: 18px;
      font-size: 14px;
    }

    .dallia-list li { margin-bottom: 3px; }

    /* ── Recommendation chip ───────────────────── */
    .rec-chip {
      display: inline-flex;
      align-items: center;
      background: #DCFCE7;
      color: #16A34A;
      border-radius: 999px;
      padding: 3px 10px;
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    /* ── Quick replies (empty state) ───────────── */
    .quick-replies {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 10px;
    }

    .quick-reply {
      background: white;
      border: 1.5px solid var(--orange);
      color: var(--orange);
      border-radius: 999px;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-align: left;
      transition: all 0.12s;
      font-family: 'DM Sans', sans-serif;
    }

    .quick-reply:active { background: var(--orange); color: white; }

    /* ── Slide-in animation ────────────────────── */
    .msg-new {
      animation: slideIn 0.2s ease-out forwards;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Input bar ─────────────────────────────── */
    .input-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      padding-bottom: max(env(safe-area-inset-bottom, 10px), 10px);
      background: white;
      box-shadow: 0 -2px 16px rgba(0,0,0,0.07);
      flex-shrink: 0;
    }

    .plus-btn {
      background: none;
      border: none;
      color: var(--text-sec);
      font-size: 22px;
      cursor: pointer;
      padding: 4px;
      line-height: 1;
      flex-shrink: 0;
    }

    #msgInput {
      flex: 1;
      border: 1.5px solid #E8EAF2;
      border-radius: 24px;
      background: var(--bg);
      padding: 9px 16px;
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      color: var(--dark);
      outline: none;
      transition: border-color 0.15s;
    }

    #msgInput:focus { border-color: var(--orange); }
    #msgInput::placeholder { color: var(--text-sec); }

    .mic-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), var(--orange-dark));
      border: none;
      color: white;
      font-size: 18px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform 0.1s;
    }

    .mic-btn:active { transform: scale(0.9); }

    .mic-btn.listening {
      animation: micPulse 0.8s infinite;
    }

    @keyframes micPulse {
      0%,100% { box-shadow: 0 0 0 0 rgba(239,82,15,0.4); }
      50%      { box-shadow: 0 0 0 10px rgba(239,82,15,0); }
    }

    /* ── Bottom nav ────────────────────────────── */
    .bottom-nav {
      display: flex;
      background: white;
      border-top: 1px solid #E8EAF2;
      padding-bottom: env(safe-area-inset-bottom, 0px);
      flex-shrink: 0;
    }

    .nav-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 8px 4px;
      text-decoration: none;
      color: var(--text-sec);
      font-size: 10px;
      font-weight: 500;
      transition: color 0.15s;
    }

    .nav-item span { font-size: 10px; }
    .nav-item .nav-icon { font-size: 20px; }
    .nav-item.active { color: var(--orange); }

    /* ── Date divider ──────────────────────────── */
    .date-divider {
      text-align: center;
      font-size: 11px;
      color: var(--text-sec);
      margin: 4px 0;
    }
  </style>
</head>
<body>

<div class="chat-shell">

  <!-- Header -->
  <header class="chat-header">
    <button class="back-btn" onclick="history.back()" aria-label="Volver">←</button>
    <div class="dallia-info">
      <div class="dallia-avatar">🤖</div>
      <div>
        <p class="dallia-name">DallIA</p>
        <p class="dallia-status online" id="statusText">● En línea</p>
      </div>
    </div>
    <div class="header-actions">
      <button onclick="window.location='/dallia/voz'" aria-label="Modo voz">📞</button>
      <button aria-label="Opciones">⋮</button>
    </div>
  </header>

  <!-- Voice inline banner -->
  <div class="voice-banner" id="voiceBanner">
    <div class="waveform">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <span class="voice-time" id="voiceTime">Voz activa · 0:00</span>
    <button class="fin-btn" onclick="stopVoice()">Fin</button>
  </div>

  <!-- Chat area -->
  <div class="chat-area" id="chatArea">
    <%
      function escapeHtml(str) {
        return String(str || '')
          .replace(/&/g,'&amp;')
          .replace(/</g,'&lt;')
          .replace(/>/g,'&gt;')
          .replace(/"/g,'&quot;');
      }
    %>

    <% if (!historial || historial.length === 0) { %>
      <!-- Empty state: welcome bubble -->
      <div class="bubble-wrap dallia-wrap">
        <div class="dallia-avatar-sm">🤖</div>
        <div class="bubble dallia-bubble">
          <p style="font-weight:600;margin-bottom:8px">¡Hola <%= escapeHtml(userName) %>! 👋</p>
          <p style="margin-bottom:10px;color:#4B5563">Soy DallIA, tu asistente de restaurante. ¿En qué te ayudo hoy?</p>
          <div class="quick-replies">
            <button class="quick-reply" onclick="sendQuick(this)">¿Cómo van las ventas?</button>
            <button class="quick-reply" onclick="sendQuick(this)">¿Qué hay en stock bajo?</button>
            <button class="quick-reply" onclick="sendQuick(this)">Resumen del día</button>
          </div>
        </div>
      </div>
    <% } else { %>
      <% historial.forEach(function(msg) { %>
        <% if (msg.role === 'assistant') { %>
          <div class="bubble-wrap dallia-wrap">
            <div class="dallia-avatar-sm">🤖</div>
            <div class="bubble dallia-bubble"><%- escapeHtml(msg.content).replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>') %></div>
          </div>
        <% } else { %>
          <div class="bubble-wrap user-wrap">
            <div class="bubble user-bubble"><%= escapeHtml(msg.content) %></div>
          </div>
        <% } %>
      <% }); %>
    <% } %>
  </div>

  <!-- Input bar -->
  <div class="input-bar">
    <button class="plus-btn" aria-label="Adjuntar">+</button>
    <input type="text" id="msgInput" placeholder="Pregunta a DallIA..." autocomplete="off" autocorrect="off">
    <button class="mic-btn" id="micBtn" aria-label="Micrófono">🎤</button>
  </div>

  <!-- Bottom nav -->
  <nav class="bottom-nav">
    <a href="/" class="nav-item"><span class="nav-icon">🏠</span><span>Inicio</span></a>
    <a href="/pedidos" class="nav-item"><span class="nav-icon">📋</span><span>Pedidos</span></a>
    <a href="/cocina-display" class="nav-item"><span class="nav-icon">🔥</span><span>Cocina</span></a>
    <a href="/caja" class="nav-item"><span class="nav-icon">💵</span><span>Caja</span></a>
    <a href="#" class="nav-item active"><span class="nav-icon">🤖</span><span>DallIA</span></a>
  </nav>

</div>

<script>
  // ── State ────────────────────────────────────────────────────────────────
  const historial = <%- JSON.stringify((historial || []).map(function(m){ return {role:m.role, content:m.content}; })) %>;
  let recognition  = null;
  let voiceTimer   = null;
  let voiceSeconds = 0;
  let isListening  = false;
  let isFetching   = false;

  // ── Init ─────────────────────────────────────────────────────────────────
  window.addEventListener('DOMContentLoaded', function() {
    scrollToBottom(false);
    loadAlertas();
  });

  // ── Proactive alerts ─────────────────────────────────────────────────────
  async function loadAlertas() {
    // Only show alerts on first open (empty chat)
    if (historial.length > 0) return;
    try {
      const r = await fetch('/api/chat/dallia/alertas');
      if (!r.ok) return;
      const data = await r.json();
      if (!data.alertas || !data.alertas.length) return;
      appendDalliaMessage(buildAlertasHtml(data.alertas));
    } catch(_) {}
  }

  function buildAlertasHtml(alertas) {
    let html = '<p style="font-weight:600;margin:0 0 10px">Tengo algunas alertas para ti:</p>';
    html += '<div class="alert-chips">';
    for (const a of alertas) {
      html += '<div class="alert-chip ' + escHTML(a.tipo) + '">' + escHTML(a.icono) + ' ' + escHTML(a.mensaje) + '</div>';
    }
    html += '</div><div class="action-chips">';
    const seen = new Set();
    for (const a of alertas) {
      if (!seen.has(a.accion_url)) {
        html += '<button class="action-chip" onclick="window.location=\'' + escHTML(a.accion_url) + '\'">' + escHTML(a.accion_texto) + '</button>';
        seen.add(a.accion_url);
      }
    }
    html += '</div>';
    return html;
  }

  // ── Send message ──────────────────────────────────────────────────────────
  async function sendMessage(texto) {
    const msg = String(texto || '').trim();
    if (!msg || isFetching) return;

    document.getElementById('msgInput').value = '';
    appendUserMessage(msg);
    saveMessage('user', msg);

    // Instant typing indicator
    const typingId = showTyping();
    setStatus('Escribiendo...');
    isFetching = true;

    try {
      const r = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mensaje: msg, historial: historial.slice(-20) })
      });
      const data = await r.json();
      removeTyping(typingId);
      setStatus('● En línea');
      isFetching = false;

      if (data.respuesta) {
        historial.push({ role: 'user', content: msg });
        historial.push({ role: 'assistant', content: data.respuesta });
        appendDalliaMessage(parseDalliaResponse(data.respuesta));
        saveMessage('assistant', data.respuesta);
      } else {
        appendDalliaMessage('Ups, respuesta vacía. Intenta de nuevo 😅');
      }
    } catch(e) {
      removeTyping(typingId);
      setStatus('● En línea');
      isFetching = false;
      appendDalliaMessage('Ups, tuve un problema al conectar. Intenta de nuevo 😅');
    }
  }

  function sendQuick(btn) {
    btn.closest('.quick-replies')?.remove();
    sendMessage(btn.textContent.trim());
  }

  // ── Parse DallIA response → rich HTML ────────────────────────────────────
  function parseDalliaResponse(text) {
    let html = '';
    const lines = text.split('\n');
    let inList = false;
    let listHtml = '';

    function flushList() {
      if (inList) {
        html += '<ul class="dallia-list">' + listHtml + '</ul>';
        inList = false;
        listHtml = '';
      }
    }

    for (const line of lines) {
      const l = line.trim();
      if (!l) { flushList(); continue; }

      // Ranking line: emoji + name + whitespace + count
      const rankMatch = l.match(/^([\u{1F300}-\u{1FFFF}✅⭐🍕🍗🥩🍜🍝🍛🥘🫕🍺🥤☕🍹🧃🍷🎂🍰🧁🥗].+?)\s{2,}(\d+.*)$/u);
      if (rankMatch) {
        flushList();
        html += '<div class="rank-row"><span class="rank-name">' + escHTML(rankMatch[1]) + '</span><span class="rank-count">' + escHTML(rankMatch[2]) + '</span></div>';
        continue;
      }

      // List items
      if (/^[-•]\s/.test(l) || /^\d+\.\s/.test(l)) {
        inList = true;
        listHtml += '<li>' + formatInline(l.replace(/^[-•]\s|^\d+\.\s/, '')) + '</li>';
        continue;
      }

      flushList();

      // Recomendación label
      if (/^recomendaci[oó]n[.:]/i.test(l)) {
        html += '<span class="rec-chip">Recomendación</span>';
        const rest = l.replace(/^recomendaci[oó]n[.:]\s*/i, '');
        if (rest) html += '<p style="margin:0 0 6px">' + formatInline(rest) + '</p>';
        continue;
      }

      html += '<p style="margin:0 0 6px">' + formatInline(l) + '</p>';
    }

    flushList();
    return html || '<p style="margin:0">' + escHTML(text) + '</p>';
  }

  function formatInline(s) {
    return escHTML(s)
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>');
  }

  function escHTML(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── DOM helpers ───────────────────────────────────────────────────────────
  function appendUserMessage(text) {
    const area = document.getElementById('chatArea');
    const wrap = document.createElement('div');
    wrap.className = 'bubble-wrap user-wrap msg-new';
    wrap.innerHTML = '<div class="bubble user-bubble">' + escHTML(text) + '</div>';
    area.appendChild(wrap);
    scrollToBottom();
    // Remove animation class after it fires
    wrap.addEventListener('animationend', function() { wrap.classList.remove('msg-new'); }, { once: true });
  }

  function appendDalliaMessage(html) {
    const area = document.getElementById('chatArea');
    const wrap = document.createElement('div');
    wrap.className = 'bubble-wrap dallia-wrap msg-new';
    wrap.innerHTML = '<div class="dallia-avatar-sm">🤖</div><div class="bubble dallia-bubble">' + html + '</div>';
    area.appendChild(wrap);
    scrollToBottom();
    wrap.addEventListener('animationend', function() { wrap.classList.remove('msg-new'); }, { once: true });
  }

  function showTyping() {
    const area = document.getElementById('chatArea');
    const id = 'typing-' + Date.now();
    const wrap = document.createElement('div');
    wrap.id = id;
    wrap.className = 'bubble-wrap dallia-wrap';
    wrap.innerHTML = '<div class="dallia-avatar-sm">🤖</div><div class="bubble dallia-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>';
    area.appendChild(wrap);
    scrollToBottom();
    return id;
  }

  function removeTyping(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  function setStatus(text) {
    const el = document.getElementById('statusText');
    el.textContent = text;
    el.className = 'dallia-status' + (text.includes('En línea') ? ' online' : '');
  }

  function scrollToBottom(smooth) {
    const area = document.getElementById('chatArea');
    area.scrollTo({ top: area.scrollHeight, behavior: smooth === false ? 'instant' : 'smooth' });
  }

  // ── Persist (fire-and-forget) ─────────────────────────────────────────────
  function saveMessage(role, content) {
    fetch('/api/chat/dallia/guardar-mensaje', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ role, content })
    }).catch(function(){});
  }

  // ── Voice input ───────────────────────────────────────────────────────────
  function startVoice() {
    const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRec) {
      alert('Tu navegador no soporta reconocimiento de voz. Prueba Chrome o Safari.');
      return;
    }
    if (isListening) return;

    recognition = new SpeechRec();
    recognition.lang = 'es-PE';
    recognition.continuous = false;
    recognition.interimResults = true;

    recognition.onstart = function() {
      isListening = true;
      document.getElementById('micBtn').classList.add('listening');
      const banner = document.getElementById('voiceBanner');
      banner.style.display = 'flex';
      startVoiceTimer();
    };

    recognition.onresult = function(e) {
      const transcript = Array.from(e.results).map(function(r){ return r[0].transcript; }).join('');
      document.getElementById('msgInput').value = transcript;
    };

    recognition.onerror = function() {
      stopVoice();
    };

    recognition.onend = function() {
      isListening = false;
      document.getElementById('micBtn').classList.remove('listening');
    };

    recognition.start();
  }

  function sendVoice() {
    if (recognition) { recognition.stop(); recognition = null; }
    stopVoice();
    const text = document.getElementById('msgInput').value.trim();
    if (text) {
      setTimeout(function(){ sendMessage(text); }, 200);
    }
  }

  function stopVoice() {
    if (recognition) { recognition.stop(); recognition = null; }
    isListening = false;
    document.getElementById('micBtn').classList.remove('listening');
    const banner = document.getElementById('voiceBanner');
    banner.style.display = 'none';
    clearInterval(voiceTimer);
    voiceSeconds = 0;
  }

  function startVoiceTimer() {
    voiceSeconds = 0;
    voiceTimer = setInterval(function() {
      voiceSeconds++;
      const m = Math.floor(voiceSeconds / 60);
      const s = voiceSeconds % 60;
      document.getElementById('voiceTime').textContent = 'Voz activa · ' + m + ':' + String(s).padStart(2, '0');
    }, 1000);
  }

  // ── Input event listeners ─────────────────────────────────────────────────
  document.getElementById('msgInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(e.target.value);
    }
  });

  document.getElementById('micBtn').addEventListener('click', function() {
    const input = document.getElementById('msgInput');
    if (input.value.trim()) {
      sendMessage(input.value);
    } else if (isListening) {
      sendVoice();
    } else {
      startVoice();
    }
  });

  // Long-press for voice on mobile
  let pressTimer = null;
  const micBtn = document.getElementById('micBtn');

  micBtn.addEventListener('touchstart', function(e) {
    pressTimer = setTimeout(function() {
      if (!document.getElementById('msgInput').value.trim()) {
        startVoice();
      }
    }, 300);
  }, { passive: true });

  micBtn.addEventListener('touchend', function(e) {
    clearTimeout(pressTimer);
    if (isListening) sendVoice();
  }, { passive: true });
</script>

</body>
</html>
