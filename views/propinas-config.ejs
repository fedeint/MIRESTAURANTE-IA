<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Configurar Reparto · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--orange:#ef520f;--orange2:#df2c05;--dark:#0a0f24;--bg:#F0F2F8;--card:#fff;--text2:#8B8FAD;--verde:#22C55E;--safe-bot:env(safe-area-inset-bottom,0px);}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100dvh;max-width:480px;margin:0 auto;padding-bottom:calc(88px + var(--safe-bot));}
    .header{background:linear-gradient(170deg,#10152f 0%,#0a0f24 50%,#090d1d 100%);padding:52px 20px 20px;border-radius:0 0 20px 20px;color:#fff;display:flex;align-items:center;gap:12px;}
    .btn-back{background:rgba(255,255,255,.12);border:none;color:#fff;width:36px;height:36px;border-radius:10px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
    .header-title{font-size:18px;font-weight:700;}
    .section-label{font-size:13px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;padding:20px 16px 10px;}
    .card{background:var(--card);margin:0 16px;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.05);}
    /* Radio list */
    .radio-row{display:flex;align-items:center;justify-content:space-between;padding:15px 16px;border-bottom:1px solid #F0F2F8;cursor:pointer;}
    .radio-row:last-child{border-bottom:none;}
    .radio-label{font-size:15px;color:var(--dark);}
    .radio-dot{width:22px;height:22px;border-radius:50%;border:2px solid #C7CAD8;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .radio-dot.sel{border-color:var(--dark);background:var(--dark);}
    .radio-dot.sel::after{content:'';width:8px;height:8px;border-radius:50%;background:#fff;}
    /* Porcentajes */
    .pcts-wrap{display:flex;gap:10px;margin:0 16px;}
    .pct-chip{flex:1;padding:12px 8px;border-radius:12px;text-align:center;font-size:16px;font-weight:700;cursor:pointer;border:2px solid transparent;background:#DCFCE7;color:#166534;transition:all .2s;}
    .pct-chip.off{background:#F3F4F6;color:var(--text2);}
    /* Método */
    .metodo-seg{display:flex;gap:6px;margin:0 16px;}
    .met-btn{flex:1;padding:12px 8px;border-radius:12px;border:2px solid #E0E2EE;font-size:14px;font-weight:600;cursor:pointer;background:#fff;color:var(--text2);font-family:'DM Sans',sans-serif;transition:all .2s;}
    .met-btn.active{background:var(--dark);color:#fff;border-color:var(--dark);}
    /* Note */
    .note{display:flex;align-items:center;gap:6px;margin:12px 16px 0;font-size:12px;color:var(--text2);}
    /* CTA */
    .cta-wrap{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;padding:12px 16px calc(12px + var(--safe-bot));background:var(--bg);border-top:1px solid #E8EAF2;}
    .cta-btn{width:100%;background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;border:none;border-radius:14px;padding:16px;font-size:16px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;}
  </style>
</head>
<body>
  <div class="header">
    <button class="btn-back" onclick="history.back()">‹</button>
    <span class="header-title">Configurar reparto</span>
  </div>

  <div class="section-label">Modo de reparto</div>
  <div class="card">
    <% const modos = [
      { val:'partes_iguales', label:'Partes iguales' },
      { val:'por_horas',      label:'Por horas trabajadas' },
      { val:'personalizado',  label:'Personalizado' }
    ]; %>
    <% modos.forEach(function(m) { %>
    <div class="radio-row" onclick="setModo('<%= m.val %>')">
      <span class="radio-label"><%= m.label %></span>
      <div class="radio-dot <%= config.modo_reparto===m.val ? 'sel' : '' %>" id="rd-<%= m.val %>"></div>
    </div>
    <% }); %>
  </div>
  <input type="hidden" id="modoInput" value="<%= config.modo_reparto || 'partes_iguales' %>">

  <div class="section-label">% sugeridos al cobrar</div>
  <div class="pcts-wrap">
    <% ['5','10','15'].forEach(function(p) {
      const activo = (config.porcentajes || ['5','10','15']).includes(p);
    %>
    <div class="pct-chip <%= activo?'':'off' %>" data-p="<%= p %>" onclick="togglePct(this)">● <%= p %>%</div>
    <% }); %>
  </div>

  <div class="section-label">Método de propina</div>
  <div class="metodo-seg">
    <button class="met-btn <%= config.metodo==='incluida'?'active':'' %>" onclick="setMetodo('incluida',this)">Incluida en pago</button>
    <button class="met-btn <%= config.metodo==='efectivo_aparte'?'active':'' %>" onclick="setMetodo('efectivo_aparte',this)">Efectivo aparte</button>
  </div>
  <input type="hidden" id="metodoInput" value="<%= config.metodo || 'incluida' %>">

  <div class="note">⊙ Las propinas se calculan automáticamente al cierre del día</div>

  <div class="cta-wrap">
    <button class="cta-btn" onclick="guardar()">✓ Guardar configuración</button>
  </div>

  <script>
    function setModo(val){
      document.querySelectorAll('.radio-dot').forEach(d=>d.classList.remove('sel'));
      document.getElementById('rd-'+val).classList.add('sel');
      document.getElementById('modoInput').value = val;
    }
    function togglePct(el){ el.classList.toggle('off'); }
    function setMetodo(val,btn){
      document.querySelectorAll('.met-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('metodoInput').value = val;
    }
    async function guardar(){
      const pcts = Array.from(document.querySelectorAll('.pct-chip:not(.off)')).map(el=>el.dataset.p);
      const body = {
        modo_reparto: document.getElementById('modoInput').value,
        porcentajes:  pcts,
        metodo:       document.getElementById('metodoInput').value
      };
      const r = await fetch('/sprint4/propinas/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      const d = await r.json();
      if(d.ok) history.back(); else alert(d.error||'Error guardando');
    }
  </script>
  <script src="/js/dallia-fab.js"></script>
</body>
</html>
