<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Reglas de Fidelidad · MiRestcon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--orange:#ef520f;--orange2:#df2c05;--dark:#0a0f24;--bg:#F0F2F8;--card:#fff;--text2:#8B8FAD;--safe-bot:env(safe-area-inset-bottom,0px);}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100dvh;max-width:480px;margin:0 auto;padding-bottom:calc(88px + var(--safe-bot));}
    .header{background:linear-gradient(170deg,#10152f 0%,#0a0f24 50%,#090d1d 100%);padding:52px 20px 20px;border-radius:0 0 20px 20px;color:#fff;display:flex;align-items:center;gap:12px;}
    .btn-back{background:rgba(255,255,255,.12);border:none;color:#fff;width:36px;height:36px;border-radius:10px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
    .header-title{font-size:18px;font-weight:700;}
    .section-label{font-size:13px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;padding:20px 16px 10px;}
    .card{background:var(--card);margin:0 16px;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.05);padding:16px;}
    .field-label{font-size:13px;font-weight:600;color:var(--text2);margin-bottom:6px;}
    .field-input{width:100%;border:1.5px solid #E0E2EE;border-radius:12px;padding:11px 14px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;color:var(--dark);margin-bottom:14px;transition:border-color .2s;}
    .field-input:focus{border-color:var(--orange);}
    .note{margin:4px 16px 0;font-size:12px;color:var(--text2);}
    .cta-wrap{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;padding:12px 16px calc(12px + var(--safe-bot));background:var(--bg);border-top:1px solid #E8EAF2;}
    .cta-btn{width:100%;background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;border:none;border-radius:14px;padding:16px;font-size:16px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;}
  </style>
</head>
<body>
  <div class="header">
    <button class="btn-back" onclick="history.back()">‹</button>
    <span class="header-title">Reglas de puntos</span>
  </div>

  <div class="section-label">Acumulación</div>
  <div class="card">
    <div class="field-label">Puntos por cada S/ 1 gastado</div>
    <input class="field-input" type="number" id="puntosxSol" value="<%= config?.puntos_por_sol || 1 %>" min="0.1" step="0.1">
    <div class="field-label">Puntos mínimos para canjear</div>
    <input class="field-input" type="number" id="puntosMin" value="<%= config?.puntos_canje_minimo || 100 %>" min="1">
    <div class="field-label">Soles por cada punto canjeado</div>
    <input class="field-input" type="number" id="solxPunto" value="<%= config?.sol_por_canje || 1 %>" min="0.1" step="0.1">
  </div>
  <div class="note">Ej: S/1 = 1 punto · 100 puntos = S/ 1 de descuento</div>

  <div class="cta-wrap">
    <button class="cta-btn" onclick="guardar()">✓ Guardar reglas</button>
  </div>

  <script>
    async function guardar(){
      const body = {
        puntos_por_sol:      document.getElementById('puntosxSol').value,
        puntos_canje_minimo: document.getElementById('puntosMin').value,
        sol_por_canje:       document.getElementById('solxPunto').value
      };
      const r = await fetch('/sprint4/fidelidad/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      const d = await r.json();
      if(d.ok) history.back(); else alert(d.error||'Error');
    }
  </script>
  <script src="/js/dallia-fab.js"></script>
</body>
</html>
