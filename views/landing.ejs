              <span>ventas@dignita.tech</span>
            </div>
            <i class="bi bi-arrow-right ms-auto text-muted"></i>
          </a>

          <hr style="margin:1.5rem 0;border-color:rgba(0,0,0,.06);">

          <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:.875rem;padding:.875rem 1rem;display:flex;gap:.75rem;align-items:flex-start;">
            <i class="bi bi-credit-card-2-front-fill" style="color:#d97706;font-size:1.2rem;margin-top:.1rem;flex-shrink:0;"></i>
            <div>
              <div style="font-size:.82rem;font-weight:700;color:#92400e;margin-bottom:.2rem;">Pago online con tarjeta — Proximamente</div>
              <div style="font-size:.78rem;color:#b45309;">Estamos integrando Izipay para que puedas pagar con Visa, Mastercard o Amex directamente desde aqui. Por ahora, coordina por WhatsApp o email.</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Izipay Payment Modal -->
  <div class="modal fade" id="modalIzipay" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="border-radius:1.25rem;border:none;box-shadow:0 32px 80px rgba(0,0,0,0.15);">
        <div class="modal-header border-0 pb-0" style="padding:1.5rem 2rem 0;">
          <h5 class="modal-title" style="font-weight:800;"><i class="bi bi-shield-lock me-2" style="color:#6366f1;"></i>Pago seguro</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" style="padding:1rem 2rem 2rem;">
          <div id="izipay-plan-info" class="mb-3"></div>
          <div id="izipay-form-container">
            <div class="text-center py-4">
              <div class="spinner-border" style="color:#F97316;" role="status"></div>
              <div class="mt-2 text-muted small">Cargando formulario de pago...</div>
            </div>
          </div>
          <div class="text-center mt-3">
            <small class="text-muted"><i class="bi bi-lock me-1"></i>Procesado por Izipay — Visa, Mastercard, Amex</small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
  async function abrirPagoIzipay(planId, planNombre, planPrecio) {
    var container = document.getElementById('izipay-form-container');
    container.innerHTML = '<div class="text-center py-4"><div class="spinner-border" style="color:#F97316;" role="status"></div><div class="mt-2 text-muted small">Cargando formulario de pago...</div></div>';
    document.getElementById('izipay-plan-info').innerHTML =
      '<div style="background:linear-gradient(135deg,rgba(249,115,22,0.08),rgba(249,115,22,0.04));border:1px solid rgba(249,115,22,0.18);border-radius:.875rem;padding:1rem 1.25rem;">' +
      '<div class="d-flex justify-content-between align-items-center"><div><strong>' + planNombre + '</strong><br><small class="text-muted">MiRest con IA</small></div>' +
      '<div style="font-size:1.4rem;font-weight:900;color:#F97316;">' + planPrecio + '</div></div></div>';

    var modal = new bootstrap.Modal(document.getElementById('modalIzipay'));
    modal.show();

    try {
      var email = prompt('Ingresa tu email para continuar:');
      if (!email) { modal.hide(); return; }

      var resp = await fetch('/api/pagos/crear-sesion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ planId: planId, email: email })
      });
      var data = await resp.json();

      if (data.free) { window.location.href = data.redirect; return; }
      if (data.error) {
        container.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>' + data.error + (data.details ? '<br><small>' + data.details + '</small>' : '') + '</div>';
        return;
      }
      if (!data.formToken) {
        container.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>No se recibio token de pago.<br><small>' + JSON.stringify(data) + '</small></div>';
        return;
      }

      // Render Krypton embedded form
      KR.setFormConfig({ formToken: data.formToken, 'kr-language': 'es-PE' });
      await KR.renderElements('#izipay-form-container');
    } catch(err) {
      container.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>Error: ' + err.message + '</div>';
    }
  }
  </script>

  <!-- Bootstrap JS -->
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

  <script>
    // ── Contact modal ────────────────────────────────────────────────────────
    const WHATSAPP_NUMBER = '51999999999'; // Replace with real WhatsApp number

    function abrirContacto(planNombre, planPrecio) {
      document.getElementById('modalPlanNombre').textContent = 'Plan ' + planNombre;
      document.getElementById('modalPlanPrecio').textContent = planPrecio;

      const msg = encodeURIComponent(
        'Hola! Quiero contratar el plan ' + planNombre +
        ' de restaurante.dignita.tech (' + planPrecio + '). ¿Me pueden ayudar?'
      );
      document.getElementById('modalWhatsApp').href =
        'https://wa.me/' + WHATSAPP_NUMBER + '?text=' + msg;

      document.getElementById('modalEmail').href =
        'mailto:ventas@dignita.tech?subject=' +
        encodeURIComponent('Contratar plan ' + planNombre + ' - dignita.tech') +
        '&body=' + encodeURIComponent(
          'Hola,\n\nMe interesa contratar el plan ' + planNombre +
          ' (' + planPrecio + ').\n\nNombre de mi restaurante:\nTelefono de contacto:\n\nGracias.'
        );

      const modal = new bootstrap.Modal(document.getElementById('modalContacto'));
      modal.show();
    }

    // ── Smooth scroll for anchor links ────────────────────────────────────────
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', function(e) {
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>

</body>
</html>
