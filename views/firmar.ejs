<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1e1b4b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="dignita">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
    <title><%= docTipo === 'nda' ? 'Firmar NDA' : 'Firmar Contrato' %> - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <style>
        body {
            background-color: #FFF8F0;
            margin: 0;
            padding: 0;
        }
        .header-gradient {
            background: linear-gradient(135deg, #FF6B35, #E55A2B);
            color: #fff;
            text-align: center;
            padding: 24px;
        }
        .header-gradient h1 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
        }
        .header-gradient p {
            margin: 4px 0 0;
            opacity: 0.9;
            font-size: 1rem;
        }
        .main-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 24px 16px;
        }
        #signature-pad {
            width: 100%;
            max-width: 500px;
            height: 200px;
            background: #fff;
            border: 2px solid #ddd;
            border-radius: 8px;
            touch-action: none;
        }
        .btn-orange {
            background: linear-gradient(135deg, #FF6B35, #E55A2B);
            border: none;
            color: #fff;
            font-weight: 600;
        }
        .btn-orange:hover {
            background: linear-gradient(135deg, #E55A2B, #CC4A1E);
            color: #fff;
        }
        .btn-orange:disabled {
            opacity: 0.6;
            color: #fff;
        }
        .contract-iframe {
            width: 100%;
            height: 500px;
            border: 1px solid #ddd;
            border-radius: 8px;
        }
        @media (max-width: 576px) {
            .contract-iframe {
                height: 350px;
            }
            #signature-pad {
                height: 160px;
            }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div class="header-gradient">
        <h1><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'DIGNITA.TECH' : 'MiRestconIA' %></h1>
        <p><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Firma de Acuerdo de Confidencialidad (NDA)' : 'MiRestconIA &mdash; Firma de Contrato' %></p>
    </div>

    <div class="main-container">

        <% if (error) { %>
        <!-- Error State -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body text-center py-5">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                <h4 class="mt-3 text-danger">Error</h4>
                <p class="text-muted mb-1"><%= error %></p>
                <p class="text-muted small">Este enlace puede haber expirado o el contrato ya fue firmado.</p>
            </div>
        </div>
        <% } %>

        <% if (contrato) { %>
        <!-- Signing Section -->
        <div id="signing-section">
            <!-- Contract Info -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-file-earmark-text me-2"></i><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Información del NDA' : 'Información del Contrato' %></h5>
                    <div class="row">
                        <div class="col-sm-4 mb-2">
                            <small class="text-muted d-block"><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Nro. NDA' : 'Nro. Contrato' %></small>
                            <strong><%= contrato.nro_nda || contrato.nro_contrato %></strong>
                        </div>
                        <div class="col-sm-4 mb-2">
                            <small class="text-muted d-block"><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Miembro' : 'Cliente' %></small>
                            <strong><%= contrato.nombre_completo || contrato.nombre_cliente || contrato.razon_social %></strong>
                        </div>
                        <div class="col-sm-4 mb-2">
                            <small class="text-muted d-block">Fecha</small>
                            <strong><%= new Date(contrato.created_at).toLocaleDateString('es-PE') %></strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PDF Preview -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-file-pdf me-2"></i>Documento del Contrato</h5>
                    <iframe src="/firmar/<%= contrato.token %>/pdf" class="contract-iframe"></iframe>
                </div>
            </div>

            <!-- Signature -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-pen me-2"></i>Su Firma:</h5>
                    <canvas id="signature-pad"></canvas>
                    <div class="mt-2">
                        <button type="button" id="btn-clear" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-eraser me-1"></i>Limpiar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Legal + Submit -->
            <div class="card shadow-sm border-0 mt-4 mb-4">
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="accept-terms">
                        <label class="form-check-label small" for="accept-terms">
                            <% if (typeof docTipo !== 'undefined' && docTipo === 'nda') { %>
                            Al firmar, declaro haber le&iacute;do y aceptado todos los t&eacute;rminos del presente Acuerdo de Confidencialidad (NDA) de DIGNITA.TECH
                            <% } else { %>
                            Al firmar, declaro haber le&iacute;do y aceptado todos los t&eacute;rminos del presente Contrato de Licencia de Software y Servicios Tecnol&oacute;gicos de mirestconia.com
                            <% } %>
                        </label>
                    </div>
                    <button type="button" id="btn-submit" class="btn btn-orange btn-lg w-100" disabled>
                        <i class="bi bi-pen me-2"></i><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Aceptar y Firmar NDA' : 'Aceptar y Firmar Contrato' %>
                    </button>
                </div>
            </div>
        </div>

        <!-- Success Section (hidden by default) -->
        <div id="success-section" style="display:none;">
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body text-center py-5">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                    <h4 class="mt-3 text-success"><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'NDA Firmado Exitosamente' : 'Contrato Firmado Exitosamente' %></h4>
                    <p class="text-muted">Recibir&aacute; una copia del documento firmado en su correo electr&oacute;nico.</p>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/signature_pad@4/dist/signature_pad.umd.min.js"></script>
        <script>
            const canvas = document.getElementById('signature-pad');
            const signaturePad = new SignaturePad(canvas, { backgroundColor: 'rgba(0,0,0,0)' });

            function resizeCanvas() {
                const ratio = Math.max(window.devicePixelRatio || 1, 1);
                canvas.width = canvas.offsetWidth * ratio;
                canvas.height = canvas.offsetHeight * ratio;
                canvas.getContext('2d').scale(ratio, ratio);
                signaturePad.clear();
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            document.getElementById('btn-clear').addEventListener('click', () => signaturePad.clear());

            const checkbox = document.getElementById('accept-terms');
            const btnSubmit = document.getElementById('btn-submit');
            checkbox.addEventListener('change', () => {
                btnSubmit.disabled = !checkbox.checked;
            });

            btnSubmit.addEventListener('click', async () => {
                if (signaturePad.isEmpty()) {
                    alert('Por favor, dibuje su firma en el recuadro.');
                    return;
                }
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Procesando...';

                try {
                    const resp = await fetch('/firmar/<%= contrato.token %>/submit', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ signature: signaturePad.toDataURL('image/png') })
                    });
                    const data = await resp.json();
                    if (data.ok) {
                        document.getElementById('signing-section').style.display = 'none';
                        document.getElementById('success-section').style.display = 'block';
                    } else {
                        alert(data.error || 'Error al firmar');
                        btnSubmit.disabled = false;
                        btnSubmit.innerHTML = '<i class="bi bi-pen me-2"></i><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Aceptar y Firmar NDA' : 'Aceptar y Firmar Contrato' %>';
                    }
                } catch (err) {
                    alert('Error de conexión');
                    btnSubmit.disabled = false;
                    btnSubmit.innerHTML = '<i class="bi bi-pen me-2"></i><%= typeof docTipo !== 'undefined' && docTipo === 'nda' ? 'Aceptar y Firmar NDA' : 'Aceptar y Firmar Contrato' %>';
                }
            });
        </script>
        <% } %>

    </div>
</body>
</html>
