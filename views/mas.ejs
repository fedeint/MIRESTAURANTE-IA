<%# @variant: pwa — Solo PWA. En desktop el sidebar ya tiene la navegación. %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#10152f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Más">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <title>Más · MiRestcon</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #ef520f; --orange2: #df2c05;
      --dark: #0a0f24; --bg: #F0F2F8;
      --card: #ffffff; --text2: #8B8FAD;
      --safe-bot: env(safe-area-inset-bottom, 0px);
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      min-height: 100dvh;
      max-width: 480px;
      margin: 0 auto;
      padding-bottom: calc(80px + var(--safe-bot));
      -webkit-font-smoothing: antialiased;
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(170deg, #10152f 0%, #0a0f24 50%, #090d1d 100%);
      padding: calc(env(safe-area-inset-top, 14px) + 14px) 20px 20px;
      border-radius: 0 0 20px 20px;
      color: #fff;
    }
    .header-top {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px;
    }
    .header-title { font-size: 22px; font-weight: 800; }

    /* Role chip */
    .role-chip {
      display: flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,.1); border-radius: 40px;
      padding: 5px 10px 5px 5px; text-decoration: none;
    }
    .role-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0;
    }
    .role-nombre { font-size: 12px; font-weight: 600; color: #fff; }
    .role-label  { font-size: 10px; color: rgba(255,255,255,.55); text-transform: uppercase; letter-spacing: .04em; }
    .role-administrador { background: linear-gradient(135deg,#ef520f,#df2c05); }
    .role-cajero        { background: linear-gradient(135deg,#22c55e,#16a34a); }
    .role-mesero        { background: linear-gradient(135deg,#8b5cf6,#7c3aed); }
    .role-cocinero      { background: linear-gradient(135deg,#ef4444,#dc2626); }
    .role-almacenero    { background: linear-gradient(135deg,#3b82f6,#2563eb); }
    .role-usuario       { background: linear-gradient(135deg,#6b7280,#4b5563); }

    /* DallIA banner */
    .dallia-banner {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.15);
      border-radius: 14px; padding: 12px 14px;
      display: flex; align-items: center; gap: 12px;
      text-decoration: none; color: #fff;
    }
    .dallia-banner:active { background: rgba(255,255,255,.13); }
    .dallia-orb {
      width: 44px; height: 44px; border-radius: 12px;
      background: linear-gradient(135deg,var(--orange),var(--orange2));
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; flex-shrink: 0;
    }
    .dallia-text { flex: 1; }
    .dallia-title { font-size: 14px; font-weight: 700; }
    .dallia-sub   { font-size: 12px; color: rgba(255,255,255,.65); margin-top: 1px; }
    .dallia-arrow { color: rgba(255,255,255,.5); font-size: 20px; }

    /* Sections */
    .section { padding: 20px 16px 0; }
    .section-label {
      font-size: 11px; font-weight: 700; color: var(--text2);
      text-transform: uppercase; letter-spacing: .8px; margin-bottom: 10px;
    }

    /* 2-col grid */
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    .module-card {
      background: var(--card); border-radius: 16px; padding: 16px;
      display: flex; flex-direction: column; gap: 10px;
      text-decoration: none; color: inherit;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
      position: relative; overflow: hidden;
      -webkit-tap-highlight-color: transparent;
    }
    .module-card:active { opacity: .85; }

    .mod-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center; font-size: 22px;
    }
    .mod-title { font-size: 14px; font-weight: 700; color: var(--dark); line-height: 1.2; }
    .mod-sub   { font-size: 11px; color: var(--text2); margin-top: 2px; }

    /* Icon color variants */
    .ic-orange { background: #FFF3E0; }
    .ic-blue   { background: #EDE9FE; }
    .ic-green  { background: #DCFCE7; }
    .ic-red    { background: #FEE2E2; }
    .ic-purple { background: #F5F3FF; }
    .ic-teal   { background: #ECFDF5; }
    .ic-yellow { background: #FEFCE8; }
    .ic-dark   { background: #F1F5F9; }
    .ic-pink   { background: #FDF2F8; }
    .ic-indigo { background: #EEF2FF; }

    /* "Pronto" badge */
    .mod-pronto {
      position: absolute; top: 10px; right: 10px;
      background: #f1f5f9; color: #94a3b8;
      font-size: 9px; font-weight: 700;
      padding: 2px 6px; border-radius: 20px;
      text-transform: uppercase; letter-spacing: .04em;
    }

    /* Wide single-row card */
    .wide-card {
      background: var(--card); border-radius: 16px; padding: 14px 16px;
      display: flex; align-items: center; gap: 14px;
      text-decoration: none; color: inherit;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
      margin-bottom: 10px;
      -webkit-tap-highlight-color: transparent;
    }
    .wide-card:active { opacity: .85; }
    .wide-info { flex: 1; min-width: 0; }
    .wide-title { font-size: 15px; font-weight: 600; color: var(--dark); }
    .wide-sub   { font-size: 12px; color: var(--text2); margin-top: 2px; }
    .wide-arrow { color: var(--text2); font-size: 20px; flex-shrink: 0; }
  </style>
</head>
<body>
<%
  var _u = (typeof user !== 'undefined' && user) ? user : {};
  var _rol = String(_u.rol || 'usuario').toLowerCase();
  var _nombre = _u.nombre || _u.usuario || 'Usuario';
  var _initial = _nombre.charAt(0).toUpperCase();
  var _rolLabels = { administrador:'Admin', cajero:'Cajero', mesero:'Mesero', cocinero:'Chef', almacenero:'Almacén', usuario:'Usuario' };
  var _rolLabel = _rolLabels[_rol] || (_rol.charAt(0).toUpperCase() + _rol.slice(1));
%>

  <!-- ── HEADER ── -->
  <div class="header">
    <div class="header-top">
      <div class="header-title">Más</div>
      <a href="/configuracion" class="role-chip">
        <div class="role-avatar role-<%= _rol %>"><%= _initial %></div>
        <div>
          <div class="role-nombre"><%= _nombre.split(' ')[0] %></div>
          <div class="role-label"><%= _rolLabel %></div>
        </div>
      </a>
    </div>
    <a href="/chat" class="dallia-banner">
      <div class="dallia-orb">🤖</div>
      <div class="dallia-text">
        <div class="dallia-title">DalIA — Tu asistente IA</div>
        <div class="dallia-sub">Pregúntame lo que quieras del restaurante</div>
      </div>
      <span class="dallia-arrow">›</span>
    </a>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CORAZÓN — inventario y producción          -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Corazón</div>
    <div class="grid">
      <a href="/almacen" class="module-card">
        <div class="mod-icon ic-teal">📦</div>
        <div><div class="mod-title">Almacén</div><div class="mod-sub">Stock · Insumos · Alertas</div></div>
      </a>
      <a href="/productos" class="module-card">
        <div class="mod-icon ic-orange">🍽️</div>
        <div><div class="mod-title">Productos</div><div class="mod-sub">Carta · Precios · Fotos</div></div>
      </a>
      <a href="/recetas" class="module-card">
        <div class="mod-icon ic-green">📋</div>
        <div><div class="mod-title">Recetas</div><div class="mod-sub">Ingredientes · Costos</div></div>
      </a>
      <a href="/proximamente?feature=Proveedores&icon=🚚" class="module-card">
        <div class="mod-icon ic-blue">🚚</div>
        <div><div class="mod-title">Proveedores</div><div class="mod-sub">Contactos · Pedidos</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- MARKETING — incluye Eventos y Cortesías    -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Marketing</div>
    <div class="grid">
      <a href="/sostac/brief" class="module-card">
        <div class="mod-icon" style="background:#FFF0E5;">🧠</div>
        <div><div class="mod-title">Análisis</div><div class="mod-sub">Brief Delfino · SOSTAC</div></div>
      </a>
      <a href="/sostac" class="module-card">
        <div class="mod-icon ic-purple">🎯</div>
        <div><div class="mod-title">Objetivos</div><div class="mod-sub">Metas SMART · KPIs</div></div>
      </a>
      <a href="/sprint4/fidelidad" class="module-card">
        <div class="mod-icon ic-yellow">⭐</div>
        <div><div class="mod-title">Fidelidad</div><div class="mod-sub">Puntos · Canjes · QR</div></div>
      </a>
      <a href="/sprint4/promociones" class="module-card">
        <div class="mod-icon ic-pink">🏷️</div>
        <div><div class="mod-title">Promociones</div><div class="mod-sub">Cupones · ROI · Origen</div></div>
      </a>
      <a href="/sprint4/eventos" class="module-card">
        <div class="mod-icon ic-teal">🎉</div>
        <div><div class="mod-title">Eventos</div><div class="mod-sub">Catering · Reservas</div></div>
      </a>
      <a href="/cortesias/nueva" class="module-card">
        <div class="mod-icon ic-indigo">🎁</div>
        <div><div class="mod-title">Cortesías</div><div class="mod-sub">Registrar · Límites</div></div>
      </a>
      <a href="/metas" class="module-card">
        <div class="mod-icon ic-green">🏆</div>
        <div><div class="mod-title">Metas del día</div><div class="mod-sub">Ventas · Pedidos · Ticket</div></div>
      </a>
      <a href="/proximamente?feature=Pronosticos&icon=📈" class="module-card">
        <div class="mod-icon ic-green">📈</div>
        <div><div class="mod-title">Pronósticos</div><div class="mod-sub">Ventas · Tendencias</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
      <a href="/proximamente?feature=FlyersIA&icon=🖼️" class="module-card">
        <div class="mod-icon ic-orange">🖼️</div>
        <div><div class="mod-title">Flyers IA</div><div class="mod-sub">Diseño automático</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- FINANZAS                                    -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Finanzas</div>
    <div class="grid">
      <a href="/sunat-pwa" class="module-card">
        <div class="mod-icon ic-red">📊</div>
        <div><div class="mod-title">SUNAT</div><div class="mod-sub">IGV · Planilla · Vencimientos</div></div>
      </a>
      <a href="/sprint4/gastos-fijos" class="module-card">
        <div class="mod-icon ic-blue">💳</div>
        <div><div class="mod-title">Gastos Fijos</div><div class="mod-sub">Alquiler · Luz · Equilibrio</div></div>
      </a>
      <a href="/sprint4/propinas" class="module-card">
        <div class="mod-icon ic-green">💵</div>
        <div><div class="mod-title">Propinas</div><div class="mod-sub">Reparto por mesero</div></div>
      </a>
      <a href="/sunat-pwa/nota-credito" class="module-card">
        <div class="mod-icon ic-yellow">🧾</div>
        <div><div class="mod-title">Notas de crédito</div><div class="mod-sub">Emitir · Anular</div></div>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- ADMINISTRACIÓN — incluye Personal Eventual  -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Administración</div>
    <div class="grid">
      <a href="/administracion" class="module-card">
        <div class="mod-icon ic-dark">🏢</div>
        <div><div class="mod-title">Administración</div><div class="mod-sub">P&L · Ganancias</div></div>
      </a>
      <a href="/api/reportes" class="module-card">
        <div class="mod-icon ic-indigo">📋</div>
        <div><div class="mod-title">Reportes</div><div class="mod-sub">Ventas · PDF · Turnos</div></div>
      </a>
      <a href="/sprint4/personal-eventual" class="module-card">
        <div class="mod-icon ic-teal">👷</div>
        <div><div class="mod-title">Personal Eventual</div><div class="mod-sub">Por día · Prueba · Semanal</div></div>
      </a>
      <a href="/sprint4/mantenimiento" class="module-card">
        <div class="mod-icon ic-dark">🔧</div>
        <div><div class="mod-title">Mantenimiento</div><div class="mod-sub">Equipos · Calendario</div></div>
      </a>
      <a href="/facturacion" class="module-card">
        <div class="mod-icon ic-orange">🧾</div>
        <div><div class="mod-title">Facturación</div><div class="mod-sub">Boletas · Facturas</div></div>
      </a>
      <a href="/finanzas" class="module-card">
        <div class="mod-icon ic-green">💰</div>
        <div><div class="mod-title">Finanzas Pro</div><div class="mod-sub">Flujo · Proyecciones</div></div>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- LEGAL                                       -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Legal</div>
    <a href="/legal-pwa/permisos" class="wide-card">
      <div class="mod-icon ic-red">📋</div>
      <div class="wide-info">
        <div class="wide-title">Permisos y Legal</div>
        <div class="wide-sub">Licencias · Defensa Civil · Carnets · Semáforo</div>
      </div>
      <span class="wide-arrow">›</span>
    </a>
    <a href="/legal-pwa/reclamaciones" class="wide-card">
      <div class="mod-icon ic-blue">📝</div>
      <div class="wide-info">
        <div class="wide-title">Libro de Reclamaciones</div>
        <div class="wide-sub">Admin · Responder · INDECOPI</div>
      </div>
      <span class="wide-arrow">›</span>
    </a>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- COMUNICACIÓN — CRM + DM con personas reales-->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Comunicación</div>
    <div class="grid">
      <a href="/clientes" class="module-card">
        <div class="mod-icon ic-purple">👥</div>
        <div><div class="mod-title">Clientes</div><div class="mod-sub">Historial · DM · CRM</div></div>
      </a>
      <a href="/proximamente?feature=ProveedoresHub&icon=🤝" class="module-card">
        <div class="mod-icon ic-blue">🤝</div>
        <div><div class="mod-title">Proveedores</div><div class="mod-sub">Historial · Contacto</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
      <a href="/canales" class="module-card">
        <div class="mod-icon ic-green">💬</div>
        <div><div class="mod-title">WhatsApp API</div><div class="mod-sub">Mensajes · Plantillas</div></div>
      </a>
      <a href="/redes-sociales" class="module-card">
        <div class="mod-icon ic-pink">📱</div>
        <div><div class="mod-title">Redes Sociales</div><div class="mod-sub">Posts · Programar</div></div>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- IA — personalidad y configuración de DalIA -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">IA</div>
    <a href="/chat" class="wide-card">
      <div class="mod-icon" style="background:linear-gradient(135deg,#ef520f,#df2c05);width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;">🤖</div>
      <div class="wide-info">
        <div class="wide-title">DalIA Chat</div>
        <div class="wide-sub">Asistente IA · Alertas · Análisis</div>
      </div>
      <span class="wide-arrow">›</span>
    </a>
    <a href="/dallia/voz" class="wide-card">
      <div class="mod-icon ic-purple">🎙️</div>
      <div class="wide-info">
        <div class="wide-title">DalIA Voz</div>
        <div class="wide-sub">Modo orb · Manos libres</div>
      </div>
      <span class="wide-arrow">›</span>
    </a>
    <a href="/config/dallia" class="wide-card">
      <div class="mod-icon ic-orange">✨</div>
      <div class="wide-info">
        <div class="wide-title">Personalidad y alma</div>
        <div class="wide-sub">Nombre · Tono · Capacidades</div>
      </div>
      <span class="wide-arrow">›</span>
    </a>
    <a href="/proximamente?feature=MemoriaDalIA&icon=🧠" class="wide-card">
      <div class="mod-icon ic-teal">🧠</div>
      <div class="wide-info">
        <div class="wide-title">Memoria y contexto</div>
        <div class="wide-sub">Recuerdos · Historial · Perfil</div>
      </div>
      <span class="wide-arrow" style="color:#94a3b8;font-size:12px;font-weight:600;">Pronto</span>
    </a>
    <a href="/proximamente?feature=Automatizaciones&icon=⚡&preview=30+de+100" class="wide-card">
      <div class="mod-icon ic-yellow">⚡</div>
      <div class="wide-info">
        <div class="wide-title">Automatizaciones</div>
        <div class="wide-sub">30 de 100 planeadas</div>
      </div>
      <span class="wide-arrow" style="color:#94a3b8;font-size:12px;font-weight:600;">Pronto</span>
    </a>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- INTEGRACIONES                               -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Integraciones</div>
    <div class="grid">
      <a href="/delivery" class="module-card">
        <div class="mod-icon ic-orange">🛵</div>
        <div><div class="mod-title">Delivery</div><div class="mod-sub">Propio · Rappi · PedidosYa</div></div>
      </a>
      <a href="/proximamente?feature=ImpresoraTermica&icon=🖨️" class="module-card">
        <div class="mod-icon ic-dark">🖨️</div>
        <div><div class="mod-title">Impresora</div><div class="mod-sub">Ticket cocina · ESC/POS</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
      <a href="/proximamente?feature=AppsCompatibles&icon=🔌" class="module-card">
        <div class="mod-icon ic-blue">🔌</div>
        <div><div class="mod-title">Apps</div><div class="mod-sub">Compatibles · Plugins</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
      <a href="/proximamente?feature=APIsExternas&icon=🌐" class="module-card">
        <div class="mod-icon ic-teal">🌐</div>
        <div><div class="mod-title">APIs Externas</div><div class="mod-sub">Conectores · Webhooks</div></div>
        <span class="mod-pronto">Pronto</span>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SISTEMA                                     -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="section">
    <div class="section-label">Sistema</div>
    <div class="grid">
      <a href="/usuarios" class="module-card">
        <div class="mod-icon ic-purple">👤</div>
        <div><div class="mod-title">Usuarios</div><div class="mod-sub">Roles · Accesos · Turnos</div></div>
      </a>
      <a href="/configuracion" class="module-card">
        <div class="mod-icon ic-dark">⚙️</div>
        <div><div class="mod-title">Configuración</div><div class="mod-sub">Sistema · Horarios · Alertas</div></div>
      </a>
      <a href="/soporte" class="module-card">
        <div class="mod-icon ic-green">🎧</div>
        <div><div class="mod-title">Soporte</div><div class="mod-sub">Tickets · Chat · Docs</div></div>
      </a>
      <a href="/setup-pwa" class="module-card">
        <div class="mod-icon ic-yellow">🎓</div>
        <div><div class="mod-title">Tour</div><div class="mod-sub">Guía · Tutorial · Ayuda</div></div>
      </a>
    </div>
  </div>

  <div style="height: 16px;"></div>

  <%- include('partials/limelight-nav', { reqPath: '/mas' }) %>

  <script src="/js/dallia-fab.js"></script>
</body>
</html>
