<%# @variant: pwa %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#10152f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Setup del Sistema · MiRestcon</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #ef520f; --orange2: #df2c05;
      --dark: #0a0f24; --bg: #F0F2F8;
      --card: #fff; --text2: #8B8FAD;
      --success: #22C55E;
      --safe-bot: env(safe-area-inset-bottom, 0px);
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      min-height: 100dvh;
      max-width: 480px;
      margin: 0 auto;
      padding-bottom: calc(80px + var(--safe-bot));
      -webkit-font-smoothing: antialiased;
      color: var(--dark);
    }

    /* Header */
    .header {
      background: linear-gradient(170deg, #10152f 0%, #0a0f24 50%, #090d1d 100%);
      padding: calc(52px + env(safe-area-inset-top, 0px)) 20px 24px;
      border-radius: 0 0 20px 20px;
      color: #fff;
      text-align: center;
    }
    .header-avatar {
      width: 64px; height: 64px; border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      display: flex; align-items: center; justify-content: center;
      font-size: 30px; margin: 0 auto 12px;
      box-shadow: 0 4px 20px rgba(239,82,15,0.40);
    }
    .header h1 { font-size: 22px; font-weight: 700; line-height: 1.2; margin-bottom: 4px; }
    .header-sub { font-size: 13px; color: rgba(255,255,255,0.6); font-weight: 500; }

    /* Progress bar */
    .progress {
      margin: 14px auto 0;
      max-width: 200px;
      height: 4px;
      background: rgba(255,255,255,0.15);
      border-radius: 4px;
      overflow: hidden;
    }
    .progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--orange), var(--orange2));
      transition: width .4s ease;
    }
    .progress-text {
      font-size: 11px; color: rgba(255,255,255,0.55);
      margin-top: 6px; font-weight: 600;
      letter-spacing: .4px;
    }

    /* Content */
    .content { padding: 16px; }
    .section-label {
      font-size: 11px; font-weight: 700; color: var(--text2);
      text-transform: uppercase; letter-spacing: .8px;
      margin: 20px 4px 10px;
    }
    .section-label:first-child { margin-top: 0; }

    /* Dallia intro card */
    .dallia-card {
      background: var(--card);
      border-radius: 16px;
      padding: 14px;
      margin-bottom: 16px;
      display: flex; gap: 12px; align-items: flex-start;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .dallia-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    .dallia-text { font-size: 13px; line-height: 1.45; color: var(--dark); }
    .dallia-text strong { color: var(--orange); }

    /* Setup cards */
    .setup-card {
      background: var(--card);
      border-radius: 14px;
      padding: 14px;
      margin-bottom: 10px;
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
      color: inherit;
      box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      transition: transform .15s, box-shadow .15s;
      border: 1.5px solid transparent;
    }
    .setup-card:active { transform: scale(.98); }
    .setup-card.done { border-color: rgba(34,197,94,0.3); background: #F7FEF9; }

    .sc-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; flex-shrink: 0;
    }
    .ic-orange { background: #FFF2EC; }
    .ic-blue   { background: #EEF2FF; }
    .ic-green  { background: #ECFDF5; }
    .ic-purple { background: #F5F3FF; }
    .ic-yellow { background: #FEFCE8; }

    .sc-info { flex: 1; min-width: 0; }
    .sc-title {
      font-size: 15px; font-weight: 700; color: var(--dark);
      margin-bottom: 2px;
      display: flex; align-items: center; gap: 6px;
    }
    .sc-sub { font-size: 12px; color: var(--text2); line-height: 1.35; }

    .sc-check {
      width: 20px; height: 20px; border-radius: 50%;
      background: var(--success);
      color: #fff; font-size: 12px; font-weight: 700;
      display: inline-flex; align-items: center; justify-content: center;
    }
    .sc-arrow {
      color: var(--text2); font-size: 22px;
      flex-shrink: 0;
    }

    /* Finish button */
    .finish-wrap { padding: 8px 4px 0; }
    .btn-finish {
      width: 100%;
      padding: 14px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, var(--orange), var(--orange2));
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px; font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(239,82,15,0.35);
    }
    .btn-finish:disabled {
      background: #CBD0E0;
      box-shadow: none;
      cursor: not-allowed;
    }
    .btn-skip {
      width: 100%;
      margin-top: 8px;
      padding: 12px;
      border-radius: 12px;
      border: none;
      background: transparent;
      color: var(--text2);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 600;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header-avatar">🚀</div>
    <h1>Configura tu sistema</h1>
    <div class="header-sub">Personaliza MiRestcon para tu restaurante</div>
    <div class="progress"><div class="progress-bar" id="progressBar" style="width:<%= progress.pct %>%"></div></div>
    <div class="progress-text"><span id="progressCount"><%= progress.done %></span> de <%= progress.total %> completados</div>
  </header>

  <div class="content">

    <div class="dallia-card">
      <div class="dallia-avatar">🤖</div>
      <div class="dallia-text">
        <strong>DalIA:</strong> ¡Genial, ya terminamos el onboarding! Ahora personaliza estas 5 cosas y estás listo para arrancar. Puedes saltarte las que quieras y volver después.
      </div>
    </div>

    <div class="section-label">Personalización</div>

    <% steps.forEach(s => { %>
      <a href="<%= s.href %>" class="setup-card <%= s.done ? 'done' : '' %>">
        <div class="sc-icon <%= s.ic %>"><%= s.icon %></div>
        <div class="sc-info">
          <div class="sc-title">
            <%= s.title %>
            <% if (s.done) { %><span class="sc-check">✓</span><% } %>
          </div>
          <div class="sc-sub"><%= s.sub %></div>
        </div>
        <div class="sc-arrow">›</div>
      </a>
    <% }); %>

    <div class="finish-wrap">
      <button class="btn-finish" id="btnFinish" <%= progress.done === 0 ? 'disabled' : '' %> onclick="terminar()">
        <%= progress.done === progress.total ? '¡Listo, entrar al sistema!' : 'Terminar configuración' %>
      </button>
      <button class="btn-skip" onclick="terminar(true)">Saltar y completar después</button>
    </div>

  </div>

  <script>
    async function terminar(skip) {
      try {
        const btn = document.getElementById('btnFinish');
        if (btn) btn.disabled = true;
        await fetch('/setup-sistema/api/completar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ skip: !!skip })
        });
      } catch (_) { /* ignore */ }
      window.location.href = '/';
    }
  </script>
</body>
</html>
