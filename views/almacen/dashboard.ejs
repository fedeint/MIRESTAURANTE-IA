<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Almacen - dignita.tech</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('../partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">

        <div class="d-flex align-items-center mb-4 mt-3">
            <i class="bi bi-box-seam fs-2 me-2"></i>
            <h2 class="mb-0">Almacen</h2>
        </div>

        <!-- KPI Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                            <i class="bi bi-egg-fried fs-3 text-success"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Total Ingredientes</h6>
                            <h3 class="mb-0"><%= stats.totalIngredientes %></h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="rounded-circle bg-danger bg-opacity-10 p-3 me-3">
                            <i class="bi bi-exclamation-triangle fs-3 text-danger"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Alertas Stock Bajo</h6>
                            <h3 class="mb-0">
                                <% if (stats.alertas > 0) { %>
                                    <span class="text-danger"><%= stats.alertas %></span>
                                <% } else { %>
                                    <span class="text-success">0</span>
                                <% } %>
                            </h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="rounded-circle bg-purple bg-opacity-10 p-3 me-3" style="background-color: rgba(111,66,193,0.1);">
                            <i class="bi bi-cash-stack fs-3" style="color: #6f42c1;"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Valor Inventario</h6>
                            <h3 class="mb-0">S/ <%= stats.valorInventario %></h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Access -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h6 class="card-title mb-3">Acceso Rapido</h6>
                <div class="row g-2">
                    <div class="col">
                        <a href="/almacen/inventario" class="btn btn-outline-primary w-100">
                            <i class="bi bi-list-ul"></i><br>Inventario
                        </a>
                    </div>
                    <div class="col">
                        <a href="/almacen/proveedores" class="btn btn-outline-primary w-100">
                            <i class="bi bi-truck"></i><br>Proveedores
                        </a>
                    </div>
                    <div class="col">
                        <a href="/almacen/compras" class="btn btn-outline-primary w-100">
                            <i class="bi bi-cart"></i><br>Compras
                        </a>
                    </div>
                    <div class="col">
                        <a href="/almacen/entradas" class="btn btn-outline-primary w-100">
                            <i class="bi bi-box-arrow-in-down"></i><br>Entradas
                        </a>
                    </div>
                    <div class="col">
                        <a href="/almacen/salidas" class="btn btn-outline-primary w-100">
                            <i class="bi bi-box-arrow-up"></i><br>Salidas
                        </a>
                    </div>
                    <div class="col">
                        <a href="/almacen/historial" class="btn btn-outline-primary w-100">
                            <i class="bi bi-clock-history"></i><br>Historial
                        </a>
                    </div>
                    <div class="col">
                        <a href="/almacen/conteo-fisico" class="btn btn-outline-primary w-100">
                            <i class="bi bi-clipboard-check"></i><br>Conteo Fisico
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Categorias -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h6 class="card-title mb-3">Categorias</h6>
                <div class="d-flex flex-wrap gap-2">
                    <% stats.categorias.forEach(function(cat) { %>
                        <span class="badge rounded-pill" style="background-color: <%= cat.color %>;">
                            <%= cat.name %>
                        </span>
                    <% }); %>
                </div>
            </div>
        </div>

    </div>
    </main>
    <%- include('../partials/footer') %>
    </div>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
</body>
</html>
