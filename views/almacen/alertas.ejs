<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alertas Stock - mirestconia.com</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('../partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">

        <div class="d-flex align-items-center mb-4 mt-3">
            <i class="bi bi-exclamation-triangle fs-2 me-2 text-danger"></i>
            <h2 class="mb-0">Alertas de Stock</h2>
        </div>

        <!-- Tabla -->
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ingrediente</th>
                            <th>Stock Actual</th>
                            <th>Stock Minimo</th>
                            <th>Diferencia</th>
                            <th>Categoria</th>
                        </tr>
                    </thead>
                    <tbody id="tablaAlertas">
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-hourglass-split"></i> Cargando alertas...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
    </main>
    <%- include('../partials/footer') %>
    </div>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', cargarAlertas);

        async function cargarAlertas() {
            try {
                const res = await fetch('/almacen/api/alertas');
                const data = await res.json();
                const tbody = document.getElementById('tablaAlertas');

                if (!data.alertas || data.alertas.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-success py-4"><i class="bi bi-check-circle"></i> No hay alertas de stock. Todo en orden.</td></tr>';
                    return;
                }

                tbody.innerHTML = data.alertas.map(function(a) {
                    var diferencia = a.stock_actual - a.stock_minimo;
                    var esCritico = a.stock_actual <= a.stock_minimo;
                    var rowClass = esCritico ? 'table-danger' : 'table-warning';
                    var difClass = esCritico ? 'text-danger fw-bold' : 'text-warning';

                    return '<tr class="' + rowClass + '">' +
                        '<td><strong>' + a.nombre + '</strong></td>' +
                        '<td>' + a.stock_actual + ' ' + (a.unidad_medida || '') + '</td>' +
                        '<td>' + a.stock_minimo + ' ' + (a.unidad_medida || '') + '</td>' +
                        '<td class="' + difClass + '">' + diferencia + '</td>' +
                        '<td><span class="badge" style="background-color:' + (a.categoria_color || '#6c757d') + '">' + (a.categoria || '-') + '</span></td>' +
                        '</tr>';
                }).join('');
            } catch (err) {
                document.getElementById('tablaAlertas').innerHTML =
                    '<tr><td colspan="5" class="text-center text-danger py-4"><i class="bi bi-exclamation-triangle"></i> Error al cargar alertas</td></tr>';
            }
        }
    </script>
</body>
</html>
