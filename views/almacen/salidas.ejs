<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salida Manual - dignita.tech</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
    <%- include('../partials/sidebar') %>
    <div class="dg-main">
    <main class="flex-grow-1">
    <div class="container">

        <div class="d-flex align-items-center mb-4 mt-3">
            <i class="bi bi-box-arrow-up fs-2 me-2 text-danger"></i>
            <h2 class="mb-0">Salida Manual</h2>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <form id="formSalida">
                            <div class="mb-3">
                                <label class="form-label">Ingrediente</label>
                                <select id="ingrediente_id" class="form-select" required>
                                    <option value="">Seleccionar ingrediente...</option>
                                    <% ingredientes.forEach(function(i) { %>
                                        <option value="<%= i._id %>"><%= i.codigo %> - <%= i.nombre %> (Stock: <%= i.stock_actual %> <%= i.unidad_medida %>)</option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Cantidad</label>
                                <input type="number" id="cantidad" class="form-control" step="0.01" min="0.01" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Motivo</label>
                                <select id="motivo" class="form-select" required>
                                    <option value="">Seleccionar motivo...</option>
                                    <option value="merma_vencimiento">Merma por vencimiento</option>
                                    <option value="merma_dano">Merma por dano</option>
                                    <option value="merma_preparacion">Merma por preparacion</option>
                                    <option value="consumo_interno">Consumo interno</option>
                                    <option value="devolucion_proveedor">Devolucion a proveedor</option>
                                    <option value="regalo">Regalo</option>
                                    <option value="robo_perdida">Robo / Perdida</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Notas <span class="text-danger">*</span></label>
                                <textarea id="notas" class="form-control" rows="3" placeholder="Describa el motivo de la salida..." required></textarea>
                            </div>
                            <button type="button" class="btn btn-danger w-100" onclick="registrarSalida()">
                                <i class="bi bi-box-arrow-up me-1"></i>Registrar Salida
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>
    </main>
    <%- include('../partials/footer') %>
    </div>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
        async function registrarSalida() {
            const ingrediente_id = document.getElementById('ingrediente_id').value;
            const cantidad = parseFloat(document.getElementById('cantidad').value);
            const motivo = document.getElementById('motivo').value;
            const notas = document.getElementById('notas').value.trim();

            if (!ingrediente_id || !cantidad || cantidad <= 0) {
                Swal.fire('Atencion', 'Seleccione un ingrediente y una cantidad valida', 'warning');
                return;
            }
            if (!motivo) {
                Swal.fire('Atencion', 'Seleccione un motivo', 'warning');
                return;
            }
            if (!notas) {
                Swal.fire('Atencion', 'Las notas son obligatorias para salidas', 'warning');
                return;
            }

            const result = await Swal.fire({
                title: 'Confirmar salida',
                text: 'Se descontara ' + cantidad + ' unidades del stock. Esta seguro?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Si, registrar',
                cancelButtonText: 'Cancelar'
            });

            if (!result.isConfirmed) return;

            const body = {
                ingrediente_id: ingrediente_id,
                cantidad: cantidad,
                motivo: motivo,
                notas: notas
            };

            try {
                const res = await fetch('/almacen/api/salida', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire('Salida Registrada', 'Stock actualizado correctamente', 'success')
                        .then(() => {
                            document.getElementById('formSalida').reset();
                        });
                } else {
                    Swal.fire('Error', data.message || 'Error al registrar salida', 'error');
                }
            } catch (err) {
                Swal.fire('Error', 'Error de conexion', 'error');
            }
        }
    </script>
</body>
</html>
