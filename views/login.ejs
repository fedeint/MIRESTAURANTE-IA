<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar Sesion - mirestconia.com</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #121212;
      overflow: hidden;
      padding: 1rem;
    }

    /* Glass card */
    .glass-card {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 24rem;
      border-radius: 1.5rem;
      background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, #121212 100%);
      backdrop-filter: blur(12px);
      box-shadow: 0 25px 50px rgba(0,0,0,0.6);
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* Logo */
    .logo-wrap {
      width: 5rem;
      height: 5rem;
      border-radius: 1.25rem;
      background: rgba(255,255,255,0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
      box-shadow: 0 8px 24px rgba(255,107,53,0.25);
    }
    .logo-wrap img { width: 3.5rem; height: 3.5rem; border-radius: 0.75rem; object-fit: contain; }

    /* Title */
    .glass-card h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 1.5rem;
      text-align: center;
      letter-spacing: -0.02em;
    }

    /* Form */
    .login-form { width: 100%; display: flex; flex-direction: column; gap: 0.75rem; }

    .glass-input {
      width: 100%;
      padding: 0.75rem 1.25rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.08);
      color: #fff;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .glass-input::placeholder { color: #9ca3af; }
    .glass-input:focus { border-color: #FF6B35; box-shadow: 0 0 0 3px rgba(255,107,53,0.2); }

    .divider { border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 0.5rem 0; }

    .btn-signin {
      width: 100%;
      padding: 0.75rem;
      border-radius: 2rem;
      border: none;
      background: rgba(255,255,255,0.1);
      color: #fff;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-signin:hover { background: rgba(255,255,255,0.18); }

    .btn-google {
      width: 100%;
      padding: 0.75rem;
      border-radius: 2rem;
      border: none;
      background: linear-gradient(to bottom, #232526, #2d2e30);
      color: #fff;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: filter 0.15s;
    }
    .btn-google:hover { filter: brightness(1.15); }
    .btn-google img { width: 1.25rem; height: 1.25rem; }

    .login-hint {
      margin-top: 0.75rem;
      font-size: 0.72rem;
      color: #6b7280;
      background: rgba(255,255,255,0.04);
      padding: 0.6rem 0.75rem;
      border-radius: 0.5rem;
      width: 100%;
      text-align: center;
    }
    .login-hint strong { color: #d1d5db; }

    .alert-glass {
      width: 100%;
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.3);
      color: #fca5a5;
      padding: 0.5rem 0.75rem;
      border-radius: 0.5rem;
      font-size: 0.8rem;
    }

    /* Tagline below card */
    .tagline {
      position: relative;
      z-index: 10;
      margin-top: 2rem;
      text-align: center;
      color: #6b7280;
      font-size: 0.85rem;
    }
    .tagline strong { color: #fff; font-weight: 600; }
    .tagline .brand { color: #FF6B35; }

    /* Client avatars */
    .avatars {
      display: flex;
      justify-content: center;
      margin-top: 0.75rem;
    }
    .avatars img {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 50%;
      border: 2px solid #1e1e2e;
      object-fit: cover;
      margin-left: -0.5rem;
    }
    .avatars img:first-child { margin-left: 0; }
  </style>
</head>
<body>

  <!-- Glass login card -->
  <div class="glass-card">
    <div class="logo-wrap">
      <img src="/isotipo.png" alt="MiRest con IA">
    </div>
    <h2>Mi<span style="color:#FF6B35;">Rest</span> con <span style="color:#ff7846;">IA</span></h2>

    <% if (error) { %>
      <div class="alert-glass mb-3"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" autocomplete="off" class="login-form">
      <input name="usuario" class="glass-input" required autofocus placeholder="Usuario">
      <input name="password" type="password" class="glass-input" required placeholder="Contrasena">
      <hr class="divider">
      <button type="submit" class="btn-signin">
        <i class="bi bi-box-arrow-in-right me-1"></i> Entrar
      </button>
      <button type="button" class="btn-google" onclick="alert('Google Sign-In proximamente')">
        <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google">
        Continuar con Google
      </button>
    </form>

    <div class="login-hint">
      <i class="bi bi-info-circle me-1"></i>
      Primer acceso: <strong>admin</strong> / <strong>admin123</strong>
    </div>
  </div>

  <!-- Tagline + avatars -->
  <div class="tagline">
    <strong>Cientos de restaurantes</strong> ya usan <span class="brand">MiRest con IA</span>.
    <div class="avatars">
      <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="cliente">
      <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="cliente">
      <img src="https://randomuser.me/api/portraits/men/54.jpg" alt="cliente">
      <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="cliente">
      <img src="https://randomuser.me/api/portraits/men/75.jpg" alt="cliente">
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
