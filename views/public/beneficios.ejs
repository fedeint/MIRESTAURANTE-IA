      </div>

      <!-- CARD 2 — Mozo -->
      <div class="profile-card">
        <div class="profile-top">
          <div class="avatar-circle">🍽️</div>
          <div>
            <p class="profile-name">María Quispe</p>
            <p class="profile-role">Mozo Senior · 3 años exp.</p>
