<script>
(function () {
  const input = document.getElementById('restaurantSearch');
  const dropdown = document.getElementById('searchDropdown');
  let debounceTimer = null;

  function showDropdown(items) {
    if (!items || items.length === 0) {
      dropdown.innerHTML = '<div class="search-loading">No encontramos ese restaurante</div>';
      dropdown.classList.add('active');
      return;
    }

    dropdown.innerHTML = items.map(function (r) {
      var name = r.nombre || r.name || '';
      var subdomain = r.subdominio || r.subdomain || '';
      var city = r.ciudad || r.city || '';
      return (
        '<div class="search-item" data-subdomain="' + subdomain + '">' +
        '<i class="bi bi-shop search-item-icon"></i>' +
        '<div>' +
        '<div>' + name + '</div>' +
        (city ? '<div class="search-item-sub">' + city + '</div>' : '') +
        '</div>' +
        '</div>'
      );
    }).join('');

    dropdown.querySelectorAll('.search-item').forEach(function (el) {
      el.addEventListener('click', function () {
        var sub = el.getAttribute('data-subdomain');
        if (sub) {
          window.location.href = '/' + sub;
        }
      });
    });

    dropdown.classList.add('active');
  }

  function hideDropdown() {
    dropdown.classList.remove('active');
    dropdown.innerHTML = '';
  }

  function search(query) {
    if (!query || query.length < 2) {
      hideDropdown();
      return;
    }

    dropdown.innerHTML = '<div class="search-loading">Buscando...</div>';
    dropdown.classList.add('active');

    fetch('/api/restaurantes?buscar=' + encodeURIComponent(query))
      .then(function (res) { return res.json(); })
      .then(function (data) {
        var items = Array.isArray(data) ? data : (data.restaurantes || data.data || []);
        showDropdown(items);
      })
      .catch(function () {
        dropdown.innerHTML = '<div class="search-loading">Error al buscar. Intenta de nuevo.</div>';
      });
  }

  input.addEventListener('input', function () {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function () {
      search(input.value.trim());
    }, 320);
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.search-wrap')) {
      hideDropdown();
    }
  });

  input.addEventListener('focus', function () {
    if (input.value.trim().length >= 2) {
      search(input.value.trim());
    }
  });
})();
</script>

