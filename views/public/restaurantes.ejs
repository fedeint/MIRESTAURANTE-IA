<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Restaurantes con IA — MiRestcon IA</title>
  <meta name="description" content="Directorio de restaurantes peruanos que usan inteligencia artificial. Descubre los mejores locales con tecnología DallIA.">

  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #F0F2F8; color: #0a0f24;
      color: #e2e8f0;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
    }

    /* ── HERO HEADER ─────────────────────────────── */
    .hero-section {
      background: linear-gradient(135deg, #10152f 0%, #0a0f24 60%, #0d1220 100%);
      border-bottom: 1px solid rgba(255,107,53,0.12);
      padding: 64px 24px 52px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero-section::before {
      content: '';
      position: absolute;
      top: -80px; left: 50%; transform: translateX(-50%);
      width: 500px; height: 300px;
      background: radial-gradient(ellipse, rgba(255,107,53,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-robot {
      width: 72px; height: 72px;
      background: linear-gradient(135deg, #FF6B35 0%, #df2c05 100%);
      border-radius: 20px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
      font-size: 36px;
      box-shadow: 0 8px 32px rgba(255,107,53,0.35);
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,107,53,0.12);
      border: 1px solid rgba(255,107,53,0.3);
      border-radius: 100px;
      padding: 4px 14px;
      font-size: 11px; font-weight: 700;
      color: #FF6B35;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .hero-title {
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 800;
      color: #ffffff;
      letter-spacing: -0.5px;
      line-height: 1.15;
      margin-bottom: 14px;
    }
    .hero-title span { color: #FF6B35; }
    .hero-subtitle {
      font-size: clamp(15px, 2.5vw, 18px);
      color: #94a3b8;
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.6;
      font-weight: 400;
    }

    /* ── SEARCH & FILTERS ───────────────────────── */
    .search-section {
      padding: 36px 24px 28px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .search-wrapper {
      position: relative;
      max-width: 560px;
      margin: 0 auto 20px;
    }
    .search-wrapper i {
      position: absolute;
      left: 16px; top: 50%; transform: translateY(-50%);
      color: #64748b; font-size: 17px;
      pointer-events: none;
    }
    .search-input {
      width: 100%;
      background: #141828;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 14px 16px 14px 44px;
      color: #e2e8f0;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-input::placeholder { color: #475569; }
    .search-input:focus { border-color: rgba(255,107,53,0.45); }

    .filter-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
    }
    .pill {
      padding: 8px 18px;
      border-radius: 100px;
      font-size: 13px; font-weight: 600;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.1);
      background: #141828;
      color: #94a3b8;
      transition: all 0.18s;
      user-select: none;
    }
    .pill:hover { border-color: rgba(255,107,53,0.4); color: #FF6B35; }
    .pill.active {
      background: #FF6B35;
      border-color: #FF6B35;
      color: #ffffff;
      box-shadow: 0 4px 16px rgba(255,107,53,0.3);
    }

    /* ── MAP ────────────────────────────────────── */
    .map-section {
      padding: 8px 24px 36px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .map-label {
      font-size: 11px; font-weight: 700;
      color: #64748b;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    #peru-map {
      height: 400px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.07);
      overflow: hidden;
    }
    .leaflet-container { background: #0a0f24 !important; }

    /* ── RESTAURANT GRID ────────────────────────── */
    .grid-section {
      padding: 8px 24px 56px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 8px;
    }
    .section-title {
      font-size: 18px; font-weight: 700;
      color: #ffffff;
    }
    .count-badge {
      font-size: 12px; font-weight: 600;
      color: #64748b;
      background: rgba(255,255,255,0.05);
      border-radius: 100px;
      padding: 4px 12px;
    }

    .restaurant-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }

    .rest-card {
      background: #141828;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      overflow: hidden;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .rest-card:hover {
      transform: translateY(-3px);
      border-color: rgba(255,107,53,0.25);
      box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    }
    .rest-card-img {
      width: 100%; height: 160px;
      object-fit: cover;
      display: block;
    }
    .rest-card-img-placeholder {
      width: 100%; height: 160px;
      background: linear-gradient(135deg, #1a2040 0%, #0f1530 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 40px;
      color: rgba(255,107,53,0.3);
    }
    .rest-card-body { padding: 20px; }
    .rest-card-tipo {
      display: inline-block;
      font-size: 10px; font-weight: 700;
      color: #FF6B35;
      background: rgba(255,107,53,0.1);
      border: 1px solid rgba(255,107,53,0.2);
      border-radius: 6px;
      padding: 2px 8px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 8px;
    }
    .rest-card-name {
      font-size: 17px; font-weight: 700;
      color: #ffffff;
      margin-bottom: 6px;
      line-height: 1.3;
    }
    .rest-card-loc {
      display: flex; align-items: center; gap: 5px;
      font-size: 13px; color: #64748b;
      margin-bottom: 18px;
    }
    .rest-card-loc i { font-size: 13px; color: #FF6B35; }
    .btn-entrar {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 10px 20px;
      background: linear-gradient(135deg, #FF6B35 0%, #df2c05 100%);
      color: #ffffff;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 700;
      border-radius: 10px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.15s;
    }
    .btn-entrar:hover { opacity: 0.88; transform: scale(1.02); color: #fff; }

    /* Loading & empty states */
    .state-loading, .state-empty {
      grid-column: 1 / -1;
      text-align: center;
      padding: 60px 20px;
    }
    .state-loading .spinner {
      width: 40px; height: 40px;
      border: 3px solid rgba(255,107,53,0.2);
      border-top-color: #FF6B35;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .state-empty-icon { font-size: 48px; color: #334155; margin-bottom: 12px; }
    .state-empty p { color: #475569; font-size: 15px; }

    /* ── BENEFITS ───────────────────────────────── */
    .benefits-section {
      background: linear-gradient(180deg, #0a0f24 0%, #080c1d 100%);
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 72px 24px;
    }
    .benefits-inner { max-width: 1200px; margin: 0 auto; }
    .benefits-label {
      text-align: center;
      font-size: 11px; font-weight: 700;
      color: #FF6B35;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .benefits-title {
      text-align: center;
      font-size: clamp(22px, 4vw, 36px);
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 48px;
      line-height: 1.2;
    }
    .benefits-title span { color: #FF6B35; }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media (max-width: 900px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .benefits-grid { grid-template-columns: 1fr; } }

    .benefit-card {
      background: #141828;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 28px 24px;
      transition: border-color 0.2s, transform 0.2s;
    }
    .benefit-card:hover {
      border-color: rgba(255,107,53,0.25);
      transform: translateY(-2px);
    }
    .benefit-icon {
      width: 48px; height: 48px;
      background: rgba(255,107,53,0.1);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      margin-bottom: 16px;
      color: #FF6B35;
    }
    .benefit-title {
      font-size: 15px; font-weight: 700;
      color: #ffffff;
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .benefit-desc {
      font-size: 13px;
      color: #64748b;
      line-height: 1.6;
    }

    /* ── RESPONSIVE ─────────────────────────────── */
    @media (max-width: 640px) {
      .hero-section { padding: 48px 20px 40px; }
      .search-section, .map-section, .grid-section { padding-left: 16px; padding-right: 16px; }
      #peru-map { height: 280px; }
      .restaurant-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<%- include('../partials/public-header') %>

<!-- ══ HERO ══════════════════════════════════════════ -->
<section class="hero-section">
  <div class="hero-robot">🤖</div>
  <div class="hero-badge">
    <i class="bi bi-stars"></i>
    Directorio IA
  </div>
  <h1 class="hero-title">RESTAURANTES<br><span>CON IA</span></h1>
  <p class="hero-subtitle">Descubre restaurantes que usan inteligencia artificial para brindarte una mejor experiencia</p>
</section>

<!-- ══ SEARCH & FILTERS ═══════════════════════════════ -->
<section class="search-section">
  <div class="search-wrapper">
    <i class="bi bi-search"></i>
    <input
      id="searchInput"
      type="text"
      class="search-input"
      placeholder="Busca un restaurante, distrito o tipo..."
      autocomplete="off"
    >
  </div>
  <div class="filter-pills" id="filterPills">
    <button class="pill active" data-tipo="">Todos</button>
    <button class="pill" data-tipo="Criollo">Criollo</button>
    <button class="pill" data-tipo="Nikkei">Nikkei</button>
    <button class="pill" data-tipo="Pizzería">Pizzería</button>
    <button class="pill" data-tipo="Café">Café</button>
    <button class="pill" data-tipo="Menú">Menú</button>
  </div>
</section>

<!-- ══ MAP OF PERU ════════════════════════════════════ -->
<section class="map-section">
  <p class="map-label"><i class="bi bi-map" style="margin-right:6px;color:#FF6B35;"></i>Explora por ciudad</p>
  <div id="peru-map"></div>
</section>

<!-- ══ RESTAURANT GRID ═══════════════════════════════ -->
<section class="grid-section">
  <div class="section-header">
    <span class="section-title">Restaurantes registrados</span>
    <span class="count-badge" id="restaurantCount">Cargando...</span>
  </div>
  <div class="restaurant-grid" id="restaurantGrid">
    <div class="state-loading">
      <div class="spinner"></div>
      <p style="color:#64748b;font-size:14px;">Cargando restaurantes...</p>
    </div>
  </div>
</section>

<!-- ══ BENEFITS ══════════════════════════════════════ -->
<section class="benefits-section">
  <div class="benefits-inner">
    <p class="benefits-label">Por qué elegirnos</p>
    <h2 class="benefits-title">
      BENEFICIOS DE SER UN<br>
      <span>RESTAURANTE INTELIGENTE</span>
    </h2>

    <div class="benefits-grid">
      <!-- 1 -->
      <div class="benefit-card">
        <div class="benefit-icon"><i class="bi bi-robot"></i></div>
        <h3 class="benefit-title">DallIA te ayuda a tomar decisiones</h3>
        <p class="benefit-desc">Tu IA personal analiza ventas, tendencias y sugiere acciones concretas para que tu negocio crezca sin adivinanzas.</p>
      </div>
      <!-- 2 -->
      <div class="benefit-card">
        <div class="benefit-icon"><i class="bi bi-bar-chart-line"></i></div>
        <h3 class="benefit-title">Reportes automáticos sin Excel</h3>
        <p class="benefit-desc">Ventas diarias, productos estrella, horas pico — todo generado automáticamente y listo en segundos.</p>
      </div>
      <!-- 3 -->
      <div class="benefit-card">
        <div class="benefit-icon"><i class="bi bi-gift"></i></div>
        <h3 class="benefit-title">Promociones dinámicas y gamificación</h3>
        <p class="benefit-desc">Fideliza clientes con puntos, sorteos y descuentos inteligentes que se activan en el momento justo.</p>
      </div>
      <!-- 4 -->
      <div class="benefit-card">
        <div class="benefit-icon"><i class="bi bi-phone"></i></div>
        <h3 class="benefit-title">Todo desde tu celular</h3>
        <p class="benefit-desc">Gestiona tu restaurante completo desde el teléfono: pedidos, caja, cocina y reportes — sin necesitar una PC.</p>
      </div>
      <!-- 5 -->
      <div class="benefit-card">
        <div class="benefit-icon"><i class="bi bi-shield-check"></i></div>
        <h3 class="benefit-title">Seguridad biométrica FaceID / Huella</h3>
        <p class="benefit-desc">Acceso seguro con reconocimiento facial y huella digital. Tu información y la de tus clientes siempre protegida.</p>
      </div>
      <!-- 6 -->
      <div class="benefit-card">
        <div class="benefit-icon"><i class="bi bi-lightning-charge"></i></div>
        <h3 class="benefit-title">Pedidos en tiempo real, cocina conectada</h3>
        <p class="benefit-desc">Los pedidos llegan al instante a pantalla de cocina. Cero errores de comanda, máxima velocidad de atención.</p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/public-footer') %>

<!-- ══ SCRIPTS ════════════════════════════════════════ -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  // ── State ──────────────────────────────────────────
  let allRestaurants = [];
  let activeTipo     = '';
  let activeCity     = '';
  let searchTimer    = null;

  // ── Leaflet Map ────────────────────────────────────
  const map = L.map('peru-map', {
    center: [-9.19, -75.015],
    zoom: 5,
    zoomControl: true,
    scrollWheelZoom: false,
    attributionControl: false
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; CartoDB',
    subdomains: 'abcd',
    maxZoom: 19
  }).addTo(map);

  const orangeIcon = L.divIcon({
    className: '',
    html: `
      <div style="
        width:44px;height:52px;
        position:relative;
        display:flex;align-items:flex-start;justify-content:center;
      ">
        <div style="
          width:44px;height:44px;
          background:linear-gradient(135deg,#FF6B35,#df2c05);
          border-radius:50%;
          border:3px solid rgba(255,255,255,0.3);
          box-shadow:0 4px 16px rgba(255,107,53,0.5);
          display:flex;align-items:center;justify-content:center;
          overflow:hidden;
        ">
          <img src="/logo-sin-fondo.png" style="width:32px;height:32px;">
        </div>
        <div style="
          position:absolute;bottom:0;left:50%;transform:translateX(-50%);
          width:0;height:0;
          border-left:8px solid transparent;
          border-right:8px solid transparent;
          border-top:10px solid #df2c05;
        "></div>
      </div>`,
    iconSize: [44, 52],
    iconAnchor: [22, 52],
    popupAnchor: [0, -54]
  });

  const cities = [
    { name: 'Lima',      lat: -12.046, lng: -77.043 },
    { name: 'Cusco',     lat: -13.532, lng: -71.967 },
    { name: 'Arequipa',  lat: -16.409, lng: -71.537 },
    { name: 'Trujillo',  lat:  -8.112, lng: -79.029 }
  ];

  cities.forEach(function (city) {
    const marker = L.marker([city.lat, city.lng], { icon: orangeIcon }).addTo(map);
    marker.bindPopup(
      `<div style="font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;color:#FF6B35;">${city.name}</div>
       <div style="font-size:12px;color:#94a3b8;margin-top:2px;">Ver restaurantes</div>`,
      { className: 'dark-popup' }
    );
    marker.on('click', function () {
      activeCity = activeCity === city.name ? '' : city.name;
      renderGrid();
    });
  });

  // Popup dark style
  const popupStyle = document.createElement('style');
  popupStyle.textContent = `
    .dark-popup .leaflet-popup-content-wrapper {
      background: #141828 !important;
      border: 1px solid rgba(255,107,53,0.25) !important;
      border-radius: 10px !important;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
    }
    .dark-popup .leaflet-popup-tip { background: #141828 !important; }
    .dark-popup .leaflet-popup-close-button { color: #64748b !important; }
  `;
  document.head.appendChild(popupStyle);

  // ── Fetch Restaurants ──────────────────────────────
  function fetchRestaurants(buscar, tipo) {
    const params = new URLSearchParams();
    if (buscar) params.set('buscar', buscar);
    if (tipo)   params.set('tipo', tipo);
    return fetch('/api/restaurantes?' + params.toString())
      .then(function (r) { return r.json(); })
      .catch(function () { return []; });
  }

  function renderGrid(restaurants) {
    const grid  = document.getElementById('restaurantGrid');
    const count = document.getElementById('restaurantCount');

    // Use provided list or filter from allRestaurants
    let list = restaurants !== undefined ? restaurants : allRestaurants;

    // City filter (client-side)
    if (activeCity) {
      list = list.filter(function (r) {
        const loc = ((r.ciudad || '') + ' ' + (r.distrito || '')).toLowerCase();
        return loc.includes(activeCity.toLowerCase());
      });
    }

    count.textContent = list.length + (list.length === 1 ? ' restaurante' : ' restaurantes');

    if (!list.length) {
      grid.innerHTML = `
        <div class="state-empty">
          <div class="state-empty-icon">🍽️</div>
          <p>No encontramos restaurantes con esos filtros.</p>
          <p style="font-size:13px;color:#334155;margin-top:6px;">Intenta con otra búsqueda o tipo de cocina.</p>
        </div>`;
      return;
    }

    grid.innerHTML = list.map(function (r) {
      const subdomain  = r.subdominio || r.slug || r.id;
      const url        = 'https://' + subdomain + '.mirestconia.com';
      const imgHtml    = r.foto_local_url
        ? `<img src="${escHtml(r.foto_local_url)}" alt="${escHtml(r.nombre)}" class="rest-card-img" loading="lazy">`
        : `<div class="rest-card-img-placeholder">🍽️</div>`;
      const tipoHtml   = r.tipo_negocio
        ? `<span class="rest-card-tipo">${escHtml(r.tipo_negocio)}</span>`
        : '';
      const distritoHtml = (r.distrito || r.ciudad)
        ? `<div class="rest-card-loc"><i class="bi bi-geo-alt-fill"></i>${escHtml(r.distrito || r.ciudad)}</div>`
        : '';

      return `
        <article class="rest-card">
          ${imgHtml}
          <div class="rest-card-body">
            ${tipoHtml}
            <h3 class="rest-card-name">${escHtml(r.nombre)}</h3>
            ${distritoHtml}
            <a href="${escHtml(url)}" target="_blank" rel="noopener" class="btn-entrar">
              Entrar <i class="bi bi-arrow-right"></i>
            </a>
          </div>
        </article>`;
    }).join('');
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function loadRestaurants() {
    const q = document.getElementById('searchInput').value.trim();
    fetchRestaurants(q, activeTipo).then(function (data) {
      allRestaurants = Array.isArray(data) ? data : (data.restaurantes || data.data || []);
      renderGrid();
    });
  }

  // Initial load
  loadRestaurants();

  // ── Filter pills ───────────────────────────────────
  document.getElementById('filterPills').addEventListener('click', function (e) {
    const pill = e.target.closest('.pill');
    if (!pill) return;
    document.querySelectorAll('.pill').forEach(function (p) { p.classList.remove('active'); });
    pill.classList.add('active');
    activeTipo = pill.dataset.tipo || '';
    activeCity = '';
    loadRestaurants();
  });

  // ── Search input ───────────────────────────────────
  document.getElementById('searchInput').addEventListener('input', function () {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(loadRestaurants, 380);
  });

})();
</script>

</body>
</html>
