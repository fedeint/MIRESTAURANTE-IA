<%# @variant: pwa — do NOT touch this file for desktop changes. See docs/superpowers/specs/2026-04-08-dashboard-desktop-pwa-separation-design.md %>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#10152f">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MiRestcon">
    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <title>Inicio - mirestconia.com</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            font-family: 'DM Sans', sans-serif;
            background: #F0F2F8;
            color: #0a0f24;
            min-height: 100dvh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overscroll-behavior: none;
        }

        .shell {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100dvh;
            position: relative;
            padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px));
        }

        /* ===== HEADER ===== */
        .dash-header {
            background: linear-gradient(180deg, #10152f 0%, #0a0f24 100%);
            border-radius: 0 0 20px 20px;
            padding: calc(52px + env(safe-area-inset-top, 0px)) 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .dash-header .greeting h1 {
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            margin: 0;
            line-height: 1.2;
        }
        .dash-header .greeting p {
            font-size: 13px;
            color: #8B8FAD;
            margin: 4px 0 0;
        }
        .avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, #ef520f, #FF6B35);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
        }

        /* ===== CONTENT ===== */
        .dash-content {
            padding: 16px 16px 20px;
        }

        /* ===== KPI GRID ===== */
        .kpi-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 24px;
        }
        .kpi-card {
            background: #fff;
            border-radius: 14px;
            padding: 14px 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        .kpi-card .kpi-value {
            font-size: 20px;
            font-weight: 700;
            line-height: 1.2;
        }
        .kpi-card .kpi-label {
            font-size: 12px;
            color: #8B8FAD;
            margin-top: 2px;
        }
        .kpi-card .kpi-badge {
            display: inline-block;
            font-size: 10px;
            font-weight: 600;
            padding: 2px 6px;
            border-radius: 6px;
            margin-top: 2px;
        }
        .kpi-dark  .kpi-value { color: #0a0f24; }
        .kpi-green .kpi-value { color: #22C55E; }
        .kpi-orange .kpi-value { color: #FF6B35; }

        /* ===== SECTION TITLE ===== */
        .section-title {
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        /* ===== DALLIA DICE ===== */
        .insight-card {
            background: #fff;
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 8px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }
        .insight-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-top: 5px;
            flex-shrink: 0;
        }
        .insight-card .insight-text {
            font-size: 13px;
            font-weight: 500;
            line-height: 1.4;
        }
        .insight-card .insight-sub {
            font-size: 11px;
            color: #8B8FAD;
            margin-top: 2px;
        }

        /* ===== ACCESOS RAPIDOS ===== */
        .quick-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 20px;
        }
        .quick-btn {
            background: #fff;
            border-radius: 14px;
            padding: 16px 12px;
            text-align: center;
            text-decoration: none;
            color: #0a0f24;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .quick-btn:active {
            transform: scale(0.96);
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }
        .quick-btn .q-icon {
            font-size: 28px;
            line-height: 1;
        }
        .quick-btn .q-label {
            font-size: 12px;
            font-weight: 600;
            color: #0a0f24;
        }

        /* ===== BOTTOM NAV ===== */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 480px;
            background: #fff;
            border-top: 1px solid #E5E7EB;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 8px 0 calc(8px + env(safe-area-inset-bottom, 0px));
            z-index: 100;
        }
        .nav-tab {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            font-size: 10px;
            font-weight: 600;
            color: #8B8FAD;
            gap: 2px;
            padding: 4px 0;
            min-width: 56px;
        }
        .nav-tab.active { color: #FF6B35; }
        .nav-tab .nav-icon {
            font-size: 20px;
            line-height: 1;
        }
        .nav-tab .nav-icon svg {
            width: 22px;
            height: 22px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
        .nav-tab.active .nav-icon svg {
            stroke: #FF6B35;
        }

        /* ===== CREDITS ===== */
        .credits {
            text-align: center;
            font-size: 11px;
            color: #8B8FAD;
            padding: 8px 0 12px;
        }
        .credits strong { color: #FF6B35; }
    </style>
</head>
<body>
<%
    var now = new Date();
    var fechaStr = now.toLocaleDateString('es-PE', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

    var ventasHoy = parseFloat(dashboard.ventasHoy) || 0;
    var ventasAyer = parseFloat(dashboard.ventasAyer) || 0;
    var diffPct = ventasAyer > 0 ? Math.round(((ventasHoy - ventasAyer) / ventasAyer) * 100) : 0;
    var diffSign = diffPct >= 0 ? '+' : '';
    var diffColor = diffPct >= 0 ? '#22C55E' : '#EF4444';

    var userInitial = (dashboard.userName || 'A').charAt(0).toUpperCase();

    var insightColors = ['#FBBF24', '#6366F1', '#FF6B35'];
%>

<div class="shell">

    <!-- ===== HEADER ===== -->
    <div class="dash-header">
        <div class="greeting">
            <h1>Hola, <%= dashboard.userName || 'Admin' %></h1>
            <p><%= fechaStr %></p>
        </div>
        <div class="avatar"><%= userInitial %></div>
    </div>

    <div class="dash-content">

        <!-- ===== KPI CARDS ===== -->
        <div class="kpi-grid">
            <div class="kpi-card kpi-dark">
                <div class="kpi-value"><%= dashboard.facturasHoy || 0 %></div>
                <div class="kpi-label">Delivery en camino</div>
            </div>
            <div class="kpi-card kpi-green">
                <div class="kpi-value"><%= (dashboard.mesasOcupadas || 0) + '/' + (dashboard.mesasTotal || 0) %></div>
                <div class="kpi-label">Mesas ocupadas</div>
            </div>
            <div class="kpi-card kpi-orange">
                <div class="kpi-value">S/ <%= ventasHoy.toFixed(0) %></div>
                <div class="kpi-label">
                    Ventas hoy
                    <% if (ventasAyer > 0) { %>
                    <span class="kpi-badge" style="background:<%= diffColor %>18;color:<%= diffColor %>;"><%= diffSign %><%= diffPct %>% vs ayer</span>
                    <% } %>
                </div>
            </div>
            <div class="kpi-card kpi-dark">
                <div class="kpi-value"><%= dashboard.productosVendidosHoy || 0 %></div>
                <div class="kpi-label">Platos activos</div>
            </div>
        </div>

        <!-- ===== DALLIA DICE ===== -->
        <div class="section-title">DallIA dice:</div>

        <% if (dashboard.iaInsights && dashboard.iaInsights.length > 0) { %>
            <% dashboard.iaInsights.forEach(function(insight, idx) { %>
            <div class="insight-card">
                <div class="insight-dot" style="background:<%= insight.color || insightColors[idx % insightColors.length] %>;"></div>
                <div>
                    <div class="insight-text"><%= insight.texto %></div>
                    <div class="insight-sub">Consejo de DallIA</div>
                </div>
            </div>
            <% }); %>
        <% } else { %>
            <% if (dashboard.alertas > 0) { %>
            <div class="insight-card">
                <div class="insight-dot" style="background:#FBBF24;"></div>
                <div>
                    <div class="insight-text"><%= dashboard.alertas %> insumo<%= dashboard.alertas > 1 ? 's' : '' %> cerca del limite de stock</div>
                    <div class="insight-sub">Consejo de DallIA</div>
                </div>
            </div>
            <% } %>
            <div class="insight-card">
                <div class="insight-dot" style="background:#6366F1;"></div>
                <div>
                    <div class="insight-text"><%= (dashboard.mesasOcupadas || 0) %> de <%= (dashboard.mesasTotal || 0) %> mesas ocupadas ahora</div>
                    <div class="insight-sub">Consejo de DallIA</div>
                </div>
            </div>
            <% if (dashboard.cajaAbierta === false) { %>
            <div class="insight-card">
                <div class="insight-dot" style="background:#FF6B35;"></div>
                <div>
                    <div class="insight-text">La caja aun no ha sido abierta hoy</div>
                    <div class="insight-sub">Consejo de DallIA</div>
                </div>
            </div>
            <% } %>
        <% } %>

        <div style="margin-bottom:24px;"></div>

        <!-- ===== ACCESOS RAPIDOS ===== -->
        <div class="section-title">Accesos rapidos</div>
        <div class="quick-grid">
            <a href="/pedidos" class="quick-btn">
                <span class="q-icon">&#x1F6F5;</span>
                <span class="q-label">Delivery</span>
            </a>
            <a href="/caja" class="quick-btn">
                <span class="q-icon">&#x1F4B0;</span>
                <span class="q-label">Caja</span>
            </a>
            <a href="/cocina-display" class="quick-btn">
                <span class="q-icon">&#x1F525;</span>
                <span class="q-label">Cocina</span>
            </a>
            <a href="/mesas" class="quick-btn">
                <span class="q-icon">&#x1FA91;</span>
                <span class="q-label">Mesas</span>
            </a>
        </div>

        <div class="credits">
            Creado por <strong>Leonidas Yauri</strong> &middot; mirestconia.com
        </div>

    </div><!-- /dash-content -->

    <!-- ===== BOTTOM NAV ===== -->
    <nav class="bottom-nav">
        <a href="/dashboard" class="nav-tab active">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </span>
            <span>INICIO</span>
        </a>
        <a href="/mesas" class="nav-tab">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            </span>
            <span>MESAS</span>
        </a>
        <a href="/cocina-display" class="nav-tab">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6 2 10.5c0 3 2 5.5 5 7v2.5a2 2 0 002 2h6a2 2 0 002-2V17.5c3-1.5 5-4 5-7C22 6 17.52 2 12 2z"/><line x1="9" y1="22" x2="15" y2="22"/></svg>
            </span>
            <span>COCINA</span>
        </a>
        <a href="/ventas" class="nav-tab">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            </span>
            <span>VENTAS</span>
        </a>
        <a href="/configuracion" class="nav-tab">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
            </span>
            <span>MAS</span>
        </a>
    </nav>

</div><!-- /shell -->

<script src="/js/dallia-fab.js"></script>
</body>
</html>
