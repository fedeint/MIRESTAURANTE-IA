# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Session
SESSION_SECRET=your-session-secret

# Grafana Cloud - Observability
GRAFANA_CLOUD_OTLP_URL=https://otlp-gateway-xx.grafana.net/otlp
GRAFANA_CLOUD_WRITE_KEY=glc_write_xxxxx
GRAFANA_CLOUD_READ_KEY=glc_read_xxxxx
GRAFANA_CLOUD_LOKI_URL=https://logs-xx.grafana.net
GRAFANA_CLOUD_LOKI_USER=123456
GRAFANA_CLOUD_PROM_URL=https://prometheus-xx.grafana.net
GRAFANA_CLOUD_PROM_USER=123456

# Alertas - Email (Resend)
ALERT_EMAIL_TO=admin@example.com
ALERT_SMTP_HOST=smtp.resend.com
ALERT_SMTP_KEY=re_xxxxx

# Alertas - WhatsApp
ALERT_WHATSAPP_TO=+51999999999

# Vercel Cron
CRON_SECRET=your-cron-secret
