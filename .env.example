# === DATABASE ===
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_HOST=db.xxxx.supabase.co
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_DATABASE=postgres
DB_PORT=5432
DB_POOL_SIZE=50

# === SERVER ===
PORT=1995
SESSION_SECRET=your-session-secret

# === AI APIs ===
KIMI_API_KEY=sk-or-v1-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Google Auth ===
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_CALLBACK_URL=http://localhost:1995/auth/google/callback

# === Meta (Facebook + Instagram) ===
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_USER_TOKEN=your-meta-user-token

# === TikTok ===
TIKTOK_ACCESS_TOKEN=your-tiktok-token

# === Izipay (Pagos) ===
IZIPAY_SHOP_ID=your-shop-id
IZIPAY_PUBLIC_KEY=your-public-key
IZIPAY_SERVER_KEY=your-server-key
IZIPAY_HMAC_KEY=your-hmac-key

# === SMTP (Email) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="MiRestcon IA <your-email@gmail.com>"

# === Grafana Cloud - Observability ===
GRAFANA_CLOUD_OTLP_URL=https://otlp-gateway-xx.grafana.net/otlp
GRAFANA_CLOUD_WRITE_KEY=glc_write_xxxxx
GRAFANA_CLOUD_READ_KEY=glc_read_xxxxx
GRAFANA_CLOUD_LOKI_URL=https://logs-xx.grafana.net
GRAFANA_CLOUD_LOKI_USER=123456
GRAFANA_CLOUD_PROM_URL=https://prometheus-xx.grafana.net
GRAFANA_CLOUD_PROM_USER=123456

# === Alertas ===
ALERT_EMAIL_TO=admin@example.com
ALERT_WHATSAPP_TO=+51999999999

# === PostHog - Product Analytics (DallIA) ===
POSTHOG_API_KEY=phc_xxxxx
POSTHOG_API_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=xxxxx (número del proyecto en PostHog)

# === Grafana Cloud - Dashboards ===
GRAFANA_INSTANCE_URL=https://your-org.grafana.net
GRAFANA_ORG_SLUG=mirestconia
GRAFANA_API_KEY=glc_xxxxx
GRAFANA_DASHBOARD_HTTP_ID=abc123 (ID del dashboard HTTP)
GRAFANA_DASHBOARD_DB_ID=def456 (ID del dashboard DB)
GRAFANA_DASHBOARD_OPENAI_ID=ghi789 (ID del dashboard OpenAI)
GRAFANA_DASHBOARD_VERCEL_ID=jkl012 (ID del dashboard Vercel)

# === Cloudflare R2 - Backups ===
CF_ACCOUNT_ID=xxxxx
CF_API_TOKEN=xxxxx
CF_API_TOKEN_SECRET=xxxxx

# === Cron ===
CRON_SECRET=your-cron-secret
