# =============================================================================
# MiRestcon IA — Variables de Entorno
# =============================================================================
# Copia este archivo a .env.local para desarrollo local.
# NUNCA comites .env.local, .env, ni archivos con valores reales.
#
# Obligatorias para arrancar (la app falla si faltan en producción):
#   DATABASE_URL, SESSION_SECRET
#
# Grupos:
#   1. Servidor
#   2. Base de datos
#   3. Autenticación
#   4. IA / LLMs
#   5. Pagos
#   6. WhatsApp / Meta / TikTok
#   7. Email (SMTP)
#   8. Observabilidad (Grafana)
#   9. Product analytics (PostHog)
#  10. Mapas
#  11. Cron / Seguridad
#  12. Auto-inyectadas por Vercel (no configurar manualmente)
# =============================================================================


# === 1. SERVIDOR ===

# Modo de DB: "cloud" (Supabase, default) o "local" (PostgreSQL local sin SSL).
MODO=cloud

# Puerto del servidor Express. APP_PORT tiene precedencia sobre PORT.
APP_PORT=1995
PORT=1995

# URL pública de la app (sin trailing slash). Usado en emails y notificaciones.
APP_URL=https://mirestconia.com
BASE_URL=https://mirestconia.com

# Entorno Node. Vercel lo setea automáticamente; en local usa "development".
NODE_ENV=development

# Orígenes permitidos para CORS (separados por coma, o "*" para dev).
CORS_ORIGIN=http://localhost:1995


# === 2. BASE DE DATOS ===

# Connection string de Supabase (modo cloud, default).
# Formato: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# OBLIGATORIO — la app no arranca sin esto en producción.
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Parámetros individuales — solo para conexión local (MODO=local).
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=mirestconia_local
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10

# URL de Supabase cloud para sincronización manual desde modo local (/sync).
# Solo necesaria si usas MODO=local.
CLOUD_DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres


# === 3. AUTENTICACIÓN ===

# Secreto para firmar sesiones Express. Genera con: openssl rand -hex 32
# OBLIGATORIO — la app no arranca sin esto en producción.
SESSION_SECRET=cambia-esto-con-openssl-rand-hex-32

# Google OAuth 2.0 — consola: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_CALLBACK_URL=http://localhost:1995/auth/google/callback

# WebAuthn (biometría / passkeys) — routes/webauthn.js
# RP_ID: dominio sin protocolo (ej: mirestconia.com, o localhost en dev)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:1995

# Bóveda de contraseñas — routes/superadmin.js /boveda
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_SECRET=


# === 4. IA / LLMs ===
# Prioridad de uso: DEEPSEEK_API_KEY > KIMI_API_KEY > ANTHROPIC_API_KEY
# El tono peruano lo fuerza el system prompt, así que cualquier modelo sirve.

# DeepSeek V3 — PRINCIPAL (más barato: ~$0.28/M input, $0.42/M output)
# Obtener en: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxx

# Kimi (Moonshot AI) — fallback (~$0.60/M input, $2.50/M output)
KIMI_API_KEY=sk-or-v1-xxxx

# Anthropic Claude — último fallback (~$3/M input, $15/M output)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Google AI Studio (Gemini) — usado por routes/tts.js con voz Aoede
# Obtener en: https://aistudio.google.com/api-keys
# Free tier: 500 req/día Gemini 2.5 Flash TTS
GOOGLE_AI_API_KEY=AIza-xxxx


# === 5. PAGOS ===

# Izipay (pasarela de pago peruana) — routes/pagos.js
IZIPAY_SHOP_ID=tu-shop-id
IZIPAY_PUBLIC_KEY=tu-public-key
IZIPAY_SERVER_KEY=tu-server-key
IZIPAY_HMAC_KEY=tu-hmac-key


# === 6. WHATSAPP / META / TIKTOK ===

# WhatsApp Business API (Cloud API de Meta) — lib/alertas.js, routes/whatsapp.js
# WHATSAPP_PHONE_ID: ID del número de teléfono en Meta for Developers
# WHATSAPP_TOKEN: token de acceso permanente del sistema
WHATSAPP_PHONE_ID=tu-phone-number-id
WHATSAPP_TOKEN=tu-whatsapp-system-token

# Meta Graph API (Facebook + Instagram) — routes/meta.js
META_APP_ID=tu-meta-app-id
META_APP_SECRET=tu-meta-app-secret
META_USER_TOKEN=tu-meta-user-access-token

# TikTok Business API — routes/tiktok.js
TIKTOK_ACCESS_TOKEN=tu-tiktok-access-token


# === 7. EMAIL (SMTP) ===

# Servidor SMTP principal — emails transaccionales (facturas, onboarding, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM="MiRestcon IA <tu-email@gmail.com>"

# SMTP para alertas de seguridad — lib/alertas.js
# Puede ser el mismo que arriba o un servicio dedicado (SendGrid, Resend, etc.)
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_KEY=tu-smtp-api-key-para-alertas

# Destinatarios de alertas de seguridad (DDoS, brute force, etc.)
ALERT_EMAIL_TO=admin@tu-dominio.com
ALERT_WHATSAPP_TO=+51999999999


# === 8. OBSERVABILIDAD (GRAFANA CLOUD) ===

# OTLP endpoint — traces y métricas OpenTelemetry
GRAFANA_CLOUD_OTLP_URL=https://otlp-gateway-prod-xx.grafana.net/otlp
GRAFANA_CLOUD_WRITE_KEY=glc_write_xxxx
GRAFANA_CLOUD_READ_KEY=glc_read_xxxx

# Loki — logs estructurados
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-xx.grafana.net
GRAFANA_CLOUD_LOKI_USER=123456

# Prometheus — métricas
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-xx.grafana.net
GRAFANA_CLOUD_PROM_USER=123456

# Grafana dashboards embebidos en /superadmin/observabilidad
GRAFANA_INSTANCE_URL=https://tu-org.grafana.net
GRAFANA_ORG_SLUG=mirestconia
GRAFANA_API_KEY=glc_xxxx
GRAFANA_DASHBOARD_HTTP_ID=id-del-dashboard-http
GRAFANA_DASHBOARD_DB_ID=id-del-dashboard-db
GRAFANA_DASHBOARD_OPENAI_ID=id-del-dashboard-openai
GRAFANA_DASHBOARD_VERCEL_ID=id-del-dashboard-vercel


# === 9. PRODUCT ANALYTICS (POSTHOG) ===

# PostHog — eventos de uso de DallIA y funnel de onboarding
POSTHOG_API_KEY=phc_xxxx
POSTHOG_API_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=tu-project-id


# === 10. MAPAS ===

# Google Maps — selector de ubicación en formulario de onboarding
GOOGLE_MAPS_API_KEY=AIza-xxxx


# === 11. CRON / SEGURIDAD ===

# Secreto para proteger los endpoints de cron (/api/cron/*).
# Genera con: openssl rand -hex 32
# Los endpoints fallan CERRADOS si este secreto no está configurado.
CRON_SECRET=cambia-esto-con-openssl-rand-hex-32


# === 12. AUTO-INYECTADAS POR VERCEL (no configurar manualmente) ===
#
# Las siguientes variables las setea Vercel automáticamente en cada deploy.
# No las agregues en Vercel Settings — solo se documentan aquí para referencia.
#
# VERCEL=1                            (indica que corre en Vercel)
# VERCEL_ENV=production|preview|development
# VERCEL_URL=xxxx.vercel.app          (URL del deploy actual)
# VERCEL_REGION=iad1                  (región del serverless function)
